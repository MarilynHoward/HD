<UserControl x:Class="RestaurantPosWpf.ProcurementPOrders"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="PoLinkButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#2563EB" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   TextDecorations="Underline"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridPrimaryCellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MainForeground}" />
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridStatusBadgeBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,4,10,4'}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="GridStatusBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

    </UserControl.Resources>

    <Border Background="Transparent" FocusVisualStyle="{x:Null}">
        <Grid Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Background="#F8FAFC"
                    SnapsToDevicePixels="True"
                    ClipToBounds="True"
                    FocusVisualStyle="{x:Null}"
                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='28,24,28,24'}"
                    CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=12}"
                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='24,24,24,24'}">

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              FocusVisualStyle="{x:Null}">
                    <StackPanel>

                        <DockPanel Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,16'}">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Style="{StaticResource VcPrimaryButtonStyle}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                                        Click="CreateNewOrder_Click"
                                        FocusVisualStyle="{x:Null}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=16}"
                                                 Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=16}"
                                                 Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,6,0'}">
                                            <Canvas Width="24" Height="24">
                                                <Path Data="M12.5 22 L18 22 C19.1 22 20 21.1 20 20 L20 7 L15 2 L6 2 C4.9 2 4 2.9 4 4 L4 13.5"
                                                      Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                <Path Data="M14 2 L14 6 C14 7.1 14.9 8 16 8 L20 8"
                                                      Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                <Path Data="M13.378 15.626 A1 1 0 1 0 10.374 12.622 L5.364 17.634 C5.17 17.828 5.028 18.068 4.858 18.488 L4.021 21.358 C3.95 21.6 4.15 21.8 4.4 21.73 L7.27 20.893 C7.69 20.723 7.93 20.581 8.124 20.387 Z"
                                                      Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="Create New Order" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Content="x"
                                        Background="#F8FAFC"
                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='18,0,18,3'}"
                                        Style="{StaticResource VcSecondaryButtonStyle}"
                                        BorderBrush="Transparent"
                                        FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                        VerticalAlignment="Top"
                                        Click="Close_Click"
                                        FocusVisualStyle="{x:Null}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Purchase Orders"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource MainForeground}"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}" />
                                <TextBlock Text="Manage and track all procurement orders"
                                           Foreground="{StaticResource DimmedForeground}"
                                           Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,0'}"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}" />
                            </StackPanel>
                        </DockPanel>

                        <Border Background="White"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,12,12,12'}"
                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,14'}">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0"
                                      Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}">
                                    <TextBox x:Name="SearchTextBox"
                                             Style="{StaticResource IcEnabledTextBoxStyle}"
                                             Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=42}"
                                             VerticalAlignment="Center"
                                             Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,8,12,8'}"
                                             TextChanged="SearchTextBox_TextChanged" />
                                    <TextBlock Text="Search by PO# or supplier..."
                                               IsHitTestVisible="False"
                                               Foreground="#9CA3AF"
                                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,0,0,0'}"
                                               VerticalAlignment="Center"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding ElementName=SearchTextBox, Path=Text}" Value="" />
                                                            <Condition Binding="{Binding ElementName=SearchTextBox, Path=IsKeyboardFocused}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <ComboBox x:Name="StatusFilterCombo"
                                          Grid.Column="1"
                                          Style="{StaticResource IcEnabledComboBoxStyle}"
                                          Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=42}"
                                          VerticalAlignment="Center"
                                          Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                                          SelectionChanged="StatusFilterCombo_SelectionChanged" />

                                <ComboBox x:Name="SupplierFilterCombo"
                                          Grid.Column="2"
                                          Style="{StaticResource IcEnabledComboBoxStyle}"
                                          Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=42}"
                                          VerticalAlignment="Center"
                                          Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                                          SelectionChanged="SupplierFilterCombo_SelectionChanged" />

                                <Button Grid.Column="3"
                                        Style="{StaticResource VcSecondaryButtonStyle}"
                                        Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=42}"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        Click="Export_Click"
                                        FocusVisualStyle="{x:Null}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=16}"
                                               Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=16}"
                                               Source="{StaticResource PeoplePOS.Icon.Download}" />
                                        <TextBlock Text="Export"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,0'}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <UniformGrid Columns="4" Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,16'}">
                            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"
                                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,14,16,14'}"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}">
                                <StackPanel>
                                    <TextBlock Text="Total Orders" Foreground="{StaticResource DimmedForeground}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                    <TextBlock x:Name="TotalOrdersText" Text="0" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=22}" />
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"
                                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,14,16,14'}"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='4,0,8,0'}">
                                <StackPanel>
                                    <TextBlock Text="Total Value" Foreground="{StaticResource DimmedForeground}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                    <TextBlock x:Name="TotalValueText" Text="R0,00" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=22}" />
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"
                                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,14,16,14'}"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='4,0,8,0'}">
                                <StackPanel>
                                    <TextBlock Text="Pending Approval" Foreground="{StaticResource DimmedForeground}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                    <TextBlock x:Name="PendingApprovalSummaryText" Text="0" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=22}" />
                                </StackPanel>
                            </Border>
                            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"
                                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,14,16,14'}"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='4,0,0,0'}">
                                <StackPanel>
                                    <TextBlock Text="Overdue" Foreground="{StaticResource DimmedForeground}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                    <TextBlock x:Name="OverdueSummaryText" Text="0" FontWeight="SemiBold" Foreground="#111827"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=22}" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#E5E7EB" CornerRadius="8,8,0,0">
                                    <Grid Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="1.15*" />
                                            <ColumnDefinition Width="1.25*" />
                                            <ColumnDefinition Width="0.85*" />
                                            <ColumnDefinition Width="0.85*" />
                                            <ColumnDefinition Width="0.65*" />
                                            <ColumnDefinition Width="0.55*" />
                                            <ColumnDefinition Width="0.95*" />
                                            <ColumnDefinition Width="0.85*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="PO #" Foreground="#111827" FontWeight="Bold"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                        <TextBlock Grid.Column="1" Text="Supplier" Foreground="#111827" FontWeight="Bold"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                        <TextBlock Grid.Column="2" Text="Branch" Foreground="#111827" FontWeight="Bold"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                        <TextBlock Grid.Column="3" Text="Order Date" Foreground="#111827" FontWeight="Bold"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                        <TextBlock Grid.Column="4" Text="Expected Delivery" Foreground="#111827" FontWeight="Bold"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                        <TextBlock Grid.Column="5" Text="Days Waiting" Foreground="#111827" FontWeight="Bold"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                        <TextBlock Grid.Column="6" Text="Items" Foreground="#111827" FontWeight="Bold"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                        <TextBlock Grid.Column="7" Text="Status" Foreground="#111827" FontWeight="Bold"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                        <TextBlock Grid.Column="8" Text="Total" Foreground="#111827" FontWeight="Bold"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              FocusVisualStyle="{x:Null}"
                                              MaxHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=420}">
                                    <ItemsControl x:Name="FullPurchaseOrderList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#F3F4F6" BorderThickness="0,1,0,0"
                                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.1*" />
                                                            <ColumnDefinition Width="1.15*" />
                                                            <ColumnDefinition Width="1.25*" />
                                                            <ColumnDefinition Width="0.85*" />
                                                            <ColumnDefinition Width="0.85*" />
                                                            <ColumnDefinition Width="0.65*" />
                                                            <ColumnDefinition Width="0.55*" />
                                                            <ColumnDefinition Width="0.95*" />
                                                            <ColumnDefinition Width="0.85*" />
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                            <Button Content="{Binding PONumber}"
                                                                    Tag="{Binding PONumber}"
                                                                    Style="{StaticResource PoLinkButtonStyle}"
                                                                    Click="ViewRow_Click" />
                                                            <Border Background="#FEE2E2" CornerRadius="4" Padding="6,2" Margin="6,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    Visibility="{Binding OverdueBadgeVisibility}">
                                                                <TextBlock Text="Overdue" Foreground="#DC2626"
                                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=10}" />
                                                            </Border>
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="1" Text="{Binding SupplierName}" TextTrimming="CharacterEllipsis"
                                                                   Style="{StaticResource GridPrimaryCellTextStyle}" />
                                                        <TextBlock Grid.Column="2" Text="{Binding BranchName}" TextTrimming="CharacterEllipsis"
                                                                   Style="{StaticResource GridPrimaryCellTextStyle}" />
                                                        <TextBlock Grid.Column="3" Text="{Binding OrderDateDisplay}" Foreground="#6B7280"
                                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                                        <TextBlock Grid.Column="4" Text="{Binding ExpectedDeliveryDisplay}" Foreground="#6B7280"
                                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                                        <TextBlock Grid.Column="5" Text="{Binding DaysWaitingText}" Foreground="{Binding DaysWaitingForeground}"
                                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                                        <TextBlock Grid.Column="6" Text="{Binding ItemsCount}" HorizontalAlignment="Center"
                                                                   Style="{StaticResource GridPrimaryCellTextStyle}" />
                                                        <Border Grid.Column="7" Background="{Binding StatusBadgeBackground}" Style="{StaticResource GridStatusBadgeBorderStyle}">
                                                            <TextBlock Text="{Binding StatusDisplay}"
                                                                       Foreground="{Binding StatusBadgeForeground}"
                                                                       Style="{StaticResource GridStatusBadgeTextStyle}" />
                                                        </Border>
                                                        <TextBlock Grid.Column="8" Text="{Binding TotalDisplay}" FontWeight="SemiBold"
                                                                   Style="{StaticResource GridPrimaryCellTextStyle}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border x:Name="FooterStrip"
                    Grid.Row="1"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="0,1,0,0">
                <Border.Padding>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource ThicknessScaleConverter}"
                             ConverterParameter="24,12,24,12" />
                </Border.Padding>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1"
                            Content="Close"
                            MinWidth="110"
                            Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=35}"
                            Style="{StaticResource VcSecondaryButtonStyle}"
                            Click="Close_Click"
                            FocusVisualStyle="{x:Null}" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
