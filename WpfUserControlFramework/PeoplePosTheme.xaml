    <Viewbox x:Key="Icon.SalesCartWhite"
              x:Shared="False" 
         SnapsToDevicePixels="True"
         UseLayoutRounding="True"
         Stretch="Uniform"
         StretchDirection="Both">

        <Viewbox.Margin>
            <Binding Source="{StaticResource UiScaleState}"
                 Path="FontScale"
                 Converter="{StaticResource ThicknessScaleConverter}"
                 ConverterParameter="4,8,0" />
        </Viewbox.Margin>

        <Viewbox.Width>
            <Binding Source="{StaticResource UiScaleState}"
                 Path="FontScale"
                 Converter="{StaticResource LayoutScaleConverter}"
                 ConverterParameter="32" />
        </Viewbox.Width>

        <Viewbox.Height>
            <Binding Source="{StaticResource UiScaleState}"
                 Path="FontScale"
                 Converter="{StaticResource LayoutScaleConverter}"
                 ConverterParameter="32" />
        </Viewbox.Height>

        <Canvas Width="28" Height="28" SnapsToDevicePixels="True">

            <Path Stroke="White"
              Fill="Transparent"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              StrokeLineJoin="Round"
              Data="M2.05 2.05
                    H4.05
                    L6.71 14.47
                    A2 2 0 0 0 8.71 16.05
                    H18.49
                    A2 2 0 0 0 20.44 14.48
                    L22.09 7.05
                    H5.12">
                <Path.StrokeThickness>
                    <Binding Source="{StaticResource UiScaleState}"
                         Path="FontScale"
                         Converter="{StaticResource LayoutScaleConverter}"
                         ConverterParameter="2" />
                </Path.StrokeThickness>
            </Path>

            <Ellipse Width="4" Height="4"
                 Canvas.Left="6" Canvas.Top="19"
                 Stroke="White"
                 Fill="Transparent">
                <Ellipse.StrokeThickness>
                    <Binding Source="{StaticResource UiScaleState}"
                         Path="FontScale"
                         Converter="{StaticResource LayoutScaleConverter}"
                         ConverterParameter="2" />
                </Ellipse.StrokeThickness>
            </Ellipse>

            <Ellipse Width="4" Height="4"
                 Canvas.Left="18" Canvas.Top="19"
                 Stroke="White"
                 Fill="Transparent">
                <Ellipse.StrokeThickness>
                    <Binding Source="{StaticResource UiScaleState}"
                         Path="FontScale"
                         Converter="{StaticResource LayoutScaleConverter}"
                         ConverterParameter="2" />
                </Ellipse.StrokeThickness>
            </Ellipse>

        </Canvas>
    </Viewbox>

    <Viewbox x:Key="Icon.PoDoc" 
         SnapsToDevicePixels="True"
         UseLayoutRounding="True"
         Stretch="Uniform"
         StretchDirection="Both">

        <Viewbox.Width>
            <Binding Source="{StaticResource UiScaleState}"
                 Path="FontScale"
                 Converter="{StaticResource LayoutScaleConverter}"
                 ConverterParameter="20" />
        </Viewbox.Width>

        <Viewbox.Height>
            <Binding Source="{StaticResource UiScaleState}"
                 Path="FontScale"
                 Converter="{StaticResource LayoutScaleConverter}"
                 ConverterParameter="20" />
        </Viewbox.Height>

        <Canvas Width="24" Height="24">

            <!-- Document outline -->
            <Path Data="M6 2 H14 L20 8 V20 A2 2 0 0 1 18 22 H6 A2 2 0 0 1 4 20 V4 A2 2 0 0 1 6 2 Z"
              Stroke="#6B7280"
              StrokeThickness="2"/>

            <!-- Folded corner -->
            <Path Data="M14 2 V6 A2 2 0 0 0 16 8 H20"
              Stroke="#6B7280"
              StrokeThickness="2"/>

            <!-- Checklist lines -->
            <Line X1="8" Y1="11" X2="16" Y2="11"
              Stroke="#6B7280"
              StrokeThickness="2"/>

            <Line X1="8" Y1="15" X2="16" Y2="15"
              Stroke="#6B7280"
              StrokeThickness="2"/>

            <Line X1="8" Y1="19" X2="13" Y2="19"
              Stroke="#6B7280"
              StrokeThickness="2"/>

            <!-- Checkmark -->
            <Path Data="M14 18 L16 20 L20 16"
              Stroke="#6B7280"
              StrokeThickness="2"/>

        </Canvas>
    </Viewbox>

