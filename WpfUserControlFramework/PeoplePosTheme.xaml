    <Style x:Key="PeoplePOS.ActionBarButtonStyle" TargetType="{x:Type Button}">
        <Style.Resources>
            <SolidColorBrush x:Key="PeoplePOS.ActionBarBgHoverBrush" Color="#F9FAFB"/>
            <SolidColorBrush x:Key="PeoplePOS.ActionBarTextHoverBrush" Color="#182331"/>

            <!-- fallback normal (used if a Button does not override it) -->
            <SolidColorBrush x:Key="PeoplePOS.ActionBarTextBrush" Color="#111827"/>
        </Style.Resources>

        <Setter Property="Height" Value="36"/>
        <Setter Property="MinWidth" Value="140"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="Margin" Value="10,0,0,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>

        <!-- defaults (override per button) -->
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderThickness" Value="1"/>

        <!-- FIX: normal (non-hover) FG now comes from per-button resource -->
        <Setter Property="Foreground" Value="{DynamicResource PeoplePOS.ActionBarTextBrush}"/>

        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10"
                        SnapsToDevicePixels="True">

                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon owned by template (reliable hover) -->
                            <Image x:Name="IconImage"
                               Grid.Column="0"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               SnapsToDevicePixels="True"
                               Source="{DynamicResource PeoplePOS.ActionBarIcon}"
                               Width="{Binding Source={StaticResource UiScaleState},
                                               Path=FontScale,
                                               Converter={StaticResource ScaledDoubleConverter},
                                               ConverterParameter=16}"
                               Height="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ScaledDoubleConverter},
                                                ConverterParameter=16}"/>

                            <!-- Button text -->
                            <ContentPresenter x:Name="TextPresenter"
                                          Grid.Column="2"
                                          Content="{TemplateBinding Content}"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          SnapsToDevicePixels="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- No icon: collapse icon + gap -->
                        <Trigger Property="Tag" Value="{x:Null}">
                            <Setter TargetName="IconImage" Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Padding" Value="14,6"/>
                        </Trigger>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource PeoplePOS.ActionBarBgHoverBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource PeoplePOS.ActionBarTextHoverBrush}"/>
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.92"/>

                            <!-- Swap icon to per-button hover resource -->
                            <Setter TargetName="IconImage" Property="Source" Value="{DynamicResource PeoplePOS.ActionBarIcon.Hover}"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.85"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.55"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


