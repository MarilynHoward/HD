                                      FocusVisualStyle="{x:Null}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Margin="0"
                                      Focusable="False"
                                      IsTabStop="False"
                                      Padding="0"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">

                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Grid Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          RecognizesAccessKey="True"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>

                                <Viewbox Stretch="Uniform"
                                     Width="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource LayoutScaleConverter},
                                             ConverterParameter=16}"
                                     Height="{Binding Source={StaticResource UiScaleState},
                                              Path=FontScale,
                                              Converter={StaticResource LayoutScaleConverter},
                                              ConverterParameter=16}">

                                    <Canvas Width="24" Height="24">

                                        <Path Stroke="#6B7280"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent"
                                          Data="M8 2v2 M16 2v2 M3 7h18 M5 5h14
                                                a2 2 0 0 1 2 2v13
                                                a2 2 0 0 1-2 2H5
                                                a2 2 0 0 1-2-2V7
                                                a2 2 0 0 1 2-2z">

                                            <Path.StrokeThickness>
                                                <Binding Source="{StaticResource UiScaleState}"
                                                     Path="FontScale"
                                                     Converter="{StaticResource LayoutScaleConverter}"
                                                     ConverterParameter="2"/>
                                            </Path.StrokeThickness>

                                        </Path>

                                    </Canvas>

                                </Viewbox>

                            </ToggleButton>

                        </Grid>

                        <!-- Popup -->
                        <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Fade"
                           StaysOpen="False"
                           HorizontalOffset="0">

                            <Popup.VerticalOffset>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="6"/>
                            </Popup.VerticalOffset>

                            <Border x:Name="SizeBox"
                                Background="Transparent"
                                SnapsToDevicePixels="True"
                                ClipToBounds="False">

                                <Border.Width>
                                    <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource LayoutScaleConverter}"
                                         ConverterParameter="520"/>
                                </Border.Width>

                                <Border.Height>
                                    <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource LayoutScaleConverter}"
                                         ConverterParameter="480"/>
                                </Border.Height>

                                <Border Background="White"
                                    BorderBrush="#FFE5E7EB"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False">

                                    <Border.BorderThickness>
                                        <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource LayoutScaleConverter}"
                                             ConverterParameter="1"/>
                                    </Border.BorderThickness>

                                    <Border.CornerRadius>
                                        <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource LayoutScaleConverter}"
                                             ConverterParameter="12"/>
                                    </Border.CornerRadius>

                                    <Grid RenderTransformOrigin="0,0">

                                        <Grid.RenderTransform>
                                            <ScaleTransform ScaleX="2" ScaleY="2"/>
                                        </Grid.RenderTransform>

                                        <Calendar x:Name="PART_Calendar"/>

                                    </Grid>

                                </Border>

                            </Border>

                        </Popup>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="SelectedDate" Value="{x:Null}"/>
                                <Condition Property="IsKeyboardFocusWithin" Value="False"/>
                                <Condition Property="IsDropDownOpen" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="WatermarkText" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>

                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="WatermarkText" Property="Visibility" Value="Hidden"/>
                        </Trigger>

                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="WatermarkText" Property="Visibility" Value="Hidden"/>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                                <Condition Property="Validation.HasError" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsDropDownOpen" Value="True"/>
                                <Condition Property="Validation.HasError" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>

                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#E53E3E"/>
                            <Setter TargetName="Chrome" Property="BorderThickness">
                                <Setter.Value>
                                    <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource LayoutScaleConverter}"
                                         ConverterParameter="1"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.65"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="LocalIcDatePickerStyle_LeftIcon"
            TargetType="{x:Type DatePicker}"
            BasedOn="{StaticResource LocalIcDatePickerStyle}">

        <Setter Property="SelectedDateFormat" Value="Long" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DatePicker}">
                    <Border x:Name="OuterBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- FULL-WIDTH click target -->
                            <Button x:Name="PART_Button"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Focusable="False"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch">

                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />

                                        <!-- Kill ALL theme chrome (this is the real fix) -->
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <ContentPresenter
                                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                        RecognizesAccessKey="True" />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>

                                        <!-- Keep these so the button never tries to paint anything -->
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="Transparent" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon (left) -->
                                    <TextBlock Grid.Column="0"
                                           Text="📅"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           Margin="{Binding Source={StaticResource UiScaleState},
                                                            Path=FontScale,
                                                            Converter={StaticResource ThicknessScaleConverter},
                                                            ConverterParameter='10,0,12,0'}"
                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource FontScaleConverter},
                                                              ConverterParameter=15}" />

                                    <!-- Text (right) -->
                                    <DatePickerTextBox x:Name="PART_TextBox"
                                           Grid.Column="1"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           VerticalAlignment="Center"
                                           VerticalContentAlignment="Center"
                                           FocusVisualStyle="{x:Null}"
                                           Focusable="False"
                                           IsTabStop="False"
                                           IsHitTestVisible="False"
                                           Padding="{Binding Source={StaticResource UiScaleState},
                                                            Path=FontScale,
                                                            Converter={StaticResource ThicknessScaleConverter},
                                                            ConverterParameter='0,4,10,4'}">

                                        <DatePickerTextBox.Template>
                                            <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                                                <Border Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                          VerticalAlignment="Center"
                                                          Focusable="False" />
                                                </Border>
                                            </ControlTemplate>
                                        </DatePickerTextBox.Template>
                                    </DatePickerTextBox>

                                </Grid>
                            </Button>

                            <!-- Popup calendar (must exist in the template) -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Top"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border Background="White"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Calendar x:Name="PART_Calendar" />
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterBorder"
                                    Property="Background"
                                    Value="#FFEFEFF2" />
                        </Trigger>

                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="OuterBorder"
                Property="BorderBrush"
                Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=BorderBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

    <!-- Lucide icon on the left; structure matches LocalIcDatePickerStyle (PART_TextBox sibling of PART_Button, not nested). -->
    <Style x:Key="LocalIcDatePickerStyle_LucideLeftIcon"
           TargetType="{x:Type DatePicker}"
           BasedOn="{StaticResource LocalIcDatePickerStyle}">

        <Setter Property="SelectedDateFormat" Value="Long" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DatePicker}">

                    <ControlTemplate.Resources>

                        <Style TargetType="{x:Type DatePickerTextBox}">
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                                        <Grid SnapsToDevicePixels="True"
                                          UseLayoutRounding="True">

                                            <Border Background="Transparent"
                                                SnapsToDevicePixels="True"
                                                Padding="{TemplateBinding Padding}">

                                                <ScrollViewer x:Name="PART_ContentHost"
                                                          VerticalAlignment="Center"
                                                          SnapsToDevicePixels="True"
                                                          FocusVisualStyle="{x:Null}" />

                                            </Border>

                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                    </ControlTemplate.Resources>

                    <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True">

                        <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">

                            <Border.CornerRadius>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="10"/>
                            </Border.CornerRadius>

                        </Border>

                        <Border x:Name="FocusOuter"
                            Visibility="Collapsed"
                            Background="Transparent"
                            BorderBrush="#C1DEFE"
                            SnapsToDevicePixels="True"
                            RenderOptions.EdgeMode="Aliased">

                            <Border.CornerRadius>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="12"/>
                            </Border.CornerRadius>

                            <Border.Margin>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ThicknessScaleConverter}"
                                     ConverterParameter="-3,-3,-3,-3"/>
                            </Border.Margin>

                            <Border.BorderThickness>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="3"/>
                            </Border.BorderThickness>

                        </Border>

                        <Border x:Name="FocusInner"
                            Visibility="Collapsed"
                            Background="Transparent"
                            BorderBrush="#93C5FD"
                            SnapsToDevicePixels="True"
                            RenderOptions.EdgeMode="Aliased">

                            <Border.CornerRadius>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="11"/>
                            </Border.CornerRadius>

                            <Border.Margin>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ThicknessScaleConverter}"
                                     ConverterParameter="-1,-1,-1,-1"/>
                            </Border.Margin>

                            <Border.BorderThickness>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="1"/>
                            </Border.BorderThickness>

                        </Border>

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding Source={StaticResource UiScaleState},
                                      Path=FontScale,
                                      Converter={StaticResource LayoutScaleConverter},
                                      ConverterParameter=40}" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ToggleButton x:Name="PART_Button"
                                      Grid.Column="0"
                                      FocusVisualStyle="{x:Null}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Margin="0"
                                      Focusable="False"
                                      IsTabStop="False"
                                      Padding="0"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">

                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Grid Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          RecognizesAccessKey="True"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ToggleButton.Template>

                                <Viewbox Stretch="Uniform"
                                     Width="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource LayoutScaleConverter},
                                             ConverterParameter=18}"
                                     Height="{Binding Source={StaticResource UiScaleState},
                                              Path=FontScale,
                                              Converter={StaticResource LayoutScaleConverter},
                                              ConverterParameter=18}">

                                    <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                        <Line X1="8"
                                              Y1="2"
                                              X2="8"
                                              Y2="6"
                                              Stroke="{StaticResource MainForeground}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                        <Line X1="16"
                                              Y1="2"
                                              X2="16"
                                              Y2="6"
                                              Stroke="{StaticResource MainForeground}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                        <Rectangle Canvas.Left="3"
                                                   Canvas.Top="4"
                                                   Width="18"
                                                   Height="18"
                                                   RadiusX="2"
                                                   RadiusY="2"
                                                   Stroke="{StaticResource MainForeground}"
                                                   StrokeThickness="2"
                                                   Fill="Transparent" />
                                        <Line X1="3"
                                              Y1="10"
                                              X2="21"
                                              Y2="10"
                                              Stroke="{StaticResource MainForeground}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </Canvas>

                                </Viewbox>

                            </ToggleButton>

                            <DatePickerTextBox x:Name="PART_TextBox"
                                           Grid.Column="1"
                                           FocusVisualStyle="{x:Null}"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           IsReadOnly="True"
                                           Padding="{TemplateBinding Padding}"
                                           VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />

                            <TextBlock x:Name="WatermarkText"
                                   Grid.Column="1"
                                   Text="Select a Date"
                                   Foreground="#8A8F98"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Visibility="Hidden"
                                   Margin="{TemplateBinding Padding}" />

                        </Grid>

                        <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Fade"
                           StaysOpen="False"
                           HorizontalOffset="0">

                            <Popup.VerticalOffset>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="6"/>
                            </Popup.VerticalOffset>

                            <Border x:Name="SizeBox"
                                Background="Transparent"
                                SnapsToDevicePixels="True"
                                ClipToBounds="False">

                                <Border.Width>
                                    <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource LayoutScaleConverter}"
                                         ConverterParameter="520"/>
                                </Border.Width>

                                <Border.Height>
                                    <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource LayoutScaleConverter}"
                                         ConverterParameter="480"/>
                                </Border.Height>

                                <Border Background="White"
                                    BorderBrush="#FFE5E7EB"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False">

                                    <Border.BorderThickness>
                                        <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource LayoutScaleConverter}"
                                             ConverterParameter="1"/>
                                    </Border.BorderThickness>

                                    <Border.CornerRadius>
                                        <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource LayoutScaleConverter}"
                                             ConverterParameter="12"/>
                                    </Border.CornerRadius>

                                    <Grid RenderTransformOrigin="0,0">

                                        <Grid.RenderTransform>
                                            <ScaleTransform ScaleX="2" ScaleY="2"/>
                                        </Grid.RenderTransform>

                                        <Calendar x:Name="PART_Calendar"/>

                                    </Grid>

                                </Border>

                            </Border>

                        </Popup>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="SelectedDate" Value="{x:Null}"/>
                                <Condition Property="IsKeyboardFocusWithin" Value="False"/>
                                <Condition Property="IsDropDownOpen" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="WatermarkText" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>

                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="WatermarkText" Property="Visibility" Value="Hidden"/>
                        </Trigger>

                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="WatermarkText" Property="Visibility" Value="Hidden"/>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                                <Condition Property="Validation.HasError" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsDropDownOpen" Value="True"/>
                                <Condition Property="Validation.HasError" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible"/>
                        </MultiTrigger>

                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="#E53E3E"/>
                            <Setter TargetName="Chrome" Property="BorderThickness">
                                <Setter.Value>
                                    <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource LayoutScaleConverter}"
                                         ConverterParameter="1"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.65"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>

            </Setter.Value>
        </Setter>
    </Style>

    
    <!-- Enabled combo (matches  IcEnabledTextBoxStyle pattern) -->
    <Style x:Key="IcEnabledComboBoxStyle"
       TargetType="ComboBox"
       BasedOn="{StaticResource IcBaseComboBoxStyle}">
        <Setter Property="IsHitTestVisible" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <!-- Operations & Services user controls: table row / field typography (base 14, scaled). -->
    <Style x:Key="IcOpsServicesComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{StaticResource MainForeground}" />
        <Setter Property="FontSize">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource FontScaleConverter}"
                     ConverterParameter="14" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource ThicknessScaleConverter}"
                     ConverterParameter="12,8,12,8" />
            </Setter.Value>
        </Setter>
        <Setter Property="Background" Value="White" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F6F8FC" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#E9EEF6" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Floor filter (and similar host chrome): list rows clear by default; blue only when selected; light tint when highlighted. -->
    <Style x:Key="IcOpsServicesFloorFilterComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource MainForeground}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FontSize">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                         Path="FontScale"
                         Converter="{StaticResource FontScaleConverter}"
                         ConverterParameter="14" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                         Path="FontScale"
                         Converter="{StaticResource ThicknessScaleConverter}"
                         ConverterParameter="12,8,12,8" />
            </Setter.Value>
        </Setter>
        <!-- Default Aero/Fluent template paints system highlight (grey + white text); host only our brushes. -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="#EFF6FF" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.PrimaryBlue}" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsSelected" Value="True" />
                    <Condition Property="IsHighlighted" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background" Value="{StaticResource Brush.PrimaryBlueHover}" />
                <Setter Property="Foreground" Value="White" />
            </MultiTrigger>
            <Trigger Property="IsEnabled" Value="False">
