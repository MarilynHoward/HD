    <!-- IcFieldCheckBoxStyle: selectable card/tile that contains a CheckBox (white + border, figma-like) -->
    <Style x:Key="IcFieldCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />

        <!-- Figma-like tile (plain white + subtle border) -->
        <Setter Property="Background" Value="White" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#E5E7EB" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />

        <!-- Same scaled padding as textbox -->
        <Setter Property="Padding">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                 Path="FontScale"
                 Converter="{StaticResource ThicknessScaleConverter}"
                 ConverterParameter="12,8,12,8" />
            </Setter.Value>
        </Setter>

        <!-- Same scaled min height as textbox -->
        <Setter Property="MinHeight">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                 Path="FontScale"
                 Converter="{StaticResource FontScaleConverter}"
                 ConverterParameter="42" />
            </Setter.Value>
        </Setter>

        <!-- Keep text sizing consistent -->
        <Setter Property="FontSize">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                 Path="FontScale"
                 Converter="{StaticResource FontScaleConverter}"
                 ConverterParameter="14" />
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <!-- Entire tile is the clickable surface -->
                    <Border x:Name="BaseBorder"
                        Background="{TemplateBinding Background}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        CornerRadius="9"
                        SnapsToDevicePixels="True">

                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Checkbox glyph -->
                            <Border x:Name="GlyphBox"
                                Width="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource LayoutScaleConverter},
                                                ConverterParameter=18}"
                                Height="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource LayoutScaleConverter},
                                                 ConverterParameter=18}"
                                CornerRadius="4"
                                BorderThickness="1"
                                BorderBrush="#D1D5DB"
                                Background="White"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True" />

                            <!-- Tick (scaled to glyph so it stays centered at 150% → 100%) -->
                            <Viewbox Grid.Column="0"
                                         Width="{Binding ElementName=GlyphBox, Path=ActualWidth}"
                                         Height="{Binding ElementName=GlyphBox, Path=ActualHeight}"
                                         Stretch="Uniform"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Center"
                                         SnapsToDevicePixels="True">

                                <!-- Inset shrinks the rendered tick so it stays centered with breathing room -->
                                <Grid Margin="{Binding Source={StaticResource UiScaleState},
                                           Path=FontScale,
                                           Converter={StaticResource ThicknessScaleConverter},
                                           ConverterParameter='2,2,4,6'}">

                                    <Path x:Name="Tick"
                                          Visibility="Collapsed"
                                          Data="M 3 8 L 6.5 11.5 L 13 4.5"
                                          Stroke="White"
                                          StrokeThickness="1"
                                          SnapsToDevicePixels="True"
                                          RenderOptions.EdgeMode="Aliased" />
                                </Grid>
                            </Viewbox>

                            <!-- Text -->
                            <ContentPresenter Grid.Column="1"
                                          Margin="{Binding Source={StaticResource UiScaleState},
                                                           Path=FontScale,
                                                           Converter={StaticResource ThicknessScaleConverter},
                                                           ConverterParameter='8,0,0,0'}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          HorizontalAlignment="Left"
                                          RecognizesAccessKey="True" />
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Checked -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="GlyphBox" Property="Background" Value="#111827" />
                            <Setter TargetName="GlyphBox" Property="BorderBrush" Value="#111827" />
                            <Setter TargetName="Tick" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!-- Hover: subtle surface (NO pink) -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BaseBorder" Property="Background" Value="#F9FAFB" />
                        </Trigger>

                        <!-- Disabled --><!--
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="BaseBorder" Property="Background" Value="#F9FAFB" />
                            <Setter TargetName="BaseBorder" Property="BorderBrush" Value="#E5E7EB" />
                            <Setter TargetName="GlyphBox" Property="BorderBrush" Value="#D1D5DB" />
                            <Setter Property="Foreground" Value="#9CA3AF" />
                        </Trigger>-->

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="IcBaseTextBoxStyle" TargetType="TextBox">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />

        <!-- Filled look -->
        <Setter Property="Background" Value="#FFF3F3F5" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                 Path="FontScale"
                 Converter="{StaticResource FontScaleConverter}"
                 ConverterParameter="14" />
            </Setter.Value>
        </Setter>

        <!-- Scaled padding -->
        <Setter Property="Padding">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource ThicknessScaleConverter}"
                     ConverterParameter="12,8,12,8" />
            </Setter.Value>
        </Setter>

        <!-- Scaled minimum height -->
        <Setter Property="MinHeight">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource FontScaleConverter}"
                     ConverterParameter="35" />
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">

                        <Border x:Name="BaseBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True" />

                        <!--BorderBrush="#CDCECE"-->
                        <Border x:Name="FocusOuter"
                            Visibility="Collapsed"
                            Margin="-3"
                            CornerRadius="9"
                            BorderThickness="3"
                            BorderBrush="#C1DEFE"
                            Background="Transparent"
                            SnapsToDevicePixels="True"
                            RenderOptions.EdgeMode="Aliased" />

                        <!--BorderBrush="#9A9A9A"-->
                        <Border x:Name="FocusInner"
                            Visibility="Collapsed"
                            Margin="-1"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="#93C5FD"
                            Background="Transparent"
                            SnapsToDevicePixels="True"
                            RenderOptions.EdgeMode="Aliased" />

                        <ScrollViewer x:Name="PART_ContentHost"
                                  Margin="0"
                                  SnapsToDevicePixels="True" />

                    </Grid>

                    <ControlTemplate.Triggers>

                        <!-- Hover: subtle background darken -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BaseBorder" Property="Background" Value="#FFEFEFF2" />
                        </Trigger>

                        <!-- Focus: show the two-layer ring (no layout shift) -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!-- Mouse focus (optional, keeps it consistent if you click in) -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="BaseBorder" Property="Background" Value="#FFE5E7EB" />
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IcSpinnerTextBoxStyle"
       TargetType="{x:Type TextBox}"
       BasedOn="{StaticResource IcBaseTextBoxStyle}">

        <!-- Spinner strip needs slightly less right padding than normal -->
        <Setter Property="Padding">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource ThicknessScaleConverter}"
                     ConverterParameter="12,0,8,0" />
            </Setter.Value>
        </Setter>

        <!-- Keep the fill owned by THIS TextBox (normal behavior) -->
        <Setter Property="Background" Value="#FFF3F3F5" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />


        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Field surface (same as IcBaseTextBoxStyle) -->
                        <Border x:Name="BaseBorder"
                            Grid.ColumnSpan="2"
                            Background="{TemplateBinding Background}"
                            CornerRadius="9"
                            BorderThickness="0"
                            SnapsToDevicePixels="True" />

                        <!-- Focus rings (same as IcBaseTextBoxStyle) -->
                        <Border x:Name="FocusOuter"
                            Grid.ColumnSpan="2"
                            Visibility="Collapsed"
                            Margin="-3"
                            CornerRadius="9"
                            BorderThickness="3"
                            BorderBrush="#C1DEFE"
                            Background="Transparent"
                            SnapsToDevicePixels="True"
                            RenderOptions.EdgeMode="Aliased" />

                        <Border x:Name="FocusInner"
                            Grid.ColumnSpan="2"
                            Visibility="Collapsed"
                            Margin="-1"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="#93C5FD"
                            Background="Transparent"
                            SnapsToDevicePixels="True"
                            RenderOptions.EdgeMode="Aliased" />

                        <!-- Text content host -->
                        <ScrollViewer x:Name="PART_ContentHost"
                                  Grid.Column="0"
                                  Margin="0"
                                  SnapsToDevicePixels="True" />

                        <!-- Spinner strip (inside the TextBox template) -->
                        <Grid Grid.Column="1"
                          HorizontalAlignment="Right"
                          Margin="0"
                          Width="{Binding Source={StaticResource UiScaleState},
                                          Path=FontScale,
                                          Converter={StaticResource LayoutScaleConverter},
                                          ConverterParameter=28}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <RepeatButton Grid.Row="0" x:Name="PART_UpButton"
                                      Style="{StaticResource IcSpinnerRepeatButtonStyle}"
                                      Content="˄"
                                      Foreground="#9CA3AF"
                                      FontSize="{Binding Source={StaticResource UiScaleState},
                                                         Path=FontScale,
                                                         Converter={StaticResource FontScaleConverter},
                                                         ConverterParameter=14}"
                                      Command="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=UpCommand}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=UpCommandParameter}" />

                            <RepeatButton Grid.Row="1" x:Name="PART_DownButton"
                                      Style="{StaticResource IcSpinnerRepeatButtonStyle}"
                                      Content="˅"
                                      Foreground="#9CA3AF"
                                      FontSize="{Binding Source={StaticResource UiScaleState},
                                                         Path=FontScale,
                                                         Converter={StaticResource FontScaleConverter},
                                                         ConverterParameter=14}"
                                      Command="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=DownCommand}"
                                      CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=DownCommandParameter}" />
                        </Grid>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BaseBorder" Property="Background" Value="#FFEFEFF2" />
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="BaseBorder" Property="Background" Value="#FFE5E7EB" />
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


