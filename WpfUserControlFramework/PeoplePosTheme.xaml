                    <GeometryDrawing.Geometry>
                        <!-- 3 paths combined -->
                        <GeometryGroup>

                            <!-- M12 15 V3 -->
                            <LineGeometry StartPoint="12,15" EndPoint="12,3"/>

                            <!-- M21 15 v4 a2 2 0 0 1 -2 2 H5 a2 2 0 0 1 -2 -2 v-4 -->
                            <PathGeometry Figures="M21,15 L21,19 C21,20.1046 20.1046,21 19,21 L5,21 C3.89543,21 3,20.1046 3,19 L3,15"/>

                            <!-- m7 10 5 5 5-5 -->
