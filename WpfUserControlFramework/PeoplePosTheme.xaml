        <Setter Property="VerticalContentAlignment" Value="Top" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">

                        <!-- Base chrome (background + optional error border) -->
                        <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{Binding RelativeSource={RelativeSource TemplatedParent},
                                                  Path=ActualHeight,
                                                  Converter={StaticResource CornerRadiusFromHeightConverter},
                                                  ConverterParameter=8}"
                            SnapsToDevicePixels="True" />

                        <!-- Focus ring OUTER -->
                        <Border x:Name="FocusOuter"
                            Visibility="Collapsed"
                            Margin="-3"
                            CornerRadius="9"
                            BorderThickness="3"
                            BorderBrush="#C1DEFE"
                            Background="Transparent"
                            SnapsToDevicePixels="True"
                            RenderOptions.EdgeMode="Aliased" />

                        <!-- Focus ring INNER -->
                        <Border x:Name="FocusInner"
                            Visibility="Collapsed"
                            Margin="-1"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="#93C5FD"
                            Background="Transparent"
                            SnapsToDevicePixels="True"
                            RenderOptions.EdgeMode="Aliased" />

                        <ScrollViewer x:Name="PART_ContentHost"
                                  VerticalAlignment="Top"
                                  SnapsToDevicePixels="True">
                            <ScrollViewer.Margin>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ThicknessScaleConverter}"
                                     ConverterParameter="1,1,1,1" />
                            </ScrollViewer.Margin>
                        </ScrollViewer>

                        <TextBlock x:Name="Watermark"
                               Text="{TemplateBinding Tag}"
                               Foreground="#8A8F98"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Visibility="Collapsed">
                            <TextBlock.Margin>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ThicknessScaleConverter}"
                                     ConverterParameter="12,2,6,0" />
                            </TextBlock.Margin>
                        </TextBlock>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <!-- Watermark only when empty AND not focused (unchanged) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value="" />
                                <Condition Property="IsKeyboardFocused" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!-- Focus: show double ring ONLY when NOT invalid -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocused" Value="True" />
                                <Condition Property="Validation.HasError" Value="False" />
                                <Condition Property="BorderThickness" Value="0" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!-- Mouse click focus path (keeps consistent) -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsFocused" Value="True" />
                                <Condition Property="Validation.HasError" Value="False" />
                                <Condition Property="BorderThickness" Value="0" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!-- Invalid = red border wins over focus (collapse rings) -->
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Collapsed" />
                            <Setter Property="BorderBrush" Value="#E53E3E" />
                            <Setter Property="BorderThickness" Value="1" />
                        </Trigger>

                        <!--<Trigger Property="BorderBrush" Value="#E53E3E">
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        --><!-- If you sometimes use the darker red, cover that too --><!--
                        <Trigger Property="BorderBrush" Value="#DC2626">
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Collapsed" />
                        </Trigger>-->

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type Control}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    </Style>

    <Style x:Key="FlatCombo" TargetType="ComboBox">
        <!-- base sizing -->
        <Setter Property="Foreground" Value="#1F2937"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />

        <!-- scaled padding -->
        <Setter Property="Padding">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource ThicknessScaleConverter}"
                     ConverterParameter="10,0" />
            </Setter.Value>
        </Setter>

        <!-- scaled min height -->
        <Setter Property="MinHeight">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource LayoutScaleConverter}"
                     ConverterParameter="36" />
            </Setter.Value>
        </Setter>

        <!-- scaled font size -->
        <Setter Property="FontSize">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource FontScaleConverter}"
                     ConverterParameter="14" />
            </Setter.Value>
        </Setter>

        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>

        <!-- ensure items stretch to the popup width -->
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True">
                        <!-- Face -->
                        <Border x:Name="Face"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{Binding RelativeSource={RelativeSource TemplatedParent},
                                                  Path=ActualHeight,
                                                  Converter={StaticResource CornerRadiusFromHeightConverter},
                                                  ConverterParameter=8}"/>

                        <!-- Content + right arrow -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource LayoutScaleConverter},
                                                             ConverterParameter=36}"/>
                            </Grid.ColumnDefinitions>

                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          IsHitTestVisible="False"/>

                            <ToggleButton x:Name="DropDownToggle"
                                      Grid.Column="1"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Path x:Name="Arrow"
                                  Data="M 0 0 L 8 0 L 4 4 Z"
                                  Width="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource LayoutScaleConverter},
                                                  ConverterParameter=10}"
                                  Height="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource LayoutScaleConverter},
                                                   ConverterParameter=5}"
                                  Stretch="Fill"
                                  Fill="#666666"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            </ToggleButton>
                        </Grid>

                        <!-- Full-width dropdown -->
                        <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Fade">
                            <Border Background="#FFFFFF"
                                BorderBrush="#D0D4DA"
                                BorderThickness="1"
                                SnapsToDevicePixels="True"
                                HorizontalAlignment="Left"
                                Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                CornerRadius="{Binding RelativeSource={RelativeSource TemplatedParent},
                                                      Path=ActualHeight,
                                                      Converter={StaticResource CornerRadiusFromHeightConverter},
                                                      ConverterParameter=8}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- States -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Arrow" Property="Fill" Value="#444444"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Arrow" Property="Fill" Value="#2555D6"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Arrow" Property="Fill" Value="#2555D6"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <!-- Item look (white list, borderless), stretches to full width -->
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="#1F2937"/>

                    <!-- scaled item padding -->
                    <Setter Property="Padding">
                        <Setter.Value>
                            <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource ThicknessScaleConverter}"
                                 ConverterParameter="12,8" />
                        </Setter.Value>
                    </Setter>

                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F6F8FC"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#E9EEF6"/>
                            <Setter Property="Foreground" Value="#1F2937"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>


