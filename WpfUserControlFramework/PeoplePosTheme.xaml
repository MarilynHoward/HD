    <ControlTemplate x:Key="OverlayScrollBarTemplateAlways"
                 TargetType="ScrollBar">
        <Grid x:Name="Root" Background="Transparent">
            <Track x:Name="PART_Track"
               Orientation="Vertical"
               IsDirectionReversed="True"
               Minimum="{TemplateBinding Minimum}"
               Maximum="{TemplateBinding Maximum}"
               Value="{TemplateBinding Value}"
               ViewportSize="{TemplateBinding ViewportSize}">
                <Track.Thumb>
                    <Thumb x:Name="Thumb" Background="#9CA3AF">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4" />
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Track.Thumb>
            </Track>
        </Grid>

        <ControlTemplate.Triggers>
            <Trigger SourceName="Thumb" Property="IsMouseOver" Value="True">
                <Setter TargetName="Thumb" Property="Background" Value="#6B7280" />
            </Trigger>

            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Thumb" Property="Background" Value="#CBD5E1" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Template B: AUTO-HIDE (opacity animation must be here, not in Style.Triggers) -->
    <ControlTemplate x:Key="OverlayScrollBarTemplateAutoHide"
                 TargetType="ScrollBar">
        <Grid x:Name="Root" Background="Transparent">
            <Grid x:Name="FadeHost" Background="Transparent" Opacity="0">
                <Track x:Name="PART_Track"
                   Orientation="Vertical"
                   IsDirectionReversed="True"
                   Minimum="{TemplateBinding Minimum}"
                   Maximum="{TemplateBinding Maximum}"
                   Value="{TemplateBinding Value}"
                   ViewportSize="{TemplateBinding ViewportSize}">
                    <Track.Thumb>
                        <Thumb x:Name="Thumb" Background="#9CA3AF">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Border Background="{TemplateBinding Background}"
                                        CornerRadius="4" />
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track.Thumb>
                </Track>
            </Grid>
        </Grid>

        <ControlTemplate.Triggers>

            <!-- Fade IN when mouse is over the thumb -->
            <Trigger SourceName="Thumb" Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="FadeHost"
                                         Storyboard.TargetProperty="Opacity"
                                         To="1"
                                         Duration="0:0:0.15" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="FadeHost"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0"
                                         Duration="0:0:0.75" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>

                <!-- Also darken thumb while hovered -->
                <Setter TargetName="Thumb" Property="Background" Value="#6B7280" />
            </Trigger>

            <!-- Disabled thumb colour -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Thumb" Property="Background" Value="#CBD5E1" />
                <Setter TargetName="FadeHost" Property="Opacity" Value="1" />
            </Trigger>

        </ControlTemplate.Triggers>
    </ControlTemplate>

