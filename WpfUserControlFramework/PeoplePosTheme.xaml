    <Style x:Key="IcBaseComboBoxStyle" TargetType="ComboBox">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />

        <Setter Property="Background" Value="#FFF3F3F5" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="VerticalContentAlignment" Value="Center" />

        <Setter Property="Padding">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource ThicknessScaleConverter}"
                     ConverterParameter="12,8,12,8" />
            </Setter.Value>
        </Setter>

        <Setter Property="MinHeight">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource FontScaleConverter}"
                     ConverterParameter="35" />
            </Setter.Value>
        </Setter>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True"
                      ClipToBounds="False">

                        <!-- Base fill / error border -->
                        <Border x:Name="BaseBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                            <Border.CornerRadius>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="9" />
                            </Border.CornerRadius>
                        </Border>

                        <!-- Click surface -->
                        <ToggleButton x:Name="ToggleButton"
                                  Focusable="False"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  ClickMode="Press"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Stretch">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent" SnapsToDevicePixels="True">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </ToggleButton.Template>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter Grid.Column="0"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              RecognizesAccessKey="True" />

                                <Path Grid.Column="1"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  Stroke="#9CA3AF"
                                  StrokeThickness="2"
                                  Data="M 0 0 L 5 5 L 10 0" />
                            </Grid>
                        </ToggleButton>

                        <!-- Focus ring INNER -->
                        <Border x:Name="FocusInner"
                            Visibility="Collapsed"
                            IsHitTestVisible="False"
                            Background="Transparent"
                            BorderBrush="#93C5FD"
                            SnapsToDevicePixels="True"
                            RenderOptions.EdgeMode="Aliased">
                            <Border.CornerRadius>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="10" />
                            </Border.CornerRadius>
                            <Border.Margin>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ThicknessScaleConverter}"
                                     ConverterParameter="-1,-1,-1,-1" />
                            </Border.Margin>
                            <Border.BorderThickness>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="1" />
                            </Border.BorderThickness>
                        </Border>

                        <!-- Focus ring OUTER -->
                        <Border x:Name="FocusOuter"
                            Visibility="Collapsed"
                            IsHitTestVisible="False"
                            Background="Transparent"
                            BorderBrush="#C1DEFE"
                            SnapsToDevicePixels="True"
                            RenderOptions.EdgeMode="Aliased">
                            <Border.CornerRadius>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="12" />
                            </Border.CornerRadius>
                            <Border.Margin>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ThicknessScaleConverter}"
                                     ConverterParameter="-3,-3,-3,-3" />
                            </Border.Margin>
                            <Border.BorderThickness>
                                <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="3" />
                            </Border.BorderThickness>
                        </Border>

                        <!-- Popup dropdown -->
                        <Popup x:Name="Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Fade">
                            <Grid SnapsToDevicePixels="True"
                              UseLayoutRounding="True"
                              MinWidth="{TemplateBinding ActualWidth}"
                              Margin="0,6,0,0">
                                <Border Background="White"
                                    BorderThickness="1"
                                    BorderBrush="#E5E7EB"
                                    SnapsToDevicePixels="True">
                                    <Border.CornerRadius>
                                        <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource LayoutScaleConverter}"
                                             ConverterParameter="9" />
                                    </Border.CornerRadius>
                                </Border>
                                <ScrollViewer Margin="0" SnapsToDevicePixels="True">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Grid>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Show blue ring on focus -->
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!-- Keep blue ring while dropdown is open -->
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible" />
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!-- Hover only changes fill -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BaseBorder" Property="Background" Value="#FFEFEFF2" />
                        </Trigger>

                        <!-- Invalid state from code-behind wins over blue -->
                        <Trigger Property="BorderThickness" Value="1">
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="BaseBorder" Property="Background" Value="#FFE5E7EB" />
                            <Setter Property="Foreground" Value="#9CA3AF" />
                            <Setter TargetName="FocusInner" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
