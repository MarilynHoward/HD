        Used for: Confirm Authorization, Apply, etc.
    -->
    <Style x:Key="VcPrimaryButtonStyle"
       TargetType="Button">

        <!-- sizing + alignment to match VC buttons, now scaled -->
        <Setter Property="FontSize">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource FontScaleConverter}"
                     ConverterParameter="14" />
            </Setter.Value>
        </Setter>

        <Setter Property="Height">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource LayoutScaleConverter}"
                     ConverterParameter="34" />
            </Setter.Value>
        </Setter>

        <Setter Property="Padding">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource ThicknessScaleConverter}"
                     ConverterParameter="9,6,10,6" />
            </Setter.Value>
        </Setter>

        <Setter Property="Margin">
            <Setter.Value>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource ThicknessScaleConverter}"
                     ConverterParameter="0,3,0,3" />
            </Setter.Value>
        </Setter>

        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />

        <!-- colours for primary state -->
        
        <Setter Property="Background" Value="{StaticResource Brush.PrimaryBlue}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.White}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />

        <!-- no default focus rectangle -->
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />

        <!-- own template (same rounded shape as secondary) -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{Binding RelativeSource={RelativeSource TemplatedParent},
                          Path=ActualHeight,
                          Converter={StaticResource CornerRadiusFromHeightConverter},
                          ConverterParameter=10}"
                        Padding="{TemplateBinding Padding}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder"
                                Property="Background"
                                Value="{StaticResource Brush.PrimaryBlueHover}" />
                        </Trigger>

                        <!-- Pressed -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder"
                                Property="Background"
                                Value="{StaticResource Brush.PrimaryBluePressed}" />
                        </Trigger>

                        <!-- Disabled: turn into grey pill, to match your long disabled buttons -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder"
                                Property="Background"
                                Value="{StaticResource Brush.SurfaceGrey}" />
                            <Setter Property="Foreground"
                                Value="#9CA3AF" />
                            <Setter Property="Cursor"
                                Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!--
        DATA GRID STYLES FOR VERSION TABLE
        These do NOT touch row height; they only handle bold headers and row colouring.
    -->

    <!-- Bold column headers -->
    <Style x:Key="BoldHeaderStyle"
           TargetType="DataGridColumnHeader">
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Versions grid row style: Figma-like hover + selected colours -->
    <Style x:Key="VersionsRowStyle"
           TargetType="DataGridRow">
        <!-- base background -->
        <Setter Property="Background" Value="White" />
        <Setter Property="SnapsToDevicePixels" Value="True" />

        <Style.Triggers>
            <!-- Selected row background -->
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background"
                        Value="{StaticResource Brush.RowSelectedBg}" />
            </Trigger>

            <!-- Hover only when NOT selected -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsSelected" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="Background"
                        Value="{StaticResource Brush.RowHoverBg}" />
            </MultiTrigger>

            <!-- Hover + selected: keep the selected colour (no darkening on hover) -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsSelected" Value="True" />
                </MultiTrigger.Conditions>
                <Setter Property="Background"
                        Value="{StaticResource Brush.RowSelectedBg}" />
            </MultiTrigger>
        </Style.Triggers>
    </Style>

