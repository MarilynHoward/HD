<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- Compact PostgreSQL: user,password,host,port,database (commas or spaces).
         The literal token 'branch' in the database position is a placeholder; at startup,
         AppStatus.LocalConnectionstring(App.aps.propertyBranchCode) replaces it with the
         branch code read from Branch.txt (located under StaffDocumentsRepositoryRoot). All
         external callers must pass propertyBranchCode explicitly (no parameterless form). -->
    <add key="cnLocal" value="bh_user,tEst5946$,localhost,5432,branch" />
    <add key="cnCloud" value="bh_user,tEst5946$,localhost,5432,branch_test123" />
    <!-- ODBC driver name (see PosDataAccess.PSQLDrivers). -->
    <add key="PostgreSqlOdbcDriver" value="PostgreSql64Ansi93" />
    <!-- Root folder for staff uploads. ID PDFs live under docs\user_docs\ and profile images under images\user_images\. Missing subfolders are auto-created on first write. -->
    <add key="StaffDocumentsRepositoryRoot" value="D:\Dev\Cursor\HD\Documents" />
    <!-- Remote destination for staff ID documents and profile images. The same relative layout is mirrored
         (docs\user_docs\*, images\user_images\*). Accepts:
         - A local / UNC folder path, e.g. D:\Dev\Cursor\HD\Remote_Documents or \\server\share\staff
         - An SFTP URI WITHOUT credentials: sftp://host[:port]/remote/root/path
           (user/password for SFTP live in StaffDocumentsRemoteSftpUser / StaffDocumentsRemoteSftpPassword below
           and MUST be stored encrypted — see those keys).
         Leave blank to disable remote sync (files stay only under StaffDocumentsRepositoryRoot). -->
    <add key="StaffDocumentsRemoteRoot" value="D:\Dev\Cursor\HD\Remote_Documents" />
    <!-- SFTP credentials for StaffDocumentsRemoteRoot when that key is an sftp:// URI. Both values MUST be
         stored as Crypt-encrypted ciphertext (never plain text) — generate them once via
         StaffDocumentsRemoteSync.EncryptForConfig(plain) and paste the result here. The app decrypts at
         runtime using App.aps.crypt.DoDecrypt. Leave blank when StaffDocumentsRemoteRoot is a local/UNC path. -->
    <add key="StaffDocumentsRemoteSftpUser" value="" />
    <add key="StaffDocumentsRemoteSftpPassword" value="" />
    <!-- When true, App.OnStartup deletes every is_seed=TRUE row from users/roles and reinserts the demo set.
         Leave FALSE on live installations; only production-safe (is_seed=FALSE) rows survive. -->
    <add key="SeedDummyDataOnStartup" value="true" />
    <!-- When true, AppStatus writes a startup/seed/LoadFromDb trace to %TEMP%\PeoplePosStartup.log.
         Leave FALSE on live installations; turn ON only when diagnosing data-access issues. -->
    <add key="DiagnosticLogging" value="false" />
  </appSettings>
</configuration>
