<UserControl x:Class="RestaurantPosWpf.StaffAccessBioMetric"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             HorizontalAlignment="Stretch">



    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Top"
                  ClipToBounds="False">

    <Grid HorizontalAlignment="Stretch" MinWidth="0">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <StackPanel Grid.Row="0"

                    Orientation="Horizontal"

                    HorizontalAlignment="Stretch"

                    Margin="{Binding Source={StaticResource UiScaleState},

                                      Path=FontScale,

                                      Converter={StaticResource ThicknessScaleConverter},

                                      ConverterParameter='0,0,0,12'}">

            <Viewbox Width="{Binding Source={StaticResource UiScaleState},

                                     Path=FontScale,

                                     Converter={StaticResource LayoutScaleConverter},

                                     ConverterParameter=40}"

                     Height="{Binding Source={StaticResource UiScaleState},

                                      Path=FontScale,

                                      Converter={StaticResource LayoutScaleConverter},

                                      ConverterParameter=40}"

                     VerticalAlignment="Center"

                     Margin="{Binding Source={StaticResource UiScaleState},

                                      Path=FontScale,

                                      Converter={StaticResource ThicknessScaleConverter},

                                      ConverterParameter='0,0,12,0'}">

                <Canvas Width="24" Height="24">

                    <Path Data="M12 2 C8 2 5 5 5 9 L5 11 C5 14 6 17 8 19 L8 22 L16 22 L16 19 C18 17 19 14 19 11 L19 9 C19 5 16 2 12 2 Z"

                          Fill="#6C63FF"

                          Opacity="0.9" />

                </Canvas>

            </Viewbox>

            <StackPanel VerticalAlignment="Center">

                <TextBlock x:Name="TxtBioTitle"

                           Text="Biometric enrollment"

                           FontWeight="SemiBold"

                           Foreground="{StaticResource MainForeground}"

                           FontSize="{Binding Source={StaticResource UiScaleState},

                                              Path=FontScale,

                                              Converter={StaticResource FontScaleConverter},

                                              ConverterParameter=16}" />

                <TextBlock x:Name="TxtBioStatus"

                           Text="Not enrolled"

                           Foreground="{StaticResource DimmedForeground}"

                           Margin="{Binding Source={StaticResource UiScaleState},

                                            Path=FontScale,

                                            Converter={StaticResource ThicknessScaleConverter},

                                            ConverterParameter='0,4,0,0'}"

                           FontSize="{Binding Source={StaticResource UiScaleState},

                                              Path=FontScale,

                                              Converter={StaticResource FontScaleConverter},

                                              ConverterParameter=15}" />

            </StackPanel>

        </StackPanel>



        <TextBlock Grid.Row="1"

                   Text="Use the terminal reader to capture a fingerprint template for this user. Demo mode toggles enrollment state only."

                   TextWrapping="Wrap"

                   HorizontalAlignment="Stretch"

                   Foreground="{StaticResource DimmedForeground}"

                   FontSize="{Binding Source={StaticResource UiScaleState},

                                      Path=FontScale,

                                      Converter={StaticResource FontScaleConverter},

                                      ConverterParameter=14}"

                   Margin="{Binding Source={StaticResource UiScaleState},

                                    Path=FontScale,

                                    Converter={StaticResource ThicknessScaleConverter},

                                    ConverterParameter='0,0,0,16'}" />



        <StackPanel Grid.Row="2"

                    Orientation="Horizontal"

                    HorizontalAlignment="Stretch">

            <Button x:Name="BtnSimulateEnroll"

                    Content="Simulate capture"

                    Style="{StaticResource VcSecondaryButtonStyle}"

                    Click="BtnSimulateEnroll_OnClick"

                    Margin="{Binding Source={StaticResource UiScaleState},

                                     Path=FontScale,

                                     Converter={StaticResource ThicknessScaleConverter},

                                     ConverterParameter='0,0,10,0'}" />

            <Button x:Name="BtnClearBio"

                    Content="Clear enrollment"

                    Style="{StaticResource VcSecondaryButtonStyle}"

                    Click="BtnClearBio_OnClick" />

        </StackPanel>

    </Grid>

    </ScrollViewer>

</UserControl>

