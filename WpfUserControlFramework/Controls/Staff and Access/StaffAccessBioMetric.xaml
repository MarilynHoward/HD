<UserControl x:Class="RestaurantPosWpf.StaffAccessBioMetric"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch">
    <UserControl.Resources>
        <!-- Same Lucide fingerprint strokes as the Biometric tab in StaffAccessUserDetails. -->
        <Style x:Key="BioMetricLucidePathStyle" TargetType="Path">
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="Stroke" Value="#111827" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Top"
                  ClipToBounds="False">
        <Border Padding="{Binding Source={StaticResource UiScaleState},
                                  Path=FontScale,
                                  Converter={StaticResource ThicknessScaleConverter},
                                  ConverterParameter='10,12,10,12'}">
            <StackPanel HorizontalAlignment="Stretch" MinWidth="0">
                <!-- Info banner (client: light purple notice) -->
                <Border Background="#F5F3FF"
                        BorderBrush="#DDD6FE"
                        BorderThickness="1"
                        CornerRadius="{Binding Source={StaticResource UiScaleState},
                                               Path=FontScale,
                                               Converter={StaticResource ScaledDoubleConverter},
                                               ConverterParameter=10}"
                        Padding="{Binding Source={StaticResource UiScaleState},
                                          Path=FontScale,
                                          Converter={StaticResource ThicknessScaleConverter},
                                          ConverterParameter='10,10,10,10'}">
                    <StackPanel Orientation="Horizontal">
                        <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource LayoutScaleConverter},
                                                 ConverterParameter=22}"
                                 Height="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource LayoutScaleConverter},
                                                  ConverterParameter=22}"
                                 VerticalAlignment="Top"
                                 Margin="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='0,0,10,0'}"
                                 Stretch="Uniform">
                            <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                      Data="M 12,10 A 2,2 0 0 0 10,12 C 10,13.02 9.9,14.51 9.74,16" />
                                <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                      Data="M 14,13.12 C 14,15.5 14,19.5 13,22" />
                                <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                      Data="M 17.29,21.02 C 17.41,20.42 17.72,18.72 17.79,18" />
                                <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                      Data="M 2,12 A 10,10 0 0 1 20,6" />
                                <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                      Data="M 2,16 L 2.01,16" />
                                <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                      Data="M 21.8,16 C 22,14 21.931,10.646 21.8,10" />
                                <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                      Data="M 5,19.5 C 5.5,18 6,15 6,12 A 6,6 0 0 1 6.34,10" />
                                <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                      Data="M 8.65,22 C 8.86,21.34 9.1,20.68 9.22,20" />
                                <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                      Data="M 9,6.8 A 6,6 0 0 1 18,12 L 18,14" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Biometric authentication provides enhanced security"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   Foreground="#5B21B6"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=14}" />
                    </StackPanel>
                </Border>

                <!-- Enrollment card -->
                <Border x:Name="BioEnrollmentCard"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='0,14,0,0'}"
                        Background="White"
                        BorderBrush="{StaticResource Brush.BorderSoft}"
                        BorderThickness="1"
                        CornerRadius="{Binding Source={StaticResource UiScaleState},
                                               Path=FontScale,
                                               Converter={StaticResource ScaledDoubleConverter},
                                               ConverterParameter=12}"
                        Padding="{Binding Source={StaticResource UiScaleState},
                                          Path=FontScale,
                                          Converter={StaticResource ThicknessScaleConverter},
                                          ConverterParameter='12,14,12,14'}">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Width="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource LayoutScaleConverter},
                                                 ConverterParameter=56}"
                                Height="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource LayoutScaleConverter},
                                                  ConverterParameter=56}"
                                Background="#F3F4F6"
                                CornerRadius="{Binding Source={StaticResource UiScaleState},
                                                       Path=FontScale,
                                                       Converter={StaticResource ScaledDoubleConverter},
                                                       ConverterParameter=10}"
                                VerticalAlignment="Center">
                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource LayoutScaleConverter},
                                                     ConverterParameter=32}"
                                     Height="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource LayoutScaleConverter},
                                                      ConverterParameter=32}"
                                     Stretch="Uniform"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                    <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                          Data="M 12,10 A 2,2 0 0 0 10,12 C 10,13.02 9.9,14.51 9.74,16" />
                                    <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                          Data="M 14,13.12 C 14,15.5 14,19.5 13,22" />
                                    <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                          Data="M 17.29,21.02 C 17.41,20.42 17.72,18.72 17.79,18" />
                                    <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                          Data="M 2,12 A 10,10 0 0 1 20,6" />
                                    <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                          Data="M 2,16 L 2.01,16" />
                                    <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                          Data="M 21.8,16 C 22,14 21.931,10.646 21.8,10" />
                                    <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                          Data="M 5,19.5 C 5.5,18 6,15 6,12 A 6,6 0 0 1 6.34,10" />
                                    <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                          Data="M 8.65,22 C 8.86,21.34 9.1,20.68 9.22,20" />
                                    <Path Style="{StaticResource BioMetricLucidePathStyle}"
                                          Data="M 9,6.8 A 6,6 0 0 1 18,12 L 18,14" />
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='12,0,12,0'}">
                            <TextBlock Text="Fingerprint"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MainForeground}"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=16}" />
                            <TextBlock x:Name="TxtFingerprintSubtitle"
                                       Text="Not enrolled"
                                       Foreground="{StaticResource DimmedForeground}"
                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                        Path=FontScale,
                                                        Converter={StaticResource ThicknessScaleConverter},
                                                        ConverterParameter='0,4,0,0'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=14}" />
                        </StackPanel>
                        <Button x:Name="BtnPrimaryBioAction"
                                Grid.Column="2"
                                Content="Enroll fingerprint"
                                Style="{StaticResource VcPrimaryButtonStyle}"
                                VerticalAlignment="Center"
                                Click="BtnPrimaryBioAction_OnClick" />
                    </Grid>
                </Border>

                <TextBlock x:Name="TxtEnrollingHint"
                           Visibility="Collapsed"
                           TextWrapping="Wrap"
                           Margin="{Binding Source={StaticResource UiScaleState},
                                            Path=FontScale,
                                            Converter={StaticResource ThicknessScaleConverter},
                                            ConverterParameter='0,10,0,0'}"
                           Foreground="{StaticResource DimmedForeground}"
                           FontSize="{Binding Source={StaticResource UiScaleState},
                                              Path=FontScale,
                                              Converter={StaticResource FontScaleConverter},
                                              ConverterParameter=14}" />

                <!-- Success banner (client: mint + chip) -->
                <Border x:Name="BioStatusBanner"
                        Visibility="Collapsed"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='0,12,0,0'}"
                        Background="#DCFCE7"
                        BorderBrush="#BBF7D0"
                        BorderThickness="1"
                        CornerRadius="{Binding Source={StaticResource UiScaleState},
                                               Path=FontScale,
                                               Converter={StaticResource ScaledDoubleConverter},
                                               ConverterParameter=10}"
                        Padding="{Binding Source={StaticResource UiScaleState},
                                          Path=FontScale,
                                          Converter={StaticResource ThicknessScaleConverter},
                                          ConverterParameter='10,10,10,10'}">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#16A34A"
                                CornerRadius="{Binding Source={StaticResource UiScaleState},
                                                        Path=FontScale,
                                                        Converter={StaticResource ScaledDoubleConverter},
                                                        ConverterParameter=6}"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource ThicknessScaleConverter},
                                                   ConverterParameter='8,3,8,3'}"
                                VerticalAlignment="Center">
                            <TextBlock Text="Enrolled"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=11}" />
                        </Border>
                        <TextBlock Text="Fingerprint authentication is active"
                                   VerticalAlignment="Center"
                                   Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='10,0,0,0'}"
                                   Foreground="#166534"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=14}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
