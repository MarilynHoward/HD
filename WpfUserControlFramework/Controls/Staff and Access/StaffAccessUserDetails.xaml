<UserControl x:Class="RestaurantPosWpf.StaffAccessUserDetails"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RestaurantPosWpf"
             Loaded="StaffAccessUserDetails_OnLoaded"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <UserControl.Resources>
        <!-- Card shadow (same weight as Operations shift scheduling) -->
        <DropShadowEffect x:Key="StaffAccessCardShadow"
                          BlurRadius="14"
                          Direction="270"
                          Opacity="0.08"
                          ShadowDepth="2"
                          Color="#000000" />

        <!-- User list row elevation (match OpsServicesTableManagement TablesListBox cards). -->
        <DropShadowEffect x:Key="StaffAccessUserRowSelectedShadow"
                          BlurRadius="12"
                          Direction="270"
                          Opacity="0.16"
                          ShadowDepth="3"
                          Color="#000000" />
        <DropShadowEffect x:Key="StaffAccessUserRowHoverShadow"
                          BlurRadius="16"
                          Direction="270"
                          Opacity="0.2"
                          ShadowDepth="4"
                          Color="#000000" />

        <!-- Stat tiles on purple header: solid fill + white type (client #7B7EF1) -->
        <SolidColorBrush x:Key="StaffStatHeaderTileBg" Color="#7B7EF1" />
        <SolidColorBrush x:Key="StaffStatHeaderTileBorder" Color="#99FFFFFF" />
        <SolidColorBrush x:Key="StaffStatTotalIconSquircleBg" Color="#9799F8" />
        <SolidColorBrush x:Key="StaffStatActiveIconSquircleBg" Color="#649BD8" />

        <SolidColorBrush x:Key="StaffAccessPurple" Color="#676BF0" />
        <SolidColorBrush x:Key="StaffAccessPurpleSubtitle" Color="#DDE4FF" />

        <Style x:Key="StaffFormLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DimmedForeground}" />
            <Setter Property="FontSize"
                    Value="{Binding Source={StaticResource UiScaleState},
                                    Path=FontScale,
                                    Converter={StaticResource FontScaleConverter},
                                    ConverterParameter=14}" />
            <Setter Property="Margin"
                    Value="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='0,0,0,4'}" />
        </Style>

        <!-- Read-only ID: regular weight + muted value (matches client reference). -->
        <Style x:Key="StaffAccessReadOnlyIdTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource IcEnabledTextBoxStyle}">
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
        </Style>

        <!-- User details tab strip: Lucide strokes follow RadioButton Foreground (#111827). -->
        <Style x:Key="StaffTabLucidePathStyle"
               TargetType="Path">
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="Stroke"
                    Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
        </Style>

        <!-- Segmented radio strip (same pattern as system config tabs): pill radius + white segment when checked. -->
        <Style x:Key="StaffDetailTabRadioStyle"
               TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="SegmentBorder"
                                Background="Transparent"
                                SnapsToDevicePixels="True">
                            <Border.CornerRadius>
                                <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource ScaledDoubleConverter}"
                                         ConverterParameter="20" />
                            </Border.CornerRadius>
                            <Border.Padding>
                                <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource ThicknessScaleConverter}"
                                         ConverterParameter="0,8" />
                            </Border.Padding>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SegmentBorder" Property="Background" Value="White" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="SegmentBorder" Property="Background" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Chrome on item card (RowBorder in template); host matches OpsTableMgmtListBoxItemStyle. -->
        <Style x:Key="StaffListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Padding is applied in code so right edge matches left when vertical scrollbar shows/hides (Procurement list pattern). -->
        <Style x:Key="StaffUsersListBoxStyle" TargetType="ListBox">
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource StaffListItemStyle}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <!-- Add User: brand teal (#1DC9B6) + white label/icon (own template so hover is not VcSecondary grey). -->
        <Style x:Key="StaffAccessHeaderAddUserButtonStyle"
               TargetType="Button">
            <Setter Property="FontSize">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource FontScaleConverter}"
                             ConverterParameter="14" />
                </Setter.Value>
            </Setter>
            <Setter Property="Height">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource LayoutScaleConverter}"
                             ConverterParameter="28" />
                </Setter.Value>
            </Setter>
            <Setter Property="Padding">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource ThicknessScaleConverter}"
                             ConverterParameter="8,2" />
                </Setter.Value>
            </Setter>
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{StaticResource Brush.White}" />
            <Setter Property="Background" Value="#1DC9B6" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{Binding RelativeSource={RelativeSource TemplatedParent},
                                                       Path=ActualHeight,
                                                       Converter={StaticResource CornerRadiusFromHeightConverter},
                                                       ConverterParameter=6}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#19B5A3" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#159E8E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#9CA3AF" />
                                <Setter Property="Foreground" Value="#E5E7EB" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Same chrome as OpsServicesReservationsManagement ReservationCardIconButtonStyle; corner from height (not FontScale). -->
        <Style x:Key="StaffAccessUserCardIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"
                    Value="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='8,6,8,6'}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth"
                    Value="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource LayoutScaleConverter},
                                     ConverterParameter=36}" />
            <Setter Property="MinHeight"
                    Value="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource LayoutScaleConverter},
                                     ConverterParameter=36}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                                       Path=ActualHeight,
                                                       Converter={StaticResource CornerRadiusFromHeightConverter},
                                                       ConverterParameter=8}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E7EB" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource FocusOuter}" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource Brush.SurfaceOffWhite}"
            SnapsToDevicePixels="True"
            VerticalAlignment="Stretch">
        <!-- Bounded height (no whole-page vertical scroll): list scrolls inside left card; header + details stay put. -->
        <!-- Same width behavior as Operations (e.g. Shift Scheduling): stretch with outer margin only — no MaxWidth + Center. -->
        <Grid x:Name="PageScroll"
              VerticalAlignment="Stretch"
              HorizontalAlignment="Stretch"
              MinHeight="0"
              Margin="{Binding Source={StaticResource UiScaleState},
                               Path=FontScale,
                               Converter={StaticResource ThicknessScaleConverter},
                               ConverterParameter='24,24,24,24'}">
            <Grid VerticalAlignment="Stretch"
                  HorizontalAlignment="Stretch"
                  MinHeight="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition
                        Width="{Binding Source={StaticResource UiScaleState},
                                        Path=FontScale,
                                        Converter={StaticResource LayoutScaleConverter},
                                        ConverterParameter=340}" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Left: user list (Operations-style white card) -->
                <Border x:Name="StaffAccessListCard"
                        Grid.Column="0"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='0,0,16,0'}"
                        VerticalAlignment="Stretch"
                        MinHeight="0"
                        Background="{StaticResource Brush.White}"
                        BorderBrush="{StaticResource Brush.BorderSoft}"
                        BorderThickness="1"
                        ClipToBounds="True"
                        CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                               Path=ActualHeight,
                                               Converter={StaticResource CornerRadiusFromHeightConverter},
                                               ConverterParameter=12}"
                        Effect="{StaticResource StaffAccessCardShadow}">
                    <Grid MinHeight="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="0" />
                        </Grid.RowDefinitions>
                        <!-- Brand header: icon + titles, Add User (secondary), stat cards on #676BF0 -->
                        <Border Grid.Row="0"
                                Background="{StaticResource StaffAccessPurple}"
                                CornerRadius="{Binding Source={StaticResource UiScaleState},
                                                       Path=FontScale,
                                                       Converter={StaticResource ScaledCornerRadiusConverter},
                                                       ConverterParameter='12,12,0,0'}"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource ThicknessScaleConverter},
                                                   ConverterParameter='16,16,16,14'}">
                            <StackPanel>
                                <!-- Header row: *+Auto with MinWidth=0 so titles ellipsize instead of drawing over the button (narrow list column). -->
                                <Grid Margin="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource ThicknessScaleConverter},
                                                      ConverterParameter='0,0,0,14'}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"
                                                          MinWidth="0" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0"
                                          MinWidth="0"
                                          Margin="{Binding Source={StaticResource UiScaleState},
                                                           Path=FontScale,
                                                           Converter={StaticResource ThicknessScaleConverter},
                                                           ConverterParameter='0,0,16,0'}"
                                          VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*"
                                                              MinWidth="0" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Background="#33FFFFFF"
                                                CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                                                       Path=ActualHeight,
                                                                       Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                       ConverterParameter=8}"
                                                Padding="{Binding Source={StaticResource UiScaleState},
                                                                 Path=FontScale,
                                                                 Converter={StaticResource ThicknessScaleConverter},
                                                                 ConverterParameter='8,8,8,8'}"
                                                Margin="{Binding Source={StaticResource UiScaleState},
                                                                 Path=FontScale,
                                                                 Converter={StaticResource ThicknessScaleConverter},
                                                                 ConverterParameter='0,0,12,0'}"
                                                VerticalAlignment="Center">
                                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource LayoutScaleConverter},
                                                             ConverterParameter=26.6}"
                                                     Height="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource LayoutScaleConverter},
                                                                      ConverterParameter=26.6}">
                                                <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                                    <Path Stroke="White"
                                                          StrokeThickness="2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Fill="Transparent"
                                                          Data="M 16 21 v -2 a 4 4 0 0 0 -4 -4 H 6 a 4 4 0 0 0 -4 4 v 2" />
                                                    <Ellipse Canvas.Left="5"
                                                             Canvas.Top="3"
                                                             Width="8"
                                                             Height="8"
                                                             Stroke="White"
                                                             StrokeThickness="2"
                                                             Fill="Transparent" />
                                                    <Path Stroke="White"
                                                          StrokeThickness="2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Fill="Transparent"
                                                          Data="M 22 21 v -2 a 4 4 0 0 0 -3 -3.87" />
                                                    <Path Stroke="White"
                                                          StrokeThickness="2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Fill="Transparent"
                                                          Data="M 16 3.13 a 4 4 0 0 1 0 7.75" />
                                                </Canvas>
                                            </Viewbox>
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    MinWidth="0">
                                            <TextBlock Text="User Access"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=15}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap" />
                                            <TextBlock Text="Manage staff members"
                                                       Foreground="{StaticResource StaffAccessPurpleSubtitle}"
                                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                                        Path=FontScale,
                                                                        Converter={StaticResource ThicknessScaleConverter},
                                                                        ConverterParameter='0,3,0,0'}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=12}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                    <Button x:Name="BtnAddUser"
                                            Grid.Column="1"
                                            Click="BtnAddUser_OnClick"
                                            Style="{StaticResource StaffAccessHeaderAddUserButtonStyle}"
                                            VerticalAlignment="Center"
                                            FocusVisualStyle="{x:Null}">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                     Path=FontScale,
                                                                     Converter={StaticResource LayoutScaleConverter},
                                                                     ConverterParameter=14}"
                                                     Height="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource LayoutScaleConverter},
                                                                      ConverterParameter=14}"
                                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource ThicknessScaleConverter},
                                                                      ConverterParameter='0,0,5,0'}">
                                                <Canvas Width="24"
                                                        Height="24"
                                                        SnapsToDevicePixels="True">
                                                    <!-- Lucide user-plus @ 24 -->
                                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}"
                                                          Data="M 16,21 L 16,19 A 4,4 0 0 0 12,15 L 6,15 A 4,4 0 0 0 2,19 L 2,21" />
                                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}"
                                                          Data="M 13,7 A 4,4 0 1 1 5,7 A 4,4 0 1 1 13,7" />
                                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}"
                                                          Data="M 19,8 L 19,14" />
                                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}"
                                                          Data="M 22,11 L 16,11" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock x:Name="TxtAddUserButtonLabel"
                                                       Text="Add User"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <UniformGrid Columns="2"
                                             Margin="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource ThicknessScaleConverter},
                                                              ConverterParameter='0,0,0,0'}">
                                    <Border Background="{StaticResource StaffStatHeaderTileBg}"
                                            BorderBrush="{StaticResource StaffStatHeaderTileBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                                                   Path=ActualHeight,
                                                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                   ConverterParameter=8}"
                                            Padding="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource ThicknessScaleConverter},
                                                              ConverterParameter='12,10,12,10'}"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='0,0,8,0'}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="Total Users"
                                                       Foreground="White"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=12}"
                                                       VerticalAlignment="Center" />
                                            <Border Grid.Row="0"
                                                    Grid.Column="1"
                                                    Background="{StaticResource StaffStatTotalIconSquircleBg}"
                                                    CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                                                           Path=ActualHeight,
                                                                           Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                           ConverterParameter=8}"
                                                    Padding="{Binding Source={StaticResource UiScaleState},
                                                                       Path=FontScale,
                                                                       Converter={StaticResource ThicknessScaleConverter},
                                                                       ConverterParameter='5,5,5,5'}"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                                     Path=FontScale,
                                                                     Converter={StaticResource ThicknessScaleConverter},
                                                                     ConverterParameter='0,0,0,2'}">
                                                <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                         Path=FontScale,
                                                                         Converter={StaticResource LayoutScaleConverter},
                                                                         ConverterParameter=20}"
                                                         Height="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource LayoutScaleConverter},
                                                                          ConverterParameter=20}">
                                                    <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                                        <Path Stroke="White"
                                                              StrokeThickness="2"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              Fill="Transparent"
                                                              Data="M 16 21 v -2 a 4 4 0 0 0 -4 -4 H 6 a 4 4 0 0 0 -4 4 v 2" />
                                                        <Ellipse Canvas.Left="5"
                                                                 Canvas.Top="3"
                                                                 Width="8"
                                                                 Height="8"
                                                                 Stroke="White"
                                                                 StrokeThickness="2"
                                                                 Fill="Transparent" />
                                                        <Path Stroke="White"
                                                              StrokeThickness="2"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              Fill="Transparent"
                                                              Data="M 22 21 v -2 a 4 4 0 0 0 -3 -3.87" />
                                                        <Path Stroke="White"
                                                              StrokeThickness="2"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              Fill="Transparent"
                                                              Data="M 16 3.13 a 4 4 0 0 1 0 7.75" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <TextBlock x:Name="TxtStatTotal"
                                                       Grid.Row="1"
                                                       Grid.Column="0"
                                                       Grid.ColumnSpan="2"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=22}"
                                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                                        Path=FontScale,
                                                                        Converter={StaticResource ThicknessScaleConverter},
                                                                        ConverterParameter='0,4,0,0'}" />
                                        </Grid>
                                    </Border>
                                    <Border Background="{StaticResource StaffStatHeaderTileBg}"
                                            BorderBrush="{StaticResource StaffStatHeaderTileBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                                                   Path=ActualHeight,
                                                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                   ConverterParameter=8}"
                                            Padding="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource ThicknessScaleConverter},
                                                              ConverterParameter='12,10,12,10'}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="0"
                                                       Text="Active"
                                                       Foreground="White"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=12}"
                                                       VerticalAlignment="Center" />
                                            <Border Grid.Row="0"
                                                    Grid.Column="1"
                                                    Background="{StaticResource StaffStatActiveIconSquircleBg}"
                                                    CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                                                           Path=ActualHeight,
                                                                           Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                           ConverterParameter=8}"
                                                    Padding="{Binding Source={StaticResource UiScaleState},
                                                                       Path=FontScale,
                                                                       Converter={StaticResource ThicknessScaleConverter},
                                                                       ConverterParameter='5,5,5,5'}"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                                     Path=FontScale,
                                                                     Converter={StaticResource ThicknessScaleConverter},
