                                    BorderBrush="#CCC"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False"
                                    BorderThickness="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource LayoutScaleConverter},
                                                              ConverterParameter=1}"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='0,0,0,12'}">
                                <Border.CornerRadius>
                                    <Binding RelativeSource="{RelativeSource Self}"
                                             Path="ActualHeight"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="8" />
                                </Border.CornerRadius>
                                <Grid>
                                    <!-- Focus rings: visibility toggled in code (same as OpsServicesFloorPlanDesign — DataTriggers lose to local Visibility). -->
                                    <Border x:Name="SearchFocusOuter"
                                            Panel.ZIndex="10"
                                            Visibility="Collapsed"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='-3'}"
                                            CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                                                   Path=ActualHeight,
                                                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                   ConverterParameter='9'}"
                                            BorderThickness="3"
                                            BorderBrush="#C1DEFE"
                                            Background="Transparent"
                                            SnapsToDevicePixels="True"
                                            RenderOptions.EdgeMode="Aliased"
                                            IsHitTestVisible="False" />
                                    <Border x:Name="SearchFocusInner"
                                            Panel.ZIndex="11"
                                            Visibility="Collapsed"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='-1'}"
                                            CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                                                   Path=ActualHeight,
                                                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                   ConverterParameter='8'}"
                                            BorderThickness="1"
                                            BorderBrush="#93C5FD"
                                            Background="Transparent"
                                            SnapsToDevicePixels="True"
                                            RenderOptions.EdgeMode="Aliased"
                                            IsHitTestVisible="False" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                 Path=FontScale,
                                                                 Converter={StaticResource LayoutScaleConverter},
                                                                 ConverterParameter=16}"
                                                 Height="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=16}"
                                                 Margin="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource ThicknessScaleConverter},
                                                                  ConverterParameter='10,0,6,0'}"
                                                 VerticalAlignment="Center">
                                            <Canvas Width="16" Height="16" SnapsToDevicePixels="True">
                                                <Ellipse Canvas.Left="2"
                                                         Canvas.Top="2"
                                                         Width="10"
                                                         Height="10"
                                                         Stroke="#9CA3AF"
                                                         StrokeThickness="1.6"
                                                         Fill="Transparent" />
                                                <Line X1="10.5"
                                                      Y1="10.5"
                                                      X2="15"
                                                      Y2="15"
                                                      Stroke="#9CA3AF"
                                                      StrokeThickness="1.6"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                            </Canvas>
                                        </Viewbox>
                                        <TextBox Grid.Column="1"
                                                 x:Name="SearchTextBox"
                                                 Height="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=40}"
                                                 TextChanged="SearchTextBox_OnTextChanged"
                                                 GotKeyboardFocus="SearchTextBox_OnGotKeyboardFocus"
                                                 LostKeyboardFocus="SearchTextBox_OnLostKeyboardFocus"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Padding="0"
                                                 FontSize="{Binding Source={StaticResource UiScaleState},
                                                                    Path=FontScale,
                                                                    Converter={StaticResource FontScaleConverter},
                                                                    ConverterParameter=14}"
                                                 VerticalAlignment="Center"
                                                 Style="{StaticResource SearchWatermarkTextBox}"
                                                 Tag="Search users by name or ID…"
                                                 ToolTip="Filter by user name, display name, or numeric ID." />
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <ListBox x:Name="UsersList"
                                 Grid.Row="2"
                                 VerticalAlignment="Stretch"
                                 MinHeight="0"
                                 Style="{StaticResource StaffUsersListBoxStyle}"
                                 SelectionChanged="UsersList_OnSelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 PreviewMouseWheel="UsersList_OnPreviewMouseWheel">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:StaffAccessListItemVm}">
                                    <Border x:Name="RowBorder"
                                            Padding="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource ThicknessScaleConverter},
                                                              ConverterParameter='8,11,8,11'}"
                                            BorderThickness="1"
                                            SnapsToDevicePixels="True"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='0,0,0,4'}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource Brush.White}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSoft}" />
                                                <Setter Property="Effect" Value="{x:Null}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                                                 Value="True">
                                                        <Setter Property="Background" Value="#EFF6FF" />
                                                        <Setter Property="BorderBrush" Value="#93C5FD" />
                                                        <Setter Property="Effect" Value="{StaticResource StaffAccessUserRowSelectedShadow}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}"
                                                                       Value="True" />
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                                                                       Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{StaticResource Brush.SurfaceGreySoft}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource Brush.SurfaceGrey}" />
                                                        <Setter Property="Effect" Value="{StaticResource StaffAccessUserRowHoverShadow}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.CornerRadius>
                                            <Binding RelativeSource="{RelativeSource Self}"
                                                     Path="ActualHeight"
                                                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                     ConverterParameter="8" />
                                        </Border.CornerRadius>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding ListPrimaryLine}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource MainForeground}"
                                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                                  Path=FontScale,
                                                                                  Converter={StaticResource FontScaleConverter},
                                                                                  ConverterParameter=14}" />
                                                    <Border Margin="{Binding Source={StaticResource UiScaleState},
                                                                              Path=FontScale,
                                                                              Converter={StaticResource ThicknessScaleConverter},
                                                                              ConverterParameter='8,0,0,0'}"
                                                            BorderThickness="1"
                                                            BorderBrush="{Binding StatusPillBorderBrush}"
                                                            Padding="{Binding Source={StaticResource UiScaleState},
                                                                              Path=FontScale,
                                                                              Converter={StaticResource ThicknessScaleConverter},
                                                                              ConverterParameter='8,2,8,2'}"
                                                            Background="{Binding StatusPillBackground}">
                                                        <Border.CornerRadius>
                                                            <Binding RelativeSource="{RelativeSource Self}"
                                                                     Path="ActualHeight"
                                                                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                                     ConverterParameter="8" />
                                                        </Border.CornerRadius>
                                                        <TextBlock Text="{Binding StatusLabel}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                                                      Path=FontScale,
                                                                                      Converter={StaticResource FontScaleConverter},
                                                                                      ConverterParameter=12}"
                                                                   Foreground="{Binding StatusPillForeground}" />
                                                    </Border>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal"
                                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                                             Path=FontScale,
                                                                             Converter={StaticResource ThicknessScaleConverter},
                                                                             ConverterParameter='0,6,0,0'}">
                                                    <TextBlock Text="{Binding IdLine}"
                                                               Foreground="{StaticResource DimmedForeground}"
                                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                                  Path=FontScale,
                                                                                  Converter={StaticResource FontScaleConverter},
                                                                                  ConverterParameter=13}" />
                                                    <Border Margin="{Binding Source={StaticResource UiScaleState},
                                                                              Path=FontScale,
                                                                              Converter={StaticResource ThicknessScaleConverter},
                                                                              ConverterParameter='8,0,0,0'}"
                                                            BorderThickness="1"
                                                            BorderBrush="{Binding RoleBadgeBorderBrush}"
                                                            Padding="{Binding Source={StaticResource UiScaleState},
                                                                              Path=FontScale,
                                                                              Converter={StaticResource ThicknessScaleConverter},
                                                                              ConverterParameter='8,2,8,2'}"
                                                            Background="{Binding RoleBadgeBackground}">
                                                        <Border.CornerRadius>
                                                            <Binding RelativeSource="{RelativeSource Self}"
                                                                     Path="ActualHeight"
                                                                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                                     ConverterParameter="8" />
                                                        </Border.CornerRadius>
                                                        <TextBlock Text="{Binding RoleBadge}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                                                      Path=FontScale,
                                                                                      Converter={StaticResource FontScaleConverter},
                                                                                      ConverterParameter=12}"
                                                                   Foreground="{Binding RoleBadgeForeground}" />
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- Stay enabled so Click runs and error toast explains Operations linkage (IsEnabled=false swallowed clicks). -->
                                            <Button Grid.Column="1"
                                                    AutomationProperties.Name="Remove user"
                                                    Style="{StaticResource StaffAccessUserCardIconButtonStyle}"
                                                    ToolTip="{Binding DeleteToolTip}"
                                                    VerticalAlignment="Center"
                                                    Tag="{Binding User.Id}"
                                                    Click="BtnDeleteUser_OnClick">
                                                <Viewbox Stretch="Uniform"
                                                         Width="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource LayoutScaleConverter},
                                                                          ConverterParameter=14.58}"
                                                         Height="{Binding Source={StaticResource UiScaleState},
                                                                           Path=FontScale,
                                                                           Converter={StaticResource LayoutScaleConverter},
                                                                           ConverterParameter=14.58}">
                                                    <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                                        <Path Stroke="#DC2626"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              Fill="Transparent"
                                                              Data="M10 11v6">
                                                            <Path.StrokeThickness>
                                                                <Binding Source="{StaticResource UiScaleState}"
                                                                         Path="FontScale"
                                                                         Converter="{StaticResource LayoutScaleConverter}"
                                                                         ConverterParameter="2" />
                                                            </Path.StrokeThickness>
                                                        </Path>
                                                        <Path Stroke="#DC2626"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              Fill="Transparent"
                                                              Data="M14 11v6">
                                                            <Path.StrokeThickness>
                                                                <Binding Source="{StaticResource UiScaleState}"
                                                                         Path="FontScale"
                                                                         Converter="{StaticResource LayoutScaleConverter}"
                                                                         ConverterParameter="2" />
                                                            </Path.StrokeThickness>
                                                        </Path>
                                                        <Path Stroke="#DC2626"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              Fill="Transparent"
                                                              Data="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6">
                                                            <Path.StrokeThickness>
                                                                <Binding Source="{StaticResource UiScaleState}"
                                                                         Path="FontScale"
                                                                         Converter="{StaticResource LayoutScaleConverter}"
                                                                         ConverterParameter="2" />
                                                            </Path.StrokeThickness>
                                                        </Path>
                                                        <Path Stroke="#DC2626"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              Fill="Transparent"
                                                              Data="M3 6h18">
                                                            <Path.StrokeThickness>
                                                                <Binding Source="{StaticResource UiScaleState}"
                                                                         Path="FontScale"
                                                                         Converter="{StaticResource LayoutScaleConverter}"
                                                                         ConverterParameter="2" />
                                                            </Path.StrokeThickness>
                                                        </Path>
                                                        <Path Stroke="#DC2626"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              Fill="Transparent"
                                                              Data="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2">
                                                            <Path.StrokeThickness>
                                                                <Binding Source="{StaticResource UiScaleState}"
                                                                         Path="FontScale"
                                                                         Converter="{StaticResource LayoutScaleConverter}"
                                                                         ConverterParameter="2" />
                                                            </Path.StrokeThickness>
                                                        </Path>
                                                    </Canvas>
                                                </Viewbox>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Right: details card -->
                <Border Grid.Column="1"
                        VerticalAlignment="Stretch"
                        MinHeight="0"
                        Background="{StaticResource Brush.White}"
                        BorderBrush="{StaticResource Brush.BorderSoft}"
                        BorderThickness="1"
                        ClipToBounds="False"
                        CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                               Path=ActualHeight,
                                               Converter={StaticResource CornerRadiusFromHeightConverter},
                                               ConverterParameter=12}"
                        Padding="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='24,14,24,16'}"
                        Effect="{StaticResource StaffAccessCardShadow}">
                    <DockPanel x:Name="DetailsBodyDock"
                               LastChildFill="True"
                               MinHeight="0"
                               HorizontalAlignment="Stretch">
                        <DockPanel DockPanel.Dock="Top" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button x:Name="BtnAuditTrail"
                                        Style="{StaticResource VcSecondaryButtonStyle}"
                                        Click="BtnAuditTrail_OnClick"
                                        Margin="{Binding Source={StaticResource UiScaleState},
                                                         Path=FontScale,
                                                         Converter={StaticResource ThicknessScaleConverter},
                                                         ConverterParameter='0,0,8,0'}">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                 Path=FontScale,
                                                                 Converter={StaticResource LayoutScaleConverter},
                                                                 ConverterParameter=16}"
                                                 Height="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=16}"
                                                 Margin="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource ThicknessScaleConverter},
                                                                  ConverterParameter='0,0,6,0'}">
                                            <Canvas Width="24"
                                                    Height="24"
                                                    SnapsToDevicePixels="True">
                                                <!-- Lucide history @ 24 -->
                                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}"
                                                      Data="M 3,12 a 9,9 0 1 0 9,-9 a 9.75,9.75 0 0 0 -6.74,2.74 L 3,8" />
                                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}"
                                                      Data="M 3,3 v 5 h 5" />
                                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}"
                                                      Data="M 12,7 v 5 l 4,2" />
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="Audit trail"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource VcPrimaryButtonStyle}"
                                        Click="BtnSave_OnClick">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                 Path=FontScale,
                                                                 Converter={StaticResource LayoutScaleConverter},
                                                                 ConverterParameter=16}"
                                                 Height="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=16}"
                                                 Margin="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource ThicknessScaleConverter},
                                                                  ConverterParameter='0,0,6,0'}">
                                            <Canvas Width="24"
                                                    Height="24"
                                                    SnapsToDevicePixels="True">
                                                <!-- Lucide save @ 24 (stroke follows primary button Foreground) -->
                                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}"
                                                      Data="M 15.2,3 a 2,2 0 0 1 1.4,0.6 l 3.8,3.8 a 2,2 0 0 1 0.6,1.4 V 19 a 2,2 0 0 1 -2,2 H 5 a 2,2 0 0 1 -2,-2 V 5 a 2,2 0 0 1 2,-2 z" />
                                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}"
                                                      Data="M 17,21 v -7 a 1,1 0 0 0 -1,-1 H 8 a 1,1 0 0 0 -1,1 v 7" />
                                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}"
                                                      Data="M 7,3 v 4 a 1,1 0 0 0 1,1 h 7" />
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="Save changes"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <StackPanel x:Name="StaffHeaderTitleArea"
                                        Orientation="Horizontal"
                                        Visibility="Collapsed">
                                <Grid x:Name="StaffHeaderAvatarHost"
                                      Width="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource LayoutScaleConverter},
                                                      ConverterParameter=52}"
                                      Height="{Binding Source={StaticResource UiScaleState},
                                                       Path=FontScale,
                                                       Converter={StaticResource LayoutScaleConverter},
                                                       ConverterParameter=52}"
                                      Margin="{Binding Source={StaticResource UiScaleState},
                                                       Path=FontScale,
                                                       Converter={StaticResource ThicknessScaleConverter},
                                                       ConverterParameter='0,0,14,0'}"
                                      Background="Transparent"
                                      Cursor="Hand"
                                      ToolTip="Open Documents to attach or replace profile image"
                                      PreviewMouseLeftButtonUp="StaffHeaderAvatarHost_OnMouseLeftButtonUp">
                                    <Border x:Name="ProfilePlaceholder"
                                            Background="{StaticResource Brush.PrimaryBlue}"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                                                   Path=ActualHeight,
                                                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                   ConverterParameter=8}"
                                            ClipToBounds="True">
                                        <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                 Path=FontScale,
                                                                 Converter={StaticResource LayoutScaleConverter},
                                                                 ConverterParameter=28}"
                                                 Height="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=28}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">
                                            <Canvas Width="24"
                                                    Height="24"
                                                    SnapsToDevicePixels="True">
                                                <!-- Lucide circle-user @ 24 (white on primary blue, matches Save changes) -->
                                                <Path Stroke="{StaticResource Brush.White}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Fill="Transparent"
                                                      Data="M 22,12 A 10,10 0 1 1 2,12 A 10,10 0 1 1 22,12" />
                                                <Path Stroke="{StaticResource Brush.White}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Fill="Transparent"
                                                      Data="M 15,10 A 3,3 0 1 1 9,10 A 3,3 0 1 1 15,10" />
                                                <Path Stroke="{StaticResource Brush.White}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Fill="Transparent"
                                                      Data="M 7,20.662 L 7,19 A 2,2 0 0 1 9,17 L 15,17 A 2,2 0 0 1 17,19 L 17,20.662" />
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                    <Border x:Name="ProfileImageHost"
                                            Background="{StaticResource Brush.White}"
                                            BorderBrush="{StaticResource Brush.BorderSoft}"
                                            BorderThickness="1"
                                            CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                                                   Path=ActualHeight,
                                                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                   ConverterParameter=8}"
                                            ClipToBounds="True"
                                            SnapsToDevicePixels="True"
                                            SizeChanged="ProfileImageHost_OnSizeChanged"
                                            Visibility="Collapsed">
                                        <!-- CornerRadius does not clip children; clip is applied in code (same circle as placeholder). -->
                                        <Image x:Name="ProfileImage"
                                               Stretch="UniformToFill"
                                               SnapsToDevicePixels="True"
                                               SizeChanged="ProfileImage_OnSizeChanged" />
                                    </Border>
                                </Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="User details"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource MainForeground}"
                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource FontScaleConverter},
                                                                  ConverterParameter=18}" />
                                    <TextBlock Text="Manage user information and permissions."
                                               Foreground="{StaticResource DimmedForeground}"
                                               Margin="{Binding Source={StaticResource UiScaleState},
                                                                Path=FontScale,
                                                                Converter={StaticResource ThicknessScaleConverter},
                                                                ConverterParameter='0,4,0,0'}"
                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource FontScaleConverter},
                                                                  ConverterParameter=15}" />
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>

                        <!-- HorizontalContentAlignment: tab body uses full details width (default Left leaves a dead band). -->
                        <!-- TabControl selected-content host breaks horizontal stretch; use strip + panes instead. -->
                        <Grid x:Name="StaffDetailNavHost"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Margin="{Binding Source={StaticResource UiScaleState},
                                               Path=FontScale,
                                               Converter={StaticResource ThicknessScaleConverter},
                                               ConverterParameter='0,12,0,0'}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <!-- Corner radius must match StaffDetailTabRadioStyle SegmentBorder (ScaledDoubleConverter 20). -->
                            <Border Grid.Row="0"
                                    HorizontalAlignment="Stretch"
                                    Background="#E5E7EB"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    Padding="4"
                                    SnapsToDevicePixels="True">
                                <Border.CornerRadius>
                                    <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource ScaledDoubleConverter}"
                                             ConverterParameter="20" />
                                </Border.CornerRadius>
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <RadioButton x:Name="RadStaffTabBasic"
                                                 Grid.Column="0"
                                                 GroupName="StaffUserDetailTabs"
                                                 Style="{StaticResource StaffDetailTabRadioStyle}"
                                                 Tag="0"
                                                 Checked="StaffDetailTabRadio_OnChecked">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                     Path=FontScale,
                                                                     Converter={StaticResource LayoutScaleConverter},
                                                                     ConverterParameter=20}"
                                                     Height="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource LayoutScaleConverter},
                                                                      ConverterParameter=20}"
                                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource ThicknessScaleConverter},
                                                                      ConverterParameter='0,0,6,0'}"
                                                     Stretch="Uniform">
                                                <Canvas Width="24"
                                                        Height="24"
                                                        SnapsToDevicePixels="True">
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 22,12 A 10,10 0 1 1 2,12 A 10,10 0 1 1 22,12" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 15,10 A 3,3 0 1 1 9,10 A 3,3 0 1 1 15,10" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 7,20.662 L 7,19 A 2,2 0 0 1 9,17 L 15,17 A 2,2 0 0 1 17,19 L 17,20.662" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock x:Name="TxtStaffTabBasic"
                                                       Text="Basic info"
                                                       Foreground="#111827"
                                                       VerticalAlignment="Center"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=14}" />
                                        </StackPanel>
                                    </RadioButton>

                                    <RadioButton x:Name="RadStaffTabSecurity"
                                                 Grid.Column="1"
                                                 GroupName="StaffUserDetailTabs"
                                                 Style="{StaticResource StaffDetailTabRadioStyle}"
                                                 Tag="1"
                                                 Checked="StaffDetailTabRadio_OnChecked">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                     Path=FontScale,
                                                                     Converter={StaticResource LayoutScaleConverter},
                                                                     ConverterParameter=20}"
                                                     Height="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource LayoutScaleConverter},
                                                                      ConverterParameter=20}"
                                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource ThicknessScaleConverter},
                                                                      ConverterParameter='0,0,6,0'}"
                                                     Stretch="Uniform">
                                                <Canvas Width="24"
                                                        Height="24"
                                                        SnapsToDevicePixels="True">
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 3,20 L 3,13 A 2,2 0 0 1 5,11 L 19,11 A 2,2 0 0 1 21,13 L 21,20 A 2,2 0 0 1 19,22 L 5,22 A 2,2 0 0 1 3,20 Z" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 7,11 L 7,7 A 5,5 0 0 1 17,7 L 17,11" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock x:Name="TxtStaffTabSecurity"
                                                       Text="Security"
                                                       Foreground="#111827"
                                                       VerticalAlignment="Center"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=14}" />
                                        </StackPanel>
                                    </RadioButton>

                                    <RadioButton x:Name="RadStaffTabBio"
                                                 Grid.Column="2"
                                                 GroupName="StaffUserDetailTabs"
                                                 Style="{StaticResource StaffDetailTabRadioStyle}"
                                                 Tag="2"
                                                 Checked="StaffDetailTabRadio_OnChecked">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                     Path=FontScale,
                                                                     Converter={StaticResource LayoutScaleConverter},
                                                                     ConverterParameter=20}"
                                                     Height="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource LayoutScaleConverter},
                                                                      ConverterParameter=20}"
                                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource ThicknessScaleConverter},
                                                                      ConverterParameter='0,0,6,0'}"
                                                     Stretch="Uniform">
                                                <Canvas Width="24"
                                                        Height="24"
                                                        SnapsToDevicePixels="True">
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 12,10 A 2,2 0 0 0 10,12 C 10,13.02 9.9,14.51 9.74,16" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 14,13.12 C 14,15.5 14,19.5 13,22" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 17.29,21.02 C 17.41,20.42 17.72,18.72 17.79,18" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 2,12 A 10,10 0 0 1 20,6" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 2,16 L 2.01,16" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 21.8,16 C 22,14 21.931,10.646 21.8,10" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 5,19.5 C 5.5,18 6,15 6,12 A 6,6 0 0 1 6.34,10" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 8.65,22 C 8.86,21.34 9.1,20.68 9.22,20" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 9,6.8 A 6,6 0 0 1 18,12 L 18,14" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock x:Name="TxtStaffTabBio"
                                                       Text="Biometric"
                                                       Foreground="#111827"
                                                       VerticalAlignment="Center"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=14}" />
                                        </StackPanel>
                                    </RadioButton>

                                    <RadioButton x:Name="RadStaffTabDocs"
                                                 Grid.Column="3"
                                                 GroupName="StaffUserDetailTabs"
                                                 Style="{StaticResource StaffDetailTabRadioStyle}"
                                                 Tag="3"
                                                 Checked="StaffDetailTabRadio_OnChecked">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                     Path=FontScale,
                                                                     Converter={StaticResource LayoutScaleConverter},
                                                                     ConverterParameter=20}"
                                                     Height="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource LayoutScaleConverter},
                                                                      ConverterParameter=20}"
                                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource ThicknessScaleConverter},
                                                                      ConverterParameter='0,0,6,0'}"
                                                     Stretch="Uniform">
                                                <Canvas Width="24"
                                                        Height="24"
                                                        SnapsToDevicePixels="True">
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 15,2 H 6 A 2,2 0 0 0 4,4 V 20 A 2,2 0 0 0 6,22 H 18 A 2,2 0 0 0 20,20 V 7 Z" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 14,2 L 14,6 A 2,2 0 0 0 16,8 L 20,8" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 10,9 L 8,9" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 16,13 L 8,13" />
                                                    <Path Style="{StaticResource StaffTabLucidePathStyle}"
                                                          Data="M 16,17 L 8,17" />
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock x:Name="TxtStaffTabDocs"
                                                       Text="Documents"
                                                       Foreground="#111827"
                                                       VerticalAlignment="Center"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=14}" />
                                        </StackPanel>
                                    </RadioButton>
                                </Grid>
                            </Border>
                            <Grid Grid.Row="1"
                                  Margin="0,8,0,0"
                                  MinHeight="0"
                                  HorizontalAlignment="Stretch">
                                <Grid x:Name="StaffPaneBasic"
                                      HorizontalAlignment="Stretch"
                                      Visibility="Visible">
                                    <Border ClipToBounds="False"
                                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,12,10,12'}">
                                        <Grid x:Name="BasicInfoFieldsGrid"
                                              HorizontalAlignment="Stretch"
                                              MinWidth="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="0"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,12,12'}">
                                            <TextBlock Text="User ID" Style="{StaticResource StaffFormLabelStyle}" />
                                            <TextBox x:Name="TxtNumericId"
                                                     HorizontalAlignment="Stretch"
                                                     Style="{StaticResource StaffAccessReadOnlyIdTextBoxStyle}"
                                                     IsReadOnly="True" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,12'}">
                                            <TextBlock Style="{StaticResource StaffFormLabelStyle}">
                                                <Run Text="User name " />
                                                <Run Text="*" Foreground="#DC2626" />
                                            </TextBlock>
                                            <TextBox x:Name="TxtUserName"
                                                     HorizontalAlignment="Stretch"
                                                     Style="{StaticResource IcEnabledTextBoxStyle}"
                                                     TextChanged="StaffDetailFields_OnTextChanged" />
                                            <TextBlock x:Name="LblUserNameError"
                                                       Visibility="Collapsed"
                                                       Foreground="#DC2626"
                                                       TextWrapping="Wrap"
                                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,0'}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1"
                                                    Grid.Column="0"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,12,12'}">
                                            <TextBlock Style="{StaticResource StaffFormLabelStyle}">
                                                <Run Text="First name " />
                                                <Run Text="*" Foreground="#DC2626" />
                                            </TextBlock>
                                            <TextBox x:Name="TxtFirstName"
                                                     HorizontalAlignment="Stretch"
                                                     Style="{StaticResource IcEnabledTextBoxStyle}"
                                                     TextChanged="StaffDetailFields_OnTextChanged" />
                                            <TextBlock x:Name="LblFirstNameError"
                                                       Visibility="Collapsed"
                                                       Foreground="#DC2626"
                                                       TextWrapping="Wrap"
                                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,0'}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1"
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,12'}">
                                            <TextBlock Text="Middle name" Style="{StaticResource StaffFormLabelStyle}" />
                                            <TextBox x:Name="TxtMiddleName"
                                                     HorizontalAlignment="Stretch"
                                                     Style="{StaticResource IcEnabledTextBoxStyle}"
                                                     TextChanged="StaffDetailFields_OnTextChanged" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2"
                                                    Grid.Column="0"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,12,12'}">
                                            <TextBlock Style="{StaticResource StaffFormLabelStyle}">
                                                <Run Text="Surname " />
                                                <Run Text="*" Foreground="#DC2626" />
                                            </TextBlock>
                                            <TextBox x:Name="TxtSurname"
                                                     HorizontalAlignment="Stretch"
                                                     Style="{StaticResource IcEnabledTextBoxStyle}"
                                                     TextChanged="StaffDetailFields_OnTextChanged" />
                                            <TextBlock x:Name="LblSurnameError"
                                                       Visibility="Collapsed"
                                                       Foreground="#DC2626"
                                                       TextWrapping="Wrap"
                                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,0'}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="2"
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,12'}">
                                            <local:StaffAccessRoles x:Name="RolePicker"
                                                                    HorizontalAlignment="Stretch" />
                                            <TextBlock x:Name="LblRoleError"
                                                       Visibility="Collapsed"
                                                       Foreground="#DC2626"
                                                       TextWrapping="Wrap"
                                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,0'}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="3"
                                                    Grid.Column="0"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,12,12'}">
                                            <TextBlock Style="{StaticResource StaffFormLabelStyle}">
                                                <Run Text="Card number " />
                                                <Run Text="*" Foreground="#DC2626" />
                                            </TextBlock>
                                            <TextBox x:Name="TxtCardNumber"
                                                     HorizontalAlignment="Stretch"
                                                     Style="{StaticResource IcEnabledTextBoxStyle}"
                                                     TextChanged="StaffDetailFields_OnTextChanged" />
                                            <TextBlock x:Name="LblCardNumberError"
                                                       Visibility="Collapsed"
                                                       Foreground="#DC2626"
                                                       TextWrapping="Wrap"
                                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,0'}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="3"
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Stretch"
                                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,12'}">
                                            <TextBlock Text="Job title (operations)"
                                                       Style="{StaticResource StaffFormLabelStyle}" />
                                            <TextBox x:Name="TxtJobTitle"
                                                     HorizontalAlignment="Stretch"
                                                     Style="{StaticResource IcEnabledTextBoxStyle}"
                                                     TextChanged="StaffDetailFields_OnTextChanged" />
                                        </StackPanel>

                                        <!-- Same boolean row pattern as Table Management → Active Status. -->
                                        <Border Grid.Row="4"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="2"
                                                HorizontalAlignment="Stretch"
                                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,0'}"
                                                Background="{StaticResource Brush.SurfaceGreySoft}"
                                                BorderBrush="{StaticResource Brush.BorderSoft}"
                                                BorderThickness="1"
                                                Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,8,10,8'}"
                                                CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0"
                                                            VerticalAlignment="Center"
                                                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}">
                                                    <TextBlock Text="Active user"
                                                               Foreground="{StaticResource MainForeground}"
                                                               FontWeight="SemiBold"
                                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}" />
                                                    <TextBlock Text="Allow this account to sign in"
                                                               Foreground="{StaticResource DimmedForeground}"
                                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}" />
                                                </StackPanel>
                                                <ToggleButton x:Name="TglActiveUser"
                                                              Grid.Column="1"
                                                              Style="{StaticResource IcPillSwitchToggleStyle}"
                                                              VerticalAlignment="Center"
                                                              Checked="TglActiveUser_OnToggle"
                                                              Unchecked="TglActiveUser_OnToggle" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    </Border>
                                </Grid>
                                <Grid x:Name="StaffPaneSecurity"
                                      HorizontalAlignment="Stretch"
                                      Visibility="Collapsed">
                                    <local:StaffAccessSecurity x:Name="SecurityPanel"
                                                               HorizontalAlignment="Stretch" />
                                </Grid>
                                <Grid x:Name="StaffPaneBio"
                                      HorizontalAlignment="Stretch"
                                      Visibility="Collapsed">
                                    <local:StaffAccessBioMetric x:Name="BioPanel"
                                                                HorizontalAlignment="Stretch" />
                                </Grid>
                                <Grid x:Name="StaffPaneDocs"
                                      HorizontalAlignment="Stretch"
                                      Visibility="Collapsed">
                                    <local:StaffAccessDocuments x:Name="DocsPanel"
                                                               HorizontalAlignment="Stretch" />
                                </Grid>
                            </Grid>
                        </Grid>

                    </DockPanel>
                </Border>
            </Grid>

            <!-- Audit trail overlay (read-only log for the selected user). -->
            <Grid x:Name="StaffAuditOverlay"
                  Panel.ZIndex="400"
                  Visibility="Collapsed"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Focusable="True"
                  PreviewKeyDown="StaffAuditOverlay_OnPreviewKeyDown">
                <Border Background="#99000000"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        PreviewMouseLeftButtonDown="StaffAuditScrim_OnPreviewMouseLeftButtonDown" />
                <local:StaffAccessAuditTrail x:Name="StaffAuditTrailPanel"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Margin="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource ThicknessScaleConverter},
                                                              ConverterParameter='20,20,20,20'}"
                                             CloseRequested="StaffAuditTrailPanel_OnCloseRequested" />
            </Grid>

            <!-- Non-modal save confirmation (replaces success MessageBox). -->
            <Border x:Name="StaffSaveToast"
                    Panel.ZIndex="100"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,36"
                    Visibility="Collapsed"
                    Background="{StaticResource Brush.White}"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="12"
                    SnapsToDevicePixels="True"
                    Effect="{StaticResource StaffAccessCardShadow}">
                <Border.Padding>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource ThicknessScaleConverter}"
                             ConverterParameter="14,10,18,10" />
                </Border.Padding>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border x:Name="StaffSaveToastAccent"
                            Width="3"
                            Height="22"
                            VerticalAlignment="Center"
                            CornerRadius="2"
                            Background="{StaticResource Brush.PrimaryBlue}" />
                    <TextBlock x:Name="StaffSaveToastText"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='10,0,0,0'}"
                               VerticalAlignment="Center"
                               Text="Changes saved."
                               Foreground="{StaticResource MainForeground}"
                               FontWeight="SemiBold"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=15}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
