<UserControl x:Class="RestaurantPosWpf.StaffAccessAuditTrail"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RestaurantPosWpf"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch"
             Loaded="StaffAccessAuditTrail_OnLoaded"
             Unloaded="StaffAccessAuditTrail_OnUnloaded">

    <UserControl.Resources>
        <DropShadowEffect x:Key="StaffAuditModalShadow"
                          BlurRadius="20"
                          Direction="270"
                          Opacity="0.12"
                          ShadowDepth="3"
                          Color="#000000" />

        <Style x:Key="StaffAuditStatCardBorderStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"
                    Value="{Binding RelativeSource={RelativeSource Self},
                                    Path=ActualHeight,
                                    Converter={StaticResource CornerRadiusFromHeightConverter},
                                    ConverterParameter=10}" />
            <Setter Property="Padding"
                    Value="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='12,10,12,10'}" />
        </Style>

        <Style x:Key="StaffAuditSuccessBadgeBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#16A34A" />
            <Setter Property="CornerRadius"
                    Value="{Binding RelativeSource={RelativeSource Self},
                                    Path=ActualHeight,
                                    Converter={StaticResource CornerRadiusFromHeightConverter},
                                    ConverterParameter=8}" />
            <Setter Property="Padding"
                    Value="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='8,3,10,3'}" />
        </Style>

        <Style x:Key="StaffAuditDeniedBadgeBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#C2410C" />
            <Setter Property="CornerRadius"
                    Value="{Binding RelativeSource={RelativeSource Self},
                                    Path=ActualHeight,
                                    Converter={StaticResource CornerRadiusFromHeightConverter},
                                    ConverterParameter=8}" />
            <Setter Property="Padding"
                    Value="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='8,3,10,3'}" />
        </Style>

        <!-- Lucide strokes match StaffAccessUserDetails tab strip; color follows row tone (IconForeground). -->
        <Style x:Key="StaffAuditTabGlyphPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="Stroke" Value="{Binding IconForeground}" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
        </Style>
    </UserControl.Resources>

    <Border x:Name="AuditTrailRoot"
            Background="{StaticResource Brush.White}"
            BorderBrush="{StaticResource Brush.BorderSoft}"
            BorderThickness="1"
            CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                   Path=ActualHeight,
                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                   ConverterParameter=12}"
            Padding="{Binding Source={StaticResource UiScaleState},
                              Path=FontScale,
                              Converter={StaticResource ThicknessScaleConverter},
                              ConverterParameter='20,18,20,16'}"
            MaxWidth="{Binding Source={StaticResource UiScaleState},
                               Path=FontScale,
                               Converter={StaticResource LayoutScaleConverter},
                               ConverterParameter=920}"
            MaxHeight="{Binding Source={StaticResource UiScaleState},
                                Path=FontScale,
                                Converter={StaticResource LayoutScaleConverter},
                                ConverterParameter=640}"
            Effect="{StaticResource StaffAuditModalShadow}"
            SnapsToDevicePixels="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="0" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#7B7EF1"
                        CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                               Path=ActualHeight,
                                               Converter={StaticResource CornerRadiusFromHeightConverter},
                                               ConverterParameter=10}"
                        Padding="{Binding Source={StaticResource UiScaleState},
                                          Path=FontScale,
                                          Converter={StaticResource ThicknessScaleConverter},
                                          ConverterParameter='10,10,10,10'}"
                        VerticalAlignment="Top"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='0,0,14,0'}">
                    <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource LayoutScaleConverter},
                                             ConverterParameter=22}"
                             Height="{Binding Source={StaticResource UiScaleState},
                                              Path=FontScale,
                                              Converter={StaticResource LayoutScaleConverter},
                                              ConverterParameter=22}">
                        <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                            <Path Stroke="White"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Data="M 3,12 a 9,9 0 1 0 9,-9 a 9.75,9.75 0 0 0 -6.74,2.74 L 3,8" />
                            <Path Stroke="White"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Data="M 3,3 v 5 h 5" />
                            <Path Stroke="White"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Data="M 12,7 v 5 l 4,2" />
                        </Canvas>
                    </Viewbox>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="0">
                    <TextBlock Text="Audit Trail"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               TextTrimming="CharacterEllipsis"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=18}" />
                    <TextBlock x:Name="TxtSubtitle"
                               Text="Activity log"
                               Foreground="{StaticResource DimmedForeground}"
                               TextWrapping="Wrap"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='0,4,0,0'}"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=14}" />
                </StackPanel>

                <!-- Same close chrome as Operations popups (e.g. OpsServicesEditReservation). -->
                <Button Grid.Column="2"
                        Click="BtnClose_OnClick"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource DimmedForeground}"
                        Content="✕"
                        Padding="0"
                        VerticalAlignment="Top"
                        Cursor="Hand"
                        FocusVisualStyle="{x:Null}"
                        FontSize="{Binding Source={StaticResource UiScaleState},
                                           Path=FontScale,
                                           Converter={StaticResource FontScaleConverter},
                                           ConverterParameter=16}"
                        ToolTip="Close"
                        AutomationProperties.Name="Close audit trail" />
            </Grid>

            <!-- Summary row -->
            <UniformGrid Grid.Row="1"
                         Columns="4"
                         Margin="0,0,0,14">
                <Border Style="{StaticResource StaffAuditStatCardBorderStyle}"
                        Background="#F0FDFA"
                        BorderBrush="#99F6E4"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                          Path=FontScale,
                                          Converter={StaticResource ThicknessScaleConverter},
                                          ConverterParameter='0,0,8,0'}">
                    <Grid VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='0,0,10,0'}"
                                VerticalAlignment="Top">
                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource LayoutScaleConverter},
                                                     ConverterParameter=22}"
                                     Height="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource LayoutScaleConverter},
                                                      ConverterParameter=22}"
                                     VerticalAlignment="Top"
                                     HorizontalAlignment="Center">
                                <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                    <Path Stroke="#0D9488"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Fill="Transparent"
                                          Data="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M10 17l5-5-5-5M13 12H3" />
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Top"
                                    MinWidth="0">
                            <TextBlock Text="Total Logins"
                                       Foreground="#0F766E"
                                       FontWeight="SemiBold"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=12}" />
                            <TextBlock x:Name="TxtStatLogins"
                                       Text="0"
                                       Foreground="#0D9488"
                                       FontWeight="Bold"
                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                        Path=FontScale,
                                                        Converter={StaticResource ThicknessScaleConverter},
                                                        ConverterParameter='0,4,0,0'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=22}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StaffAuditStatCardBorderStyle}"
                        Background="#FAF5FF"
                        BorderBrush="#DDD6FE"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                          Path=FontScale,
                                          Converter={StaticResource ThicknessScaleConverter},
                                          ConverterParameter='0,0,8,0'}">
                    <Grid VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='0,0,10,0'}"
                                VerticalAlignment="Top">
                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource LayoutScaleConverter},
                                                     ConverterParameter=22}"
                                     Height="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource LayoutScaleConverter},
                                                      ConverterParameter=22}"
                                     VerticalAlignment="Top"
                                     HorizontalAlignment="Center">
                                <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                    <Rectangle Width="18"
                                               Height="14"
                                               Canvas.Left="3"
                                               Canvas.Top="8"
                                               RadiusX="2"
                                               RadiusY="2"
                                               Stroke="#7C3AED"
                                               StrokeThickness="2"
                                               Fill="Transparent" />
                                    <Path Stroke="#7C3AED"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          Data="M8 8V6a4 4 0 0 1 8 0v2"
                                          Fill="Transparent" />
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Top"
                                    MinWidth="0">
                            <TextBlock Text="Security Events"
                                       Foreground="#5B21B6"
                                       FontWeight="SemiBold"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=12}" />
                            <TextBlock x:Name="TxtStatSecurity"
                                       Text="0"
                                       Foreground="#7C3AED"
                                       FontWeight="Bold"
                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                        Path=FontScale,
                                                        Converter={StaticResource ThicknessScaleConverter},
                                                        ConverterParameter='0,4,0,0'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=22}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StaffAuditStatCardBorderStyle}"
                        Background="#FEF2F2"
                        BorderBrush="#FECACA"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                          Path=FontScale,
                                          Converter={StaticResource ThicknessScaleConverter},
                                          ConverterParameter='0,0,8,0'}">
                    <Grid VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='0,0,10,0'}"
                                VerticalAlignment="Top">
                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource LayoutScaleConverter},
                                                     ConverterParameter=22}"
                                     Height="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource LayoutScaleConverter},
                                                      ConverterParameter=22}"
                                     VerticalAlignment="Top"
                                     HorizontalAlignment="Center">
                                <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                    <Ellipse Canvas.Left="4" Canvas.Top="4" Width="16" Height="16"
                                             Stroke="#DC2626" StrokeThickness="2" Fill="Transparent" />
                                    <Path Stroke="#DC2626" StrokeThickness="2" StrokeStartLineCap="Round"
                                          Data="M15 9l-6 6M9 9l6 6" />
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Top"
                                    MinWidth="0">
                            <TextBlock Text="Failed Attempts"
                                       Foreground="#991B1B"
                                       FontWeight="SemiBold"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=12}" />
                            <TextBlock x:Name="TxtStatFailed"
                                       Text="0"
                                       Foreground="#DC2626"
                                       FontWeight="Bold"
                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                        Path=FontScale,
                                                        Converter={StaticResource ThicknessScaleConverter},
                                                        ConverterParameter='0,4,0,0'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=22}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource StaffAuditStatCardBorderStyle}"
                        Background="#F0FDF4"
                        BorderBrush="#BBF7D0">
                    <Grid VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='0,0,10,0'}"
                                VerticalAlignment="Top">
                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource LayoutScaleConverter},
                                                     ConverterParameter=22}"
                                     Height="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource LayoutScaleConverter},
                                                      ConverterParameter=22}"
                                     VerticalAlignment="Top"
                                     HorizontalAlignment="Center">
                                <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                    <Ellipse Canvas.Left="3" Canvas.Top="3" Width="18" Height="18"
                                             Stroke="#16A34A" StrokeThickness="2" Fill="Transparent" />
                                    <Path Stroke="#16A34A" StrokeThickness="2.5" StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" Data="M8 12.5l2.5 2.5L16 9" Fill="Transparent" />
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Top"
                                    MinWidth="0">
                            <TextBlock Text="Total Actions"
                                       Foreground="#166534"
                                       FontWeight="SemiBold"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=12}" />
                            <TextBlock x:Name="TxtStatActions"
                                       Text="0"
                                       Foreground="#16A34A"
                                       FontWeight="Bold"
                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                        Path=FontScale,
                                                        Converter={StaticResource ThicknessScaleConverter},
                                                        ConverterParameter='0,4,0,0'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=22}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Activity list (star row so vertical scroll works) -->
            <ScrollViewer x:Name="SvActivityList"
                          Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,0,12"
                          CanContentScroll="False">
                <ItemsControl x:Name="ItemsActivity">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:StaffAccessAuditEntryVm}">
                            <Border Background="{Binding RowBackground}"
                                    BorderBrush="{StaticResource Brush.BorderSoft}"
                                    BorderThickness="1"
                                    CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                                           Path=ActualHeight,
                                                           Converter={StaticResource CornerRadiusFromHeightConverter},
                                                           ConverterParameter=10}"
                                    Padding="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource ThicknessScaleConverter},
                                                      ConverterParameter='12,12,12,12'}"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='0,0,0,8'}">
                                <Grid VerticalAlignment="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                                                   Path=ActualHeight,
                                                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                   ConverterParameter=8}"
                                            Padding="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource ThicknessScaleConverter},
                                                              ConverterParameter='8,8,8,8'}"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='0,0,12,0'}"
                                            VerticalAlignment="Top">
                                        <Grid MinWidth="{Binding Source={StaticResource UiScaleState},
                                                                Path=FontScale,
                                                                Converter={StaticResource LayoutScaleConverter},
                                                                ConverterParameter=36}"
                                              MinHeight="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=36}">
                                            <!-- Tab strip glyphs (same Path Data as StaffAccessUserDetails tabs). -->
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Top"
                                                        Orientation="Horizontal"
                                                        Visibility="{Binding ShowAnyTabGlyph,
                                                                             Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                         Path=FontScale,
                                                                         Converter={StaticResource LayoutScaleConverter},
                                                                         ConverterParameter=18}"
                                                         Height="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource LayoutScaleConverter},
                                                                          ConverterParameter=18}"
                                                         Margin="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource ThicknessScaleConverter},
                                                                          ConverterParameter='0,0,4,0'}"
                                                         Stretch="Uniform"
                                                         Visibility="{Binding ShowStaffTabBasicGlyph,
                                                                              Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 22,12 A 10,10 0 1 1 2,12 A 10,10 0 1 1 22,12" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 15,10 A 3,3 0 1 1 9,10 A 3,3 0 1 1 15,10" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 7,20.662 L 7,19 A 2,2 0 0 1 9,17 L 15,17 A 2,2 0 0 1 17,19 L 17,20.662" />
                                                    </Canvas>
                                                </Viewbox>
                                                <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                         Path=FontScale,
                                                                         Converter={StaticResource LayoutScaleConverter},
                                                                         ConverterParameter=18}"
                                                         Height="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource LayoutScaleConverter},
                                                                          ConverterParameter=18}"
                                                         Margin="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource ThicknessScaleConverter},
                                                                          ConverterParameter='0,0,4,0'}"
                                                         Stretch="Uniform"
                                                         Visibility="{Binding ShowStaffTabSecurityGlyph,
                                                                              Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 3,20 L 3,13 A 2,2 0 0 1 5,11 L 19,11 A 2,2 0 0 1 21,13 L 21,20 A 2,2 0 0 1 19,22 L 5,22 A 2,2 0 0 1 3,20 Z" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 7,11 L 7,7 A 5,5 0 0 1 17,7 L 17,11" />
                                                    </Canvas>
                                                </Viewbox>
                                                <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                         Path=FontScale,
                                                                         Converter={StaticResource LayoutScaleConverter},
                                                                         ConverterParameter=18}"
                                                         Height="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource LayoutScaleConverter},
                                                                          ConverterParameter=18}"
                                                         Margin="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource ThicknessScaleConverter},
                                                                          ConverterParameter='0,0,4,0'}"
                                                         Stretch="Uniform"
                                                         Visibility="{Binding ShowStaffTabBiometricGlyph,
                                                                              Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 12,10 A 2,2 0 0 0 10,12 C 10,13.02 9.9,14.51 9.74,16" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 14,13.12 C 14,15.5 14,19.5 13,22" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 17.29,21.02 C 17.41,20.42 17.72,18.72 17.79,18" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 2,12 A 10,10 0 0 1 20,6" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 2,16 L 2.01,16" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 21.8,16 C 22,14 21.931,10.646 21.8,10" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 5,19.5 C 5.5,18 6,15 6,12 A 6,6 0 0 1 6.34,10" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 8.65,22 C 8.86,21.34 9.1,20.68 9.22,20" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 9,6.8 A 6,6 0 0 1 18,12 L 18,14" />
                                                    </Canvas>
                                                </Viewbox>
                                                <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                         Path=FontScale,
                                                                         Converter={StaticResource LayoutScaleConverter},
                                                                         ConverterParameter=18}"
                                                         Height="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource LayoutScaleConverter},
                                                                          ConverterParameter=18}"
                                                         Stretch="Uniform"
                                                         Visibility="{Binding ShowStaffTabDocumentsGlyph,
                                                                              Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 15,2 H 6 A 2,2 0 0 0 4,4 V 20 A 2,2 0 0 0 6,22 H 18 A 2,2 0 0 0 20,20 V 7 Z" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 14,2 L 14,6 A 2,2 0 0 0 16,8 L 20,8" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 10,9 L 8,9" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 16,13 L 8,13" />
                                                        <Path Style="{StaticResource StaffAuditTabGlyphPathStyle}"
                                                              Data="M 16,17 L 8,17" />
                                                    </Canvas>
                                                </Viewbox>
                                            </StackPanel>
                                            <!-- Default: activity / history clock when no tab mapping. -->
                                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                     Path=FontScale,
                                                                     Converter={StaticResource LayoutScaleConverter},
                                                                     ConverterParameter=20}"
                                                     Height="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource LayoutScaleConverter},
                                                                      ConverterParameter=20}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Top"
                                                     Visibility="{Binding ShowDefaultActivityGlyph,
                                                                          Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                                    <Path Stroke="{Binding IconForeground}"
                                                          StrokeThickness="2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Fill="Transparent"
                                                          Data="M 3,12 a 9,9 0 1 0 9,-9 a 9.75,9.75 0 0 0 -6.74,2.74 L 3,8" />
                                                    <Path Stroke="{Binding IconForeground}"
                                                          StrokeThickness="2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Fill="Transparent"
                                                          Data="M 3,3 v 5 h 5" />
                                                </Canvas>
                                            </Viewbox>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                MinWidth="0"
                                                VerticalAlignment="Top">
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,0,0,6"
                                                    VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#0F172A"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Top"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=16}" />
                                            <Border Style="{StaticResource StaffAuditSuccessBadgeBorderStyle}"
                                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                                     Path=FontScale,
                                                                     Converter={StaticResource ThicknessScaleConverter},
                                                                     ConverterParameter='10,0,0,0'}"
                                                    VerticalAlignment="Top"
                                                    Visibility="{Binding ShowSuccessOutcomeBadge,
                                                                         Converter={StaticResource BoolToVisibilityConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="✓"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                                  Path=FontScale,
                                                                                  Converter={StaticResource FontScaleConverter},
                                                                                  ConverterParameter=12}"
                                                               Margin="{Binding Source={StaticResource UiScaleState},
                                                                                Path=FontScale,
                                                                                Converter={StaticResource ThicknessScaleConverter},
                                                                                ConverterParameter='0,0,4,0'}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding StatusLabel}"
                                                               Foreground="White"
                                                               FontWeight="SemiBold"
                                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                                  Path=FontScale,
                                                                                  Converter={StaticResource FontScaleConverter},
                                                                                  ConverterParameter=12}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource StaffAuditDeniedBadgeBorderStyle}"
                                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                                     Path=FontScale,
                                                                     Converter={StaticResource ThicknessScaleConverter},
                                                                     ConverterParameter='10,0,0,0'}"
                                                    VerticalAlignment="Top"
                                                    Visibility="{Binding ShowDeniedOutcomeBadge,
                                                                         Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="{Binding StatusLabel}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"
                                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                                              Path=FontScale,
                                                                              Converter={StaticResource FontScaleConverter},
                                                                              ConverterParameter=12}"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{StaticResource DimmedForeground}"
                                                   TextWrapping="Wrap"
                                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource FontScaleConverter},
                                                                      ConverterParameter=14}"
                                                   Margin="0,0,0,8" />

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Foreground="{StaticResource DimmedForeground}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=12}"
                                                       Margin="0,0,16,0">
                                                <Run Text="Time: " FontWeight="SemiBold" />
                                                <Run Text="{Binding Timestamp, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Foreground="{StaticResource DimmedForeground}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=12}"
                                                       Margin="0,0,16,0">
                                                <Run Text="Device: " FontWeight="SemiBold" />
                                                <Run Text="{Binding Device, Mode=OneWay}" />
                                            </TextBlock>
                                            <TextBlock Foreground="{StaticResource DimmedForeground}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=12}">
                                                <Run Text="IP: " FontWeight="SemiBold" />
                                                <Run Text="{Binding Ip, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="3"
                    BorderBrush="#E5E7EB"
                    BorderThickness="0,1,0,0"
                    Padding="{Binding Source={StaticResource UiScaleState},
                                      Path=FontScale,
                                      Converter={StaticResource ThicknessScaleConverter},
                                      ConverterParameter='0,12,0,0'}">
                <TextBlock TextWrapping="Wrap"
                           Foreground="{StaticResource DimmedForeground}"
                           FontSize="{Binding Source={StaticResource UiScaleState},
                                              Path=FontScale,
                                              Converter={StaticResource FontScaleConverter},
                                              ConverterParameter=12}">
                    <Run Text="All user activities are logged and monitored for security and compliance."
                         FontStyle="Italic" />
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</UserControl>
