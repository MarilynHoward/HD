<UserControl x:Class="RestaurantPosWpf.StaffAccessRoles"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch">

    <Grid HorizontalAlignment="Stretch" MinWidth="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   Foreground="{StaticResource DimmedForeground}"
                   FontSize="{Binding Source={StaticResource UiScaleState},
                                      Path=FontScale,
                                      Converter={StaticResource FontScaleConverter},
                                      ConverterParameter=14}"
                   Margin="{Binding Source={StaticResource UiScaleState},
                                    Path=FontScale,
                                    Converter={StaticResource ThicknessScaleConverter},
                                    ConverterParameter='0,0,0,4'}">
            <Run Text="Role " />
            <Run Text="*" Foreground="#DC2626" />
        </TextBlock>
        <ComboBox x:Name="RoleCombo"
                  Grid.Row="1"
                  HorizontalAlignment="Stretch"
                  Style="{StaticResource IcOpsServicesEnabledComboBoxStyle}"
                  SelectionChanged="RoleCombo_OnSelectionChanged" />
    </Grid>
</UserControl>
