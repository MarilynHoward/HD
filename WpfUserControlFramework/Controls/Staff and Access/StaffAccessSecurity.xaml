<UserControl x:Class="RestaurantPosWpf.StaffAccessSecurity"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             HorizontalAlignment="Stretch">



    <!-- ScrollViewer here (not under TabControl): parent UserControl gets full width from pane host. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Top"
                  ClipToBounds="False">

    <Grid HorizontalAlignment="Stretch"

          MinWidth="0">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

            <RowDefinition Height="Auto" />

        </Grid.RowDefinitions>



        <TextBlock Grid.Row="0"

                   Text="Password"

                   Foreground="{StaticResource DimmedForeground}"

                   FontSize="{Binding Source={StaticResource UiScaleState},

                                      Path=FontScale,

                                      Converter={StaticResource FontScaleConverter},

                                      ConverterParameter=14}"

                   Margin="{Binding Source={StaticResource UiScaleState},

                                    Path=FontScale,

                                    Converter={StaticResource ThicknessScaleConverter},

                                    ConverterParameter='0,0,0,4'}" />

        <PasswordBox x:Name="PwdNew"

                     Grid.Row="1"

                     HorizontalAlignment="Stretch"

                     Style="{StaticResource IcEnabledPasswordBoxStyle}"

                     Margin="{Binding Source={StaticResource UiScaleState},

                                      Path=FontScale,

                                      Converter={StaticResource ThicknessScaleConverter},

                                      ConverterParameter='0,0,0,14'}" />



        <TextBlock Grid.Row="2"

                   Text="Confirm password"

                   Foreground="{StaticResource DimmedForeground}"

                   FontSize="{Binding Source={StaticResource UiScaleState},

                                      Path=FontScale,

                                      Converter={StaticResource FontScaleConverter},

                                      ConverterParameter=14}"

                   Margin="{Binding Source={StaticResource UiScaleState},

                                    Path=FontScale,

                                    Converter={StaticResource ThicknessScaleConverter},

                                    ConverterParameter='0,0,0,4'}" />

        <PasswordBox x:Name="PwdConfirm"

                     Grid.Row="3"

                     HorizontalAlignment="Stretch"

                     Style="{StaticResource IcEnabledPasswordBoxStyle}"

                     Margin="{Binding Source={StaticResource UiScaleState},

                                      Path=FontScale,

                                      Converter={StaticResource ThicknessScaleConverter},

                                      ConverterParameter='0,0,0,14'}" />



        <TextBlock Grid.Row="4"

                   Text="Security question (demo)"

                   Foreground="{StaticResource DimmedForeground}"

                   FontSize="{Binding Source={StaticResource UiScaleState},

                                      Path=FontScale,

                                      Converter={StaticResource FontScaleConverter},

                                      ConverterParameter=14}"

                   Margin="{Binding Source={StaticResource UiScaleState},

                                    Path=FontScale,

                                    Converter={StaticResource ThicknessScaleConverter},

                                    ConverterParameter='0,8,0,4'}" />

        <TextBox x:Name="TxtSecurityQuestion"

                 Grid.Row="5"

                 HorizontalAlignment="Stretch"

                 Style="{StaticResource IcEnabledTextBoxStyle}"

                 TextWrapping="Wrap"

                 AcceptsReturn="True"

                 MinHeight="{Binding Source={StaticResource UiScaleState},

                                     Path=FontScale,

                                     Converter={StaticResource LayoutScaleConverter},

                                     ConverterParameter=72}" />



        <Border Grid.Row="6"

                HorizontalAlignment="Stretch"

                Margin="{Binding Source={StaticResource UiScaleState},

                                 Path=FontScale,

                                 Converter={StaticResource ThicknessScaleConverter},

                                 ConverterParameter='0,16,0,0'}"

                Background="{StaticResource Brush.SurfaceGreySoft}"

                BorderBrush="{StaticResource Brush.BorderSoft}"

                BorderThickness="1"

                Padding="{Binding Source={StaticResource UiScaleState},

                                 Path=FontScale,

                                 Converter={StaticResource ThicknessScaleConverter},

                                 ConverterParameter='10,8,10,8'}"

                CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}">

            <Grid HorizontalAlignment="Stretch">

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*" />

                    <ColumnDefinition Width="Auto" />

                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"

                            VerticalAlignment="Center"

                            Margin="{Binding Source={StaticResource UiScaleState},

                                             Path=FontScale,

                                             Converter={StaticResource ThicknessScaleConverter},

                                             ConverterParameter='0,0,10,0'}">

                    <TextBlock Text="Require password change"

                               Foreground="{StaticResource MainForeground}"

                               FontWeight="SemiBold"

                               FontSize="{Binding Source={StaticResource UiScaleState},

                                                  Path=FontScale,

                                                  Converter={StaticResource FontScaleConverter},

                                                  ConverterParameter=16}" />

                    <TextBlock Text="User must set a new password on next sign-in"

                               Foreground="{StaticResource DimmedForeground}"

                               FontSize="{Binding Source={StaticResource UiScaleState},

                                                  Path=FontScale,

                                                  Converter={StaticResource FontScaleConverter},

                                                  ConverterParameter=14}"

                               Margin="{Binding Source={StaticResource UiScaleState},

                                                Path=FontScale,

                                                Converter={StaticResource ThicknessScaleConverter},

                                                ConverterParameter='0,2,0,0'}" />

                </StackPanel>

                <ToggleButton x:Name="TglRequirePasswordChange"

                              Grid.Column="1"

                              Style="{StaticResource IcPillSwitchToggleStyle}"

                              VerticalAlignment="Center" />

            </Grid>

        </Border>

    </Grid>

    </ScrollViewer>

</UserControl>

