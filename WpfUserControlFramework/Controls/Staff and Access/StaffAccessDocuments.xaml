<UserControl x:Class="RestaurantPosWpf.StaffAccessDocuments"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             HorizontalAlignment="Stretch">
    <UserControl.Resources>
        <!-- Same keys as StaffAccessUserDetails so labels + read-only path fields resolve when this UC is opened alone or in its own resource scope. -->
        <Style x:Key="StaffFormLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DimmedForeground}" />
            <Setter Property="FontSize"
                    Value="{Binding Source={StaticResource UiScaleState},
                                    Path=FontScale,
                                    Converter={StaticResource FontScaleConverter},
                                    ConverterParameter=14}" />
            <Setter Property="Margin"
                    Value="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='0,0,0,4'}" />
        </Style>

        <Style x:Key="StaffAccessReadOnlyIdTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource IcEnabledTextBoxStyle}">
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
        </Style>

        <!-- Lucide strokes (match StaffAccessSecurity icon buttons — #64748B). -->
        <Style x:Key="StaffDocsActionPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="Stroke" Value="#64748B" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
        </Style>

        <!-- Same as StaffAccessSecurity: compact row actions + hover / pressed / keyboard focus. -->
        <Style x:Key="StaffAccessUserCardIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource Brush.TextDark}" />
            <Setter Property="Padding"
                    Value="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='10,6,10,6'}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight"
                    Value="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource LayoutScaleConverter},
                                     ConverterParameter=36}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                                       Path=ActualHeight,
                                                       Converter={StaticResource CornerRadiusFromHeightConverter},
                                                       ConverterParameter=8}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E7EB" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource FocusOuter}" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Top"
                  ClipToBounds="False">
        <Border Padding="{Binding Source={StaticResource UiScaleState},
                                  Path=FontScale,
                                  Converter={StaticResource ThicknessScaleConverter},
                                  ConverterParameter='10,12,10,12'}">
            <!-- Match StaffAccessSecurity: column grid for field + trailing actions (same 6px gap as password rows). -->
            <Grid HorizontalAlignment="Stretch" MinWidth="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ID document -->
                <TextBlock Grid.Row="0"
                           Text="ID document"
                           Style="{StaticResource StaffFormLabelStyle}" />
                <Grid Grid.Row="1"
                      Margin="{Binding Source={StaticResource UiScaleState},
                                       Path=FontScale,
                                       Converter={StaticResource ThicknessScaleConverter},
                                       ConverterParameter='0,0,0,0'}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtIdDocPath"
                             Grid.Column="0"
                             HorizontalAlignment="Stretch"
                             MinHeight="0"
                             IsReadOnly="True"
                             IsTabStop="True"
                             Style="{StaticResource StaffAccessReadOnlyIdTextBoxStyle}"
                             Margin="{Binding Source={StaticResource UiScaleState},
                                              Path=FontScale,
                                              Converter={StaticResource ThicknessScaleConverter},
                                              ConverterParameter='0,0,6,0'}" />
                    <Border x:Name="BdrIdSync"
                            Grid.Column="1"
                            VerticalAlignment="Stretch"
                            Margin="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource ThicknessScaleConverter},
                                             ConverterParameter='0,0,6,0'}"
                            BorderThickness="1"
                            CornerRadius="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ScaledDoubleConverter},
                                                    ConverterParameter=10}"
                            Padding="{Binding Source={StaticResource UiScaleState},
                                               Path=FontScale,
                                               Converter={StaticResource ThicknessScaleConverter},
                                               ConverterParameter='10,0,10,0'}"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtIdSync"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=14}" />
                    </Border>
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Stretch">
                        <Button x:Name="BtnIdView"
                                Style="{StaticResource StaffAccessUserCardIconButtonStyle}"
                                VerticalAlignment="Stretch"
                                Click="BtnIdView_OnClick"
                                ToolTip="Open ID PDF">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                         Path=FontScale,
                                                         Converter={StaticResource LayoutScaleConverter},
                                                         ConverterParameter=18}"
                                         Height="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource LayoutScaleConverter},
                                                          ConverterParameter=18}"
                                         Margin="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource ThicknessScaleConverter},
                                                          ConverterParameter='0,0,6,0'}"
                                         VerticalAlignment="Center"
                                         Stretch="Uniform">
                                    <Canvas Width="16" Height="16" SnapsToDevicePixels="True">
                                        <Ellipse Canvas.Left="2"
                                                 Canvas.Top="2"
                                                 Width="10"
                                                 Height="10"
                                                 Stroke="#64748B"
                                                 StrokeThickness="1.6"
                                                 Fill="Transparent" />
                                        <Line X1="10.5"
                                              Y1="10.5"
                                              X2="15"
                                              Y2="15"
                                              Stroke="#64748B"
                                              StrokeThickness="1.6"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="View"
                                           VerticalAlignment="Center"
                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource FontScaleConverter},
                                                              ConverterParameter=14}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnIdAttach"
                                Style="{StaticResource StaffAccessUserCardIconButtonStyle}"
                                Margin="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource ThicknessScaleConverter},
                                                 ConverterParameter='6,0,0,0'}"
                                VerticalAlignment="Stretch"
                                Click="BtnIdAttach_OnClick"
                                ToolTip="Attach PDF (replaces existing file)">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                         Path=FontScale,
                                                         Converter={StaticResource LayoutScaleConverter},
                                                         ConverterParameter=18}"
                                         Height="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource LayoutScaleConverter},
                                                          ConverterParameter=18}"
                                         Margin="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource ThicknessScaleConverter},
                                                          ConverterParameter='0,0,6,0'}"
                                         VerticalAlignment="Center"
                                         Stretch="Uniform">
                                    <Canvas Width="24"
                                            Height="24"
                                            SnapsToDevicePixels="True">
                                        <Path Style="{StaticResource StaffDocsActionPathStyle}"
                                              Data="M 15,2 H 6 A 2,2 0 0 0 4,4 V 20 A 2,2 0 0 0 6,22 H 18 A 2,2 0 0 0 20,20 V 7 Z" />
                                        <Path Style="{StaticResource StaffDocsActionPathStyle}"
                                              Data="M 14,2 L 14,6 A 2,2 0 0 0 16,8 L 20,8" />
                                        <Path Style="{StaticResource StaffDocsActionPathStyle}"
                                              Data="M 10,9 L 8,9" />
                                        <Path Style="{StaticResource StaffDocsActionPathStyle}"
                                              Data="M 16,13 L 8,13" />
                                        <Path Style="{StaticResource StaffDocsActionPathStyle}"
                                              Data="M 16,17 L 8,17" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Attach"
                                           VerticalAlignment="Center"
                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource FontScaleConverter},
                                                              ConverterParameter=14}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Profile image -->
                <TextBlock Grid.Row="2"
                           Text="Profile image"
                           Style="{StaticResource StaffFormLabelStyle}"
                           Margin="{Binding Source={StaticResource UiScaleState},
                                            Path=FontScale,
                                            Converter={StaticResource ThicknessScaleConverter},
                                            ConverterParameter='0,14,0,0'}" />
                <Grid Grid.Row="3"
                      Margin="{Binding Source={StaticResource UiScaleState},
                                       Path=FontScale,
                                       Converter={StaticResource ThicknessScaleConverter},
                                       ConverterParameter='0,0,0,0'}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtProfilePath"
                             Grid.Column="0"
                             HorizontalAlignment="Stretch"
                             MinHeight="0"
                             IsReadOnly="True"
                             IsTabStop="True"
                             Style="{StaticResource StaffAccessReadOnlyIdTextBoxStyle}"
                             Margin="{Binding Source={StaticResource UiScaleState},
                                              Path=FontScale,
                                              Converter={StaticResource ThicknessScaleConverter},
                                              ConverterParameter='0,0,6,0'}" />
                    <Border x:Name="BdrProfileSync"
                            Grid.Column="1"
                            VerticalAlignment="Stretch"
                            Margin="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource ThicknessScaleConverter},
                                             ConverterParameter='0,0,6,0'}"
                            BorderThickness="1"
                            CornerRadius="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ScaledDoubleConverter},
                                                    ConverterParameter=10}"
                            Padding="{Binding Source={StaticResource UiScaleState},
                                               Path=FontScale,
                                               Converter={StaticResource ThicknessScaleConverter},
                                               ConverterParameter='10,0,10,0'}"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtProfileSync"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=14}" />
                    </Border>
                    <Button x:Name="BtnProfileAttach"
                            Grid.Column="2"
                            Style="{StaticResource StaffAccessUserCardIconButtonStyle}"
                            VerticalAlignment="Stretch"
                            Click="BtnProfileAttach_OnClick"
                            ToolTip="Attach profile image (replaces existing file)">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource LayoutScaleConverter},
                                                     ConverterParameter=18}"
                                     Height="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource LayoutScaleConverter},
                                                      ConverterParameter=18}"
                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource ThicknessScaleConverter},
                                                      ConverterParameter='0,0,6,0'}"
                                     VerticalAlignment="Center"
                                     Stretch="Uniform">
                                <Canvas Width="24"
                                        Height="24"
                                        SnapsToDevicePixels="True">
                                    <Path Style="{StaticResource StaffDocsActionPathStyle}"
                                          Data="M 15,2 H 6 A 2,2 0 0 0 4,4 V 20 A 2,2 0 0 0 6,22 H 18 A 2,2 0 0 0 20,20 V 7 Z" />
                                    <Path Style="{StaticResource StaffDocsActionPathStyle}"
                                          Data="M 14,2 L 14,6 A 2,2 0 0 0 16,8 L 20,8" />
                                    <Path Style="{StaticResource StaffDocsActionPathStyle}"
                                          Data="M 10,9 L 8,9" />
                                    <Path Style="{StaticResource StaffDocsActionPathStyle}"
                                          Data="M 16,13 L 8,13" />
                                    <Path Style="{StaticResource StaffDocsActionPathStyle}"
                                          Data="M 16,17 L 8,17" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Attach"
                                       VerticalAlignment="Center"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=14}" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Attached files summary (match StaffAccessBioMetric enrollment card chrome). -->
                <Border Grid.Row="4"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='0,12,0,0'}"
                        Background="White"
                        BorderBrush="{StaticResource Brush.BorderSoft}"
                        BorderThickness="1"
                        CornerRadius="{Binding Source={StaticResource UiScaleState},
                                               Path=FontScale,
                                               Converter={StaticResource ScaledDoubleConverter},
                                               ConverterParameter=12}"
                        Padding="{Binding Source={StaticResource UiScaleState},
                                          Path=FontScale,
                                          Converter={StaticResource ThicknessScaleConverter},
                                          ConverterParameter='12,14,12,14'}">
                    <StackPanel>
                        <TextBlock Text="Attached files"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MainForeground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=16}"
                                   Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='0,0,0,4'}" />
                        <TextBlock x:Name="TxtAttachedProfileLine"
                                   Foreground="{StaticResource DimmedForeground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=14}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed" />
                        <TextBlock x:Name="TxtAttachedIdLine"
                                   Foreground="{StaticResource DimmedForeground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=14}"
                                   TextWrapping="Wrap"
                                   Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='0,4,0,0'}"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </ScrollViewer>
</UserControl>
