<UserControl x:Class="RestaurantPosWpf.ProcurementDispute"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Focusable="True"
             PreviewKeyDown="ProcurementDispute_PreviewKeyDown">

    <UserControl.Resources>
        <Style x:Key="DisputeSummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DimmedForeground}" />
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Border Background="Transparent">
        <Grid x:Name="OverlayRoot">
            <Border x:Name="DialogCard"
                    Width="{Binding ActualWidth, ElementName=OverlayRoot, Converter={StaticResource WidthMultiplierConverter}, ConverterParameter=0.48}"
                    MaxWidth="{Binding ActualWidth, ElementName=OverlayRoot, Converter={StaticResource WidthMultiplierConverter}, ConverterParameter=0.49}"
                    MaxHeight="{Binding ActualHeight, ElementName=OverlayRoot, Converter={StaticResource WidthMultiplierConverter}, ConverterParameter=0.96}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Background="White"
                    SnapsToDevicePixels="True"
                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,14,16,16'}"
                    CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=12}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0"
                          Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,12'}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Dispute Discrepancy"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MainForeground}"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}" />
                            <TextBlock Text="{Binding DisputeSubtitleLine}"
                                       Foreground="{StaticResource DimmedForeground}"
                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,0'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                VerticalAlignment="Top"
                                Content="×"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource MainForeground}"
                                FontWeight="SemiBold"
                                FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}"
                                Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,8'}"
                                MinWidth="32"
                                MinHeight="32"
                                Click="Close_Click"
                                FocusVisualStyle="{x:Null}" />
                    </Grid>

                    <!-- Form -->
                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <!-- Summary -->
                            <Border Background="#F3F4F6"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='14,12,14,12'}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,12,0'}">
                                        <TextBlock Text="Ingredient" Style="{StaticResource DisputeSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding Ingredient}"
                                                   Foreground="{StaticResource MainForeground}"
                                                   TextWrapping="Wrap"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,10'}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                        <TextBlock Text="Ordered" Style="{StaticResource DisputeSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding Ordered}"
                                                   Foreground="{StaticResource MainForeground}"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,10'}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                        <TextBlock Text="Variance" Style="{StaticResource DisputeSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding Variance}"
                                                   Foreground="{Binding VarianceForegroundHex}"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Supplier" Style="{StaticResource DisputeSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding Supplier}"
                                                   Foreground="{StaticResource MainForeground}"
                                                   TextWrapping="Wrap"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,10'}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                        <TextBlock Text="Received" Style="{StaticResource DisputeSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding Received}"
                                                   Foreground="{StaticResource MainForeground}"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,10'}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                        <TextBlock Text="Type" Style="{StaticResource DisputeSummaryLabelStyle}" />
                                        <Border Background="{Binding TypeBadgeBg}"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                HorizontalAlignment="Left"
                                                Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,4,10,4'}"
                                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}">
                                            <TextBlock Text="{Binding Type}"
                                                       Foreground="{Binding TypeBadgeText}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Reason for Dispute (same pattern as UploadDocumentDialog Notes) -->
                            <StackPanel Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,14,0,0'}">
                                <StackPanel Orientation="Horizontal"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='0,0,0,6'}">
                                    <TextBlock Text="Reason for Dispute"
                                               Foreground="#374151"
                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource FontScaleConverter},
                                                                  ConverterParameter=12}" />
                                    <TextBlock Text="*"
                                               Foreground="#DC2626"
                                               VerticalAlignment="Center"
                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource FontScaleConverter},
                                                                  ConverterParameter=12}" />
                                </StackPanel>
                                <Grid>
                                    <TextBox x:Name="ReasonTextBox"
                                             Style="{StaticResource IcEnabledTextBoxStyle}"
                                             Height="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource LayoutScaleConverter},
                                                              ConverterParameter=80}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalContentAlignment="Top"
                                             Padding="10,8,10,8" />
                                    <TextBlock Text="Describe the reason for disputing this discrepancy..."
                                               IsHitTestVisible="False"
                                               Foreground="#9CA3AF"
                                               Margin="12,8,0,0"
                                               VerticalAlignment="Top"
                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource FontScaleConverter},
                                                                  ConverterParameter=13}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding ElementName=ReasonTextBox, Path=Text}" Value="" />
                                                            <Condition Binding="{Binding ElementName=ReasonTextBox, Path=IsKeyboardFocused}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>

                            <!-- Contact Person (same pattern as UploadDocumentDialog DocumentNameTextBox) -->
                            <StackPanel Margin="{Binding Source={StaticResource UiScaleState},
                                                         Path=FontScale,
                                                         Converter={StaticResource ThicknessScaleConverter},
                                                         ConverterParameter='0,14,0,0'}">
                                <TextBlock Text="Contact Person *"
                                           Foreground="#374151"
                                           Margin="{Binding Source={StaticResource UiScaleState},
                                                            Path=FontScale,
                                                            Converter={StaticResource ThicknessScaleConverter},
                                                            ConverterParameter='0,0,0,6'}"
                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource FontScaleConverter},
                                                              ConverterParameter=12}" />
                                <Grid>
                                    <TextBox x:Name="ContactPersonTextBox"
                                             Style="{StaticResource IcEnabledTextBoxStyle}"
                                             Padding="10,8,10,8" />
                                    <TextBlock Text="e.g., John Doe"
                                               IsHitTestVisible="False"
                                               Foreground="#9CA3AF"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource FontScaleConverter},
                                                                  ConverterParameter=13}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding ElementName=ContactPersonTextBox, Path=Text}" Value="" />
                                                            <Condition Binding="{Binding ElementName=ContactPersonTextBox, Path=IsKeyboardFocused}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>

                            <!-- Contact Email (same pattern as UploadDocumentDialog DocumentNameTextBox) -->
                            <StackPanel Margin="{Binding Source={StaticResource UiScaleState},
                                                         Path=FontScale,
                                                         Converter={StaticResource ThicknessScaleConverter},
                                                         ConverterParameter='0,14,0,0'}">
                                <TextBlock Text="Contact Email *"
                                           Foreground="#374151"
                                           Margin="{Binding Source={StaticResource UiScaleState},
                                                            Path=FontScale,
                                                            Converter={StaticResource ThicknessScaleConverter},
                                                            ConverterParameter='0,0,0,6'}"
                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource FontScaleConverter},
                                                              ConverterParameter=12}" />
                                <Grid>
                                    <TextBox x:Name="ContactEmailTextBox"
                                             Style="{StaticResource IcEnabledTextBoxStyle}"
                                             Padding="10,8,10,8" />
                                    <TextBlock Text="e.g., john.doe@example.com"
                                               IsHitTestVisible="False"
                                               Foreground="#9CA3AF"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource FontScaleConverter},
                                                                  ConverterParameter=13}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding ElementName=ContactEmailTextBox, Path=Text}" Value="" />
                                                            <Condition Binding="{Binding ElementName=ContactEmailTextBox, Path=IsKeyboardFocused}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>

                            <!-- Info note -->
                            <Border Background="#EFF6FF"
                                    BorderBrush="#BFDBFE"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,16,0,0'}"
                                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="#374151"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}">
                                        <Run FontWeight="SemiBold">Note:</Run>
                                        <Run> Disputing this discrepancy will:</Run>
                                    </TextBlock>
                                    <TextBlock Text="    • Update the PO status"
                                               Foreground="#374151"
                                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,0'}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                    <TextBlock Text="    • Log dispute in audit trail"
                                               Foreground="#374151"
                                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                    <TextBlock Text="    • Notify relevant stakeholders"
                                               Foreground="#374151"
                                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Rectangle Grid.Row="3" Height="1" Fill="transparent"
                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,14,0,12'}" />

                    <!-- Footer -->
                    <Border Grid.Row="4" Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Cancel"
                                        MinWidth="110"
                                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"
                                        Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=35}"
                                        Style="{StaticResource VcSecondaryButtonStyle}"
                                        Click="Close_Click"
                                        FocusVisualStyle="{x:Null}" />
                                <Button Content="Mark as Disputed"
                                        MinWidth="140"
                                        Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=35}"
                                        Style="{StaticResource VcPrimaryButtonStyle}"
                                        Click="MarkAsDisputed_Click"
                                        FocusVisualStyle="{x:Null}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
