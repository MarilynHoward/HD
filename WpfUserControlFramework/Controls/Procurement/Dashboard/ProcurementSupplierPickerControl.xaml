<UserControl x:Class="RestaurantPosWpf.ProcurementSupplierPickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="RootControl"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">

    <Grid Background="Transparent">

        <Border Background="White"
                SnapsToDevicePixels="True"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Padding>
                <Binding Source="{StaticResource UiScaleState}"
                         Path="FontScale"
                         Converter="{StaticResource ThicknessScaleConverter}"
                         ConverterParameter="32,28" />
            </Border.Padding>

            <Border.CornerRadius>
                <Binding RelativeSource="{RelativeSource Self}"
                         Path="ActualHeight"
                         Converter="{StaticResource CornerRadiusFromHeightConverter}"
                         ConverterParameter="24" />
            </Border.CornerRadius>

            <Grid>
                <Grid.MaxWidth>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource ScaledDoubleConverter}"
                             ConverterParameter="460" />
                </Grid.MaxWidth>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel.Margin>
                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ThicknessScaleConverter}"
                                     ConverterParameter="0,0,0,10" />
                        </StackPanel.Margin>

                        <TextBlock x:Name="txtTitle"
                                   Text="Select Supplier"
                                   FontWeight="Bold"
                                   Foreground="#111827"
                                   TextAlignment="Left"
                                   HorizontalAlignment="Left">
                            <TextBlock.FontSize>
                                <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource FontScaleConverter}"
                                         ConverterParameter="18" />
                            </TextBlock.FontSize>
                        </TextBlock>

                        <TextBlock x:Name="txtSubtitle"
                                   Text="Choose a supplier to create a new purchase order."
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap">
                            <TextBlock.Margin>
                                <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource ThicknessScaleConverter}"
                                         ConverterParameter="0,4,0,0" />
                            </TextBlock.Margin>
                            <TextBlock.FontSize>
                                <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource FontScaleConverter}"
                                         ConverterParameter="15" />
                            </TextBlock.FontSize>
                            <TextBlock.Width>
                                <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource ScaledDoubleConverter}"
                                         ConverterParameter="320" />
                            </TextBlock.Width>
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Column="1"
                            x:Name="btnClose"
                            FontWeight="SemiBold"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="btnClose_Click"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Cursor="Hand">
                        <Button.Width>
                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ScaledDoubleConverter}"
                                     ConverterParameter="32" />
                        </Button.Width>
                        <Button.Height>
                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ScaledDoubleConverter}"
                                     ConverterParameter="32" />
                        </Button.Height>

                        <TextBlock x:Name="txtCloseGlyph"
                                   Text="✕"
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.FontSize>
                                <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource FontScaleConverter}"
                                         ConverterParameter="16" />
                            </TextBlock.FontSize>
                        </TextBlock>
                    </Button>
                </Grid>

                <Rectangle Grid.Row="1"
                               Height="1"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"
                               Fill="#80E5E7EB"
                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,0'}" />

                <StackPanel Grid.Row="2">
                    <StackPanel.Margin>
                        <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource ThicknessScaleConverter}"
                                 ConverterParameter="0,12,0,20" />
                    </StackPanel.Margin>

                    <TextBlock x:Name="txtSupplierLabel"
                               Text="Supplier"
                               Foreground="#111827"
                               FontWeight="Normal">
                        <TextBlock.Margin>
                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ThicknessScaleConverter}"
                                     ConverterParameter="0,4,0,4" />
                        </TextBlock.Margin>
                        <TextBlock.FontSize>
                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource FontScaleConverter}"
                                     ConverterParameter="13" />
                        </TextBlock.FontSize>
                    </TextBlock>

                    <ComboBox x:Name="cmbSuppliers"
                              Style="{StaticResource IcEnabledComboBoxStyle}"
                              SelectionChanged="cmbSuppliers_SelectionChanged"
                              DisplayMemberPath="DisplayText"
                              SelectedValuePath="SupplierCode"
                              HorizontalAlignment="Stretch">
                        <ComboBox.FontSize>
                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource FontScaleConverter}"
                                     ConverterParameter="14" />
                        </ComboBox.FontSize>
                        <ComboBox.MinWidth>
                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ScaledDoubleConverter}"
                                     ConverterParameter="320" />
                        </ComboBox.MinWidth>
                        <ComboBox.MinHeight>
                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ScaledDoubleConverter}"
                                     ConverterParameter="40" />
                        </ComboBox.MinHeight>
                        <ComboBox.Margin>
                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ThicknessScaleConverter}"
                                     ConverterParameter="6,0,6,0" />
                        </ComboBox.Margin>
                    </ComboBox>

                    <TextBlock x:Name="txtValidation"
                               Text="Please select a supplier."
                               Foreground="#DC2626"
                               Visibility="Collapsed">
                        <TextBlock.Margin>
                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ThicknessScaleConverter}"
                                     ConverterParameter="0,0,0,0" />
                        </TextBlock.Margin>
                        <TextBlock.FontSize>
                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource FontScaleConverter}"
                                     ConverterParameter="12" />
                        </TextBlock.FontSize>
                    </TextBlock>
                </StackPanel>

                <!--<Border Grid.Row="2"
                        Background="Transparent">
                    <Border.Height>
                        <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource ScaledDoubleConverter}"
                                 ConverterParameter="8" />
                    </Border.Height>
                </Border>-->

                <Rectangle Grid.Row="3"
                               Height="1"
                               Fill="#90E5E7EB"
                               SnapsToDevicePixels="True"
                               UseLayoutRounding="True"
                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,0'}" />

                
                <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">

                    <Button x:Name="btnCancel"
                            Content="Cancel"
                            Click="btnCancel_Click"
                            Cursor="Hand"
                            Style="{StaticResource VcSecondaryButtonStyle}"
                            HorizontalAlignment="Center">
                        <Button.MinWidth>
                            <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource ScaledDoubleConverter}"
                                 ConverterParameter="120" />
                        </Button.MinWidth>
                        <Button.FontSize>
                            <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource FontScaleConverter}"
                                 ConverterParameter="16" />
                        </Button.FontSize>
                        <Button.Height>
                            <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource ScaledDoubleConverter}"
                                 ConverterParameter="40" />
                        </Button.Height>
                        <Button.Margin>
                            <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource ThicknessScaleConverter}"
                                 ConverterParameter="0,12,0,0" />
                        </Button.Margin>
                    </Button>

                    <Button x:Name="btnContinue"
                                Content="Continue"
                                Click="btnContinue_Click"
                                Cursor="Hand"
                                Style="{StaticResource VcPrimaryButtonStyle}"
                                HorizontalAlignment="Center">
                        <Button.Margin>
                            <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource ThicknessScaleConverter}"
                                 ConverterParameter="12,12,0,0" />
                        </Button.Margin>
                        <Button.MinWidth>
                            <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource ScaledDoubleConverter}"
                                 ConverterParameter="120" />
                        </Button.MinWidth>
                        <Button.FontSize>
                            <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource FontScaleConverter}"
                                 ConverterParameter="16" />
                        </Button.FontSize>
                        <Button.Height>
                            <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource ScaledDoubleConverter}"
                                 ConverterParameter="40" />
                        </Button.Height>
                    </Button>
                </StackPanel>
                
            </Grid>
        </Border>
    </Grid>
</UserControl>