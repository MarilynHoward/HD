<UserControl x:Class="RestaurantPosWpf.ProcurementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RestaurantPosWpf">

    <UserControl.Resources>
        <!-- Alert banner (red-tinted) -->
        <SolidColorBrush x:Key="AlertBgBrush" Color="#FEF2F2" />
        <SolidColorBrush x:Key="AlertBorderBrush" Color="#F0DADD" />
        <SolidColorBrush x:Key="AlertIconBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="AlertTextBrush" Color="#991B1B" />

        <!-- Orders In Progress card colors -->
        <SolidColorBrush x:Key="AwaitingApprovalBg" Color="#FFF9E6" />
        <SolidColorBrush x:Key="AwaitingApprovalBorder" Color="#FFF9E6" />
        <SolidColorBrush x:Key="AwaitingApprovalText" Color="#111827" />

        <SolidColorBrush x:Key="AwaitingDeliveryBg" Color="#E6F4FF" />
        <SolidColorBrush x:Key="AwaitingDeliveryBorder" Color="#C7DDF2" />
        <SolidColorBrush x:Key="AwaitingDeliveryText" Color="#2563EB" />

        <SolidColorBrush x:Key="PartiallyDeliveredBg" Color="#FFE9DC" />
        <SolidColorBrush x:Key="PartiallyDeliveredBorder" Color="#E8CFC0" />
        <SolidColorBrush x:Key="PartiallyDeliveredText" Color="#D97706" />

        <SolidColorBrush x:Key="DeliveredBg" Color="#E8F6E9" />
        <SolidColorBrush x:Key="DeliveredBorder" Color="#C9DDCB" />
        <SolidColorBrush x:Key="DeliveredText" Color="#16A34A" />

        <SolidColorBrush x:Key="InvoiceIssuesBg" Color="#FBE4EC" />
        <SolidColorBrush x:Key="InvoiceIssuesBorder" Color="#E4C8D3" />
        <SolidColorBrush x:Key="InvoiceIssuesText" Color="#BE185D" />

        <SolidColorBrush x:Key="PaymentsPendingBg" Color="#F3E5F6" />
        <SolidColorBrush x:Key="PaymentsPendingBorder" Color="#F3E5F6" />
        <SolidColorBrush x:Key="PaymentsPendingText" Color="#111827" />

        <!-- Operational Performance card colors -->
        <SolidColorBrush x:Key="OutstandingBg" Color="#EFF6FF" />
        <SolidColorBrush x:Key="OutstandingBorder" Color="#D3DCE8" />
        <SolidColorBrush x:Key="AccruedBg" Color="#FFF6ED" />
        <SolidColorBrush x:Key="AccruedBorder" Color="#E6DDD4" />
        <SolidColorBrush x:Key="InvoiceProcessingBg" Color="#FEFBEA" />
        <SolidColorBrush x:Key="InvoiceProcessingBorder" Color="#E7E3D3" />
        <SolidColorBrush x:Key="DueWithinBg" Color="#FAF5FF" />
        <SolidColorBrush x:Key="DueWithinBorder" Color="#E3DDE8" />
        
        <!-- Trend row card colors -->
        <SolidColorBrush x:Key="TotalTrendBg" Color="#F0FDF4" />
        <SolidColorBrush x:Key="TotalTrendBorder" Color="#CFEBDC" />
        <SolidColorBrush x:Key="CycleTimeBg" Color="#FDF2F8" />
        <SolidColorBrush x:Key="CycleTimeBorder" Color="#FBEFF9" />
        <SolidColorBrush x:Key="LeadTimeBg" Color="#FEF2F2" />
        <SolidColorBrush x:Key="LeadTimeBorder" Color="#F1DDDE" />

        <!-- Orders In Progress card hover style (shadow + lift) -->
        <Style x:Key="OrderStatusCard" TargetType="Border">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0" />
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.06" Color="#000000" Direction="270" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-2" />
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect ShadowDepth="4" BlurRadius="14" Opacity="0.22" Color="#000000" Direction="270" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- PO Status badge styles -->
        <SolidColorBrush x:Key="DraftBadgeBg" Color="#F3F4F6" />
        <SolidColorBrush x:Key="DraftBadgeText" Color="#374151" />
        <SolidColorBrush x:Key="SentBadgeBg" Color="#DBEAFE" />
        <SolidColorBrush x:Key="SentBadgeText" Color="#1E40AF" />
        <SolidColorBrush x:Key="PendingInvoiceBadgeBg" Color="#FEF3C7" />
        <SolidColorBrush x:Key="PendingInvoiceBadgeText" Color="#92400E" />
        <SolidColorBrush x:Key="PartialShipmentBadgeBg" Color="#FCE7F3" />
        <SolidColorBrush x:Key="PartialShipmentBadgeText" Color="#9D174D" />

        <!-- PO row hover style -->
        <SolidColorBrush x:Key="PORowDefaultBorder" Color="#E5E7EB" />
        <SolidColorBrush x:Key="PORowHoverBorder" Color="#93C5FD" />
        <SolidColorBrush x:Key="PORowHoverBg" Color="#F8FAFF" />

        <Style x:Key="PORowBorder" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="14,12" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PORowHoverBg}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProcurementAmountTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#708ECA" />
            <Setter Property="TextDecorations" Value="Underline" />
        </Style>
    </UserControl.Resources>

    <!-- Content Root Border pattern -->
    <Border BorderBrush="#E5E7EB"
            BorderThickness="1"
            Background="#F8FAFC"
            SnapsToDevicePixels="True"
            ClipToBounds="True"
            FocusVisualStyle="{x:Null}"
            Padding="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter},
                             ConverterParameter='28,24,28,24'}"
            CornerRadius="{Binding ActualHeight,
                                   RelativeSource={RelativeSource Self},
                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                   ConverterParameter=12}"
            Margin="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter},
                             ConverterParameter='24,24,24,24'}">



        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" FocusVisualStyle="{x:Null}">
            <StackPanel>

                <!-- ═══ HEADER: Title + Create New Order button ═══ -->
                <DockPanel Margin="{Binding Source={StaticResource UiScaleState},
                                            Path=FontScale,
                                            Converter={StaticResource ThicknessScaleConverter},
                                            ConverterParameter='0,0,0,16'}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Procurement Dashboard"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MainForeground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=18}" />
                        <TextBlock Text="Overview of purchase orders and inventory procurement"
                                   Foreground="{StaticResource DimmedForeground}"
                                   FontWeight="Normal"
                                   Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='0,2,0,0'}"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=15}" />
                    </StackPanel>
                    <Button Style="{StaticResource VcPrimaryButtonStyle}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="CreateNewOrder_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource LayoutScaleConverter},
                                                     ConverterParameter=16}"
                                     Height="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource LayoutScaleConverter},
                                                      ConverterParameter=16}"
                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource ThicknessScaleConverter},
                                                      ConverterParameter='0,0,6,0'}">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12.5 22 L18 22 C19.1 22 20 21.1 20 20 L20 7 L15 2 L6 2 C4.9 2 4 2.9 4 4 L4 13.5"
                                          Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                    <Path Data="M14 2 L14 6 C14 7.1 14.9 8 16 8 L20 8"
                                          Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                    <Path Data="M13.378 15.626 A1 1 0 1 0 10.374 12.622 L5.364 17.634 C5.17 17.828 5.028 18.068 4.858 18.488 L4.021 21.358 C3.95 21.6 4.15 21.8 4.4 21.73 L7.27 20.893 C7.69 20.723 7.93 20.581 8.124 20.387 Z"
                                          Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Create New Order" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </DockPanel>

                <!-- ═══ ATTENTION REQUIRED BANNER ═══ -->
                <Border Background="{StaticResource AlertBgBrush}"
                        BorderBrush="{StaticResource AlertBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='16,12,16,12'}"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='0,0,0,20'}">
                    <DockPanel>
                        <Button Content="View Details"
                                   Style="{StaticResource VcSecondaryButtonStyle}"
                                   VerticalAlignment="Top"
                                   DockPanel.Dock="Right"
                                   Click="ViewAlertDetails_Click"
                                   FocusVisualStyle="{x:Null}" />
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Margin="{Binding Source={StaticResource UiScaleState},
                                                         Path=FontScale,
                                                         Converter={StaticResource ThicknessScaleConverter},
                                                         ConverterParameter='0,0,0,6'}">
                                <TextBlock Text="⚠" Foreground="{StaticResource AlertIconBrush}"
                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource FontScaleConverter},
                                                              ConverterParameter=14}"
                                           Margin="{Binding Source={StaticResource UiScaleState},
                                                            Path=FontScale,
                                                            Converter={StaticResource ThicknessScaleConverter},
                                                            ConverterParameter='0,0,8,0'}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Attention Required"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AlertTextBrush}"
                                           VerticalAlignment="Center"
                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource FontScaleConverter},
                                                              ConverterParameter=13}" />
                            </StackPanel>
                            <TextBlock x:Name="OverdueDeliveryText"
                                       Text="• 2 overdue delivery expected"
                                       Foreground="#DC2626"
                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                        Path=FontScale,
                                                        Converter={StaticResource ThicknessScaleConverter},
                                                        ConverterParameter='18,0,0,2'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=12}" />
                            <TextBlock x:Name="DiscrepanciesPendingText"
                                       Text="• 1 discrepancies pending review"
                                       Foreground="#DC2626"
                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                        Path=FontScale,
                                                        Converter={StaticResource ThicknessScaleConverter},
                                                        ConverterParameter='18,0,0,0'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=12}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ═══ ORDERS IN PROGRESS ═══ -->
                <TextBlock Text="Orders In Progress"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource MainForeground}"
                           Margin="{Binding Source={StaticResource UiScaleState},
                                            Path=FontScale,
                                            Converter={StaticResource ThicknessScaleConverter},
                                            ConverterParameter='0,0,0,10'}"
                           FontSize="{Binding Source={StaticResource UiScaleState},
                                              Path=FontScale,
                                              Converter={StaticResource FontScaleConverter},
                                              ConverterParameter=15}" />

                <UniformGrid Columns="6"
             Margin="{Binding Source={StaticResource UiScaleState},
                              Path=FontScale,
                              Converter={StaticResource ThicknessScaleConverter},
                              ConverterParameter='0,0,0,24'}">

                    <!-- Awaiting Approval -->
                    <Border Background="{StaticResource AwaitingApprovalBg}"
            BorderBrush="{StaticResource AwaitingApprovalBorder}"
            Style="{StaticResource OrderStatusCard}"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='14,12,14,12'}"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,6,0'}">
                        <StackPanel>
                            <TextBlock Text="Awaiting Approval" TextDecorations="Underline" Foreground="{StaticResource AwaitingApprovalText}" Cursor="Hand"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="ApprovalValue" Text="R 8 890 000" Foreground="#708ECA" TextDecorations="Underline"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,18,0,0'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="ApprovalCount" Text="25" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=28}" />
                        </StackPanel>
                    </Border>

                    <!-- Awaiting Delivery -->
                    <Border Background="{StaticResource AwaitingDeliveryBg}"
            BorderBrush="{StaticResource AwaitingDeliveryBorder}"
            Style="{StaticResource OrderStatusCard}"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='14,12,14,12'}"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='3,0,6,0'}">
                        <StackPanel>
                            <TextBlock Text="Awaiting Delivery" TextDecorations="Underline" Foreground="{StaticResource AwaitingDeliveryText}" Cursor="Hand"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="DeliveryValue" Text="R 1 904 567" Foreground="#708ECA" TextDecorations="Underline"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,18,0,0'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="DeliveryCount" Text="38" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=28}" />
                        </StackPanel>
                    </Border>

                    <!-- Partially Delivered -->
                    <Border Background="{StaticResource PartiallyDeliveredBg}"
            BorderBrush="{StaticResource PartiallyDeliveredBorder}"
            Style="{StaticResource OrderStatusCard}"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='14,12,14,12'}"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='3,0,6,0'}">
                        <StackPanel>
                            <TextBlock Text="Partially Delivered" TextDecorations="Underline" Foreground="{StaticResource PartiallyDeliveredText}" Cursor="Hand"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="PartialValue" Text="R 892 345" Foreground="#708ECA" TextDecorations="Underline"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,18,0,0'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="PartialCount" Text="18" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=28}" />
                        </StackPanel>
                    </Border>

                    <!-- Delivered -->
                    <Border Background="{StaticResource DeliveredBg}"
            BorderBrush="{StaticResource DeliveredBorder}"
            Style="{StaticResource OrderStatusCard}"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='14,12,14,12'}"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='3,0,6,0'}">
                        <StackPanel>
                            <TextBlock Text="Delivered" TextDecorations="Underline" Foreground="{StaticResource DeliveredText}" Cursor="Hand"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="DeliveredValue" Text="R 4 198 700" Foreground="#708ECA" TextDecorations="Underline"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,18,0,0'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="DeliveredCount" Text="45" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=28}" />
                        </StackPanel>
                    </Border>

                    <!-- Invoice Issues -->
                    <Border Background="{StaticResource InvoiceIssuesBg}"
            BorderBrush="{StaticResource InvoiceIssuesBorder}"
            Style="{StaticResource OrderStatusCard}"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='14,12,14,12'}"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='3,0,6,0'}">
                        <StackPanel>
                            <TextBlock Text="Invoice Issues" TextDecorations="Underline" Foreground="{StaticResource InvoiceIssuesText}" Cursor="Hand"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="InvoiceIssuesValue" Text="R 45 890" Foreground="#708ECA" TextDecorations="Underline"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,18,0,0'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="InvoiceIssuesCount" Text="7" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=28}" />
                        </StackPanel>
                    </Border>

                    <!-- Payments Pending -->
                    <Border Background="{StaticResource PaymentsPendingBg}"
            BorderBrush="{StaticResource PaymentsPendingBorder}"
            Style="{StaticResource OrderStatusCard}"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='14,12,14,12'}"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='3,0,0,0'}">
                        <StackPanel>
                            <TextBlock Text="Payments Pending" TextDecorations="Underline" Foreground="{StaticResource PaymentsPendingText}" Cursor="Hand"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="PaymentsPendingValue" Text="R 34 123" Foreground="#708ECA" TextDecorations="Underline"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,18,0,0'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="PaymentsPendingCount" Text="5" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=28}" />
                        </StackPanel>
                    </Border>

                </UniformGrid>
                <!-- ═══ OPERATIONAL PERFORMANCE ═══ -->
                <TextBlock Text="Operational Performance"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource MainForeground}"
                           Margin="{Binding Source={StaticResource UiScaleState},
                                            Path=FontScale,
                                            Converter={StaticResource ThicknessScaleConverter},
                                            ConverterParameter='0,0,0,10'}"
                           FontSize="{Binding Source={StaticResource UiScaleState},
                                              Path=FontScale,
                                              Converter={StaticResource FontScaleConverter},
                                              ConverterParameter=15}" />

                <!-- Row 1: 4 performance cards -->
                <UniformGrid Columns="4"
             Margin="{Binding Source={StaticResource UiScaleState},
                              Path=FontScale,
                              Converter={StaticResource ThicknessScaleConverter},
                              ConverterParameter='0,0,0,10'}">

                    <!-- Outstanding Orders -->
                    <Border Background="{StaticResource OutstandingBg}" BorderBrush="{StaticResource OutstandingBorder}" BorderThickness="1"
            CornerRadius="8"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,14,16,14'}"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,6,0'}">
                        <StackPanel>
                            <TextBlock Text="APPROVED + SENT" Foreground="#1564FF"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                       FontWeight="Normal"/>
                            <TextBlock Text="Outstanding Orders" Foreground="{StaticResource DimmedForeground}"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,14'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="OutstandingAmount" Text="R 1 234 560" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}" />
                            <StackPanel Orientation="Horizontal"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,6,0,0'}">
                                <Viewbox Width="14" Height="14" VerticalAlignment="Center"
                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,2,0'}">
                                    <Canvas Width="24" Height="24">
                                        <Polyline Points="22,7 13.5,15.5 8.5,10.5 2,17"
                                  Stroke="#22C55E" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Polyline Points="16,7 22,7 22,13"
                                  Stroke="#22C55E" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="OutstandingTrend" Text="12%" Foreground="#22C55E"
                           Margin="2,0,0,0"
                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Accrued Liability -->
                    <Border Background="{StaticResource AccruedBg}" BorderBrush="{StaticResource AccruedBorder}" BorderThickness="1"
            CornerRadius="8"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,14,16,14'}"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='3,0,6,0'}">
                        <StackPanel>
                            <TextBlock Text="ACCRUED LIABILITY" Foreground="#7F1D1D"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                       FontWeight="Normal"/>
                            <TextBlock Text="Delivered Not Invoiced" Foreground="{StaticResource DimmedForeground}"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,14'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="AccruedAmount" Text="R 892 340" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}" />
                            <StackPanel Orientation="Horizontal"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,6,0,0'}">
                                <Viewbox Width="14" Height="14" VerticalAlignment="Center"
                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,2,0'}"
                         RenderTransformOrigin="0.5,0.5">
                                    <Viewbox.RenderTransform>
                                        <RotateTransform Angle="180" />
                                    </Viewbox.RenderTransform>
                                    <Canvas Width="24" Height="24">
                                        <Polyline Points="22,7 13.5,15.5 8.5,10.5 2,17"
                                  Stroke="#852622" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Polyline Points="16,7 22,7 22,13"
                                  Stroke="#852622" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="AccruedTrend" Text="18 POs" Foreground="#852622"
                           Margin="2,0,0,0"
                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Awaiting Processing -->
                    <Border Background="{StaticResource InvoiceProcessingBg}" BorderBrush="{StaticResource InvoiceProcessingBorder}" BorderThickness="1"
            CornerRadius="8"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,14,16,14'}"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='3,0,6,0'}">
                        <StackPanel>
                            <TextBlock Text="AWAITING PROCESSING" Foreground="#99978D"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                       FontWeight="Normal"/>
                            <TextBlock Text="Invoices to Review" Foreground="{StaticResource DimmedForeground}"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,14'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="ProcessingAmount" Text="R 456 780" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}" />
                            <TextBlock x:Name="ProcessingDetail" Text="9 invoices" Foreground="{StaticResource DimmedForeground}"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,6,0,0'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                        </StackPanel>
                    </Border>

                    <!-- Due Within 30 Days -->
                    <Border Background="{StaticResource DueWithinBg}" BorderBrush="{StaticResource DueWithinBorder}" BorderThickness="1"
            CornerRadius="8"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,14,16,14'}"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='3,0,0,0'}">
                        <StackPanel>
                            <TextBlock Text="DUE WITHIN 30 DAYS" Foreground="#C53EFA"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                       FontWeight="Normal"/>
                            <TextBlock Text="Supplier Payments Due" Foreground="{StaticResource DimmedForeground}"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,14'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="DueAmount" Text="R 1 567 890" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}" />
                            <StackPanel Orientation="Horizontal"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,6,0,0'}">
                                <Viewbox Width="14" Height="14" VerticalAlignment="Center"
                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,2,0'}">
                                    <Canvas Width="24" Height="24">
                                        <Polyline Points="22,7 13.5,15.5 8.5,10.5 2,17"
                                  Stroke="#22C55E" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Polyline Points="16,7 22,7 22,13"
                                  Stroke="#22C55E" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="DueTrend" Text="5%" Foreground="#22C55E"
                           Margin="2,0,0,0"
                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- Row 2: 3 metric cards — same column sizing as the 4-column row above (4-col grid, 4th slot empty) -->
                <UniformGrid Columns="4"
             Margin="{Binding Source={StaticResource UiScaleState},
                              Path=FontScale,
                              Converter={StaticResource ThicknessScaleConverter},
                              ConverterParameter='0,0,0,24'}">
                    <!-- Total Trend -->
                    <Border Background="{StaticResource TotalTrendBg}" BorderBrush="{StaticResource TotalTrendBorder}" BorderThickness="1"
            CornerRadius="8"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,14,16,14'}"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,6,0'}">
                        <StackPanel>
                            <TextBlock Text="TOTAL SPEND 2026" Foreground="#065F46"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                       FontWeight="Normal"/>
                            <TextBlock Text="This Month's Spend" Foreground="{StaticResource DimmedForeground}"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,14'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="TotalTrendAmount" Text="R 15 678 900" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}" />
                            <StackPanel Orientation="Horizontal"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,6,0,0'}">
                                <Viewbox Width="14" Height="14" VerticalAlignment="Center"
                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,2,0'}">
                                    <Canvas Width="24" Height="24">
                                        <Polyline Points="22,7 13.5,15.5 8.5,10.5 2,17"
                                  Stroke="#22C55E" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Polyline Points="16,7 22,7 22,13"
                                  Stroke="#22C55E" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="TotalTrendPercent" Text="8%" Foreground="#22C55E"
                           Margin="2,0,0,0"
                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Cycle Time Metric -->
                    <Border Background="{StaticResource CycleTimeBg}" BorderBrush="{StaticResource CycleTimeBorder}" BorderThickness="1"
            CornerRadius="8"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,14,16,14'}"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='3,0,6,0'}">
                        <StackPanel>
                            <TextBlock Text="CYCLE TIME METRIC" Foreground="#1E40AF"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                       FontWeight="Normal"/>
                            <TextBlock Text="Average Approval Time" Foreground="{StaticResource DimmedForeground}"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,14'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="CycleTimeValue" Text="4.2 days" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}" />
                            <StackPanel Orientation="Horizontal"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,6,0,0'}">
                                <Viewbox Width="14" Height="14" VerticalAlignment="Center"
                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,2,0'}"
                         RenderTransformOrigin="0.5,0.5">
                                    <Viewbox.RenderTransform>
                                        <RotateTransform Angle="180" />
                                    </Viewbox.RenderTransform>
                                    <Canvas Width="24" Height="24">
                                        <Polyline Points="22,7 13.5,15.5 8.5,10.5 2,17"
                                  Stroke="#22C55E" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Polyline Points="16,7 22,7 22,13"
                                  Stroke="#22C55E" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="CycleTimeTrend" Text="0.8d" Foreground="#22C55E"
                           Margin="2,0,0,0"
                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Lead Time Accuracy -->
                    <Border Background="{StaticResource LeadTimeBg}" BorderBrush="{StaticResource LeadTimeBorder}" BorderThickness="1"
            CornerRadius="8"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,14,16,14'}"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='3,0,6,0'}">
                        <StackPanel>
                            <TextBlock Text="LEAD TIME ACCURACY" Foreground="#92400E"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                       FontWeight="Normal"/>
                            <TextBlock Text="Average Delivery Variance" Foreground="{StaticResource DimmedForeground}"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,14'}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                            <TextBlock x:Name="LeadTimeValue" Text="+2.1 days" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}" />
                            <StackPanel Orientation="Horizontal"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,6,0,0'}">
                                <Viewbox Width="14" Height="14" VerticalAlignment="Center"
                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,2,0'}">
                                    <Canvas Width="24" Height="24">
                                        <Polyline Points="22,7 13.5,15.5 8.5,10.5 2,17"
                                  Stroke="#852622" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                        <Polyline Points="16,7 22,7 22,13"
                                  Stroke="#852622" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock x:Name="LeadTimeTrend" Text="0.3d" Foreground="#852622"
                           Margin="2,0,0,0"
                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Empty 4th slot -->
                    <Border Visibility="Hidden" />
                </UniformGrid>

                <!-- ═══ RECENT PURCHASE ORDERS — header + list inside one rounded container ═══ -->
                <Border Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="{Binding ActualHeight,
                                               RelativeSource={RelativeSource Self},
                                               Converter={StaticResource CornerRadiusFromHeightConverter},
                                               ConverterParameter=10}"
                        ClipToBounds="True">
                    <StackPanel>
                        <!-- Header row -->
                        <DockPanel Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='16,14,16,14'}">
                            <TextBlock Text="Recent Purchase Orders"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource MainForeground}"
                                       VerticalAlignment="Center"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=15}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="View All" Foreground="{StaticResource DimmedForeground}" Cursor="Hand"
                                           VerticalAlignment="Center"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                <TextBlock Text=" →" Foreground="{StaticResource DimmedForeground}"
                                           VerticalAlignment="Center"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                            </StackPanel>
                        </DockPanel>
                        <!-- Divider below header -->
                        <Rectangle Height="1" Fill="#E5E7EB" />
                    <ItemsControl x:Name="RecentPOList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Border Style="{StaticResource PORowBorder}"
                                            Padding="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='24,14,24,14'}">
                                        <DockPanel>
                                        <!-- Right side: Amount + Invoice date -->
                                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding AmountDisplay}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource MainForeground}" HorizontalAlignment="Right"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}" />
                                            <TextBlock Text="{Binding InvoiceDateDisplay}" Foreground="{StaticResource DimmedForeground}" HorizontalAlignment="Right"
                                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                                        </StackPanel>

                                        <!-- Left side: PO info -->
                                        <StackPanel VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding PONumber}" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}" />
                                                <!-- Status badge -->
                                                <Border CornerRadius="4"
                                                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,0'}"
                                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,2,8,2'}"
                                                        Background="{Binding StatusBadgeBg}" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Status}" Foreground="{Binding StatusBadgeText}"
                                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=10}" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,0'}">
                                                <TextBlock Text="{Binding SupplierName}" Foreground="{StaticResource DimmedForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                                                <TextBlock Text="  •  " Foreground="{StaticResource DimmedForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                                                <TextBlock Text="{Binding DateDisplay}" Foreground="{StaticResource DimmedForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                                                <TextBlock Text="  •  " Foreground="{StaticResource DimmedForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                                                <TextBlock Text="{Binding ItemCountDisplay}" Foreground="{StaticResource DimmedForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>
                                    </Border>
                                    <!-- Row divider — hidden on last item via converter -->
                                    <Rectangle Height="1" Fill="#E5E7EB"
                                               Margin="{Binding Source={StaticResource UiScaleState},
                                                                Path=FontScale,
                                                                Converter={StaticResource ThicknessScaleConverter},
                                                                ConverterParameter='24,0,24,0'}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
