<UserControl x:Class="RestaurantPosWpf.ProcurementDiscrepancies"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RestaurantPosWpf">

    <UserControl.Resources>
        <Style x:Key="DiscrepancyHeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
        </Style>

        <Style x:Key="GridResolveButtonStyle" TargetType="Button" BasedOn="{StaticResource VcPrimaryButtonStyle}">
            <Setter Property="Background" Value="#03051A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
            <Setter Property="Padding" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,4,10,4'}" />
            <Setter Property="MinWidth" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=68}" />
            <Setter Property="Height" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=32}" />
        </Style>

        <Style x:Key="GridDisputeButtonStyle" TargetType="Button" BasedOn="{StaticResource VcSecondaryButtonStyle}">
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
            <Setter Property="Padding" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,4,10,4'}" />
            <Setter Property="MinWidth" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=68}" />
            <Setter Property="Height" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=32}" />
        </Style>

        <Style x:Key="DiscrepancyFilterComboStyle" TargetType="ComboBox" BasedOn="{StaticResource IcEnabledComboBoxStyle}">
            <Setter Property="Background" Value="#F3F4F6" />
            <Setter Property="BorderBrush" Value="#E5E7EB" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryButtonForeground}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,0,24,0'}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="DiscrepancyFilterButtonStyle" TargetType="Button" BasedOn="{StaticResource VcSecondaryButtonStyle}">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,0,16,0'}" />
        </Style>

        <Style x:Key="DiscrepancyFilterComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MainForeground}" />
            <Setter Property="Padding" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,8,10,8'}" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='4,2,4,2'}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left" />
                                <TextBlock x:Name="SelectedCheck"
                                           Grid.Column="1"
                                           Text="✓"
                                           Visibility="Collapsed"
                                           Foreground="#6B7280"
                                           VerticalAlignment="Center"
                                           Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,0,0,0'}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F9FAFB" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F3F4F6" />
                                <Setter TargetName="SelectedCheck" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridTypeBadgeBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,4,10,4'}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="GridTypeBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridStatusBadgeBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,4,10,4'}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="GridStatusBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridPrimaryCellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MainForeground}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridSecondaryCellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="GridNumericCellTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MainForeground}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PoLinkButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#2563EB" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock Text="{TemplateBinding Content}"
                                   TextDecorations="Underline"
                                   Foreground="{TemplateBinding Foreground}"
                                   Style="{StaticResource GridPrimaryCellTextStyle}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <Border BorderBrush="#E5E7EB"
            BorderThickness="1"
            Background="#F8FAFC"
            SnapsToDevicePixels="True"
            ClipToBounds="True"
            FocusVisualStyle="{x:Null}"
            Padding="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter},
                             ConverterParameter='28,24,28,24'}"
            CornerRadius="{Binding ActualHeight,
                                   RelativeSource={RelativeSource Self},
                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                   ConverterParameter=12}"
            Margin="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter},
                             ConverterParameter='24,24,24,24'}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" FocusVisualStyle="{x:Null}">
            <StackPanel>
                <DockPanel Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,14'}">
                    <Button Content="x"
                            Background="#F8FAFC"
                            Padding="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource ThicknessScaleConverter},
                                             ConverterParameter='18,0,18,3'}"
                            Style="{StaticResource VcSecondaryButtonStyle}"
                            FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Top"
                            Click="Close_Click" />
                    <Button Content="Add Demo Record"
                            Visibility="Collapsed"
                            Padding="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource ThicknessScaleConverter},
                                             ConverterParameter='18,4'}"
                            Style="{StaticResource VcSecondaryButtonStyle}"
                            DockPanel.Dock="Right"
                            FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                            VerticalAlignment="Top"
                            Click="AddDemoRecord_Click" />
                    <StackPanel>
                        <TextBlock Text="Discrepancies"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource MainForeground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}" />
                        <TextBlock Text="Track and resolve delivery and pricing discrepancies"
                                   Foreground="{StaticResource DimmedForeground}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,0'}"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}" />
                    </StackPanel>
                </DockPanel>

                <UniformGrid Columns="4"
                             Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,14'}">
                    <Border Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,6,0'}"
                            Background="#FDECEC" BorderBrush="#E9B8B8" BorderThickness="1" CornerRadius="8"
                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='14,12,14,12'}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=34}"
                                    Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=34}"
                                    CornerRadius="10"
                                    Background="#FDECEC"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}">
                                <Viewbox Stretch="Uniform" Margin="6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M21.73 18 L13.73 4 A2 2 0 0 0 10.25 4 L2.25 18 A2 2 0 0 0 4 21 L20 21 A2 2 0 0 0 21.73 18"
                                              Stroke="#DC2626" StrokeThickness="2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        <Path Data="M12 9 L12 13"
                                              Stroke="#DC2626" StrokeThickness="2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Ellipse Width="2" Height="2" Fill="#DC2626" Canvas.Left="11" Canvas.Top="16"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Open Issues" Foreground="#6B7280"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                <TextBlock x:Name="OpenIssuesCountText" Text="0" Foreground="#C9213E" FontWeight="SemiBold"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=24}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='3,0,6,0'}"
                            Background="#FEF6E7" BorderBrush="#E8C98A" BorderThickness="1" CornerRadius="8"
                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='14,12,14,12'}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=34}"
                                    Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=34}"
                                    CornerRadius="10"
                                    Background="#FEF6E7"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}">
                                <Viewbox Stretch="Uniform" Margin="6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M15 2 L6 2 A2 2 0 0 0 4 4 L4 20 A2 2 0 0 0 6 22 L18 22 A2 2 0 0 0 20 20 L20 7 Z"
                                              Stroke="#D97706" StrokeThickness="2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        <Path Data="M14 2 L14 6 A2 2 0 0 0 16 8 L20 8"
                                              Stroke="#D97706" StrokeThickness="2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        <Path Data="M10 9 L8 9 M16 13 L8 13 M16 17 L8 17"
                                              Stroke="#D97706" StrokeThickness="2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Disputed" Foreground="#6B7280"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                <TextBlock x:Name="DisputedCountText" Text="0" Foreground="#D7721D" FontWeight="SemiBold"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=24}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='3,0,6,0'}"
                            Background="#EAF8EF" BorderBrush="#A9D8B8" BorderThickness="1" CornerRadius="8"
                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='14,12,14,12'}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=34}"
                                    Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=34}"
                                    CornerRadius="10"
                                    Background="#EAF8EF"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}">
                                <Viewbox Stretch="Uniform" Margin="6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M21.801 10 A10 10 0 1 1 17 3.335"
                                              Stroke="#16A34A" StrokeThickness="2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        <Path Data="M9 11 L12 14 L22 4"
                                              Stroke="#16A34A" StrokeThickness="2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Resolved" Foreground="#6B7280"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                <TextBlock x:Name="ResolvedCountText" Text="0" Foreground="#019D50" FontWeight="SemiBold"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=24}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='3,0,0,0'}"
                            Background="#EEF4FF" BorderBrush="#B7CAE8" BorderThickness="1" CornerRadius="8"
                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='14,12,14,12'}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=34}"
                                    Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=34}"
                                    CornerRadius="10"
                                    Background="#EEF4FF"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}">
                                <Viewbox Stretch="Uniform" Margin="6">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M15 2 L6 2 A2 2 0 0 0 4 4 L4 20 A2 2 0 0 0 6 22 L18 22 A2 2 0 0 0 20 20 L20 7 Z"
                                              Stroke="#2563EB" StrokeThickness="2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        <Path Data="M14 2 L14 6 A2 2 0 0 0 16 8 L20 8"
                                              Stroke="#2563EB" StrokeThickness="2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                        <Path Data="M10 9 L8 9 M16 13 L8 13 M16 17 L8 17"
                                              Stroke="#2563EB" StrokeThickness="2" Fill="Transparent" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Credited" Foreground="#6B7280"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                <TextBlock x:Name="CreditedCountText" Text="0" Foreground="#506AEF" FontWeight="SemiBold"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=24}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"
                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,14'}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1.8*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}">
                            <TextBlock Text="Status" 
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"
                                       Foreground="#374151" 
                                       Margin="0,0,0,4"/>
                        <ComboBox x:Name="StatusFilterComboBox"
                                  Style="{StaticResource IcEnabledComboBoxStyle}"
                                  FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                  ItemContainerStyle="{StaticResource DiscrepancyFilterComboItemStyle}"
                                  Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=36}"
                                  SelectionChanged="StatusFilterComboBox_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}">
                            <TextBlock Text="Type" 
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"
                                       Foreground="#374151" 
                                       Margin="0,0,0,4"
                                       />
                        <ComboBox x:Name="TypeFilterComboBox"
                                  FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                  Style="{StaticResource IcEnabledComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource DiscrepancyFilterComboItemStyle}"
                                  Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=36}"
                                  SelectionChanged="TypeFilterComboBox_SelectionChanged"/>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Clear Filters"
                                FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                Style="{StaticResource DiscrepancyFilterButtonStyle}"
                                Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=36}"
                                VerticalAlignment="Bottom"
                                Click="ClearFilters_Click"/>
                    </Grid>
                </Border>

                <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                            <Border Grid.Row="0"
        Background="#E5E7EB"
        CornerRadius="8,8,0,0">
                                <Grid Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.05*" />
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="1.95*" />
                                        <ColumnDefinition Width="0.92*" />
                                        <ColumnDefinition Width="0.48*" />
                                        <ColumnDefinition Width="0.6*" />
                                        <ColumnDefinition Width="0.6*" />
                                        <ColumnDefinition Width="0.74*" />
                                        <ColumnDefinition Width="0.9*" />
                                        <ColumnDefinition Width="1.6*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                   Text="PO #"
                   Style="{StaticResource DiscrepancyHeaderText}"
                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />

                                    <TextBlock Grid.Column="1"
                   Text="Supplier"
                   Style="{StaticResource DiscrepancyHeaderText}"
                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />

                                    <TextBlock Grid.Column="2"
                   Text="Ingredient"
                   Style="{StaticResource DiscrepancyHeaderText}"
                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />

                                    <TextBlock Grid.Column="3"
                   Text="Type"
                   Style="{StaticResource DiscrepancyHeaderText}"
                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />

                                    <TextBlock Grid.Column="4"
                   Text="Ordered"
                   Style="{StaticResource DiscrepancyHeaderText}"
                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />

                                    <TextBlock Grid.Column="5"
                   Text="Received"
                                               Margin="8,0,0,0"
                   Style="{StaticResource DiscrepancyHeaderText}"
                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />

                                    <TextBlock Grid.Column="6"
                   Text="Variance" Margin="5,0,0,0"
                   Style="{StaticResource DiscrepancyHeaderText}"
                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />

                                    <TextBlock Grid.Column="7"
                   Text="Status"
                   Style="{StaticResource DiscrepancyHeaderText}"
                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />

                                    <TextBlock Grid.Column="8"
                   Text="Reported"
                   Style="{StaticResource DiscrepancyHeaderText}"
                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />

                                    <TextBlock Grid.Column="9"
                   Text="Actions"
                   Style="{StaticResource DiscrepancyHeaderText}"
                   HorizontalAlignment="Right"
                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                </Grid>
                            </Border>

                            <ItemsControl x:Name="DiscrepancyList" Grid.Row="1">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F3F4F6" BorderThickness="0,1,0,0"
                                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.05*" />
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="1.95*" />
                                                <ColumnDefinition Width="0.92*" />
                                                <ColumnDefinition Width="0.48*" />
                                                <ColumnDefinition Width="0.6*" />
                                                <ColumnDefinition Width="0.6*" />
                                                <ColumnDefinition Width="0.74*" />
                                                <ColumnDefinition Width="0.9*" />
                                                <ColumnDefinition Width="1.6*" />
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Content="{Binding PONumber}"
                                                    Tag="{Binding PONumber}"
                                                    Style="{StaticResource PoLinkButtonStyle}"
                                                    FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                    Click="PONumber_Click" />
                                            <TextBlock Grid.Column="1" Text="{Binding Supplier}" TextTrimming="CharacterEllipsis"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                       Style="{StaticResource GridPrimaryCellTextStyle}" />
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Ingredient}" TextTrimming="CharacterEllipsis"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                           Style="{StaticResource GridPrimaryCellTextStyle}" />
                                                <TextBlock Text="{Binding Detail}" TextTrimming="CharacterEllipsis"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"
                                                           Style="{StaticResource GridSecondaryCellTextStyle}" />
                                            </StackPanel>
                                            <Border Grid.Column="3"
                                                    Background="{Binding TypeBadgeBg}"
                                                    Style="{StaticResource GridTypeBadgeBorderStyle}">
                                                <TextBlock Text="{Binding Type}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}"
                                                           Foreground="{Binding TypeBadgeText}"
                                                           Style="{StaticResource GridTypeBadgeTextStyle}" />
                                            </Border>
                                            <TextBlock Grid.Column="4" Text="{Binding Ordered}" Style="{StaticResource GridNumericCellTextStyle}" 
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                       />
                                            <TextBlock Grid.Column="5" Text="{Binding Received}" Style="{StaticResource GridNumericCellTextStyle}" 
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                       />
                                            <TextBlock Grid.Column="6" Text="{Binding Variance}" Style="{StaticResource GridNumericCellTextStyle}" 
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                       />
                                            <Border Grid.Column="7"
                                                    Background="{Binding StatusBadgeBg}"
                                                    Style="{StaticResource GridStatusBadgeBorderStyle}">
                                                <TextBlock Text="{Binding StatusDisplay}"
                                                           Foreground="{Binding StatusBadgeText}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"
                                                           Style="{StaticResource GridStatusBadgeTextStyle}" />
                                            </Border>
                                            <StackPanel Grid.Column="8">
                                                <TextBlock Text="{Binding ReportedBy}" TextTrimming="CharacterEllipsis"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                           Style="{StaticResource GridPrimaryCellTextStyle}" />
                                                <TextBlock Text="{Binding ReportedDateDisplay}" Style="{StaticResource GridSecondaryCellTextStyle}" 
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"
                                                           />
                                            </StackPanel>
                                            <StackPanel Grid.Column="9" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <Button Content="Dispute"
                                                        Style="{StaticResource GridDisputeButtonStyle}"
                                                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,6,0'}"
                                                        Tag="{Binding}"
                                                        FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                        Click="Dispute_Click"/>
                                                <Button Content="Resolve"
                                                        Style="{StaticResource GridResolveButtonStyle}"
                                                        FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                        Tag="{Binding}"
                                                        Click="Resolve_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Border>
        <Border Grid.Row="1"
                 x:Name="FooterStrip"
            Background="White"
            BorderBrush="#E5E7EB"
            BorderThickness="0,1,0,0">

            <Border.Padding>
                <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource ThicknessScaleConverter}"
                     ConverterParameter="24,12,24,12" />
            </Border.Padding>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="btnCloseFooter"
                    Grid.Column="1"
                    Content="Close"
                    MinWidth="110"
                    Height="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource LayoutScaleConverter},
                                     ConverterParameter=35}"
                    Click="Close_Click"
                    Style="{StaticResource VcSecondaryButtonStyle}"
                    FocusVisualStyle="{x:Null}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
