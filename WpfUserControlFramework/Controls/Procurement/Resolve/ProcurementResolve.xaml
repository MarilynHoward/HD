<UserControl x:Class="RestaurantPosWpf.ProcurementResolve"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Focusable="True"
             PreviewKeyDown="ProcurementResolve_PreviewKeyDown">

    <UserControl.Resources>
        <Style x:Key="ResolveSummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DimmedForeground}" />
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Border Background="Transparent" FocusVisualStyle="{x:Null}">
        <Grid x:Name="OverlayRoot" FocusVisualStyle="{x:Null}">
            <Border x:Name="DialogCard"
                    Width="{Binding ActualWidth, ElementName=OverlayRoot, Converter={StaticResource WidthMultiplierConverter}, ConverterParameter=0.48}"
                    MaxWidth="{Binding ActualWidth, ElementName=OverlayRoot, Converter={StaticResource WidthMultiplierConverter}, ConverterParameter=0.49}"
                    MaxHeight="{Binding ActualHeight, ElementName=OverlayRoot, Converter={StaticResource WidthMultiplierConverter}, ConverterParameter=0.96}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Background="White"
                    SnapsToDevicePixels="True"
                    CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=12}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Padding">
                            <Setter.Value>
                                <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource ThicknessScaleConverter}"
                                         ConverterParameter="16,14,16,16" />
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=FormScrollViewer, Path=ComputedVerticalScrollBarVisibility}" Value="Visible">
                                <Setter Property="Padding">
                                    <Setter.Value>
                                        <Binding Source="{StaticResource UiScaleState}"
                                                 Path="FontScale"
                                                 Converter="{StaticResource ThicknessScaleConverter}"
                                                 ConverterParameter="16,14,0,16" />
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,6'}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Resolve Discrepancy"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource MainForeground}"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}" />
                            <TextBlock Text="{Binding ResolveSubtitleLine}"
                                       FontWeight="Normal"
                                       Foreground="{StaticResource DimmedForeground}"
                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,3,0,0'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                VerticalAlignment="Top"
                                Content="×"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource MainForeground}"
                                FontWeight="SemiBold"
                                FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,8,4'}"
                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"
                                MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=32}"
                                MinHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=32}"
                                Click="Close_Click"
                                FocusVisualStyle="{x:Null}" />
                    </Grid>

                    <Rectangle Grid.Row="1"
                               Height="1"
                               Fill="#FFE5E7EB"
                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,10'}" />

                    <ScrollViewer Grid.Row="2"
                                  x:Name="FormScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  FocusVisualStyle="{x:Null}">
                        <StackPanel Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,4,8,0'}">
                            <Border Background="#F3F4F6"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='4,0,4,0'}"
                                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='14,12,14,12'}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,12,0'}">
                                        <TextBlock Text="Ingredient" Style="{StaticResource ResolveSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding Ingredient}"
                                                   Foreground="{StaticResource MainForeground}"
                                                   TextWrapping="Wrap"
                                                   FontWeight="SemiBold"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,10'}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                        <TextBlock Text="Ordered" Style="{StaticResource ResolveSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding Ordered}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MainForeground}"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,10'}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                        <TextBlock Text="Variance" Style="{StaticResource ResolveSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding Variance}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding VarianceForegroundHex}"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Supplier" Style="{StaticResource ResolveSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding Supplier}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MainForeground}"
                                                   TextWrapping="Wrap"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,10'}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                        <TextBlock Text="Received" Style="{StaticResource ResolveSummaryLabelStyle}" />
                                        <TextBlock Text="{Binding Received}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MainForeground}"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,10'}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                        <TextBlock Text="Type" Style="{StaticResource ResolveSummaryLabelStyle}" />
                                        <Border Background="{Binding TypeBadgeBg}"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                HorizontalAlignment="Left"
                                                Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,5,10,5'}"
                                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}">
                                            <TextBlock Text="{Binding Type}"
                                                       Foreground="{Binding TypeBadgeText}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <StackPanel Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='6,14,6,0'}">
                                <TextBlock Foreground="#111827"
                                           Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}">
                                    <Run Text="Credit Note Number (Optional)" />
                                </TextBlock>
                                <Border Background="Transparent"
                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='2,2,2,2'}">
                                    <Grid>
                                        <TextBox x:Name="CreditNoteTextBox"
                                                 Style="{StaticResource IcEnabledTextBoxStyle}"
                                                 Padding="10,8,10,8" />
                                        <TextBlock Text="e.g., CN-2026-001"
                                                   IsHitTestVisible="False"
                                                   Foreground="#9CA3AF"
                                                   Margin="12,0,0,0"
                                                   VerticalAlignment="Center"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding ElementName=CreditNoteTextBox, Path=Text}" Value="" />
                                                                <Condition Binding="{Binding ElementName=CreditNoteTextBox, Path=IsKeyboardFocused}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='6,14,6,0'}">
                                <TextBlock Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"
                                           Foreground="#111827"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}">
                                    <Run Text="Resolution Details " />
                                    <Run Text="*" Foreground="#DC2626" />
                                </TextBlock>
                                <Border Background="Transparent"
                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='2,2,2,2'}">
                                    <Grid>
                                        <TextBox x:Name="ResolutionDetailsTextBox"
                                                 Style="{StaticResource IcEnabledTextBoxStyle}"
                                                 Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=80}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalContentAlignment="Top"
                                                 Padding="10,8,10,8" />
                                        <TextBlock Text="Describe how this discrepancy was resolved..."
                                                   IsHitTestVisible="False"
                                                   Foreground="#9CA3AF"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,8,0,0'}"
                                                   VerticalAlignment="Top"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding ElementName=ResolutionDetailsTextBox, Path=Text}" Value="" />
                                                                <Condition Binding="{Binding ElementName=ResolutionDetailsTextBox, Path=IsKeyboardFocused}" Value="False" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <Border Background="#EFF6FF"
                                    BorderBrush="#BFDBFE"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='6,16,6,0'}"
                                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="#374151"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}">
                                        <Run FontWeight="SemiBold">Note:</Run>
                                        <Run> Resolving this discrepancy will:</Run>
                                    </TextBlock>
                                    <TextBlock Text="    • Update the PO status"
                                               Foreground="#374151"
                                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,0'}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                    <TextBlock Text="    • Log resolution in audit trail"
                                               Foreground="#374151"
                                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                    <TextBlock Text="    • Notify relevant stakeholders"
                                               Foreground="#374151"
                                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Rectangle Grid.Row="3"
                               Height="1"
                               Fill="#FFE5E7EB"
                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,14,0,12'}" />

                    <Border Grid.Row="4" Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Cancel"
                                        MinWidth="110"
                                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"
                                        Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=35}"
                                        Style="{StaticResource VcSecondaryButtonStyle}"
                                        Click="Close_Click"
                                        FocusVisualStyle="{x:Null}" />
                                <Button Content="Mark as Resolved"
                                        MinWidth="140"
                                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,16,0'}"
                                        Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=35}"
                                        Style="{StaticResource VcPrimaryButtonStyle}"
                                        Click="MarkAsResolved_Click"
                                        FocusVisualStyle="{x:Null}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
