<UserControl x:Class="RestaurantPosWpf.OpsServicesShiftScheduling"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <!-- Card shadow (matches procurement dashboard card weight) -->
        <DropShadowEffect x:Key="OpsSchedulePanelShadow"
                          BlurRadius="14"
                          Direction="270"
                          Opacity="0.08"
                          ShadowDepth="2"
                          Color="#000000" />
        <DropShadowEffect x:Key="OpsScheduleCardShadow"
                          BlurRadius="8"
                          Direction="270"
                          Opacity="0.06"
                          ShadowDepth="1"
                          Color="#000000" />

        <!-- Stat strip (semantic tints aligned with procurement stat cards) -->
        <SolidColorBrush x:Key="OpsStatStaffBg" Color="#EFF6FF" />
        <SolidColorBrush x:Key="OpsStatStaffBorder" Color="#BFDBFE" />
        <SolidColorBrush x:Key="OpsStatShiftsBg" Color="#ECFDF5" />
        <SolidColorBrush x:Key="OpsStatShiftsBorder" Color="#BBF7D0" />
        <SolidColorBrush x:Key="OpsStatHoursBg" Color="#FAF5FF" />
        <SolidColorBrush x:Key="OpsStatHoursBorder" Color="#E9D5FF" />
        <SolidColorBrush x:Key="OpsStatExportBg" Color="#FFFBEB" />
        <SolidColorBrush x:Key="OpsStatExportBorder" Color="#FDE68A" />
        <SolidColorBrush x:Key="OpsStatExportIcon" Color="#D97706" />
        <SolidColorBrush x:Key="OpsStatShiftsIconBrush" Color="{StaticResource Color.SuccessGreen}" />
        <SolidColorBrush x:Key="OpsStatHoursIconBrush" Color="#7C3AED" />

        <!-- Rounded like toolbar secondary; transparent chrome inside export card -->
        <Style x:Key="OpsExportLinkButtonStyle" TargetType="Button" BasedOn="{StaticResource VcSecondaryButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Date range pill: flat &lt; / &gt; (client reference), no secondary chrome -->
        <Style x:Key="OpsDateRangeChevronButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource MainForeground}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontSize">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource FontScaleConverter}"
                             ConverterParameter="17" />
                </Setter.Value>
            </Setter>
            <Setter Property="Padding">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource ThicknessScaleConverter}"
                             ConverterParameter="6,2,6,2" />
                </Setter.Value>
            </Setter>
            <Setter Property="MinWidth">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource LayoutScaleConverter}"
                             ConverterParameter="28" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#14000000" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#22000000" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#10000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource Brush.White}"
          SnapsToDevicePixels="True"
          FocusVisualStyle="{x:Null}"
          Margin="{Binding Source={StaticResource UiScaleState},
                           Path=FontScale,
                           Converter={StaticResource ThicknessScaleConverter},
                           ConverterParameter='24,24,24,24'}">
        <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Sub-nav pills (fixed; not inside schedule scroll) -->
            <DockPanel Grid.Row="0"
                       LastChildFill="False"
                       Margin="{Binding Source={StaticResource UiScaleState},
                                        Path=FontScale,
                                        Converter={StaticResource ThicknessScaleConverter},
                                        ConverterParameter='0,0,0,14'}">
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal">
                    <Button x:Name="PillShiftScheduling"
                            Click="PillShiftScheduling_Click"
                            Style="{StaticResource OpsSubNavPillButtonStyle}"
                            Margin="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource ThicknessScaleConverter},
                                             ConverterParameter='0,0,8,0'}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=20}"
                                     Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=20}"
                                     VerticalAlignment="Center">
                                <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M8,2 L8,6" />
                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M16,2 L16,6" />
                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M5,4 L19,4 A2,2 0 0 1 21,6 L21,20 A2,2 0 0 1 19,22 L5,22 A2,2 0 0 1 3,20 L3,6 A2,2 0 0 1 5,4 Z" />
                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M3,10 L21,10" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Shift Scheduling"
                                       VerticalAlignment="Center"
                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,0'}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="PillFloorPlan"
                            IsEnabled="False"
                            ToolTipService.ShowDuration="60000"
                            ToolTip="Coming soon"
                            Style="{StaticResource OpsSubNavPillButtonStyle}"
                            Margin="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource ThicknessScaleConverter},
                                             ConverterParameter='0,0,8,0'}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=20}"
                                     Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=20}"
                                     VerticalAlignment="Center">
                                <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M4,3 L9,3 A1,1 0 0 1 10,4 L10,9 A1,1 0 0 1 9,10 L4,10 A1,1 0 0 1 3,9 L3,4 A1,1 0 0 1 4,3 Z" />
                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M15,3 L20,3 A1,1 0 0 1 21,4 L21,9 A1,1 0 0 1 20,10 L15,10 A1,1 0 0 1 14,9 L14,4 A1,1 0 0 1 15,3 Z" />
                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M15,14 L20,14 A1,1 0 0 1 21,15 L21,20 A1,1 0 0 1 20,21 L15,21 A1,1 0 0 1 14,20 L14,15 A1,1 0 0 1 15,14 Z" />
                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M4,14 L9,14 A1,1 0 0 1 10,15 L10,20 A1,1 0 0 1 9,21 L4,21 A1,1 0 0 1 3,20 L3,15 A1,1 0 0 1 4,14 Z" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Floor Plan Designer"
                                       VerticalAlignment="Center"
                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,0'}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="PillTableManagement"
                            Click="PillTableManagement_Click"
                            Style="{StaticResource OpsSubNavPillButtonStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=20}"
                                     Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=20}"
                                     VerticalAlignment="Center">
                                <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M3,2 L3,9 C3,10.1045695 3.8954305,11 5,11 L9,11 A2,2 0 0 0 11,9 L11,2" />
                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M7,2 L7,22" />
                                    <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M21,15 L21,2 A5,5 0 0 0 16,7 L16,13 C16,14.1045695 16.8954305,15 18,15 L21,15 Z M21,15 L21,22" />
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Table Management"
                                       VerticalAlignment="Center"
                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,0'}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>

            <!-- Main workspace: toolbar stays visible; week/day staff rows scroll inside the body viewer (date row sticky). -->
            <Border Grid.Row="1"
                    Background="{StaticResource Brush.White}"
                    BorderBrush="{StaticResource Brush.BorderSoft}"
                    BorderThickness="1"
                    CornerRadius="{Binding ActualHeight,
                                           RelativeSource={RelativeSource Self},
                                           Converter={StaticResource CornerRadiusFromHeightConverter},
                                           ConverterParameter=12}"
                    Padding="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='16,16,16,16'}"
                    Margin="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='0,0,0,0'}">
                <Border.Effect>
                    <StaticResource ResourceKey="OpsSchedulePanelShadow" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Date range + view + add shift: pinned above vertical scroll -->
                    <DockPanel Grid.Row="0"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='0,0,0,14'}"
                               LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Border VerticalAlignment="Center"
                                    Background="{StaticResource Brush.SurfaceGreySoft}"
                                    SnapsToDevicePixels="True"
                                    CornerRadius="{Binding ActualHeight,
                                                           RelativeSource={RelativeSource Self},
                                                           Converter={StaticResource CornerRadiusFromHeightConverter},
                                                           ConverterParameter=10}"
                                    Padding="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource ThicknessScaleConverter},
                                                      ConverterParameter='4,6,4,6'}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button x:Name="BtnPrevRange"
                                            Content="&#x3C;"
                                            Click="BtnPrevRange_Click"
                                            Style="{StaticResource OpsDateRangeChevronButtonStyle}"
                                            ToolTipService.ShowDuration="60000"
                                            ToolTip="Previous range" />
                                    <TextBlock x:Name="TxtRangeLabel"
                                               VerticalAlignment="Center"
                                               Margin="{Binding Source={StaticResource UiScaleState},
                                                                Path=FontScale,
                                                                Converter={StaticResource ThicknessScaleConverter},
                                                                ConverterParameter='4,0,4,0'}"
                                               Foreground="{StaticResource MainForeground}"
                                               FontWeight="SemiBold"
                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource FontScaleConverter},
                                                                  ConverterParameter=15}" />
                                    <Button x:Name="BtnNextRange"
                                            Content="&#x3E;"
                                            Click="BtnNextRange_Click"
                                            Style="{StaticResource OpsDateRangeChevronButtonStyle}"
                                            ToolTipService.ShowDuration="60000"
                                            ToolTip="Next range" />
                                </StackPanel>
                            </Border>
                            <Button x:Name="BtnToday"
                                    Click="BtnToday_Click"
                                    Style="{StaticResource VcSecondaryButtonStyle}"
                                    FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='10,0,0,0'}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <!-- Lucide calendar (stroke matches button foreground) -->
                                    <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource LayoutScaleConverter},
                                                              ConverterParameter=22}"
                                             Height="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource LayoutScaleConverter},
                                                              ConverterParameter=22}"
                                             VerticalAlignment="Center"
                                             Margin="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource ThicknessScaleConverter},
                                                              ConverterParameter='0,0,8,0'}">
                                        <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                            <Line X1="8" Y1="2" X2="8" Y2="6"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"/>
                                            <Line X1="16" Y1="2" X2="16" Y2="6"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"/>
                                            <Rectangle Canvas.Left="3" Canvas.Top="4"
                                                       Width="18" Height="18" RadiusX="2" RadiusY="2"
                                                       Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                       StrokeThickness="2"
                                                       Fill="Transparent"/>
                                            <Line X1="3" Y1="10" X2="21" Y2="10"
                                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Today"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="BtnMonthScrollDaysLeft"
                                    Content="&#x3C;"
                                    Click="BtnMonthScrollDaysLeft_Click"
                                    ToolTipService.ShowDuration="60000"
                                    ToolTip="Earlier days in this month (scroll the schedule left)"
                                    Style="{StaticResource VcSecondaryButtonStyle}"
                                    Visibility="Collapsed"
                                    FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                    MinWidth="{Binding Source={StaticResource UiScaleState},
                                                        Path=FontScale,
                                                        Converter={StaticResource LayoutScaleConverter},
                                                        ConverterParameter=36}"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='8,0,0,0'}"/>
                            <Button x:Name="BtnMonthScrollDaysRight"
                                    Content="&#x3E;"
                                    Click="BtnMonthScrollDaysRight_Click"
                                    ToolTipService.ShowDuration="60000"
                                    ToolTip="Later days in this month (scroll the schedule right)"
                                    Style="{StaticResource VcSecondaryButtonStyle}"
                                    Visibility="Collapsed"
                                    FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                    MinWidth="{Binding Source={StaticResource UiScaleState},
                                                        Path=FontScale,
                                                        Converter={StaticResource LayoutScaleConverter},
                                                        ConverterParameter=36}"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='8,0,0,0'}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <ComboBox x:Name="CmbViewMode"
                                      Style="{StaticResource IcOpsServicesEnabledComboBoxStyle}"
                                      Width="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource LayoutScaleConverter},
                                                      ConverterParameter=160}"
                                      SelectionChanged="CmbViewMode_SelectionChanged">
                                <ComboBoxItem Content="Day View" Tag="Day"/>
                                <ComboBoxItem Content="Week View" Tag="Week"/>
                                <ComboBoxItem Content="Month View" Tag="Month"/>
                            </ComboBox>
                            <Button x:Name="BtnAddShift"
                                    Click="BtnAddShift_Click"
                                    Style="{StaticResource VcPrimaryButtonStyle}"
                                    Height="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource LayoutScaleConverter},
                                                      ConverterParameter=25}"
                                    Padding="{Binding Source={StaticResource UiScaleState},
                                                       Path=FontScale,
                                                       Converter={StaticResource ThicknessScaleConverter},
                                                       ConverterParameter='9,3,10,3'}"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='12,0,0,0'}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="+"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource FontScaleConverter},
                                                                  ConverterParameter=18}"/>
                                    <TextBlock Text=" Add Shift"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource FontScaleConverter},
                                                                  ConverterParameter=16}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <!-- Week/Day: no outer vertical ScrollViewer — parent row * gives a finite height so the body ScrollViewer scrolls and date headers stay sticky. -->
                        <Grid x:Name="ScheduleWeekDayHostGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                        <ScrollViewer x:Name="ScheduleHorizontalScroll"
                                      Grid.Row="0"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      FocusVisualStyle="{x:Null}"
                                      PreviewMouseWheel="ScheduleHorizontalScroll_PreviewMouseWheel"
                                      VerticalAlignment="Stretch"
                                      MinHeight="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource LayoutScaleConverter},
                                                          ConverterParameter=360}">
                            <Grid x:Name="ScheduleHScrollExtentGrid">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ScheduleGridChromeBorder"
                                        Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Background="{StaticResource Brush.SurfaceOffWhite}"
                                        BorderBrush="{StaticResource Brush.BorderSoft}"
                                        BorderThickness="1"
                                        CornerRadius="{Binding ActualHeight,
                                                               RelativeSource={RelativeSource Self},
                                                               Converter={StaticResource CornerRadiusFromHeightConverter},
                                                               ConverterParameter=10}"
                                        Padding="{Binding Source={StaticResource UiScaleState},
                                                         Path=FontScale,
                                                         Converter={StaticResource ThicknessScaleConverter},
                                                         ConverterParameter='8,8,8,8'}">
                                    <Grid x:Name="ScheduleChromeShell">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="0"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <!-- Search lives in the Staff corner cell (code-behind); collapsed mount keeps names for InitializeComponent. -->
                                        <Border x:Name="StaffSearchInitialMount"
                                                Grid.Row="0"
                                                Visibility="Collapsed"
                                                Height="0"
                                                MinHeight="0"
                                                Margin="0"
                                                Padding="0"
                                                SnapsToDevicePixels="True"
                                                IsHitTestVisible="False">
                                                <Border x:Name="StaffFilterSearchBoxBorder"
                                                        PreviewMouseLeftButtonDown="StaffFilterSearchBoxBorder_PreviewMouseLeftButtonDown"
                                                        Background="White"
                                                        BorderBrush="#CCC"
                                                        SnapsToDevicePixels="True"
                                                        ClipToBounds="False"
                                                        BorderThickness="{Binding Source={StaticResource UiScaleState},
                                                                                  Path=FontScale,
                                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                                  ConverterParameter=1}">

                                                    <Border.CornerRadius>
                                                        <Binding RelativeSource="{RelativeSource Self}"
                                                                 Path="ActualHeight"
                                                                 Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                                 ConverterParameter="8" />
                                                    </Border.CornerRadius>

                                                    <Grid>

                                                        <Border x:Name="StaffSearchFocusOuter"
                                                                Panel.ZIndex="10"
                                                                Visibility="Collapsed"
                                                                Margin="{Binding Source={StaticResource UiScaleState},
                                                                                 Path=FontScale,
                                                                                 Converter={StaticResource ThicknessScaleConverter},
                                                                                 ConverterParameter='-3'}"
                                                                CornerRadius="{Binding Source={StaticResource UiScaleState},
                                                                                        Path=FontScale,
                                                                                        Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                                        ConverterParameter='9'}"
                                                                BorderThickness="3"
                                                                BorderBrush="#C1DEFE"
                                                                Background="Transparent"
                                                                SnapsToDevicePixels="True"
                                                                RenderOptions.EdgeMode="Aliased"
                                                                IsHitTestVisible="False">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=StaffSearchTextBox}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>

                                                        <Border x:Name="StaffSearchFocusInner"
                                                                Panel.ZIndex="11"
                                                                Visibility="Collapsed"
                                                                Margin="{Binding Source={StaticResource UiScaleState},
                                                                                 Path=FontScale,
                                                                                 Converter={StaticResource ThicknessScaleConverter},
                                                                                 ConverterParameter='-1'}"
                                                                CornerRadius="{Binding Source={StaticResource UiScaleState},
                                                                                        Path=FontScale,
                                                                                        Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                                        ConverterParameter='8'}"
                                                                BorderThickness="1"
                                                                BorderBrush="#93C5FD"
                                                                Background="Transparent"
                                                                SnapsToDevicePixels="True"
                                                                RenderOptions.EdgeMode="Aliased"
                                                                IsHitTestVisible="False">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=StaffSearchTextBox}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>

                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                                     Path=FontScale,
                                                                                     Converter={StaticResource LayoutScaleConverter},
                                                                                     ConverterParameter=16}"
                                                                     Height="{Binding Source={StaticResource UiScaleState},
                                                                                      Path=FontScale,
                                                                                      Converter={StaticResource LayoutScaleConverter},
                                                                                      ConverterParameter=16}"
                                                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                                                      Path=FontScale,
                                                                                      Converter={StaticResource ThicknessScaleConverter},
                                                                                      ConverterParameter='10,0,6,0'}"
                                                                     VerticalAlignment="Center">
                                                                <Canvas Width="16" Height="16" SnapsToDevicePixels="True">
                                                                    <Ellipse Canvas.Left="2"
                                                                             Canvas.Top="2"
                                                                             Width="10"
                                                                             Height="10"
                                                                             Stroke="#9CA3AF"
                                                                             StrokeThickness="1.6"
                                                                             Fill="Transparent" />
                                                                    <Line X1="10.5"
                                                                          Y1="10.5"
                                                                          X2="15"
                                                                          Y2="15"
                                                                          Stroke="#9CA3AF"
                                                                          StrokeThickness="1.6"
                                                                          StrokeStartLineCap="Round"
                                                                          StrokeEndLineCap="Round" />
                                                                </Canvas>
                                                            </Viewbox>

                                                            <TextBox Grid.Column="1"
                                                                     x:Name="StaffSearchTextBox"
                                                                     Height="{Binding Source={StaticResource UiScaleState},
                                                                                      Path=FontScale,
                                                                                      Converter={StaticResource LayoutScaleConverter},
                                                                                      ConverterParameter=36}"
                                                                     TextChanged="StaffSearchTextBox_TextChanged"
                                                                     BorderThickness="0"
                                                                     Background="Transparent"
                                                                     Padding="0"
                                                                     FontSize="{Binding Source={StaticResource UiScaleState},
                                                                                        Path=FontScale,
                                                                                        Converter={StaticResource FontScaleConverter},
                                                                                        ConverterParameter=14}"
                                                                     VerticalAlignment="Center"
                                                                     Style="{StaticResource SearchWatermarkTextBox}"
                                                                     Tag="Filter by staff/role" />
                                                        </Grid>
                                                    </Grid>

                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="#CCC" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=StaffSearchTextBox}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                        </Border>

                                        <Grid x:Name="ScheduleInnerHost"
                                              Grid.Row="1"
                                              SnapsToDevicePixels="True">
                                            <Grid x:Name="ScheduleWeekLayoutRoot">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <!-- Row 0: Staff (n) + filter + day headers; row 1: body -->
                                                <Grid x:Name="ScheduleWeekHeaderGrid"
                                                      Grid.Row="0"
                                                      SnapsToDevicePixels="True"/>
                                                <ScrollViewer x:Name="ScheduleWeekBodyScrollViewer"
                                                              Grid.Row="1"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              CanContentScroll="False"
                                                              FocusVisualStyle="{x:Null}">
                                                    <Grid x:Name="ScheduleHostGrid"/>
                                                </ScrollViewer>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                        <StackPanel x:Name="FooterShiftCountsRow"
                                    Grid.Row="1"
                                    Orientation="Horizontal"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='0,8,0,0'}"/>
                        </Grid>
                        <!-- Month: vertical page scroll; day columns use an inner horizontal ScrollViewer (staff column fixed beside it). -->
                        <Grid x:Name="ScheduleMonthHostGrid"
                              Visibility="Collapsed"
                              ToolTipService.ShowDuration="60000"
                              ToolTip="Scroll vertically: mouse wheel on the schedule. Move across days: ◀ ▶ after Today, the horizontal bar under the day grid, Ctrl+wheel, Shift+wheel, or a horizontal trackpad swipe."
                              MinHeight="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource LayoutScaleConverter},
                                                  ConverterParameter=360}">
                            <Border x:Name="MonthScheduleClipBorder"
                                    Background="Transparent"
                                    ClipToBounds="True"
                                    SnapsToDevicePixels="True"
                                    PreviewMouseWheel="MonthScheduleClipBorder_PreviewMouseWheel"
                                    SizeChanged="MonthScheduleClipBorder_SizeChanged">
                                <ScrollViewer x:Name="ScheduleMonthInnerVerticalScroll"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              CanContentScroll="False"
                                              FocusVisualStyle="{x:Null}"
                                              SizeChanged="ScheduleMonthInnerVerticalScroll_SizeChanged" />
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- Summary footer -->
            <Border Grid.Row="2"
                    Background="Transparent"
                    Margin="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='0,16,0,0'}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="{StaticResource OpsStatStaffBg}"
                                BorderBrush="{StaticResource OpsStatStaffBorder}"
                                BorderThickness="1"
                                CornerRadius="{Binding ActualHeight,
                                                        RelativeSource={RelativeSource Self},
                                                        Converter={StaticResource CornerRadiusFromHeightConverter},
                                                        ConverterParameter=10}"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='14,10,14,10'}"
                                Margin="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource ThicknessScaleConverter},
                                                 ConverterParameter='0,0,10,0'}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=22}"
                                         Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=22}"
                                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"
                                         VerticalAlignment="Center">
                                    <!-- Lucide users (stroke icon); SVG paths from lucide icons -->
                                    <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                        <Path Stroke="{StaticResource Brush.PrimaryBlue}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent"
                                              Data="M 16 21 v -2 a 4 4 0 0 0 -4 -4 H 6 a 4 4 0 0 0 -4 4 v 2" />
                                        <Ellipse Canvas.Left="5"
                                                 Canvas.Top="3"
                                                 Width="8"
                                                 Height="8"
                                                 Stroke="{StaticResource Brush.PrimaryBlue}"
                                                 StrokeThickness="2"
                                                 Fill="Transparent" />
                                        <Path Stroke="{StaticResource Brush.PrimaryBlue}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent"
                                              Data="M 22 21 v -2 a 4 4 0 0 0 -3 -3.87" />
                                        <Path Stroke="{StaticResource Brush.PrimaryBlue}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent"
                                              Data="M 16 3.13 a 4 4 0 0 1 0 7.75" />
                                    </Canvas>
                                </Viewbox>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtStatStaff"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource MainForeground}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"/>
                                    <TextBlock Text="Total Staff"
                                               Foreground="{StaticResource Brush.TextMuted}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Background="{StaticResource OpsStatShiftsBg}"
                                BorderBrush="{StaticResource OpsStatShiftsBorder}"
                                BorderThickness="1"
                                CornerRadius="{Binding ActualHeight,
                                                        RelativeSource={RelativeSource Self},
                                                        Converter={StaticResource CornerRadiusFromHeightConverter},
                                                        ConverterParameter=10}"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='14,10,14,10'}"
                                Margin="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource ThicknessScaleConverter},
                                                 ConverterParameter='0,0,10,0'}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=22}"
                                         Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=22}"
                                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"
                                         VerticalAlignment="Center">
                                    <Path Data="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z"
                                          Fill="{StaticResource OpsStatShiftsIconBrush}"
                                          Stretch="Uniform" />
                                </Viewbox>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtStatShifts"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource MainForeground}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"/>
                                    <TextBlock Text="Scheduled Shifts"
                                               Foreground="{StaticResource Brush.TextMuted}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2"
                                Background="{StaticResource OpsStatHoursBg}"
                                BorderBrush="{StaticResource OpsStatHoursBorder}"
                                BorderThickness="1"
                                CornerRadius="{Binding ActualHeight,
                                                        RelativeSource={RelativeSource Self},
                                                        Converter={StaticResource CornerRadiusFromHeightConverter},
                                                        ConverterParameter=10}"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='14,10,14,10'}"
                                Margin="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource ThicknessScaleConverter},
                                                 ConverterParameter='0,0,10,0'}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=22}"
                                         Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=22}"
                                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"
                                         VerticalAlignment="Center">
                                    <Path Data="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.2 3.2.8-1.3-4.5-2.7V7z"
                                          Fill="{StaticResource OpsStatHoursIconBrush}"
                                          Stretch="Uniform" />
                                </Viewbox>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtStatHours"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource MainForeground}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"/>
                                    <TextBlock Text="Total Hours"
                                               Foreground="{StaticResource Brush.TextMuted}"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3"
                                Background="{StaticResource OpsStatExportBg}"
                                BorderBrush="{StaticResource OpsStatExportBorder}"
                                BorderThickness="1"
                                CornerRadius="{Binding ActualHeight,
                                                        RelativeSource={RelativeSource Self},
                                                        Converter={StaticResource CornerRadiusFromHeightConverter},
                                                        ConverterParameter=10}"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='14,10,14,10'}">
                            <Button Style="{StaticResource OpsExportLinkButtonStyle}"
                                    Click="BtnExport_Click"
                                    HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=22}"
                                             Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=22}"
                                             Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"
                                             VerticalAlignment="Center">
                                        <!-- Lucide download (stroke); tray + chevron + stem -->
                                        <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                            <Path Stroke="{StaticResource OpsStatExportIcon}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent"
                                                  Data="M 21 15 v 4 a 2 2 0 0 1 -2 2 H 5 a 2 2 0 0 1 -2 -2 v -4" />
                                            <Path Stroke="{StaticResource OpsStatExportIcon}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent"
                                                  Data="M 7 10 L 12 15 L 17 10" />
                                            <Line X1="12"
                                                  Y1="15"
                                                  X2="12"
                                                  Y2="3"
                                                  Stroke="{StaticResource OpsStatExportIcon}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" />
                                        </Canvas>
                                    </Viewbox>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Export Schedule"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource MainForeground}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"/>
                                        <TextBlock Text="Download or share"
                                                   Foreground="{StaticResource Brush.TextMuted}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </Border>
                </Grid>
            </Border>
        </Grid>
</UserControl>
