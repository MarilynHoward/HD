<UserControl x:Class="RestaurantPosWpf.OpsServicesShiftScheduling"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="#F3F4F6"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            SnapsToDevicePixels="True"
            FocusVisualStyle="{x:Null}"
            Padding="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter},
                             ConverterParameter='0,0,0,0'}"
            CornerRadius="{Binding ActualHeight,
                                   RelativeSource={RelativeSource Self},
                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                   ConverterParameter=12}"
            Margin="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter},
                             ConverterParameter='24,24,24,24'}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Module header -->
            <Border Grid.Row="0"
                    Background="#5D5FEF"
                    CornerRadius="10"
                    Padding="{Binding Source={StaticResource UiScaleState},
                                      Path=FontScale,
                                      Converter={StaticResource ThicknessScaleConverter},
                                      ConverterParameter='20,16,20,16'}"
                    Margin="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='0,0,0,12'}">
                <StackPanel>
                    <TextBlock Text="Operations and Services"
                               Foreground="White"
                               FontWeight="Bold"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=18}"/>
                    <TextBlock Text="Retail Point of Sale &amp; Inventory Management System"
                               Foreground="#E0E7FF"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='0,4,0,0'}"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=14}"/>
                </StackPanel>
            </Border>

            <!-- Sub-nav pills -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='0,0,0,14'}">
                <Button x:Name="PillShiftScheduling"
                        Content="Shift Scheduling"
                        Click="PillShiftScheduling_Click"
                        Style="{StaticResource VcSecondaryButtonStyle}"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='0,0,8,0'}"/>
                <Button x:Name="PillFloorPlan"
                        Content="Floor Plan Designer"
                        IsEnabled="False"
                        ToolTipService.ShowDuration="60000"
                        ToolTip="Coming soon"
                        Style="{StaticResource VcSecondaryButtonStyle}"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='0,0,8,0'}"/>
                <Button x:Name="PillTableManagement"
                        Content="Table Management"
                        Click="PillTableManagement_Click"
                        Style="{StaticResource VcSecondaryButtonStyle}"/>
            </StackPanel>

            <!-- Main scroll area -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          FocusVisualStyle="{x:Null}">
                <StackPanel>

                    <!-- Toolbar -->
                    <DockPanel Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='0,0,0,12'}"
                               LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <Button x:Name="BtnPrevRange"
                                    Content="◀"
                                    Click="BtnPrevRange_Click"
                                    Style="{StaticResource VcSecondaryButtonStyle}"
                                    MinWidth="{Binding Source={StaticResource UiScaleState},
                                                       Path=FontScale,
                                                       Converter={StaticResource LayoutScaleConverter},
                                                       ConverterParameter=36}"/>
                            <TextBlock x:Name="TxtRangeLabel"
                                       VerticalAlignment="Center"
                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                        Path=FontScale,
                                                        Converter={StaticResource ThicknessScaleConverter},
                                                        ConverterParameter='10,0,10,0'}"
                                       Foreground="#111827"
                                       FontWeight="SemiBold"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=14}"/>
                            <Button x:Name="BtnNextRange"
                                    Content="▶"
                                    Click="BtnNextRange_Click"
                                    Style="{StaticResource VcSecondaryButtonStyle}"
                                    MinWidth="{Binding Source={StaticResource UiScaleState},
                                                       Path=FontScale,
                                                       Converter={StaticResource LayoutScaleConverter},
                                                       ConverterParameter=36}"/>
                            <Button x:Name="BtnToday"
                                    Content="Today"
                                    Click="BtnToday_Click"
                                    Style="{StaticResource VcSecondaryButtonStyle}"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='10,0,0,0'}"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <ComboBox x:Name="CmbViewMode"
                                      Style="{StaticResource IcEnabledComboBoxStyle}"
                                      Width="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource LayoutScaleConverter},
                                                      ConverterParameter=140}"
                                      SelectionChanged="CmbViewMode_SelectionChanged">
                                <ComboBoxItem Content="Day View" Tag="Day"/>
                                <ComboBoxItem Content="Week View" Tag="Week"/>
                                <ComboBoxItem Content="Month View" Tag="Month"/>
                            </ComboBox>
                            <Button x:Name="BtnAddShift"
                                    Content="+ Add Shift"
                                    Click="BtnAddShift_Click"
                                    Style="{StaticResource VcPrimaryButtonStyle}"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='12,0,0,0'}"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Staff + schedule (horizontal scroll for month view) -->
                    <ScrollViewer x:Name="ScheduleHorizontalScroll"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  FocusVisualStyle="{x:Null}"
                                  MinHeight="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource LayoutScaleConverter},
                                                      ConverterParameter=320}">
                        <Grid x:Name="ScheduleHostGrid"/>
                    </ScrollViewer>

                    <!-- Per-column shift counts -->
                    <StackPanel x:Name="FooterShiftCountsRow"
                                Orientation="Horizontal"
                                Margin="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource ThicknessScaleConverter},
                                                 ConverterParameter='0,8,0,0'}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Summary footer -->
            <Border Grid.Row="3"
                    Background="Transparent"
                    Margin="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='0,16,0,0'}">
                <DockPanel LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='14,10,14,10'}"
                                Margin="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource ThicknessScaleConverter},
                                                 ConverterParameter='0,0,10,0'}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👤" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock x:Name="TxtStatStaff"
                                               FontWeight="SemiBold"
                                               Foreground="#1D4ED8"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"/>
                                    <TextBlock Text="Total Staff"
                                               Foreground="#6B7280"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Background="#ECFDF5"
                                BorderBrush="#BBF7D0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='14,10,14,10'}"
                                Margin="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource ThicknessScaleConverter},
                                                 ConverterParameter='0,0,10,0'}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📅" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock x:Name="TxtStatShifts"
                                               FontWeight="SemiBold"
                                               Foreground="#15803D"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"/>
                                    <TextBlock Text="Scheduled Shifts"
                                               Foreground="#6B7280"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Background="#FAF5FF"
                                BorderBrush="#E9D5FF"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='14,10,14,10'}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏱" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock x:Name="TxtStatHours"
                                               FontWeight="SemiBold"
                                               Foreground="#7C3AED"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"/>
                                    <TextBlock Text="Total Hours"
                                               Foreground="#6B7280"
                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <Button DockPanel.Dock="Right"
                            Content="Export Schedule"
                            Style="{StaticResource VcSecondaryButtonStyle}"
                            Click="BtnExport_Click"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
