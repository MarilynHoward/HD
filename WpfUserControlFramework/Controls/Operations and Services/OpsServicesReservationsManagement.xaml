                                                <Viewbox Grid.Column="0"
                                                         Stretch="Uniform"
                                                         Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=15}"
                                                         Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=15}"
                                                         VerticalAlignment="Center"
                                                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}">
                                                    <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                                        <Path Style="{StaticResource ReservationsCardIconPath}"
                                                              Data="M16,21 v-2 a4,4 0 0 0 -4,-4 H6 a4,4 0 0 0 -4,4 v2" />
                                                        <Ellipse Canvas.Left="5"
                                                                 Canvas.Top="3"
                                                                 Width="8"
                                                                 Height="8"
                                                                 Style="{StaticResource ReservationsCardIconEllipse}" />
                                                        <Path Style="{StaticResource ReservationsCardIconPath}"
                                                              Data="M22,21 v-2 a4,4 0 0 0 -3,-3.87" />
                                                        <Path Style="{StaticResource ReservationsCardIconPath}"
                                                              Data="M16,3.13 a4,4 0 0 1 0,7.75" />
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Reservation.PartySizeGuestsDisplay}"
                                                           Foreground="{StaticResource DimmedForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                            <!-- Phone (handset: cubic path — avoids WPF arc glitches from Lucide’s long arc chain) -->
                                            <Grid Grid.Row="1"
                                                  Grid.Column="0"
                                                  Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,14,0'}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Viewbox Grid.Column="0"
                                                         Stretch="Uniform"
                                                         Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=15}"
                                                         Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=15}"
                                                         VerticalAlignment="Center"
                                                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}">
                                                    <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                                        <Path Style="{StaticResource ReservationsCardIconPath}"
                                                              Data="M6.62,10.79 C8.06,13.62 10.38,15.93 13.21,17.38 L15.41,15.18 C15.68,14.91 16.08,14.82 16.43,14.94 C17.55,15.31 18.76,15.51 20,15.51 C20.55,15.51 21,15.96 21,16.51 L21,20 C21,20.55 20.55,21 20,21 C10.84,21 3,13.39 3,4.51 C3,3.96 3.45,3.51 4,3.51 L7.5,3.51 C8.05,3.51 8.5,3.96 8.5,4.51 C8.5,5.76 8.7,6.96 9.07,8.08 C9.18,8.43 9.1,8.82 8.82,9.1 L6.62,10.79 Z" />
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Reservation.PhoneDisplay}"
                                                           Foreground="{StaticResource DimmedForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                            <!-- Email (Lucide mail) -->
                                            <Grid Grid.Row="1"
                                                  Grid.Column="1"
                                                  Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='14,0,0,0'}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Viewbox Grid.Column="0"
                                                         Stretch="Uniform"
                                                         Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=15}"
                                                         Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=15}"
                                                         VerticalAlignment="Center"
                                                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}">
                                                    <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                                        <Rectangle Canvas.Left="2"
                                                                   Canvas.Top="4"
                                                                   Width="20"
                                                                   Height="16"
                                                                   RadiusX="2"
                                                                   RadiusY="2"
                                                                   Style="{StaticResource ReservationsCardIconRectangle}" />
                                                        <Path Style="{StaticResource ReservationsCardIconPath}"
                                                              Data="M22,7 L13.03,12.7 A1.94,1.94 0 0 1 10.97,12.7 L2,7" />
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Reservation.EmailDisplay}"
                                                           Foreground="{StaticResource DimmedForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"
                                                           TextWrapping="Wrap"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Grid>
                                        <Border Grid.Row="3"
                                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,14,0,0'}"
                                                Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,12,0,0'}"
                                                BorderBrush="#CBD5E1"
                                                BorderThickness="0,1,0,0"
                                                Visibility="{Binding Reservation.Notes, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                                            <TextBlock Foreground="{StaticResource DimmedForeground}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"
                                                       TextWrapping="Wrap">
                                                <Run Text="Notes: " FontWeight="SemiBold" />
                                                <Run Text="{Binding Reservation.Notes, Mode=OneWay}" />
                                            </TextBlock>
                                        </Border>
                                        <Border Grid.Row="4"
                                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,12,0,0'}"
                                                Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,12,12,12'}"
                                                Background="{StaticResource Brush.DangerSurfaceLight}"
                                                BorderBrush="{StaticResource Brush.DangerBorderLight}"
                                                BorderThickness="1"
                                                CornerRadius="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}"
                                                Visibility="{Binding ShowDeleteConfirm, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="Are you sure you want to delete this reservation?"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource MainForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,10,0,0'}">
                                                    <Button Content="Cancel"
                                                            Click="CancelDeleteReservation_Click"
                                                            Style="{StaticResource VcSecondaryButtonStyle}"
                                                            FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"
                                                            FocusVisualStyle="{x:Null}" />
                                                    <Button Content="Delete"
                                                            Click="ConfirmDeleteReservation_Click"
                                                            Tag="{Binding Reservation.Id}"
                                                            Style="{StaticResource DangerButton}"
                                                            FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                                            FocusVisualStyle="{x:Null}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                
                </StackPanel>
                </Border>
            </ScrollViewer>

            <Rectangle Grid.Row="5"
                       Height="1"
                       Fill="{StaticResource Brush.BorderSoft}"
                       Margin="{Binding Source={StaticResource UiScaleState},
                                        Path=FontScale,
                                        Converter={StaticResource ThicknessScaleConverter},
                                        ConverterParameter='0,12,0,12'}" />

            <Grid Grid.Row="6">
                <Button Click="AddNewReservation_Click"
                        Style="{StaticResource VcPrimaryButtonStyle}"
                        HorizontalAlignment="Stretch"
                        FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="+"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,6,0'}" />
                        <TextBlock Text="Add New Reservation"
                                   VerticalAlignment="Center"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
