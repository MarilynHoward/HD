<UserControl x:Class="RestaurantPosWpf.OpsServicesReservationsManagement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RestaurantPosWpf"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">
    <UserControl.Resources>
        <!-- Lucide-style strokes for reservation detail row icons (24×24 logical canvas). -->
        <Style x:Key="ReservationsCardIconLine" TargetType="Line">
            <Setter Property="Stroke" Value="#64748B" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeThickness">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource LayoutScaleConverter}"
                             ConverterParameter="1.75" />
                </Setter.Value>
            </Setter>
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="ReservationsCardIconPolyline" TargetType="Polyline">
            <Setter Property="Stroke" Value="#64748B" />
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="StrokeThickness">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource LayoutScaleConverter}"
                             ConverterParameter="1.75" />
                </Setter.Value>
            </Setter>
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="ReservationsCardIconEllipse" TargetType="Ellipse">
            <Setter Property="Stroke" Value="#64748B" />
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="StrokeThickness">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource LayoutScaleConverter}"
                             ConverterParameter="1.75" />
                </Setter.Value>
            </Setter>
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="ReservationsCardIconRectangle" TargetType="Rectangle">
            <Setter Property="Stroke" Value="#64748B" />
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="StrokeThickness">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource LayoutScaleConverter}"
                             ConverterParameter="1.75" />
                </Setter.Value>
            </Setter>
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="ReservationsCardIconPath" TargetType="Path">
            <Setter Property="Stroke" Value="#64748B" />
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="StrokeThickness">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource LayoutScaleConverter}"
                             ConverterParameter="1.75" />
                </Setter.Value>
            </Setter>
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>
        <Style x:Key="ReservationsCardIconPathDanger" TargetType="Path" BasedOn="{StaticResource ReservationsCardIconPath}">
            <Setter Property="Stroke" Value="{StaticResource Brush.DangerRed}" />
        </Style>
        <!-- Lucide pen / trash row actions (padding matches barcode row sample; hover + keyboard focus). -->
        <Style x:Key="ReservationCardIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"
                    Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,6,8,6'}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth"
                    Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=36}" />
            <Setter Property="MinHeight"
                    Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=36}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E7EB" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource FocusOuter}" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <!-- Same shell pattern as OpsServicesAddTable: one card, stretch to modal window, header title + ✕ (never clipped). -->
    <Border Background="White"
        BorderBrush="{StaticResource Brush.BorderSoft}"
        BorderThickness="1"
        VerticalAlignment="Center"
        HorizontalAlignment="Center"
        MaxWidth="{Binding RelativeSource={RelativeSource AncestorType=Window},
                           Path=ActualWidth}"
        MaxHeight="{Binding RelativeSource={RelativeSource AncestorType=Window},
                            Path=ActualHeight}"
        Margin="{Binding Source={StaticResource UiScaleState},
                         Path=FontScale,
                         Converter={StaticResource ThicknessScaleConverter},
                         ConverterParameter='24,24,24,24'}"
        Padding="{Binding Source={StaticResource UiScaleState},
                         Path=FontScale,
                         Converter={StaticResource ThicknessScaleConverter},
                         ConverterParameter='8,20,8,20'}">

        <!-- Do not bind CornerRadius to this Border's ActualHeight (layout feedback can hang measure). -->
        <Border.CornerRadius>
            <Binding RelativeSource="{RelativeSource Self}"
             Path="ActualHeight"
             Converter="{StaticResource CornerRadiusFromHeightConverter}"
             ConverterParameter="14" />
        </Border.CornerRadius>
        
        
        <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  MaxHeight="{Binding RelativeSource={RelativeSource AncestorType=Window},
                          Path=ActualHeight}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="0" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <!-- Icon + title on one baseline (not centered against subtitle block). -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=24}"
                                 Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=24}"
                                 VerticalAlignment="Center"
                                 Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='28,0,10,0'}">
                            <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                <Line X1="8" Y1="2" X2="8" Y2="6"
                                      Stroke="#5865F2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round">
                                    <Line.StrokeThickness>
                                        <Binding Source="{StaticResource UiScaleState}" Path="FontScale" Converter="{StaticResource LayoutScaleConverter}" ConverterParameter="2" />
                                    </Line.StrokeThickness>
                                </Line>
                                <Line X1="16" Y1="2" X2="16" Y2="6"
                                      Stroke="#5865F2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round">
                                    <Line.StrokeThickness>
                                        <Binding Source="{StaticResource UiScaleState}" Path="FontScale" Converter="{StaticResource LayoutScaleConverter}" ConverterParameter="2" />
                                    </Line.StrokeThickness>
                                </Line>
                                <Rectangle Canvas.Left="3" Canvas.Top="4" Width="18" Height="18" RadiusX="2" RadiusY="2"
                                           Stroke="#5865F2" Fill="Transparent">
                                    <Rectangle.StrokeThickness>
                                        <Binding Source="{StaticResource UiScaleState}" Path="FontScale" Converter="{StaticResource LayoutScaleConverter}" ConverterParameter="2" />
                                    </Rectangle.StrokeThickness>
                                </Rectangle>
                                <Line X1="3" Y1="10" X2="21" Y2="10"
                                      Stroke="#5865F2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round">
                                    <Line.StrokeThickness>
                                        <Binding Source="{StaticResource UiScaleState}" Path="FontScale" Converter="{StaticResource LayoutScaleConverter}" ConverterParameter="2" />
                                    </Line.StrokeThickness>
                                </Line>
                                <Path Stroke="#5865F2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Data="M 9,16 L 11,18 L 15,14">
                                    <Path.StrokeThickness>
                                        <Binding Source="{StaticResource UiScaleState}" Path="FontScale" Converter="{StaticResource LayoutScaleConverter}" ConverterParameter="2" />
                                    </Path.StrokeThickness>
                                </Path>
                            </Canvas>
                        </Viewbox>
                        <TextBlock x:Name="TxtTitle"
                                   Text="Reservations Management"
                                   Foreground="{StaticResource MainForeground}"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}" />
                    </StackPanel>
                    <TextBlock Text="View and manage table reservations."
                               Foreground="{StaticResource DimmedForeground}"
                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='28,4,0,0'}"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="TxtContextLine"
                               Foreground="{StaticResource DimmedForeground}"
                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='28,6,0,0'}"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                               TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1"
                        Click="CloseButton_Click"
                        IsCancel="True"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource DimmedForeground}"
                        Content="✕"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        FocusVisualStyle="{x:Null}"
                        Cursor="Hand"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,18,0'}"
                        FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                        MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=40}"
                        MinHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=40}" />
            </Grid>

            <Rectangle Grid.Row="1"
                           Height="1"
                           Fill="{StaticResource Brush.BorderSoft}"
                           Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,14,0,14'}" />

            <!-- Stats -->
            <UniformGrid Grid.Row="2"
                             Rows="1"
                             Columns="4"
                             Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='28,0,28,12'}">
                <Border x:Name="StatConfirmedHost"
                            Background="#F0FDF4"
                            BorderBrush="#D1FAE5"
                            BorderThickness="1"
                            CornerRadius="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=10}"
                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,10,10,10'}"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,6,0'}">
                    <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                        <TextBlock x:Name="TxtStatConfirmed"
                                       Text="0"
                                       Foreground="#0D9F4C"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}" />
                        <TextBlock Text="Confirmed"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}" />
                    </StackPanel>
                </Border>
                <Border Background="#FEFBE8"
                            BorderBrush="#FDE68A"
                            BorderThickness="1"
                            CornerRadius="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=10}"
                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,10,10,10'}"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,6,0'}">
                    <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                        <TextBlock x:Name="TxtStatPending"
                                       Text="0"
                                       Foreground="#BD8C26"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}" />
                        <TextBlock Text="Pending"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}" />
                    </StackPanel>
                </Border>
                <Border Background="#EFF6FF"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1"
                            CornerRadius="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=10}"
                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,10,10,10'}"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,6,0'}">
                    <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                        <TextBlock x:Name="TxtStatSeated"
                                       Text="0"
                                       Foreground="#195DEC"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}" />
                        <TextBlock Text="Seated"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}" />
                    </StackPanel>
                </Border>
                <Border Background="#F9FAFC"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=10}"
                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,10,10,10'}">
                    <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                        <TextBlock x:Name="TxtStatTotal"
                                       Text="0"
                                       Foreground="#4B515F"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=20}" />
                        <TextBlock Text="Total"
                                       Foreground="#64748B"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}" />
                    </StackPanel>
                </Border>
            </UniformGrid>



            <ScrollViewer x:Name="ReservationsBodyScrollViewer"
              Grid.Row="4"
              VerticalAlignment="Stretch"
              MinHeight="0"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              CanContentScroll="False"
              HorizontalContentAlignment="Stretch"
              VerticalContentAlignment="Top"
              FocusVisualStyle="{x:Null}"
              Padding="0">
                <ScrollViewer.Resources>
                    <Style TargetType="ScrollBar" BasedOn="{StaticResource ScrollBarAutoHide}" />
                </ScrollViewer.Resources>

                <Border HorizontalAlignment="Stretch">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Margin" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ComputedVerticalScrollBarVisibility, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                 Value="Visible">
                                    <Setter Property="Margin">
                                        <Setter.Value>
                                            <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource ThicknessScaleConverter}"
                                         ConverterParameter="20,0,0,0" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel HorizontalAlignment="Stretch">

                        <Border x:Name="InlineReservationEditorPanel"
    MinWidth="{Binding Source={StaticResource UiScaleState},
                       Path=FontScale,
                       Converter={StaticResource LayoutScaleConverter},
                       ConverterParameter=880}"
    Visibility="Collapsed"
    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,12'}"
    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,16,16,16'}"
    Background="#F9FAFB"
    BorderBrush="{StaticResource Brush.BorderSoft}"
    BorderThickness="1"
    CornerRadius="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=10}">
                            
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock x:Name="TxtInlineEditorTitle"
                                       Text="Edit Reservation"
                                       Foreground="{StaticResource MainForeground}"
                                       FontWeight="Bold"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}" />
                                <TextBlock x:Name="TxtInlineEditorSubtitle"
               Text="Update reservation details."
               Foreground="{StaticResource DimmedForeground}"
               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,0'}"
               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"
               TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Row="1"
            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,12,0,0'}">
                                <TextBlock Text="Customer Information"
                   Foreground="{StaticResource MainForeground}"
                   FontWeight="SemiBold"
                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,10'}" />
                                <StackPanel Orientation="Horizontal"
                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}">
                                    <TextBlock Text="Customer Name "
                       Foreground="{StaticResource DimmedForeground}"
                       VerticalAlignment="Center"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                    <TextBlock Text="*"
                       Foreground="{StaticResource Brush.DangerRed}"
                       VerticalAlignment="Center"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                </StackPanel>
                                <TextBox x:Name="TxtInlineCustomerName"
                 TextChanged="InlineEditorField_Changed"
                 Style="{StaticResource IcEnabledTextBoxStyle}"
                 Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"
                 FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                <TextBlock x:Name="TxtInlineCustomerNameError"
                   Foreground="{StaticResource Brush.DangerTextStrong}"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"
                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"
                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,8'}" />
                                <Grid Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,12'}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=12}" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}">
                                            <TextBlock Text="Phone Number "
                               Foreground="{StaticResource DimmedForeground}"
                               VerticalAlignment="Center"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                            <TextBlock Text="*"
                               Foreground="{StaticResource Brush.DangerRed}"
                               VerticalAlignment="Center"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                        </StackPanel>
                                        <TextBox x:Name="TxtInlinePhone"
                         PreviewTextInput="TxtInlinePhone_PreviewTextInput"
                         TextChanged="InlineEditorField_Changed"
                         Style="{StaticResource IcEnabledTextBoxStyle}"
                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"
                         FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                        <TextBlock x:Name="TxtInlinePhoneError"
                           Foreground="{StaticResource Brush.DangerTextStrong}"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"
                           Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,0'}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Email (Optional)"
                           Foreground="{StaticResource DimmedForeground}"
                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                           Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}" />
                                        <TextBox x:Name="TxtInlineEmail"
                         TextChanged="InlineEditorField_Changed"
                         Style="{StaticResource IcEnabledTextBoxStyle}"
                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"
                         FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" />
                                        <TextBlock x:Name="TxtInlineEmailError"
                           Foreground="{StaticResource Brush.DangerTextStrong}"
                           TextWrapping="Wrap"
                           Visibility="Collapsed"
                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"
