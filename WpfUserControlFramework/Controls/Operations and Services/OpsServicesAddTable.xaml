<UserControl x:Class="RestaurantPosWpf.OpsServicesAddTable"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource Brush.White}"
            BorderBrush="{StaticResource Brush.BorderSoft}"
            BorderThickness="1"
            SnapsToDevicePixels="True"
            Padding="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter},
                             ConverterParameter='28,20,28,20'}">
        <Border.CornerRadius>
            <Binding RelativeSource="{RelativeSource Self}"
                     Path="ActualHeight"
                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                     ConverterParameter="14"/>
        </Border.CornerRadius>

        <Grid MaxWidth="{Binding Source={StaticResource UiScaleState},
                                 Path=FontScale,
                                 Converter={StaticResource LayoutScaleConverter},
                                 ConverterParameter=520}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Add New Table"
                               Foreground="{StaticResource MainForeground}"
                               FontWeight="Bold"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=18}"/>
                    <TextBlock Text="Enter the details for the new table."
                               Foreground="{StaticResource DimmedForeground}"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='0,4,0,0'}"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=15}"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Click="CloseButton_Click"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource DimmedForeground}"
                        Content="✕"
                        Padding="0"
                        VerticalAlignment="Top"
                        Cursor="Hand"
                        FocusVisualStyle="{x:Null}"
                        FontSize="{Binding Source={StaticResource UiScaleState},
                                           Path=FontScale,
                                           Converter={StaticResource FontScaleConverter},
                                           ConverterParameter=16}"
                        ToolTip="Close"/>
            </Grid>

            <Border Grid.Row="1"
                    Height="{Binding Source={StaticResource UiScaleState},
                                    Path=FontScale,
                                    Converter={StaticResource LayoutScaleConverter},
                                    ConverterParameter=1}"
                    Background="{StaticResource Brush.BorderSoft}"
                    Margin="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='0,14,0,14'}"/>

            <ScrollViewer x:Name="FormScroll"
                          Grid.Row="2"
                          Style="{StaticResource IcPopupShellBodyScrollViewerStyle}"
                          MaxHeight="{Binding Source={StaticResource UiScaleState},
                                              Path=FontScale,
                                              Converter={StaticResource LayoutScaleConverter},
                                              ConverterParameter=480}">
                <Grid x:Name="FormFieldsGrid"
                      Margin="{Binding Source={StaticResource UiScaleState},
                                        Path=FontScale,
                                        Converter={StaticResource ThicknessScaleConverter},
                                        ConverterParameter='0,0,0,4'}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0"
                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,18'}">
                        <StackPanel Orientation="Horizontal"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}">
                            <TextBlock Text="Table Name"
                                       Foreground="{StaticResource DimmedForeground}"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                            <TextBlock Text=" *"
                                       Foreground="{StaticResource Brush.PrimaryBlue}"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                        </StackPanel>
                        <TextBox x:Name="TxtName" Style="{StaticResource IcEnabledTextBoxStyle}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1"
                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,18'}">
                        <StackPanel Orientation="Horizontal"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}">
                            <TextBlock Text="Seats"
                                       Foreground="{StaticResource DimmedForeground}"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                            <TextBlock Text=" *"
                                       Foreground="{StaticResource Brush.PrimaryBlue}"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                        </StackPanel>
                        <TextBox x:Name="TxtSeats" Style="{StaticResource IcEnabledTextBoxStyle}" Text="4"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0"
                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,18'}">
                        <TextBlock Text="Shape"
                                   Foreground="{StaticResource DimmedForeground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"/>
                        <ComboBox x:Name="CmbShape" Style="{StaticResource IcOpsServicesEnabledComboBoxStyle}"
                                  Foreground="{StaticResource MainForeground}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1"
                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,18'}">
                        <TextBlock Text="Floor"
                                   Foreground="{StaticResource DimmedForeground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"/>
                        <ComboBox x:Name="CmbFloor" Style="{StaticResource IcOpsServicesEnabledComboBoxStyle}"
                                  Foreground="{StaticResource MainForeground}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,18'}">
                        <TextBlock Text="Assigned Waiter"
                                   Foreground="{StaticResource DimmedForeground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"/>
                        <ComboBox x:Name="CmbWaiter" Style="{StaticResource IcOpsServicesEnabledComboBoxStyle}"
                                  Foreground="{StaticResource MainForeground}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0"
                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,18'}">
                        <TextBlock Text="Zone"
                                   Foreground="{StaticResource DimmedForeground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"/>
                        <TextBox x:Name="TxtZone" Style="{StaticResource IcEnabledTextBoxStyle}" Text="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="1"
                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,18'}">
                        <TextBlock Text="Station"
                                   Foreground="{StaticResource DimmedForeground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"/>
                        <TextBox x:Name="TxtStation" Style="{StaticResource IcEnabledTextBoxStyle}" Text="1"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0"
                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,18'}">
                        <TextBlock Text="Turn Time (min)"
                                   Foreground="{StaticResource DimmedForeground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"/>
                        <TextBox x:Name="TxtTurn" Style="{StaticResource IcEnabledTextBoxStyle}" Text="60"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="1"
                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,18'}">
                        <TextBlock Text="Status"
                                   Foreground="{StaticResource DimmedForeground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"/>
                        <ComboBox x:Name="CmbStatus" Style="{StaticResource IcOpsServicesEnabledComboBoxStyle}"
                                  Foreground="{StaticResource MainForeground}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,10,0,22'}">
                        <TextBlock Text="Notes"
                                   Foreground="{StaticResource DimmedForeground}"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,6'}"/>
                        <TextBox x:Name="TxtNotes" Style="{StaticResource IcEnabledTextBoxStyle}"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 VerticalScrollBarVisibility="Auto"
                                 Foreground="{StaticResource MainForeground}"
                                 MinHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=60}"
                                 MaxHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=60}"
                                 TextWrapping="Wrap"/>
                    </StackPanel>

                    <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="Options"
                               Foreground="{StaticResource MainForeground}"
                               FontWeight="SemiBold"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,18,0,12'}"/>

                    <Grid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <CheckBox x:Name="ChkActive"
                                  Grid.Row="0" Grid.Column="0"
                                  Style="{StaticResource IcFieldCheckBoxStyle}"
                                  Content="Active"
                                  Foreground="{StaticResource MainForeground}"
                                  IsChecked="True"
                                  HorizontalAlignment="Stretch"
                                  Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,12'}"/>
                        <CheckBox x:Name="ChkAccessible"
                                  Grid.Row="0" Grid.Column="1"
                                  Style="{StaticResource IcFieldCheckBoxStyle}"
                                  Content="Accessible"
                                  Foreground="{StaticResource MainForeground}"
                                  HorizontalAlignment="Stretch"
                                  Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,0,0,12'}"/>
                        <CheckBox x:Name="ChkVip"
                                  Grid.Row="1" Grid.Column="0"
                                  Style="{StaticResource IcFieldCheckBoxStyle}"
                                  Content="VIP / Priority"
                                  Foreground="{StaticResource MainForeground}"
                                  HorizontalAlignment="Stretch"
                                  Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"/>
                        <CheckBox x:Name="ChkMerge"
                                  Grid.Row="1" Grid.Column="1"
                                  Style="{StaticResource IcFieldCheckBoxStyle}"
                                  Content="Can merge"
                                  Foreground="{StaticResource MainForeground}"
                                  IsChecked="True"
                                  HorizontalAlignment="Stretch"
                                  Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,0,0,0'}"/>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <TextBlock x:Name="TxtError" Grid.Row="3" Foreground="{StaticResource Brush.DangerTextStrong}" TextWrapping="Wrap" Visibility="Collapsed"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,4'}"/>

            <Border Grid.Row="4"
                    Height="{Binding Source={StaticResource UiScaleState},
                                    Path=FontScale,
                                    Converter={StaticResource LayoutScaleConverter},
                                    ConverterParameter=1}"
                    Background="{StaticResource Brush.BorderSoft}"
                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,12'}"/>

            <StackPanel Grid.Row="5"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='0,4,0,0'}">
                <Button Content="Cancel" Click="CloseButton_Click" Style="{StaticResource VcSecondaryButtonStyle}"
                        FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"/>
                <Button Content="Add Table" Click="AddTable_Click" Style="{StaticResource VcPrimaryButtonStyle}"
                        FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
