<UserControl x:Class="RestaurantPosWpf.OpsServicesAddTable"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="White"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            Padding="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter},
                             ConverterParameter='24,16,24,20'}">
        <Border.CornerRadius>
            <Binding RelativeSource="{RelativeSource Self}"
                     Path="ActualHeight"
                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                     ConverterParameter="14"/>
        </Border.CornerRadius>

        <Grid MaxWidth="{Binding Source={StaticResource UiScaleState},
                                 Path=FontScale,
                                 Converter={StaticResource LayoutScaleConverter},
                                 ConverterParameter=640}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Add New Table"
                               Foreground="#0F172A"
                               FontWeight="Bold"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=18}"/>
                    <TextBlock Text="Enter the details for the new table."
                               Foreground="#6B7280"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='0,4,0,0'}"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=14}"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Click="CloseButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#64748B"
                        Content="✕"
                        VerticalAlignment="Top"
                        FocusVisualStyle="{x:Null}"/>
            </Grid>

            <Rectangle Grid.Row="1" Height="1" Fill="#E5E7EB"
                       Margin="{Binding Source={StaticResource UiScaleState},
                                        Path=FontScale,
                                        Converter={StaticResource ThicknessScaleConverter},
                                        ConverterParameter='0,10,0,10'}"/>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          FocusVisualStyle="{x:Null}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <TextBlock Text="Table Name *" Foreground="#374151"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"
                                   Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtName" Style="{StaticResource IcEnabledTextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,10">
                        <TextBlock Text="Seats *" Foreground="#374151" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtSeats" Style="{StaticResource IcEnabledTextBoxStyle}" Text="4"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,10">
                        <TextBlock Text="Shape" Foreground="#374151" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbShape" Style="{StaticResource IcEnabledComboBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,8,10">
                        <TextBlock Text="Floor" Foreground="#374151" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbFloor" Style="{StaticResource IcEnabledComboBoxStyle}" IsEditable="True"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,10">
                        <TextBlock Text="Assigned Waiter" Foreground="#374151" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbWaiter" Style="{StaticResource IcEnabledComboBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,8,10">
                        <TextBlock Text="Zone" Foreground="#374151" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtZone" Style="{StaticResource IcEnabledTextBoxStyle}" Text="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="8,0,0,10">
                        <TextBlock Text="Station" Foreground="#374151" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtStation" Style="{StaticResource IcEnabledTextBoxStyle}" Text="1"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,8,10">
                        <TextBlock Text="Turn Time (min)" Foreground="#374151" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtTurn" Style="{StaticResource IcEnabledTextBoxStyle}" Text="60"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,0,0,10">
                        <TextBlock Text="Status" Foreground="#374151" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CmbStatus" Style="{StaticResource IcEnabledComboBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                        <TextBlock Text="Notes" Foreground="#374151" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtNotes" Style="{StaticResource IcEnabledTextBoxStyle}" AcceptsReturn="True" MinHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="Active" VerticalAlignment="Center" Margin="0,0,12,0"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                        <ToggleButton x:Name="TogActive" IsChecked="True" Margin="0,0,24,0"/>
                        <TextBlock Text="Accessible" VerticalAlignment="Center" Margin="0,0,12,0"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                        <ToggleButton x:Name="TogAccessible" Margin="0,0,24,0"/>
                        <TextBlock Text="VIP/Priority" VerticalAlignment="Center" Margin="0,0,12,0"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                        <ToggleButton x:Name="TogVip" Margin="0,0,24,0"/>
                        <TextBlock Text="Can Merge" VerticalAlignment="Center" Margin="0,0,12,0"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                        <ToggleButton x:Name="TogMerge" IsChecked="True"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <TextBlock x:Name="TxtError" Grid.Row="3" Foreground="#B91C1C" TextWrapping="Wrap" Visibility="Collapsed"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"
                       Margin="0,8,0,4"/>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Cancel" Click="CloseButton_Click" Style="{StaticResource VcSecondaryButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="Add Table" Click="AddTable_Click" Style="{StaticResource VcPrimaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
