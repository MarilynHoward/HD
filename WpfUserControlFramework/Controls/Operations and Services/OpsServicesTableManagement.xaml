<UserControl x:Class="RestaurantPosWpf.OpsServicesTableManagement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RestaurantPosWpf"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <UserControl.Resources>
        <!-- Table list cards: elevation (shadow) reads as “standing up” vs flat rows. -->
        <DropShadowEffect x:Key="OpsTableMgmtTableRowSelectedShadow"
                          BlurRadius="12"
                          Direction="270"
                          Opacity="0.16"
                          ShadowDepth="3"
                          Color="#000000" />
        <DropShadowEffect x:Key="OpsTableMgmtTableRowHoverShadow"
                          BlurRadius="16"
                          Direction="270"
                          Opacity="0.2"
                          ShadowDepth="4"
                          Color="#000000" />

        <Style x:Key="OpsTableMgmtListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <!-- Chrome is on the card (RowBorder) so fill matches Floor Location pill; keep host transparent. -->
                        <Border x:Name="ItemChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OpsTableMgmtListBoxStyle" TargetType="ListBox">
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource OpsTableMgmtListBoxItemStyle}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding"
                    Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='4,4,4,4'}" />
        </Style>

        <!-- String Content on detail buttons: avoids stretched AccessText so labels stay visually centered. -->
        <DataTemplate x:Key="OpsTableMgmtDetailButtonStringContentTemplate">
            <TextBlock Text="{Binding}"
                       TextAlignment="Center"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center" />
        </DataTemplate>

        <Style x:Key="OpsTableMgmtDetailPrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource VcPrimaryButtonStyle}">
            <Setter Property="Margin" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Height">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource LayoutScaleConverter}"
                             ConverterParameter="28" />
                </Setter.Value>
            </Setter>
            <Setter Property="Padding">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource ThicknessScaleConverter}"
                             ConverterParameter="10,4,10,4" />
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Primary + plain text Content only (composite Content must use OpsTableMgmtDetailPrimaryButtonStyle without this template). -->
        <Style x:Key="OpsTableMgmtDetailPrimaryTextButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource OpsTableMgmtDetailPrimaryButtonStyle}">
            <Setter Property="ContentTemplate" Value="{StaticResource OpsTableMgmtDetailButtonStringContentTemplate}" />
        </Style>
        <Style x:Key="OpsTableMgmtDetailSecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource VcSecondaryButtonStyle}">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="ContentTemplate" Value="{StaticResource OpsTableMgmtDetailButtonStringContentTemplate}" />
            <Setter Property="Height">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource LayoutScaleConverter}"
                             ConverterParameter="28" />
                </Setter.Value>
            </Setter>
            <Setter Property="Padding">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource ThicknessScaleConverter}"
                             ConverterParameter="12,4,12,4" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- VcSecondaryButtonStyle fixes Height; strip row needs auto height to match Active Status border. -->
        <Style x:Key="OpsTableMgmtHistoryStripButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource VcSecondaryButtonStyle}">
            <Setter Property="Height" Value="{x:Static sys:Double.NaN}" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Padding">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource ThicknessScaleConverter}"
                             ConverterParameter="10,8,10,8" />
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource Brush.White}"
          SnapsToDevicePixels="True"
          FocusVisualStyle="{x:Null}"
          Margin="{Binding Source={StaticResource UiScaleState},
                           Path=FontScale,
                           Converter={StaticResource ThicknessScaleConverter},
                           ConverterParameter='24,24,24,24'}">
        <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,14'}">
                <Button x:Name="PillShift"
                        Click="PillShift_Click"
                        Style="{StaticResource OpsSubNavPillButtonStyle}"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=20}"
                                 Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=20}"
                                 VerticalAlignment="Center">
                            <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M8,2 L8,6" />
                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M16,2 L16,6" />
                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M5,4 L19,4 A2,2 0 0 1 21,6 L21,20 A2,2 0 0 1 19,22 L5,22 A2,2 0 0 1 3,20 L3,6 A2,2 0 0 1 5,4 Z" />
                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M3,10 L21,10" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Shift Scheduling"
                                   VerticalAlignment="Center"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,0'}" />
                    </StackPanel>
                </Button>
                <Button x:Name="PillFloor"
                        IsEnabled="False"
                        ToolTipService.ShowDuration="60000"
                        ToolTip="Coming soon"
                        Style="{StaticResource OpsSubNavPillButtonStyle}"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=20}"
                                 Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=20}"
                                 VerticalAlignment="Center">
                            <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M4,3 L9,3 A1,1 0 0 1 10,4 L10,9 A1,1 0 0 1 9,10 L4,10 A1,1 0 0 1 3,9 L3,4 A1,1 0 0 1 4,3 Z" />
                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M15,3 L20,3 A1,1 0 0 1 21,4 L21,9 A1,1 0 0 1 20,10 L15,10 A1,1 0 0 1 14,9 L14,4 A1,1 0 0 1 15,3 Z" />
                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M15,14 L20,14 A1,1 0 0 1 21,15 L21,20 A1,1 0 0 1 20,21 L15,21 A1,1 0 0 1 14,20 L14,15 A1,1 0 0 1 15,14 Z" />
                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M4,14 L9,14 A1,1 0 0 1 10,15 L10,20 A1,1 0 0 1 9,21 L4,21 A1,1 0 0 1 3,20 L3,15 A1,1 0 0 1 4,14 Z" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Floor Plan Designer"
                                   VerticalAlignment="Center"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,0'}" />
                    </StackPanel>
                </Button>
                <Button x:Name="PillTable"
                        Style="{StaticResource OpsSubNavPillButtonStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=20}"
                                 Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=20}"
                                 VerticalAlignment="Center">
                            <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M3,2 L3,9 C3,10.1045695 3.8954305,11 5,11 L9,11 A2,2 0 0 0 11,9 L11,2" />
                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M7,2 L7,22" />
                                <Path Style="{StaticResource OpsLucideNavIconPathStyle}" Data="M21,15 L21,2 A5,5 0 0 0 16,7 L16,13 C16,14.1045695 16.8954305,15 18,15 L21,15 Z M21,15 L21,22" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Table Management"
                                   VerticalAlignment="Center"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,0'}" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <ScrollViewer x:Name="TableMgmtBodyScroll"
                          Grid.Row="1"
                          Margin="0,0,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False"
                          FocusVisualStyle="{x:Null}">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch">
                    <!-- MinHeight synced to page ScrollViewer viewport in code-behind so outer scroll works -->
                    <Grid x:Name="TopWorkspaceGrid"
                          MinHeight="320"
                          HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=320}" MinWidth="260"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar: search + floor filter (full width, aligned) + list + overview -->
                <Border Grid.Column="0"
                        VerticalAlignment="Stretch"
                        Background="{StaticResource Brush.White}"
                        BorderBrush="{StaticResource Brush.BorderSoft}"
                        BorderThickness="1"
                        CornerRadius="{Binding ActualHeight,
                                                RelativeSource={RelativeSource Self},
                                                Converter={StaticResource CornerRadiusFromHeightConverter},
                                                ConverterParameter=10}"
                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,12,12,12'}">
                    <DockPanel LastChildFill="True">

                        <!-- Search + floor filter stack -->
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <!-- Search tables (matches ProcurementPOrders) -->
                            <Border x:Name="TableSearchHostBorder"
                                    PreviewMouseLeftButtonDown="TableSearchHostBorder_PreviewMouseLeftButtonDown"
                                    Background="White"
                                    BorderBrush="#CCC"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False"
                                    Margin="0,0,0,8"
                                    BorderThickness="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource LayoutScaleConverter},
                                                              ConverterParameter=1}">

                                <Border.CornerRadius>
                                    <Binding RelativeSource="{RelativeSource Self}"
                                             Path="ActualHeight"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="8" />
                                </Border.CornerRadius>

                                <Grid>

                                    <Border Panel.ZIndex="10"
                                            Visibility="Collapsed"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='-3'}"
                                            CornerRadius="{Binding Source={StaticResource UiScaleState},
                                                                    Path=FontScale,
                                                                    Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                    ConverterParameter='9'}"
                                            BorderThickness="3"
                                            BorderBrush="#C1DEFE"
                                            Background="Transparent"
                                            SnapsToDevicePixels="True"
                                            RenderOptions.EdgeMode="Aliased"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=TxtSearch}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <Border Panel.ZIndex="11"
                                            Visibility="Collapsed"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='-1'}"
                                            CornerRadius="{Binding Source={StaticResource UiScaleState},
                                                                    Path=FontScale,
                                                                    Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                    ConverterParameter='8'}"
                                            BorderThickness="1"
                                            BorderBrush="#93C5FD"
                                            Background="Transparent"
                                            SnapsToDevicePixels="True"
                                            RenderOptions.EdgeMode="Aliased"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=TxtSearch}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource LayoutScaleConverter},
                                                 ConverterParameter=16}"
                                                 Height="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource LayoutScaleConverter},
                                                  ConverterParameter=16}"
                                                 Margin="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='10,0,6,0'}"
                                                 VerticalAlignment="Center">
                                            <Canvas Width="16" Height="16" SnapsToDevicePixels="True">
                                                <Ellipse Canvas.Left="2"
                                                         Canvas.Top="2"
                                                         Width="10"
                                                         Height="10"
                                                         Stroke="#9CA3AF"
                                                         StrokeThickness="1.6"
                                                         Fill="Transparent" />
                                                <Line X1="10.5"
                                                      Y1="10.5"
                                                      X2="15"
                                                      Y2="15"
                                                      Stroke="#9CA3AF"
                                                      StrokeThickness="1.6"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round" />
                                            </Canvas>
                                        </Viewbox>

                                        <TextBox x:Name="TxtSearch"
                                                 Grid.Column="1"
                                                 Height="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=40}"
                                                 TextChanged="TxtSearch_TextChanged"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Padding="0"
                                                 FontSize="{Binding Source={StaticResource UiScaleState},
                                                                    Path=FontScale,
                                                                    Converter={StaticResource FontScaleConverter},
                                                                    ConverterParameter=14}"
                                                 VerticalAlignment="Center"
                                                 Style="{StaticResource SearchWatermarkTextBox}"
                                                 Tag="Search tables..." />
                                    </Grid>
                                </Grid>

                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="#CCC" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=TxtSearch}" Value="True">
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <!-- Floor filter: full-width chrome + focus rings (same pattern as search) -->
                            <Border x:Name="FloorFilterHostBorder"
                                    PreviewMouseLeftButtonDown="FloorFilterHostBorder_PreviewMouseLeftButtonDown"
                                    Background="{StaticResource Brush.White}"
                                    BorderBrush="{StaticResource Brush.BorderGrey}"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False"
                                    BorderThickness="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource LayoutScaleConverter},
                                                              ConverterParameter=1}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderGrey}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=CmbFloorFilter}" Value="True">
                                                <Setter Property="BorderBrush" Value="Transparent" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.CornerRadius>
                                    <Binding RelativeSource="{RelativeSource Self}"
                                             Path="ActualHeight"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="8" />
                                </Border.CornerRadius>
                                <Grid>
                                    <Border Panel.ZIndex="10"
                                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='-3'}"
                                            BorderThickness="3"
                                            BorderBrush="{StaticResource FocusOuter}"
                                            Background="Transparent"
                                            SnapsToDevicePixels="True"
                                            RenderOptions.EdgeMode="Aliased"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=CmbFloorFilter}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.CornerRadius>
                                            <Binding RelativeSource="{RelativeSource Self}"
                                                     Path="ActualHeight"
                                                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                     ConverterParameter="9" />
                                        </Border.CornerRadius>
                                    </Border>
                                    <Border Panel.ZIndex="11"
                                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='-1'}"
                                            BorderThickness="1"
                                            BorderBrush="{StaticResource FocusInner}"
                                            Background="Transparent"
                                            SnapsToDevicePixels="True"
                                            RenderOptions.EdgeMode="Aliased"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin, ElementName=CmbFloorFilter}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.CornerRadius>
                                            <Binding RelativeSource="{RelativeSource Self}"
                                                     Path="ActualHeight"
                                                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                     ConverterParameter="8" />
                                        </Border.CornerRadius>
                                    </Border>
                                    <Grid Panel.ZIndex="1"
                                          MinHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=42}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Viewbox Grid.Column="0"
                                                 Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=18}"
                                                 Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=18}"
                                                 Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,0,6,0'}"
                                                 VerticalAlignment="Center">
                                            <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                                <Path Fill="Transparent"
                                                      Stroke="{StaticResource DimmedForeground}"
                                                      StrokeThickness="2"
                                                      StrokeLineJoin="Round"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Data="M22,3 L2,3 L10,12.46 L10,19 L14,21 L14,12.46 Z" />
                                            </Canvas>
                                        </Viewbox>
                                        <ComboBox x:Name="CmbFloorFilter"
                                                  Grid.Column="1"
                                                  Style="{StaticResource IcOpsServicesComboBoxHostChromeOnlyStyle}"
                                                  VerticalAlignment="Stretch"
                                                  Margin="0,4,8,4"
                                                  BorderThickness="0"
                                                  Background="Transparent"
                                                  Foreground="{StaticResource MainForeground}"
                                                  FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                  FocusVisualStyle="{x:Null}"
                                                  SelectionChanged="CmbFloorFilter_SelectionChanged"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Overview stats -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                            <TextBlock Text="Overview"
                                       Foreground="{StaticResource MainForeground}"
                                       FontWeight="SemiBold"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,6'}"/>
                            <UniformGrid Columns="2" Margin="0,0,0,6">
                                <Border Background="#F1F5FE"
                                        BorderBrush="{StaticResource Brush.BorderSoft}"
                                        BorderThickness="1"
                                        CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}"
                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,10,10,10'}"
                                        Margin="0,0,4,4">
                                    <StackPanel>
                                        <TextBlock x:Name="StatTotal"
                                                   FontWeight="SemiBold"
                                                   Foreground="#6465D9"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
                                        <TextBlock Text="Total Tables"
                                                   Foreground="#636363"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#F0FDF4"
                                        BorderBrush="{StaticResource Brush.BorderSoft}"
                                        BorderThickness="1"
                                        CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}"
                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,10,10,10'}"
                                        Margin="4,0,0,4">
                                    <StackPanel>
                                        <TextBlock x:Name="StatActive"
                                                   FontWeight="SemiBold"
                                                   Foreground="#319E5D"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
                                        <TextBlock Text="Active"
                                                   Foreground="#636363"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <UniformGrid Columns="2">
                                <Border Background="#FBF5FF"
                                        BorderBrush="{StaticResource Brush.BorderSoft}"
                                        BorderThickness="1"
                                        CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}"
                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,10,10,10'}"
                                        Margin="0,0,4,0">
                                    <StackPanel>
                                        <TextBlock x:Name="StatSeats"
                                                   FontWeight="SemiBold"
                                                   Foreground="#9F54CB"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
                                        <TextBlock Text="Total Seats"
                                                   Foreground="#636363"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FEFBEA"
                                        BorderBrush="{StaticResource Brush.BorderSoft}"
                                        BorderThickness="1"
                                        CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}"
                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,10,10,10'}"
                                        Margin="4,0,0,0">
                                    <StackPanel>
                                        <TextBlock x:Name="StatAssigned"
                                                   FontWeight="SemiBold"
                                                   Foreground="#C47D2F"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
                                        <TextBlock Text="Assigned"
                                                   Foreground="#636363"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>

                        <!-- ~6 compact cards visible; inner scroll when more tables (client list pattern) -->
                        <ListBox x:Name="TablesListBox"
                                 Style="{StaticResource OpsTableMgmtListBoxStyle}"
                                 SelectionChanged="TablesListBox_SelectionChanged"
                                 PreviewMouseWheel="TablesListBox_PreviewMouseWheel"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 MaxHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=360}">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:OpsFloorTable}">
                                    <Border x:Name="RowBorder"
                                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='6,5,6,5'}"
                                            BorderThickness="1"
                                            SnapsToDevicePixels="True"
                                            Margin="0,0,0,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource Brush.White}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSoft}" />
                                                <Setter Property="Effect" Value="{x:Null}" />
                                                <Style.Triggers>
                                                    <!-- Same pill treatment as Floor Location (DetFloorPillBorder): #EFF6FF / #93C5FD; shadow keeps card “standing up”. -->
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#EFF6FF" />
                                                        <Setter Property="BorderBrush" Value="#93C5FD" />
                                                        <Setter Property="Effect" Value="{StaticResource OpsTableMgmtTableRowSelectedShadow}" />
                                                    </DataTrigger>
                                                    <!-- Hover only when not selected (selected row unchanged on hover except same elevation). -->
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True" />
                                                            <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{StaticResource Brush.SurfaceGreySoft}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource Brush.SurfaceGrey}" />
                                                        <Setter Property="Effect" Value="{StaticResource OpsTableMgmtTableRowHoverShadow}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.CornerRadius>
                                            <Binding Path="ActualHeight"
                                                     RelativeSource="{RelativeSource Self}"
                                                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                     ConverterParameter="8" />
                                        </Border.CornerRadius>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource MainForeground}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,56,2"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                            <Border x:Name="InactiveBadge"
                                                    Grid.Row="0"
                                                    Panel.ZIndex="1"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='5,1,5,1'}"
                                                    Background="{StaticResource Brush.SurfaceGreySoft}"
                                                    BorderBrush="{StaticResource Brush.BorderSoft}"
                                                    BorderThickness="1"
                                                    Visibility="Collapsed"
                                                    CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=6}">
                                                <TextBlock Text="Inactive"
                                                           Foreground="{StaticResource DimmedForeground}"
                                                           FontWeight="SemiBold"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=10}"/>
                                            </Border>
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding LocationName}"
                                                       Foreground="{StaticResource DimmedForeground}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"
                                                       Margin="0,0,0,2"/>
                                            <DockPanel Grid.Row="2" LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Left"
                                                           Text="{Binding AssignedWaiterDisplay}"
                                                           Foreground="{StaticResource DimmedForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Border DockPanel.Dock="Right"
                                                        Background="{StaticResource Brush.SurfaceGreySoft}"
                                                        BorderBrush="{StaticResource Brush.BorderSoft}"
                                                        BorderThickness="1"
                                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='6,2,6,2'}"
                                                        VerticalAlignment="Center"
                                                        CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=6}">
                                                    <TextBlock FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"
                                                               Foreground="{StaticResource MainForeground}">
                                                        <Run Text="{Binding SeatCount, Mode=OneWay}"/><Run Text=" seats"/>
                                                    </TextBlock>
                                                </Border>
                                            </DockPanel>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                            <Setter TargetName="InactiveBadge" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="RowBorder" Property="Opacity" Value="0.88" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Table details (scroll inside column; wheel bubbles to page when at ends) -->
                <ScrollViewer x:Name="DetailsScrollViewer"
                                  Grid.Column="2"
                                  VerticalAlignment="Stretch"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="False"
                                  FocusVisualStyle="{x:Null}"
                                  PreviewMouseWheel="DetailsScrollViewer_PreviewMouseWheel">
                        <!-- Table details card -->
                        <Border Background="{StaticResource Brush.White}"
                                BorderBrush="{StaticResource Brush.BorderSoft}"
                                BorderThickness="1"
                                Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='16,14,16,16'}"
                                Margin="0,0,0,0"
                                SnapsToDevicePixels="True"
                                CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=10}">
                            <StackPanel>
                                <DockPanel LastChildFill="False" Margin="0,0,0,0">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="Table Details"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource MainForeground}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}"/>
                                        <TextBlock Text="View and manage table settings."
                                                   Foreground="{StaticResource DimmedForeground}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}"/>
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button x:Name="BtnAddFloor"
                                                Click="BtnAddFloor_Click"
                                                Style="{StaticResource OpsTableMgmtDetailPrimaryButtonStyle}"
                                                Margin="0,0,8,0"
                                                FocusVisualStyle="{x:Null}">
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=18}"
                                                         Height="{Binding Source={StaticResource UiScaleState},
                                                                   Path=FontScale,
                                                                   Converter={StaticResource LayoutScaleConverter},
                                                                   ConverterParameter=18}"
                                                         Margin="{Binding Source={StaticResource UiScaleState},
                                                                   Path=FontScale,
                                                                   Converter={StaticResource ThicknessScaleConverter},
                                                                   ConverterParameter='0,0,6,0'}"
                                                         VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24" SnapsToDevicePixels="True">
                                                        <Path Style="{StaticResource OpsLucideNavIconPathStyle}"
                                                              Data="M12.83 2.18a2 2 0 0 0 -1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58 -3.9a1 1 0 0 0 0 -1.83z" />
                                                        <Path Style="{StaticResource OpsLucideNavIconPathStyle}"
                                                              Data="M2 12a1 1 0 0 0 .58 .91l8.6 3.91a2 2 0 0 0 1.65 0l8.58 -3.9A1 1 0 0 0 22 12" />
                                                        <Path Style="{StaticResource OpsLucideNavIconPathStyle}"
                                                              Data="M2 17a1 1 0 0 0 .58 .91l8.6 3.91a2 2 0 0 0 1.65 0l8.58 -3.9A1 1 0 0 0 22 17" />
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Text="Add Floor"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="BtnAddTable"
                                                Click="BtnAddTable_Click"
                                                Style="{StaticResource OpsTableMgmtDetailPrimaryButtonStyle}"
                                                Margin="0,0,8,0"
                                                FocusVisualStyle="{x:Null}">
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="+"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}"/>
                                                <TextBlock Text=" Add Table"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="BtnEdit"
                                                Content="Edit"
                                                Click="BtnEdit_Click"
                                                Style="{StaticResource OpsTableMgmtDetailSecondaryButtonStyle}"
                                                FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                                Margin="0,0,8,0"
                                                FocusVisualStyle="{x:Null}"/>
                                        <Button x:Name="BtnSave"
                                                Content="Save"
                                                Click="BtnSave_Click"
                                                Style="{StaticResource OpsTableMgmtDetailPrimaryTextButtonStyle}"
                                                FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                                Margin="0,0,8,0"
                                                Visibility="Collapsed"
                                                FocusVisualStyle="{x:Null}"/>
                                        <Button x:Name="BtnCancelEdit"
                                                Content="Cancel"
                                                Click="BtnCancelEdit_Click"
                                                Style="{StaticResource OpsTableMgmtDetailSecondaryButtonStyle}"
                                                FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                                Margin="0,0,8,0"
                                                Visibility="Collapsed"
                                                FocusVisualStyle="{x:Null}"/>
                                        <Button x:Name="BtnDelete"
                                                Content="Delete"
                                                Click="BtnDelete_Click"
                                                Style="{StaticResource OpsTableMgmtDetailSecondaryButtonStyle}"
                                                FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                                Foreground="{StaticResource Brush.DangerRed}"
                                                BorderBrush="{StaticResource Brush.DangerButtonBorderSoft}"
                                                FocusVisualStyle="{x:Null}"/>
                                    </StackPanel>
                                </DockPanel>

                                <Border x:Name="DeleteTableBlockedByShiftsPanel"
                                        Visibility="Collapsed"
                                        Background="{StaticResource Brush.SurfaceGreySoft}"
                                        BorderBrush="{StaticResource Brush.BorderSoft}"
                                        BorderThickness="1"
                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}"
                                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,12,0,0'}"
                                        HorizontalAlignment="Stretch"
                                        SnapsToDevicePixels="True">
                                    <Border.CornerRadius>
                                        <Binding Path="ActualHeight"
                                                 RelativeSource="{RelativeSource Self}"
                                                 Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                 ConverterParameter="8"/>
                                    </Border.CornerRadius>
                                    <StackPanel>
                                        <TextBlock x:Name="TxtDeleteTableBlockedTitle"
                                                   Foreground="{StaticResource MainForeground}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,8'}"/>
                                        <TextBlock Text="You can keep it in the list but unavailable by editing the table and turning Active Status off."
                                                   Foreground="{StaticResource DimmedForeground}"
                                                   TextWrapping="Wrap"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,10'}"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Dismiss"
                                                    Click="BtnDismissDeleteBlockedByShifts_Click"
                                                    Style="{StaticResource OpsTableMgmtDetailSecondaryButtonStyle}"
                                                    FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                                                    FocusVisualStyle="{x:Null}"/>
                                            <Button Content="Edit table"
                                                    Click="BtnEditTableFromDeleteBlocked_Click"
                                                    Style="{StaticResource OpsTableMgmtDetailPrimaryTextButtonStyle}"
                                                    FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                                    FocusVisualStyle="{x:Null}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="DeleteTableConfirmPanel"
                                        Visibility="Collapsed"
                                        Background="{StaticResource Brush.SurfaceGreySoft}"
                                        BorderBrush="{StaticResource Brush.BorderSoft}"
                                        BorderThickness="1"
                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}"
                                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,12,0,0'}"
                                        HorizontalAlignment="Stretch"
                                        SnapsToDevicePixels="True">
                                    <Border.CornerRadius>
                                        <Binding Path="ActualHeight"
                                                 RelativeSource="{RelativeSource Self}"
                                                 Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                 ConverterParameter="8"/>
                                    </Border.CornerRadius>
                                    <StackPanel>
                                        <TextBlock x:Name="TxtDeleteTableConfirmMessage"
                                                   Foreground="{StaticResource MainForeground}"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,8'}"/>
                                        <TextBlock Text="This action cannot be undone."
                                                   Foreground="{StaticResource DimmedForeground}"
                                                   TextWrapping="Wrap"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,10'}"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Cancel"
                                                    Click="BtnCancelDeleteTableConfirm_Click"
                                                    Style="{StaticResource OpsTableMgmtDetailSecondaryButtonStyle}"
                                                    FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                                                    FocusVisualStyle="{x:Null}"/>
                                            <Button Content="Delete table"
                                                    Click="BtnConfirmDeleteTable_Click"
                                                    Style="{StaticResource OpsTableMgmtDetailSecondaryButtonStyle}"
                                                    FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                                    Foreground="{StaticResource Brush.DangerRed}"
                                                    BorderBrush="{StaticResource Brush.DangerButtonBorderSoft}"
                                                    FocusVisualStyle="{x:Null}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=1}"
                                        Background="{StaticResource Brush.BorderSoft}"
                                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,12,0,12'}"
                                        HorizontalAlignment="Stretch"
                                        SnapsToDevicePixels="True"/>

                                <TextBlock x:Name="TxtNoSelection"
                                           Text="Select a table from the list."
                                           Foreground="{StaticResource DimmedForeground}"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                           Margin="0,0,0,0"/>

                                <StackPanel x:Name="DetailPanel" Visibility="Collapsed">
                                    <!-- Row 0: two form columns. Row 1: Active Status | View History in one grid row (matched height; no * rows inside StackPanel). -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Table Name"
                                                       Foreground="{StaticResource DimmedForeground}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                       Margin="0,0,0,4"/>
                                            <TextBox x:Name="DetName"
                                                     Style="{StaticResource IcEnabledTextBoxStyle}"
                                                     IsReadOnly="True"
                                                     FontWeight="SemiBold"
                                                     FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
                                            <TextBlock Text="Number of Seats"
                                                       Foreground="{StaticResource DimmedForeground}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                       Margin="0,12,0,4"/>
                                            <Grid MinHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=36}">
                                                <TextBlock x:Name="DetSeatsReadOnly"
                                                           VerticalAlignment="Center"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource Brush.PrimaryBlue}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
                                                <TextBox x:Name="DetSeats"
                                                         Style="{StaticResource IcEnabledTextBoxStyle}"
                                                         Visibility="Collapsed"
                                                         VerticalAlignment="Center"
                                                         FontWeight="SemiBold"
                                                         Foreground="{StaticResource Brush.PrimaryBlue}"
                                                         FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                                            </Grid>
                                            <TextBlock Text="Table Shape"
                                                       Foreground="{StaticResource DimmedForeground}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                       Margin="0,12,0,4"/>
                                            <Grid MinHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=36}">
                                                <Border x:Name="DetShapePillBorder"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Background="{StaticResource Brush.White}"
                                                        BorderBrush="{StaticResource Brush.BorderSoft}"
                                                        BorderThickness="1"
                                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,6,10,6'}"
                                                        SnapsToDevicePixels="True"
                                                        CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}">
                                                    <TextBlock x:Name="DetShapePillText"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource MainForeground}"
                                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                                                </Border>
                                                <ComboBox x:Name="DetShape"
                                                          Style="{StaticResource IcOpsServicesEnabledComboBoxStyle}"
                                                          Visibility="Collapsed"
                                                          VerticalAlignment="Center"
                                                          Foreground="{StaticResource MainForeground}"
                                                          IsEnabled="False"
                                                          FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                                            </Grid>
                                            <TextBlock x:Name="TxtActiveStatusSectionLabel"
                                                       Text="Active Status"
                                                       Foreground="{StaticResource DimmedForeground}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,12,0,10'}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1">
                                            <TextBlock Text="Floor Location"
                                                       Foreground="{StaticResource DimmedForeground}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                       Margin="0,0,0,4"/>
                                            <Grid MinHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=36}">
                                                <Border x:Name="DetFloorPillBorder"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Background="#EFF6FF"
                                                        BorderBrush="#93C5FD"
                                                        BorderThickness="1"
                                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,6,10,6'}"
                                                        SnapsToDevicePixels="True"
                                                        CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}">
                                                    <TextBlock x:Name="DetFloorPillText"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource Brush.PrimaryBlue}"
                                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                                                </Border>
                                                <ComboBox x:Name="DetFloor"
                                                          Style="{StaticResource IcOpsServicesEnabledComboBoxStyle}"
                                                          Visibility="Collapsed"
                                                          VerticalAlignment="Center"
                                                          Foreground="{StaticResource MainForeground}"
                                                          IsEnabled="False"
                                                          FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                                            </Grid>
                                            <TextBlock Text="Assigned Waiter"
                                                       Foreground="{StaticResource DimmedForeground}"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                       Margin="0,12,0,4"/>
                                            <Grid MinHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=36}">
                                                <TextBlock x:Name="DetWaiterReadOnly"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource MainForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                                                <ComboBox x:Name="DetWaiter"
                                                          Style="{StaticResource IcOpsServicesEnabledComboBoxStyle}"
                                                          Visibility="Collapsed"
                                                          VerticalAlignment="Center"
                                                          IsEnabled="False"
                                                          Foreground="{StaticResource MainForeground}"
                                                          FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                                            </Grid>
                                            <TextBlock Text="Additional Information"
                                                       Foreground="{StaticResource DimmedForeground}"
                                                       FontWeight="SemiBold"
                                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                       Margin="0,12,0,8"/>
                                            <Grid Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,10'}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="Table ID"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource DimmedForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                           Margin="0,0,12,6"/>
                                                <TextBlock x:Name="DetId"
                                                           Grid.Row="0" Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Stretch"
                                                           TextAlignment="Right"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource MainForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                           Margin="0,0,0,6"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0"
                                                           Text="Created"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource DimmedForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                           Margin="0,0,12,6"/>
                                                <TextBlock x:Name="DetCreated"
                                                           Grid.Row="1" Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Stretch"
                                                           TextAlignment="Right"
                                                           Foreground="{StaticResource MainForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                           Margin="0,0,0,6"/>
                                                <TextBlock Grid.Row="2" Grid.Column="0"
                                                           Text="Last Modified"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource DimmedForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                           Margin="0,0,12,0"/>
                                                <TextBlock x:Name="DetModified"
                                                           Grid.Row="2" Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Stretch"
                                                           TextAlignment="Right"
                                                           Foreground="{StaticResource MainForeground}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                                            </Grid>
                                        </StackPanel>
                                        <Border Grid.Row="1"
                                                Grid.Column="0"
                                                Margin="0,0,12,0"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                Background="{StaticResource Brush.SurfaceGreySoft}"
                                                BorderBrush="{StaticResource Brush.BorderSoft}"
                                                BorderThickness="1"
                                                Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,8,10,8'}"
                                                CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}">
                                            <Grid>
                                                <DockPanel x:Name="DetActiveReadOnlyRow" LastChildFill="False">
                                                    <TextBlock x:Name="TxtDetActiveCaption"
                                                               DockPanel.Dock="Left"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource MainForeground}"
                                                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                                                    <Border x:Name="DetActivePillBorder"
                                                            DockPanel.Dock="Right"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Background="#DCFCE7"
                                                            BorderBrush="#86EFAC"
                                                            BorderThickness="1"
                                                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,4,8,4'}"
                                                            SnapsToDevicePixels="True"
                                                            CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=6}">
                                                        <TextBlock x:Name="DetActivePillText"
                                                                   FontWeight="Bold"
                                                                   Foreground="{StaticResource Brush.SuccessGreen}"
                                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                                    </Border>
                                                </DockPanel>
                                                <Grid x:Name="DetActiveEditPanel"
                                                      Visibility="Collapsed">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0"
                                                                VerticalAlignment="Center"
                                                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}">
                                                        <TextBlock Text="Active Status"
                                                                   Foreground="{StaticResource MainForeground}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
                                                        <TextBlock Text="Toggle table availability"
                                                                   Foreground="{StaticResource DimmedForeground}"
                                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,0'}"/>
                                                    </StackPanel>
                                                    <ToggleButton x:Name="DetActive"
                                                                  Grid.Column="1"
                                                                  Style="{StaticResource IcPillSwitchToggleStyle}"
                                                                  VerticalAlignment="Center"
                                                                  IsEnabled="False"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <Button x:Name="BtnHistory"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Content="View History"
                                                Click="BtnHistory_Click"
                                                Style="{StaticResource OpsTableMgmtHistoryStripButtonStyle}"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                FocusVisualStyle="{x:Null}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>
</UserControl>
