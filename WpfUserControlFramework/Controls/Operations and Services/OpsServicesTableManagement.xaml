<UserControl x:Class="RestaurantPosWpf.OpsServicesTableManagement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RestaurantPosWpf">

    <Border Background="#F3F4F6"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            CornerRadius="{Binding ActualHeight,
                                   RelativeSource={RelativeSource Self},
                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                   ConverterParameter=12}"
            Margin="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter},
                             ConverterParameter='24,24,24,24'}"
            Padding="0"
            FocusVisualStyle="{x:Null}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#5D5FEF" CornerRadius="10"
                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='20,16,20,16'}"
                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,12'}">
                <StackPanel>
                    <TextBlock Text="Operations and Services" Foreground="White" FontWeight="Bold"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}"/>
                    <TextBlock Text="Retail Point of Sale &amp; Inventory Management System" Foreground="#E0E7FF"
                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,4,0,0'}"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,14'}">
                <Button x:Name="PillShift" Content="Shift Scheduling" Click="PillShift_Click" Style="{StaticResource VcSecondaryButtonStyle}" Margin="0,0,8,0"/>
                <Button x:Name="PillFloor" Content="Floor Plan Designer" IsEnabled="False" ToolTip="Coming soon" Style="{StaticResource VcSecondaryButtonStyle}" Margin="0,0,8,0"/>
                <Button x:Name="PillTable" Content="Table Management" Style="{StaticResource VcSecondaryButtonStyle}"/>
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=300}" MinWidth="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Margin="0,0,12,0" Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,12,12,12'}">
                    <DockPanel LastChildFill="True">
                        <TextBox x:Name="TxtSearch" DockPanel.Dock="Top" Style="{StaticResource IcEnabledTextBoxStyle}"
                                 Margin="0,0,0,8" TextChanged="TxtSearch_TextChanged"/>
                        <ComboBox x:Name="CmbFloorFilter" DockPanel.Dock="Top" Style="{StaticResource IcEnabledComboBoxStyle}"
                                  Margin="0,0,0,10" SelectionChanged="CmbFloorFilter_SelectionChanged"/>
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                            <UniformGrid Columns="2" Margin="0,0,0,6">
                                <Border Background="#EFF6FF" CornerRadius="6" Padding="8" Margin="0,0,4,4">
                                    <StackPanel>
                                        <TextBlock x:Name="StatTotal" FontWeight="Bold" Foreground="#2563EB" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"/>
                                        <TextBlock Text="Total Tables" Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#ECFDF5" CornerRadius="6" Padding="8" Margin="4,0,0,4">
                                    <StackPanel>
                                        <TextBlock x:Name="StatActive" FontWeight="Bold" Foreground="#15803D" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"/>
                                        <TextBlock Text="Active" Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <UniformGrid Columns="2">
                                <Border Background="#FAF5FF" CornerRadius="6" Padding="8" Margin="0,0,4,0">
                                    <StackPanel>
                                        <TextBlock x:Name="StatSeats" FontWeight="Bold" Foreground="#7C3AED" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"/>
                                        <TextBlock Text="Total Seats" Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#FEF9C3" CornerRadius="6" Padding="8" Margin="4,0,0,0">
                                    <StackPanel>
                                        <TextBlock x:Name="StatAssigned" FontWeight="Bold" Foreground="#A16207" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"/>
                                        <TextBlock Text="Assigned" Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=11}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                        <ListBox x:Name="TablesListBox" BorderThickness="0" SelectionChanged="TablesListBox_SelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:OpsFloorTable}">
                                    <Border x:Name="RowBorder" Padding="10,8" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Margin="0,0,0,6">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                                            <TextBlock Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}">
                                                <Run Text="{Binding LocationName, Mode=OneWay}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding SeatCount, Mode=OneWay}"/><Run Text=" seats"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                            <Setter TargetName="RowBorder" Property="Opacity" Value="0.65"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Detail -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" FocusVisualStyle="{x:Null}">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,12">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Table Details" FontWeight="Bold" Foreground="#111827"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}"/>
                                <TextBlock Text="View and manage table settings" Foreground="#6B7280"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button x:Name="BtnAddTable" Content="+ Add Table" Click="BtnAddTable_Click" Style="{StaticResource VcPrimaryButtonStyle}" Margin="0,0,8,0"/>
                                <Button x:Name="BtnEdit" Content="Edit" Click="BtnEdit_Click" Style="{StaticResource VcSecondaryButtonStyle}" Margin="0,0,8,0"/>
                                <Button x:Name="BtnSave" Content="Save" Click="BtnSave_Click" Style="{StaticResource VcPrimaryButtonStyle}" Margin="0,0,8,0" Visibility="Collapsed"/>
                                <Button x:Name="BtnCancelEdit" Content="Cancel" Click="BtnCancelEdit_Click" Style="{StaticResource VcSecondaryButtonStyle}" Margin="0,0,8,0" Visibility="Collapsed"/>
                                <Button x:Name="BtnDelete" Content="Delete" Click="BtnDelete_Click" Style="{StaticResource VcSecondaryButtonStyle}" Foreground="#B91C1C" BorderBrush="#FCA5A5"/>
                            </StackPanel>
                        </DockPanel>

                        <TextBlock x:Name="TxtNoSelection" Text="Select a table from the list." Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}" Margin="0,24,0,0"/>

                        <StackPanel x:Name="DetailPanel" Visibility="Collapsed">
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Table Name" Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="DetName" Style="{StaticResource IcEnabledTextBoxStyle}" IsReadOnly="True"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Floor Location" Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="DetFloor" Style="{StaticResource IcEnabledComboBoxStyle}" IsEditable="True" IsEnabled="False"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Number of Seats" Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                                    <TextBox x:Name="DetSeats" Style="{StaticResource IcEnabledTextBoxStyle}" IsReadOnly="True"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Table Shape" Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="DetShape" Style="{StaticResource IcEnabledComboBoxStyle}" IsEnabled="False"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Assigned Waiter" Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="DetWaiter" Style="{StaticResource IcEnabledComboBoxStyle}" IsEnabled="False"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Active" Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}" Margin="0,0,0,4"/>
                                    <ToggleButton x:Name="DetActive" IsEnabled="False" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Grid>
                            <DockPanel LastChildFill="False" Margin="0,0,0,16">
                                <StackPanel DockPanel.Dock="Right">
                                    <TextBlock Text="Table ID" Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"/>
                                    <TextBlock x:Name="DetId" FontWeight="SemiBold" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                    <TextBlock Text="Created" Foreground="#6B7280" Margin="0,8,0,0" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"/>
                                    <TextBlock x:Name="DetCreated" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                    <TextBlock Text="Last Modified" Foreground="#6B7280" Margin="0,8,0,0" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"/>
                                    <TextBlock x:Name="DetModified" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                </StackPanel>
                            </DockPanel>

                            <UniformGrid Columns="3" Margin="0,0,0,20">
                                <Button Content="Export Details" Style="{StaticResource VcSecondaryButtonStyle}" Margin="0,0,6,0" Click="BtnExport_Click"/>
                                <Button Content="View History" Style="{StaticResource VcSecondaryButtonStyle}" Margin="6,0,6,0" Click="BtnHistory_Click"/>
                                <Button Content="Duplicate" Style="{StaticResource VcSecondaryButtonStyle}" Margin="6,0,0,0" Click="BtnDuplicate_Click"/>
                            </UniformGrid>

                            <TextBlock Text="Table Operations" FontWeight="SemiBold" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}" Margin="0,0,0,8"/>
                            <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                <TextBlock Text="Current status" DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#6B7280" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                <Border DockPanel.Dock="Right" Background="#FEE2E2" CornerRadius="8" Padding="8,4">
                                    <TextBlock x:Name="DetOpsStatus" FontWeight="SemiBold" Foreground="#991B1B" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                </Border>
                            </DockPanel>
                            <Border x:Name="OverdueBanner" Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12" Visibility="Collapsed">
                                <DockPanel LastChildFill="False">
                                    <TextBlock x:Name="TxtOverdue" TextWrapping="Wrap" DockPanel.Dock="Left" Foreground="#991B1B" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                    <Button Content="Clear Table" DockPanel.Dock="Right" Style="{StaticResource VcSecondaryButtonStyle}" Click="BtnClearTable_Click"/>
                                </DockPanel>
                            </Border>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="Merge Tables" Style="{StaticResource VcSecondaryButtonStyle}" Margin="0,0,8,0" Click="BtnMerge_Click"/>
                                <Button Content="Split Tables" Style="{StaticResource VcSecondaryButtonStyle}" Margin="0,0,8,0" Click="BtnSplit_Click"/>
                            </StackPanel>
                            <DockPanel Margin="0,0,0,12">
                                <TextBlock x:Name="TxtServerName" DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                                <Button Content="Transfer" DockPanel.Dock="Right" Style="{StaticResource VcSecondaryButtonStyle}" Click="BtnTransfer_Click"/>
                            </DockPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Accessible" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                <ToggleButton x:Name="DetAccessible" IsEnabled="False" Margin="0,0,24,0"/>
                                <TextBlock Text="Priority / VIP" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"/>
                                <ToggleButton x:Name="DetVip" IsEnabled="False"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</UserControl>
