<UserControl x:Class="RestaurantPosWpf.OpsServicesManageFloors"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="OpsManageFloorsScrollCompensationHostStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ComputedVerticalScrollBarVisibility,
                                               RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                             Value="Visible">
                    <Setter Property="Margin">
                        <Setter.Value>
                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource ThicknessScaleConverter}"
                                     ConverterParameter="16,0,0,0" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="White"
            BorderBrush="{StaticResource Brush.BorderSoft}"
            BorderThickness="1"
            SnapsToDevicePixels="True"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="{Binding Source={StaticResource UiScaleState},
                            Path=FontScale,
                            Converter={StaticResource LayoutScaleConverter},
                            ConverterParameter=900}"
            MaxHeight="{Binding RelativeSource={RelativeSource AncestorType=ContentControl},
                                Path=ActualHeight}"
            Padding="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter},
                             ConverterParameter='28,16,28,16'}">
        <Border.CornerRadius>
            <Binding RelativeSource="{RelativeSource Self}"
                     Path="ActualHeight"
                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                     ConverterParameter="14"/>
        </Border.CornerRadius>

        <DockPanel LastChildFill="True">

            <Grid DockPanel.Dock="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Manage Floor Locations"
                               Foreground="{StaticResource MainForeground}"
                               FontWeight="Bold"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=18}"/>
                    <TextBlock Text="View floor locations, table counts, add or rename locations, and remove empty ones."
                               Foreground="{StaticResource DimmedForeground}"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='0,4,0,0'}"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=15}"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Click="CloseButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource DimmedForeground}"
                        Content="✕"
                        VerticalAlignment="Top"
                        FocusVisualStyle="{x:Null}"
                        FontSize="{Binding Source={StaticResource UiScaleState},
                                           Path=FontScale,
                                           Converter={StaticResource FontScaleConverter},
                                           ConverterParameter=16}"/>
            </Grid>

            <Rectangle DockPanel.Dock="Top"
                       Height="1"
                       Fill="{StaticResource Brush.BorderSoft}"
                       Margin="{Binding Source={StaticResource UiScaleState},
                                        Path=FontScale,
                                        Converter={StaticResource ThicknessScaleConverter},
                                        ConverterParameter='0,12,0,14'}"/>

            <StackPanel DockPanel.Dock="Top"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,12'}">
                <TextBlock Text="Add Floor Location"
                           Foreground="{StaticResource MainForeground}"
                           FontWeight="Normal"
                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"
                           Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,8'}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtNewFloor"
                             Grid.Column="0"
                             Style="{StaticResource IcEnabledTextBoxStyle}"
                             Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                             FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                    <Button x:Name="BtnAddFloor"
                             Grid.Column="1"
                                    Click="AddFloorInner_Click"
                                    Style="{StaticResource VcPrimaryButtonStyle}"
                                    Height="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource LayoutScaleConverter},
                                                      ConverterParameter=30}"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='12,0,16,0'}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="+"
                                               VerticalAlignment="Center"
                                                Padding="{Binding Source={StaticResource UiScaleState},
                                                                   Path=FontScale,
                                                                   Converter={StaticResource ThicknessScaleConverter},
                                                                   ConverterParameter='2,4,1,6'}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource FontScaleConverter},
                                                                  ConverterParameter=18}"/>
                            <TextBlock Text=" Add"
                                               VerticalAlignment="Center"
                                                Padding="{Binding Source={StaticResource UiScaleState},
                                                                   Path=FontScale,
                                                                   Converter={StaticResource ThicknessScaleConverter},
                                                                   ConverterParameter='2,4,1,5'}"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource FontScaleConverter},
                                                                  ConverterParameter=16}"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <TextBlock DockPanel.Dock="Top"
                       Text="Floor Locations"
                       Foreground="{StaticResource MainForeground}"
                       FontWeight="SemiBold"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,8'}"/>

            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,4'}">
                <Button Content="Close"
                        Click="CloseButton_Click"
                        Style="{StaticResource VcSecondaryButtonStyle}"
                        FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                        FocusVisualStyle="{x:Null}"/>
            </StackPanel>

            <Rectangle DockPanel.Dock="Bottom"
                       Height="1"
                       Fill="{StaticResource Brush.BorderSoft}"
                       Margin="{Binding Source={StaticResource UiScaleState},
                                        Path=FontScale,
                                        Converter={StaticResource ThicknessScaleConverter},
                                        ConverterParameter='0,12,0,12'}"/>

            <TextBlock x:Name="TxtError"
                       DockPanel.Dock="Bottom"
                       Foreground="{StaticResource Brush.DangerTextStrong}"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"
                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,4'}"/>

            <Grid DockPanel.Dock="Bottom">
                <Border x:Name="DeleteConfirmPanel"
                        Visibility="Collapsed"
                        Background="{StaticResource Brush.SurfaceGreySoft}"
                        BorderBrush="{StaticResource Brush.BorderSoft}"
                        BorderThickness="1"
                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,12,0,0'}">
                    <Border.CornerRadius>
                        <Binding Path="ActualHeight"
                                 RelativeSource="{RelativeSource Self}"
                                 Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                 ConverterParameter="8"/>
                    </Border.CornerRadius>
                    <StackPanel>
                        <TextBlock x:Name="TxtDeleteConfirm"
                                   Foreground="{StaticResource MainForeground}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,8'}"/>
                        <TextBlock Text="Only floors with no tables can be removed."
                                   Foreground="{StaticResource DimmedForeground}"
                                   TextWrapping="Wrap"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,10'}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Cancel"
                                    Click="CancelDeleteConfirm_Click"
                                    Style="{StaticResource VcSecondaryButtonStyle}"
                                    FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                                    FocusVisualStyle="{x:Null}"/>
                            <Button Content="Delete floor"
                                    Click="ConfirmDeleteFloor_Click"
                                    Style="{StaticResource VcSecondaryButtonStyle}"
                                    FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                    Foreground="{StaticResource Brush.DangerRed}"
                                    BorderBrush="{StaticResource Brush.DangerButtonBorderSoft}"
                                    FocusVisualStyle="{x:Null}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border x:Name="RenamePanel"
                        Visibility="Collapsed"
                        Background="{StaticResource Brush.SurfaceGreySoft}"
                        BorderBrush="{StaticResource Brush.BorderSoft}"
                        BorderThickness="1"
                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}"
                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,12,0,0'}">
                    <Border.CornerRadius>
                        <Binding Path="ActualHeight"
                                 RelativeSource="{RelativeSource Self}"
                                 Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                 ConverterParameter="8"/>
                    </Border.CornerRadius>
                    <StackPanel>
                        <TextBlock x:Name="TxtRenameTitle"
                                   Foreground="{StaticResource MainForeground}"
                                   FontWeight="SemiBold"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,8'}"/>
                        <TextBox x:Name="TxtRename"
                                 Style="{StaticResource IcEnabledTextBoxStyle}"
                                 FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,10,0,0'}">
                            <Button Content="Cancel"
                                    Click="CancelRename_Click"
                                    Style="{StaticResource VcSecondaryButtonStyle}"
                                    FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                                    FocusVisualStyle="{x:Null}"/>
                            <Button Content="Save name"
                                    Click="ApplyRename_Click"
                                    Style="{StaticResource VcPrimaryButtonStyle}"
                                    FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                    FocusVisualStyle="{x:Null}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          FocusVisualStyle="{x:Null}">
                <Grid Style="{StaticResource OpsManageFloorsScrollCompensationHostStyle}">
                    <ItemsControl x:Name="FloorsList"
                                  Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,8'}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource Brush.White}"
                                        BorderBrush="{StaticResource Brush.BorderSoft}"
                                        BorderThickness="1"
                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,8,10,8'}"
                                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,10'}"
                                        SnapsToDevicePixels="True">
                                    <Border.CornerRadius>
                                        <Binding Path="ActualHeight"
                                                 RelativeSource="{RelativeSource Self}"
                                                 Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                 ConverterParameter="8"/>
                                    </Border.CornerRadius>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontWeight="Normal"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource MainForeground}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,0,12,0'}"
                                                   Foreground="{StaticResource DimmedForeground}"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=13}">
                                            <Run Text="{Binding TableCount, Mode=OneWay}"/><Run Text=" tables"/>
                                        </TextBlock>
                                        <Button Grid.Column="2"
                                                Content="Edit"
                                                Tag="{Binding Name}"
                                                Height="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=30}"
                                                Padding="{Binding Source={StaticResource UiScaleState},
                                                                   Path=FontScale,
                                                                   Converter={StaticResource ThicknessScaleConverter},
                                                                   ConverterParameter='18,4,18,6'}"
                                                Click="EditFloorRow_Click"
                                                Style="{StaticResource VcSecondaryButtonStyle}"
                                                FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,6,0'}"
                                                FocusVisualStyle="{x:Null}"/>
                                        <Button Grid.Column="3"
                                                Content="Delete"
                                                Height="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=30}"
                                                Padding="{Binding Source={StaticResource UiScaleState},
                                                                   Path=FontScale,
                                                                   Converter={StaticResource ThicknessScaleConverter},
                                                                   ConverterParameter='18,4,18,6'}"
                                                Tag="{Binding Name}"
                                                Click="DeleteFloorRow_Click"
                                                IsEnabled="{Binding CanDelete}"
                                                Style="{StaticResource VcSecondaryButtonStyle}"
                                                FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                Foreground="{StaticResource Brush.DangerRed}"
                                                BorderBrush="{StaticResource Brush.DangerButtonBorderSoft}"
                                                FocusVisualStyle="{x:Null}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

        </DockPanel>
    </Border>
</UserControl>