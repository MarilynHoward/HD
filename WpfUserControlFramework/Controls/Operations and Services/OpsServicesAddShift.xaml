<UserControl x:Class="RestaurantPosWpf.OpsServicesAddShift"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="White"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            Padding="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter},
                             ConverterParameter='24,16,24,20'}">
        <Border.CornerRadius>
            <Binding RelativeSource="{RelativeSource Self}"
                     Path="ActualHeight"
                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                     ConverterParameter="14"/>
        </Border.CornerRadius>

        <Grid MaxWidth="{Binding Source={StaticResource UiScaleState},
                                 Path=FontScale,
                                 Converter={StaticResource LayoutScaleConverter},
                                 ConverterParameter=720}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0"
                  Margin="{Binding Source={StaticResource UiScaleState},
                                   Path=FontScale,
                                   Converter={StaticResource ThicknessScaleConverter},
                                   ConverterParameter='0,0,0,6'}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Add New Shift"
                               Foreground="#0F172A"
                               FontWeight="Bold"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=18}"/>
                    <TextBlock Text="Schedule a staff member for daily, weekly, or monthly shifts with table assignments"
                               Foreground="#6B7280"
                               TextWrapping="Wrap"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='0,4,0,0'}"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=14}"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Click="CloseButton_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#64748B"
                        Padding="6"
                        Content="✕"
                        VerticalAlignment="Top"
                        FocusVisualStyle="{x:Null}"/>
            </Grid>

            <Rectangle Grid.Row="1"
                       Height="1"
                       Fill="#E5E7EB"
                       Margin="{Binding Source={StaticResource UiScaleState},
                                        Path=FontScale,
                                        Converter={StaticResource ThicknessScaleConverter},
                                        ConverterParameter='0,0,0,10'}"/>

            <!-- Form -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          FocusVisualStyle="{x:Null}">
                <StackPanel>

                    <!-- Frequency pills -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource ThicknessScaleConverter},
                                                 ConverterParameter='0,0,0,14'}">
                        <Button x:Name="BtnFreqDaily"
                                Content="Daily"
                                Click="BtnFreqDaily_Click"
                                Style="{StaticResource VcSecondaryButtonStyle}"
                                Margin="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource ThicknessScaleConverter},
                                                 ConverterParameter='0,0,6,0'}"/>
                        <Button x:Name="BtnFreqWeekly"
                                Content="Weekly"
                                Click="BtnFreqWeekly_Click"
                                Style="{StaticResource VcSecondaryButtonStyle}"
                                Margin="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource ThicknessScaleConverter},
                                                 ConverterParameter='0,0,6,0'}"/>
                        <Button x:Name="BtnFreqMonthly"
                                Content="Monthly"
                                Click="BtnFreqMonthly_Click"
                                Style="{StaticResource VcSecondaryButtonStyle}"/>
                    </StackPanel>

                    <!-- Employee -->
                    <TextBlock Text="Employee *"
                               Foreground="#374151"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=14}"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='0,0,0,6'}"/>
                    <ComboBox x:Name="CmbEmployee"
                              Style="{StaticResource IcEnabledComboBoxStyle}"
                              Margin="{Binding Source={StaticResource UiScaleState},
                                               Path=FontScale,
                                               Converter={StaticResource ThicknessScaleConverter},
                                               ConverterParameter='0,0,0,14'}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}">
                                    <Run Text="{Binding Name, Mode=OneWay}"/>
                                    <Run Text=" (" Foreground="#6B7280"/>
                                    <Run Text="{Binding Role, Mode=OneWay}" Foreground="#6B7280"/>
                                    <Run Text=")" Foreground="#6B7280"/>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Daily -->
                    <StackPanel x:Name="PanelDaily" Visibility="Collapsed">
                        <TextBlock Text="Select Date *"
                                   Foreground="#374151"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=14}"
                                   Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='0,0,0,6'}"/>
                        <Calendar x:Name="CalDaily"
                                  SelectionMode="SingleDate"
                                  SelectedDatesChanged="CalDaily_OnSelectedDatesChanged"
                                  Margin="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource ThicknessScaleConverter},
                                                   ConverterParameter='0,0,0,6'}"/>
                        <TextBlock x:Name="TxtDailySelected"
                                   Foreground="#6B7280"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=13}"
                                   Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='0,0,0,14'}"/>
                    </StackPanel>

                    <!-- Weekly -->
                    <StackPanel x:Name="PanelWeekly" Visibility="Collapsed">
                        <TextBlock Text="Select Days of Week *"
                                   Foreground="#374151"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=14}"
                                   Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='0,0,0,6'}"/>
                        <UniformGrid Columns="7"
                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource ThicknessScaleConverter},
                                                      ConverterParameter='0,0,0,6'}">
                            <ToggleButton x:Name="TogMon" Content="Mon" Click="DayToggle_Click" Margin="2"/>
                            <ToggleButton x:Name="TogTue" Content="Tue" Click="DayToggle_Click" Margin="2"/>
                            <ToggleButton x:Name="TogWed" Content="Wed" Click="DayToggle_Click" Margin="2"/>
                            <ToggleButton x:Name="TogThu" Content="Thu" Click="DayToggle_Click" Margin="2"/>
                            <ToggleButton x:Name="TogFri" Content="Fri" Click="DayToggle_Click" Margin="2"/>
                            <ToggleButton x:Name="TogSat" Content="Sat" Click="DayToggle_Click" Margin="2"/>
                            <ToggleButton x:Name="TogSun" Content="Sun" Click="DayToggle_Click" Margin="2"/>
                        </UniformGrid>
                        <TextBlock x:Name="TxtWeeklyDaysSummary"
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=13}"
                                   Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='0,0,0,8'}"/>
                        <TextBlock x:Name="TxtWeeklyRange"
                                   Foreground="#2563EB"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=13}"
                                   TextWrapping="Wrap"
                                   Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='0,0,0,10'}"/>
                        <Border Background="#EFF6FF"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='12,10,12,10'}"
                                Margin="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource ThicknessScaleConverter},
                                                 ConverterParameter='0,0,0,14'}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↻" FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}" Margin="0,0,8,0" Foreground="#2563EB"/>
                                <TextBlock TextWrapping="Wrap"
                                           Foreground="#1E40AF"
                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource FontScaleConverter},
                                                              ConverterParameter=13}"
                                           Text="Weekly recurring schedule — this shift will repeat every week on the selected days for the date range shown above."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Monthly -->
                    <StackPanel x:Name="PanelMonthly" Visibility="Collapsed">
                        <TextBlock Text="Select Dates for the Month *"
                                   Foreground="#374151"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=14}"
                                   Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='0,0,0,4'}"/>
                        <TextBlock Text="Click multiple dates to create shifts for each selected day"
                                   Foreground="#6B7280"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=12}"
                                   Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='0,0,0,6'}"/>
                        <Calendar x:Name="CalMonthly"
                                  SelectionMode="MultipleRange"
                                  SelectedDatesChanged="CalMonthly_OnSelectedDatesChanged"
                                  Margin="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource ThicknessScaleConverter},
                                                   ConverterParameter='0,0,0,8'}"/>
                        <WrapPanel x:Name="MonthlyChipsPanel"
                                   Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='0,0,0,14'}"/>
                    </StackPanel>

                    <!-- Times -->
                    <Grid Margin="{Binding Source={StaticResource UiScaleState},
                                           Path=FontScale,
                                           Converter={StaticResource ThicknessScaleConverter},
                                           ConverterParameter='0,0,0,14'}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Start Time *"
                                       Foreground="#374151"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=14}"
                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                        Path=FontScale,
                                                        Converter={StaticResource ThicknessScaleConverter},
                                                        ConverterParameter='0,0,0,6'}"/>
                            <TextBox x:Name="TxtStartTime"
                                     Style="{StaticResource IcEnabledTextBoxStyle}"
                                     Text="09:00"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="End Time *"
                                       Foreground="#374151"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=14}"
                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                        Path=FontScale,
                                                        Converter={StaticResource ThicknessScaleConverter},
                                                        ConverterParameter='0,0,0,6'}"/>
                            <TextBox x:Name="TxtEndTime"
                                     Style="{StaticResource IcEnabledTextBoxStyle}"
                                     Text="17:00"/>
                        </StackPanel>
                    </Grid>

                    <!-- Table assignment -->
                    <DockPanel LastChildFill="True"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='0,0,0,6'}">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Table Assignment *"
                                   Foreground="#374151"
                                   FontWeight="SemiBold"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=16}"/>
                        <Border DockPanel.Dock="Right"
                                Background="#F3F4F6"
                                CornerRadius="10"
                                Padding="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='8,4,8,4'}"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0">
                            <TextBlock x:Name="TxtTableCount"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=12}"
                                       Foreground="#374151"/>
                        </Border>
                    </DockPanel>
                    <TextBlock x:Name="TxtTableSubtitle"
                               Foreground="#6B7280"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=13}"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='0,0,0,8'}"/>

                    <Border BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            MaxHeight="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource LayoutScaleConverter},
                                                ConverterParameter=220}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      FocusVisualStyle="{x:Null}">
                            <StackPanel x:Name="TablePickHost"
                                        Margin="{Binding Source={StaticResource UiScaleState},
                                                         Path=FontScale,
                                                         Converter={StaticResource ThicknessScaleConverter},
                                                         ConverterParameter='10,10,10,10'}"/>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <TextBlock x:Name="TxtFormError"
                       Grid.Row="3"
                       Foreground="#B91C1C"
                       TextWrapping="Wrap"
                       Visibility="Collapsed"
                       FontSize="{Binding Source={StaticResource UiScaleState},
                                          Path=FontScale,
                                          Converter={StaticResource FontScaleConverter},
                                          ConverterParameter=13}"
                       Margin="{Binding Source={StaticResource UiScaleState},
                                        Path=FontScale,
                                        Converter={StaticResource ThicknessScaleConverter},
                                        ConverterParameter='0,8,0,4'}"/>

            <Rectangle Grid.Row="4"
                       Height="1"
                       Fill="#E5E7EB"
                       Margin="{Binding Source={StaticResource UiScaleState},
                                        Path=FontScale,
                                        Converter={StaticResource ThicknessScaleConverter},
                                        ConverterParameter='0,0,0,8'}"/>

            <!-- Footer -->
            <StackPanel Grid.Row="5"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='0,12,0,0'}">
                <Button Content="Cancel"
                        Click="CloseButton_Click"
                        Style="{StaticResource VcSecondaryButtonStyle}"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='0,0,10,0'}"/>
                <Button Content="+ Add Shift"
                        Click="AddShift_Click"
                        Style="{StaticResource VcPrimaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
