<UserControl x:Class="RestaurantPosWpf.DocumentRepositoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RestaurantPosWpf">

    <UserControl.Resources>
        <local:FileSizeConverter x:Key="FileSizeConverter" />

        <!-- Summary card border colors -->
        <SolidColorBrush x:Key="TotalCardBorderBrush" Color="#93C5FD" />
        <SolidColorBrush x:Key="TotalCardBgBrush" Color="#EFF6FF" />
        <SolidColorBrush x:Key="TotalCardIconBrush" Color="#3B82F6" />
        <SolidColorBrush x:Key="TotalCardTextBrush" Color="#1E40AF" />

        <SolidColorBrush x:Key="ComplianceCardBorderBrush" Color="#86EFAC" />
        <SolidColorBrush x:Key="ComplianceCardBgBrush" Color="#F0FDF4" />
        <SolidColorBrush x:Key="ComplianceCardIconBrush" Color="#22C55E" />
        <SolidColorBrush x:Key="ComplianceCardTextBrush" Color="#166534" />

        <SolidColorBrush x:Key="LegalCardBorderBrush" Color="#C4B5FD" />
        <SolidColorBrush x:Key="LegalCardBgBrush" Color="#FAF5FF" />
        <SolidColorBrush x:Key="LegalCardIconBrush" Color="#8B5CF6" />
        <SolidColorBrush x:Key="LegalCardTextBrush" Color="#5B21B6" />

        <SolidColorBrush x:Key="BankingCardBorderBrush" Color="#FDE68A" />
        <SolidColorBrush x:Key="BankingCardBgBrush" Color="#FFFBEB" />
        <SolidColorBrush x:Key="BankingCardIconBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="BankingCardTextBrush" Color="#92400E" />

        <!-- Document row icon -->
        <SolidColorBrush x:Key="DocIconBrush" Color="#3B82F6" />
        <SolidColorBrush x:Key="DocIconBgBrush" Color="#EFF6FF" />

        <!-- Lucide icon geometries (24x24 viewbox, stroke-based) -->
        <!-- file-text: document with lines -->
        <Geometry x:Key="FileTextIcon">M15 2 L6 2 C4.9 2 4 2.9 4 4 L4 20 C4 21.1 4.9 22 6 22 L18 22 C19.1 22 20 21.1 20 20 L20 7 Z M14 2 L14 6 C14 7.1 14.9 8 16 8 L20 8 M10 9 L8 9 M16 13 L8 13 M16 17 L8 17</Geometry>
        <!-- circle-check-big: checkmark in circle -->
        <Geometry x:Key="CircleCheckIcon">M21.801 10 A10 10 0 1 1 17 3.335 M9 11 L12 14 L22 4</Geometry>
        <!-- shield -->
        <Geometry x:Key="ShieldIcon">M20 13 C20 18 16.5 20.5 12.34 21.95 C12.12 22.03 11.88 22.03 11.67 21.94 C7.5 20.5 4 18 4 13 L4 6 C4 5.45 4.45 5 5 5 C7 5 9.5 3.8 11.24 2.28 C11.63 1.94 12.37 1.94 12.76 2.28 C14.51 3.81 17 5 19 5 C19.55 5 20 5.45 20 6 Z</Geometry>
        <!-- building -->
        <Geometry x:Key="BuildingIcon">M4 2 L20 2 C21.1 2 22 2.9 22 4 L22 22 L2 22 L2 4 C2 2.9 2.9 2 4 2 Z M9 22 L9 18 L15 18 L15 22 M8 6 L8.01 6 M16 6 L16.01 6 M12 6 L12.01 6 M12 10 L12.01 10 M12 14 L12.01 14 M16 10 L16.01 10 M16 14 L16.01 14 M8 10 L8.01 10 M8 14 L8.01 14</Geometry>

        <!-- Document card hover style -->
        <SolidColorBrush x:Key="DocCardDefaultBorder" Color="#E5E7EB" />
        <SolidColorBrush x:Key="DocCardHoverBorder" Color="#2563EB" />
        <SolidColorBrush x:Key="DocCardHoverBg" Color="#F8FAFF" />

        <Style x:Key="DocumentCardBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource DocCardDefaultBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource DocCardHoverBorder}" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="Background" Value="{StaticResource DocCardHoverBg}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- Content Root Border pattern -->
    <Border BorderBrush="#E5E7EB"
            BorderThickness="1"
            Background="#F8FAFC"
            SnapsToDevicePixels="True"
            ClipToBounds="True"
            FocusVisualStyle="{x:Null}"
            Padding="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter},
                             ConverterParameter='28,24,28,24'}"
            CornerRadius="{Binding ActualHeight,
                                   RelativeSource={RelativeSource Self},
                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                   ConverterParameter=12}"
            Margin="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource ThicknessScaleConverter},
                             ConverterParameter='0'}"
            >

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header row: Title/subtitle + Upload button -->
            <DockPanel Grid.Row="0"
                       Margin="{Binding Source={StaticResource UiScaleState},
                                        Path=FontScale,
                                        Converter={StaticResource ThicknessScaleConverter},
                                        ConverterParameter='0,0,0,20'}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Document Repository"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource MainForeground}"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=22}" />
                    <TextBlock Text="Certificates, contracts, and compliance documents"
                               Foreground="{StaticResource DimmedForeground}"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='0,2,0,0'}"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=13}" />
                </StackPanel>
                <Button Style="{StaticResource VcPrimaryButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="UploadButton_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                 Path=FontScale,
                                                 Converter={StaticResource LayoutScaleConverter},
                                                 ConverterParameter=16}"
                                 Height="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource LayoutScaleConverter},
                                                  ConverterParameter=16}"
                                 Margin="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource ThicknessScaleConverter},
                                                  ConverterParameter='0,0,6,0'}">
                            <Canvas Width="24" Height="24">
                                <Path Data="M21,15 L21,19 C21,20.1046 20.1046,21 19,21 L5,21 C3.8954,21 3,20.1046 3,19 L3,15"
                                      Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                <Path Data="M17,8 L12,3 L7,8"
                                      Stroke="White" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                <Line X1="12" Y1="3" X2="12" Y2="15"
                                      Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Upload Document" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </DockPanel>

            <!-- Summary cards with left colored border -->
            <UniformGrid Grid.Row="1" Columns="4"
                         Margin="{Binding Source={StaticResource UiScaleState},
                                          Path=FontScale,
                                          Converter={StaticResource ThicknessScaleConverter},
                                          ConverterParameter='0,0,0,20'}">
                <!-- Total Documents -->
                <Border BorderBrush="{StaticResource TotalCardBorderBrush}" BorderThickness="2"
                        Background="{StaticResource TotalCardBgBrush}" CornerRadius="8"
                        Padding="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='14'}"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='0,0,8,0'}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='0,0,0,8'}">
                            <Viewbox Width="16" Height="16"
                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource ThicknessScaleConverter},
                                                      ConverterParameter='0,0,6,0'}">
                                <Path Data="{StaticResource FileTextIcon}" Stroke="{StaticResource TotalCardIconBrush}"
                                      StrokeThickness="2" Width="24" Height="24" Stretch="Uniform" />
                            </Viewbox>
                            <TextBlock Text="Total Documents"
                                       Foreground="{StaticResource DimmedForeground}" VerticalAlignment="Center"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=12}" />
                        </StackPanel>
                        <TextBlock x:Name="TotalCount" Text="0"
                                   FontWeight="Bold"
                                   Padding="{Binding Source={StaticResource UiScaleState},
                                                                            Path=FontScale,
                                                                            Converter={StaticResource ThicknessScaleConverter},
                                                                            ConverterParameter='0,14,0,0'}"                                   
                                   Foreground="{StaticResource TotalCardTextBrush}"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=18}" />
                    </StackPanel>
                </Border>
                <!-- Compliance -->
                <Border BorderBrush="{StaticResource ComplianceCardBorderBrush}" BorderThickness="2"
                        Background="{StaticResource ComplianceCardBgBrush}" CornerRadius="8"
                        Padding="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='14'}"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='4,0,8,0'}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='0,0,0,8'}">
                            <Viewbox Width="16" Height="16"
                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource ThicknessScaleConverter},
                                                      ConverterParameter='0,0,6,0'}">
                                <Path Data="{StaticResource CircleCheckIcon}" Stroke="{StaticResource ComplianceCardIconBrush}"
                                      StrokeThickness="2" Width="24" Height="24" Stretch="Uniform" />
                            </Viewbox>
                            <TextBlock Text="Compliance"
                                       Foreground="{StaticResource DimmedForeground}" VerticalAlignment="Center"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=12}" />
                        </StackPanel>
                        <TextBlock x:Name="ComplianceCount" Text="0"
                                   FontWeight="Bold"
                                   Padding="{Binding Source={StaticResource UiScaleState},
                                                                            Path=FontScale,
                                                                            Converter={StaticResource ThicknessScaleConverter},
                                                                            ConverterParameter='0,14,0,0'}"                                   
                                   Foreground="{StaticResource TotalCardTextBrush}"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=18}" />
                    </StackPanel>
                </Border>
                <!-- Legal -->
                <Border BorderBrush="{StaticResource LegalCardBorderBrush}" BorderThickness="2"
                        Background="{StaticResource LegalCardBgBrush}" CornerRadius="8"
                        Padding="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='14'}"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='4,0,8,0'}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='0,0,0,8'}">
                            <Viewbox Width="16" Height="16"
                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource ThicknessScaleConverter},
                                                      ConverterParameter='0,0,6,0'}">
                                <Path Data="{StaticResource ShieldIcon}" Stroke="{StaticResource LegalCardIconBrush}"
                                      StrokeThickness="2" Width="24" Height="24" Stretch="Uniform" />
                            </Viewbox>
                            <TextBlock Text="Legal"
                                       Foreground="{StaticResource DimmedForeground}" VerticalAlignment="Center"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=12}" />
                        </StackPanel>
                        <TextBlock x:Name="LegalCount" Text="0"
                                   FontWeight="Bold"
                                   Padding="{Binding Source={StaticResource UiScaleState},
                                                                            Path=FontScale,
                                                                            Converter={StaticResource ThicknessScaleConverter},
                                                                            ConverterParameter='0,14,0,0'}"                                   
                                   Foreground="{StaticResource TotalCardTextBrush}"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=18}" />
                    </StackPanel>
                </Border>
                <!-- Banking -->
                <Border BorderBrush="{StaticResource BankingCardBorderBrush}" BorderThickness="2"
                        Background="{StaticResource BankingCardBgBrush}" CornerRadius="8"
                        Padding="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='14'}"
                        Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='4,0,0,0'}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                     Path=FontScale,
                                                     Converter={StaticResource ThicknessScaleConverter},
                                                     ConverterParameter='0,0,0,8'}">
                            <Viewbox Width="16" Height="16"
                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource ThicknessScaleConverter},
                                                      ConverterParameter='0,0,6,0'}">
                                <Path Data="{StaticResource BuildingIcon}" Stroke="{StaticResource BankingCardIconBrush}"
                                      StrokeThickness="2" Width="24" Height="24" Stretch="Uniform" />
                            </Viewbox>
                            <TextBlock Text="Banking"
                                       Foreground="{StaticResource DimmedForeground}" VerticalAlignment="Center"
                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                          Path=FontScale,
                                                          Converter={StaticResource FontScaleConverter},
                                                          ConverterParameter=12}" />
                        </StackPanel>
                        <TextBlock x:Name="BankingCount" Text="0"
                                   FontWeight="Bold"
                                   Padding="{Binding Source={StaticResource UiScaleState},
                                                                            Path=FontScale,
                                                                            Converter={StaticResource ThicknessScaleConverter},
                                                                            ConverterParameter='0,14,0,0'}"                                   
                                   Foreground="{StaticResource TotalCardTextBrush}"
                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                      Path=FontScale,
                                                      Converter={StaticResource FontScaleConverter},
                                                      ConverterParameter=18}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Document list area -->
            <Grid Grid.Row="2">
                <!-- Empty state -->
                <TextBlock x:Name="EmptyState"
                           Text="No documents found."
                           Foreground="{StaticResource DimmedForeground}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"
                           FontSize="{Binding Source={StaticResource UiScaleState},
                                              Path=FontScale,
                                              Converter={StaticResource FontScaleConverter},
                                              ConverterParameter=14}" />

                <!-- Scrollable document card list -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DocumentList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource DocumentCardBorder}">
                                    <DockPanel>
                                        <!-- Document icon -->
                                        <Border Background="{StaticResource DocIconBgBrush}"
                                                CornerRadius="6" Width="40" Height="40"
                                                VerticalAlignment="Center"
                                                Margin="{Binding Source={StaticResource UiScaleState},
                                                                 Path=FontScale,
                                                                 Converter={StaticResource ThicknessScaleConverter},
                                                                 ConverterParameter='0,0,14,0'}">
                                            <Viewbox Width="20" Height="20">
                                                <Path Data="{StaticResource FileTextIcon}" Stroke="{StaticResource DocIconBrush}"
                                                      StrokeThickness="2" Width="24" Height="24" Stretch="Uniform" />
                                            </Viewbox>
                                        </Border>

                                        <!-- Document info -->
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource MainForeground}"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=14}" />
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="{Binding Source={StaticResource UiScaleState},
                                                                         Path=FontScale,
                                                                         Converter={StaticResource ThicknessScaleConverter},
                                                                         ConverterParameter='0,4,0,0'}">
                                                <!-- Category badge -->
                                                <Border CornerRadius="4"
                                                        Padding="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource ThicknessScaleConverter},
                                                                          ConverterParameter='8,2,8,2'}"
                                                        Margin="{Binding Source={StaticResource UiScaleState},
                                                                         Path=FontScale,
                                                                         Converter={StaticResource ThicknessScaleConverter},
                                                                         ConverterParameter='0,0,8,0'}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource ComplianceBadgeBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Category}" Value="Legal">
                                                                    <Setter Property="Background" Value="{StaticResource LegalBadgeBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Category}" Value="Banking">
                                                                    <Setter Property="Background" Value="{StaticResource BankingBadgeBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Category}" FontWeight="SemiBold"
                                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                                  Path=FontScale,
                                                                                  Converter={StaticResource FontScaleConverter},
                                                                                  ConverterParameter=11}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource ComplianceBadgeTextBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Category}" Value="Legal">
                                                                        <Setter Property="Foreground" Value="{StaticResource LegalBadgeTextBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Category}" Value="Banking">
                                                                        <Setter Property="Foreground" Value="{StaticResource BankingBadgeTextBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <!-- File type -->
                                                <TextBlock Text="{Binding FileType}"
                                                           Foreground="{StaticResource DimmedForeground}"
                                                           VerticalAlignment="Center"
                                                           Margin="{Binding Source={StaticResource UiScaleState},
                                                                            Path=FontScale,
                                                                            Converter={StaticResource ThicknessScaleConverter},
                                                                            ConverterParameter='0,0,4,0'}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                                              Path=FontScale,
                                                                              Converter={StaticResource FontScaleConverter},
                                                                              ConverterParameter=12}" />
                                                <TextBlock Text="•" Foreground="{StaticResource DimmedForeground}"
                                                           VerticalAlignment="Center"
                                                           Margin="{Binding Source={StaticResource UiScaleState},
                                                                            Path=FontScale,
                                                                            Converter={StaticResource ThicknessScaleConverter},
                                                                            ConverterParameter='0,0,4,0'}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                                              Path=FontScale,
                                                                              Converter={StaticResource FontScaleConverter},
                                                                              ConverterParameter=12}" />
                                                <!-- File size -->
                                                <TextBlock Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}"
                                                           Foreground="{StaticResource DimmedForeground}"
                                                           VerticalAlignment="Center"
                                                           Margin="{Binding Source={StaticResource UiScaleState},
                                                                            Path=FontScale,
                                                                            Converter={StaticResource ThicknessScaleConverter},
                                                                            ConverterParameter='0,0,4,0'}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                                              Path=FontScale,
                                                                              Converter={StaticResource FontScaleConverter},
                                                                              ConverterParameter=12}" />
                                                <TextBlock Text="•" Foreground="{StaticResource DimmedForeground}"
                                                           VerticalAlignment="Center"
                                                           Margin="{Binding Source={StaticResource UiScaleState},
                                                                            Path=FontScale,
                                                                            Converter={StaticResource ThicknessScaleConverter},
                                                                            ConverterParameter='0,0,4,0'}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                                              Path=FontScale,
                                                                              Converter={StaticResource FontScaleConverter},
                                                                              ConverterParameter=12}" />
                                                <!-- Upload date -->
                                                <TextBlock Foreground="{StaticResource DimmedForeground}"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding UploadDate, StringFormat='Uploaded {0:MMM dd, yyyy}'}"
                                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                                              Path=FontScale,
                                                                              Converter={StaticResource FontScaleConverter},
                                                                              ConverterParameter=12}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</UserControl>
