<UserControl x:Class="RestaurantPosWpf.SupplierNewPO"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RestaurantPosWpf"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Focusable="True"
             PreviewKeyDown="SupplierNewPO_PreviewKeyDown">

    <Grid Background="Transparent">

        <!-- Centered card -->
        <Border Width="{Binding ActualWidth,
                       RelativeSource={RelativeSource AncestorType=Window},
                       Converter={StaticResource WidthMultiplierConverter},
                       ConverterParameter=0.75}"
                MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            
            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="4"
                                  Direction="270"
                                  Opacity="0.30"/>
            </Border.Effect>

            <!-- Card surface -->
            <Border Background="White"
                    BorderBrush="#D0D4DA"
                    BorderThickness="1">
                <Border.CornerRadius>
                    <Binding RelativeSource="{RelativeSource Self}"
                             Path="ActualHeight"
                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                             ConverterParameter="10" />
                </Border.CornerRadius>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Divider -->
                        <RowDefinition Height="*"/>
                        <!-- Scroll body -->
                        <RowDefinition Height="Auto"/>
                        <!-- Footer -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="16,12,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <!-- Title -->
                            <TextBlock Text="Create New Purchase Order"
                                       FontWeight="Medium"
                                       Foreground="#111827">
                                <TextBlock.FontSize>
                                    <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource FontScaleConverter}"
                                             ConverterParameter="18" />
                                </TextBlock.FontSize>
                            </TextBlock>

                            <!-- Subtitle -->
                            <TextBlock Text="Procurement Workspace: Manage supplier procurement requests, line items, and delivery parameters."
                                       Foreground="#6B7280">
                                <TextBlock.Margin>
                                    <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource ThicknessScaleConverter}"
                                             ConverterParameter="0,4,0,0" />
                                </TextBlock.Margin>
                                <TextBlock.FontSize>
                                    <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource FontScaleConverter}"
                                             ConverterParameter="14" />
                                </TextBlock.FontSize>
                            </TextBlock>

                            <!-- spacing before underline -->
                            <StackPanel.Margin>
                                <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource ThicknessScaleConverter}"
                                         ConverterParameter="0,6,0,6" />
                            </StackPanel.Margin>
                        </StackPanel>

                        <!-- Top-right close -->
                        <Button Grid.Column="1"
                                Width="36"
                                Height="36"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="BtnClose_Click"
                                ToolTip="Close"
                                VerticalAlignment="Top"
                                FocusVisualStyle="{x:Null}">
                            <TextBlock Text="×"
                                       Foreground="#111827"
                                       VerticalAlignment="Top"
                                       HorizontalAlignment="Center">
                                <TextBlock.FontSize>
                                    <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource FontScaleConverter}"
                                             ConverterParameter="18" />
                                </TextBlock.FontSize>
                            </TextBlock>
                        </Button>
                    </Grid>

                    <!-- Divider -->
                    <Border Grid.Row="1" Height="1" Background="#FFE5E7EB"/>

                    <ScrollViewer Grid.Row="2"
                          x:Name="svSupplierNewPO"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0"
                          Padding="0">

                        <StackPanel Margin="16">

                            <!-- 3-card row under header underline -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  CARD 1  -->
                                <Border Grid.Column="0"
                                    Background="White"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource LayoutScaleConverter},
                                                             ConverterParameter=1}"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='0,0,12,0'}"
                                    Padding="0">
                                    <Border.CornerRadius>
                                        <Binding RelativeSource="{RelativeSource Self}"
                                             Path="ActualHeight"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="10" />
                                    </Border.CornerRadius>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Grid Grid.Row="0"
                                          Margin="{Binding Source={StaticResource UiScaleState},
                                                           Path=FontScale,
                                                           Converter={StaticResource ThicknessScaleConverter},
                                                           ConverterParameter='16,14,16,12'}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Building2 icon -->
                                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource LayoutScaleConverter},
                                                             ConverterParameter=20}"
                                             Height="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource LayoutScaleConverter},
                                                              ConverterParameter=20}"
                                             VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"
                                                          Stroke="#2563EB"
                                                          StrokeThickness="{Binding Source={StaticResource UiScaleState},
                                                                                   Path=FontScale,
                                                                                   Converter={StaticResource LayoutScaleConverter},
                                                                                   ConverterParameter=2}"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Fill="Transparent"/>

                                                    <Path Data="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"
                                                          Stroke="#2563EB"
                                                          StrokeThickness="{Binding Source={StaticResource UiScaleState},
                                                                                   Path=FontScale,
                                                                                   Converter={StaticResource LayoutScaleConverter},
                                                                                   ConverterParameter=2}"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Fill="Transparent"/>

                                                    <Path Data="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"
                          Stroke="#2563EB"
                          StrokeThickness="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource LayoutScaleConverter},
                                                   ConverterParameter=2}"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Fill="Transparent"/>

                                                    <Path Data="M10 6h4"
                          Stroke="#2563EB"
                          StrokeThickness="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource LayoutScaleConverter},
                                                   ConverterParameter=2}"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"/>

                                                    <Path Data="M10 10h4"
                          Stroke="#2563EB"
                          StrokeThickness="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource LayoutScaleConverter},
                                                   ConverterParameter=2}"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"/>

                                                    <Path Data="M10 14h4"
                          Stroke="#2563EB"
                          StrokeThickness="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource LayoutScaleConverter},
                                                   ConverterParameter=2}"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"/>

                                                    <Path Data="M10 18h4"
                          Stroke="#2563EB"
                          StrokeThickness="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource LayoutScaleConverter},
                                                   ConverterParameter=2}"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"/>
                                                </Canvas>
                                            </Viewbox>

                                            <TextBlock Grid.Column="1"
                       Text="SUPPLIER INTEGRATION"
                       Foreground="#111827"
                       FontWeight="SemiBold"
                       Margin="{Binding Source={StaticResource UiScaleState},
                                        Path=FontScale,
                                        Converter={StaticResource ThicknessScaleConverter},
                                        ConverterParameter='10,0,0,0'}"
                       VerticalAlignment="Center">
                                                <TextBlock.FontSize>
                                                    <Binding Source="{StaticResource UiScaleState}"
                             Path="FontScale"
                             Converter="{StaticResource FontScaleConverter}"
                             ConverterParameter="13" />
                                                </TextBlock.FontSize>
                                            </TextBlock>
                                        </Grid>

                                        <!-- Divider under card header -->
                                        <Border Grid.Row="1"
                Height="{Binding Source={StaticResource UiScaleState},
                                 Path=FontScale,
                                 Converter={StaticResource LayoutScaleConverter},
                                 ConverterParameter=1}"
                Background="#E5E7EB" />

                                        <!-- Content -->
                                        <StackPanel Grid.Row="2"
                    Margin="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='16,18,16,16'}">

                                            <!-- Supplier -->
                                            <StackPanel>
                                                <TextBlock Text="SUPPLIER"
                           Foreground="#6B7280"
                           Margin="{Binding Source={StaticResource UiScaleState},
                                            Path=FontScale,
                                            Converter={StaticResource ThicknessScaleConverter},
                                            ConverterParameter='2,0,12,0'}"
                           FontWeight="Regular">
                                                    <TextBlock.FontSize>
                                                        <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource FontScaleConverter}"
                                 ConverterParameter="11" />
                                                    </TextBlock.FontSize>
                                                </TextBlock>

                                                <TextBox x:Name="tbPoSupplierDisplay"
                                                     Text=""
                                                     Style="{x:Null}"
                                                     IsReadOnly="True"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Padding="0"
                                                     Margin="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource ThicknessScaleConverter},
                                                                      ConverterParameter='0,3,0,20'}"
                                                                         FontWeight="SemiBold"
                                                                         TextWrapping="NoWrap"
                                                                         HorizontalScrollBarVisibility="Hidden"
                                                                         VerticalScrollBarVisibility="Hidden"
                                                                         Focusable="False"
                                                                         Foreground="#111827">
                                                    <TextBox.FontSize>
                                                        <Binding Source="{StaticResource UiScaleState}"
                                                             Path="FontScale"
                                                             Converter="{StaticResource FontScaleConverter}"
                                                             ConverterParameter="14" />
                                                    </TextBox.FontSize>
                                                </TextBox>
                                            </StackPanel>

                                            <!-- Email / Phone row -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Email -->
                                                <StackPanel Grid.Column="0"
                            Margin="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource ThicknessScaleConverter},
                                             ConverterParameter='0,0,12,0'}">
                                                    <TextBlock Text="EMAIL CONTACT"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='2,0,0,0'}"
                               Foreground="#6B7280"
                               FontWeight="Regular">
                                                        <TextBlock.FontSize>
                                                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource FontScaleConverter}"
                                     ConverterParameter="11" />
                                                        </TextBlock.FontSize>
                                                    </TextBlock>

                                                    <TextBox x:Name="tbPoEmailContact"
                                                         Text=""
                                                         Style="{x:Null}"
                                                         IsReadOnly="True"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         FontWeight="SemiBold"
                                                         Padding="0"
                                                         Margin="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource ThicknessScaleConverter},
                                                                          ConverterParameter='0,3,0,20'}"
                                                         TextWrapping="NoWrap"
                                                         HorizontalScrollBarVisibility="Hidden"
                                                         VerticalScrollBarVisibility="Hidden"
                                                         Focusable="False"
                                                         Foreground="#111827">
                                                        <TextBox.FontSize>
                                                            <Binding Source="{StaticResource UiScaleState}"
                                                                 Path="FontScale"
                                                                 Converter="{StaticResource FontScaleConverter}"
                                                                 ConverterParameter="14" />
                                                        </TextBox.FontSize>
                                                    </TextBox>
                                                </StackPanel>

                                                <!-- Phone -->
                                                <StackPanel Grid.Column="1"
                            Margin="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource ThicknessScaleConverter},
                                             ConverterParameter='12,0,0,0'}">
                                                    <TextBlock Text="DIRECT PHONE"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='4,0,0,0'}"
                               Foreground="#6B7280"
                               FontWeight="Regular">
                                                        <TextBlock.FontSize>
                                                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource FontScaleConverter}"
                                     ConverterParameter="11" />
                                                        </TextBlock.FontSize>
                                                    </TextBlock>

                                                    <TextBox x:Name="tbPoPhoneNumber"
                             Text=""
                             Style="{x:Null}"
                             IsReadOnly="True"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0"
                             FontWeight="SemiBold"
                             Margin="{Binding Source={StaticResource UiScaleState},
                                              Path=FontScale,
                                              Converter={StaticResource ThicknessScaleConverter},
                                              ConverterParameter='0,3,0,20'}"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Hidden"
                             VerticalScrollBarVisibility="Hidden"
                             Focusable="False"
                             Foreground="#111827">
                                                        <TextBox.FontSize>
                                                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource FontScaleConverter}"
                                     ConverterParameter="14" />
                                                        </TextBox.FontSize>
                                                    </TextBox>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Payment terms (blue + wallet icon, no frame) -->
                                            <StackPanel Margin="{Binding Source={StaticResource UiScaleState},
                                         Path=FontScale,
                                         Converter={StaticResource ThicknessScaleConverter},
                                         ConverterParameter='1,0,0,0'}">
                                                <TextBlock Text="PAYMENT TERMS"
                           Foreground="#6B7280"
                           FontWeight="Regular">
                                                    <TextBlock.FontSize>
                                                        <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource FontScaleConverter}"
                                 ConverterParameter="11" />
                                                    </TextBlock.FontSize>
                                                </TextBlock>

                                                <StackPanel Orientation="Horizontal"
                            Margin="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource ThicknessScaleConverter},
                                             ConverterParameter='0,3,0,8'}"
                            VerticalAlignment="Center">

                                                    <!-- Wallet icon -->
                                                    <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                         Path=FontScale,
                                                                         Converter={StaticResource LayoutScaleConverter},
                                                                         ConverterParameter=14}"
                                                         Height="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource LayoutScaleConverter},
                                                                          ConverterParameter=14}"
                                                         VerticalAlignment="Center"
                                                         Margin="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource ThicknessScaleConverter},
                                                                          ConverterParameter='0,2,0,0'}">
                                                        <Canvas Width="24" Height="24">
                                                            <Path Data="M19 7V4a1 1 0 0 0-1-1H5a2 2 0 0 0 0 4h15a1 1 0 0 1 1 1v4h-3a2 2 0 0 0 0 4h3a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1"
                                                              Stroke="#2563EB"
                                                              StrokeThickness="{Binding Source={StaticResource UiScaleState},
                                                                                       Path=FontScale,
                                                                                       Converter={StaticResource LayoutScaleConverter},
                                                                                       ConverterParameter=2}"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              Fill="Transparent"/>

                                                            <Path Data="M3 5v14a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4"
                                                                  Stroke="#2563EB"
                                                                  StrokeThickness="{Binding Source={StaticResource UiScaleState},
                                                                                           Path=FontScale,
                                                                                           Converter={StaticResource LayoutScaleConverter},
                                                                                           ConverterParameter=2}"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              StrokeLineJoin="Round"
                                                              Fill="Transparent"/>
                                                        </Canvas>
                                                    </Viewbox>

                                                    <TextBox x:Name="tbPoPaymentTerms"
                                                             Text=""
                                                             Margin="{Binding Source={StaticResource UiScaleState},
                                                                              Path=FontScale,
                                                                              Converter={StaticResource ThicknessScaleConverter},
                                                                              ConverterParameter='6,0,0,0'}"
                                                             Style="{x:Null}"
                                                             IsReadOnly="True"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             Padding="0"
                                                             TextWrapping="NoWrap"
                                                             HorizontalScrollBarVisibility="Hidden"
                                                             VerticalScrollBarVisibility="Hidden"
                                                             Focusable="False"
                                                             Foreground="#183F96"
                                                             FontWeight="SemiBold">
                                                        <TextBox.FontSize>
                                                            <Binding Source="{StaticResource UiScaleState}"
                                                                     Path="FontScale"
                                                                     Converter="{StaticResource FontScaleConverter}"
                                                                     ConverterParameter="14" />
                                                        </TextBox.FontSize>
                                                    </TextBox>
                                                </StackPanel>
                                            </StackPanel>

                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- CARD 2: ORDER SCHEDULE -->
                                <Border Grid.Column="1"
                                    Background="White"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource LayoutScaleConverter},
                                                             ConverterParameter=1}"
                                    Margin="{Binding Source={StaticResource UiScaleState},
                                                    Path=FontScale,
                                                    Converter={StaticResource ThicknessScaleConverter},
                                                    ConverterParameter='0,0,12,0'}"
                                    Padding="0">
                                    <Border.CornerRadius>
                                        <Binding RelativeSource="{RelativeSource Self}"
                                                 Path="ActualHeight"
                                                 Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                 ConverterParameter="10" />
                                    </Border.CornerRadius>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Grid Grid.Row="0"
                                              Margin="{Binding Source={StaticResource UiScaleState},
                                                               Path=FontScale,
                                                               Converter={StaticResource ThicknessScaleConverter},
                                                               ConverterParameter='16,14,16,12'}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Calendar icon (no Round caps) -->
                                            <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource LayoutScaleConverter},
                                     ConverterParameter=20}"
                     Height="{Binding Source={StaticResource UiScaleState},
                                      Path=FontScale,
                                      Converter={StaticResource LayoutScaleConverter},
                                      ConverterParameter=20}"
                     VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                    <Path Data="M8 2v4"
                          Stroke="#F97316"
                          StrokeThickness="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource LayoutScaleConverter},
                                                   ConverterParameter=2}"
                          StrokeStartLineCap="Flat"
                          StrokeEndLineCap="Flat"
                          StrokeLineJoin="Miter" />
                                                    <Path Data="M16 2v4"
                          Stroke="#F97316"
                          StrokeThickness="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource LayoutScaleConverter},
                                                   ConverterParameter=2}"
                          StrokeStartLineCap="Flat"
                          StrokeEndLineCap="Flat"
                          StrokeLineJoin="Miter" />
                                                    <Path Data="M3 10h18"
                          Stroke="#F97316"
                          StrokeThickness="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource LayoutScaleConverter},
                                                   ConverterParameter=2}"
                          StrokeStartLineCap="Flat"
                          StrokeEndLineCap="Flat"
                          StrokeLineJoin="Miter" />
                                                    <Path Data="M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z"
                          Stroke="#F97316"
                          StrokeThickness="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource LayoutScaleConverter},
                                                   ConverterParameter=2}"
                          StrokeStartLineCap="Flat"
                          StrokeEndLineCap="Flat"
                          StrokeLineJoin="Miter"
                          Fill="Transparent" />
                                                </Canvas>
                                            </Viewbox>

                                            <TextBlock Grid.Column="1"
                                               Text="ORDER SCHEDULE"
                                               Foreground="#111827"
                                               FontWeight="SemiBold"
                                               Margin="{Binding Source={StaticResource UiScaleState},
                                                                Path=FontScale,
                                                                Converter={StaticResource ThicknessScaleConverter},
                                                                ConverterParameter='10,0,0,0'}"
                                                VerticalAlignment="Center">
                                                <TextBlock.FontSize>
                                                    <Binding Source="{StaticResource UiScaleState}"
                                                         Path="FontScale"
                                                         Converter="{StaticResource FontScaleConverter}"
                                                         ConverterParameter="13" />
                                                </TextBlock.FontSize>
                                            </TextBlock>
                                        </Grid>

                                        <!-- Divider under card header -->
                                        <Border Grid.Row="1"
                                            Height="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource LayoutScaleConverter},
                                                             ConverterParameter=1}"
                                            Background="#E5E7EB" />

                                        <!-- Content -->
                                        <StackPanel Grid.Row="2"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='16,18,16,0'}">

                                            <!-- Row 1: Order Date / Required Date -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Order Date -->
                                                <Grid Grid.Column="0"
                                                  Margin="{Binding Source={StaticResource UiScaleState},
                                                                   Path=FontScale,
                                                                   Converter={StaticResource ThicknessScaleConverter},
                                                                   ConverterParameter='0,0,10,0'}">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0"
                                                       Text="ORDER DATE"
                                                       Foreground="#6B7280"
                                                       FontWeight="Regular"
                                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                                        Path=FontScale,
                                                                        Converter={StaticResource ThicknessScaleConverter},
                                                                        ConverterParameter='0,0,0,4'}">
                                                        <TextBlock.FontSize>
                                                            <Binding Source="{StaticResource UiScaleState}"
                                                                 Path="FontScale"
                                                                 Converter="{StaticResource FontScaleConverter}"
                                                                 ConverterParameter="11" />
                                                        </TextBlock.FontSize>
                                                    </TextBlock>

                                                    <DatePicker Grid.Row="1"
                                                        x:Name="dpPoOrderDate"
                                                                
                                                        Style="{StaticResource LocalIcDatePickerStyle}"
                                                        FontSize="{Binding Source={StaticResource UiScaleState},
                                                                           Path=FontScale,
                                                                           Converter={StaticResource FontScaleConverter},
                                                                           ConverterParameter=12}" />
                                                </Grid>

                                                <!-- Required Date -->
                                                <Grid Grid.Column="1"
                                                  Margin="{Binding Source={StaticResource UiScaleState},
                                                                   Path=FontScale,
                                                                   Converter={StaticResource ThicknessScaleConverter},
                                                                   ConverterParameter='10,0,0,0'}">
                                                                                <Grid.RowDefinitions>
                                                                                    <RowDefinition Height="Auto" />
                                                                                    <RowDefinition Height="Auto" />
                                                                                </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0"
                                                       Text="REQUIRED DATE"
                                                       Foreground="#6B7280"
                                                       FontWeight="Regular"
                                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                                        Path=FontScale,
                                                                        Converter={StaticResource ThicknessScaleConverter},
                                                                        ConverterParameter='0,0,0,4'}">
