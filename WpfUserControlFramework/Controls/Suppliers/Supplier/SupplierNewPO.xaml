                                                           Foreground="#111827"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center">
                                                            <TextBlock.FontSize>
                                                                <Binding Source="{StaticResource UiScaleState}"
                                         Path="FontScale"
                                         Converter="{StaticResource FontScaleConverter}"
                                         ConverterParameter="11" />
                                                            </TextBlock.FontSize>
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>

                                                <!-- Lead Time (Days) -->
                                                <Grid Grid.Column="1"
                      Margin="{Binding Source={StaticResource UiScaleState},
                                       Path=FontScale,
                                       Converter={StaticResource ThicknessScaleConverter},
                                       ConverterParameter='12,0,0,0'}">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0"
                               Foreground="#6B7280"
                               FontWeight="Regular"
                               Margin="{Binding Source={StaticResource UiScaleState},
                                                Path=FontScale,
                                                Converter={StaticResource ThicknessScaleConverter},
                                                ConverterParameter='0,20,0,4'}">
                        <Run Text="LEAD TIME (DAYS)" />
                        <Run Text=" *" Foreground="#DC2626" />
                                                        <TextBlock.FontSize>
                                                            <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource FontScaleConverter}"
                                     ConverterParameter="11" />
                                                        </TextBlock.FontSize>
                                                    </TextBlock>

                                                    <Grid Grid.Row="1">
                                                        <local:SpinnerTextBox x:Name="txtPoLeadTimeDays"
                                                 Style="{StaticResource IcSpinnerTextBoxStyle}"
