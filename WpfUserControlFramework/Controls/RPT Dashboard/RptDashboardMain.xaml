<UserControl x:Class="RestaurantPosWpf.RptDashboardMain"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RestaurantPosWpf"
             x:Name="Root">

    <UserControl.Resources>

        <!-- Recently used card -->
        <Style x:Key="RecentlyUsedCardButtonStyle" TargetType="Button">
            <Setter Property="Foreground"
                    Value="{StaticResource MainForeground}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Grid MinWidth="0"
                              ClipToBounds="False"
                              TextOptions.TextFormattingMode="Display"
                              TextOptions.TextRenderingMode="ClearType">

                            <Border x:Name="RecentCardShadowNormal"
                                    Background="{StaticResource Brush.White}"
                                    BorderThickness="0"
                                    IsHitTestVisible="False"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False">
                                <Border.CornerRadius>
                                    <Binding Path="ActualHeight"
                                             RelativeSource="{RelativeSource Self}"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="10"/>
                                </Border.CornerRadius>
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0"
                                                      BlurRadius="5"
                                                      Opacity="0.08"
                                                      Color="#FF000000"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="RecentCardShadowHover"
                                    Background="{StaticResource Brush.White}"
                                    BorderThickness="0"
                                    Opacity="0"
                                    IsHitTestVisible="False"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False">
                                <Border.CornerRadius>
                                    <Binding Path="ActualHeight"
                                             RelativeSource="{RelativeSource Self}"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="10"/>
                                </Border.CornerRadius>
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0"
                                                      BlurRadius="16"
                                                      Opacity="0.22"
                                                      Color="#FF000000"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="CardRoot"
                                    Background="{StaticResource Brush.White}"
                                    BorderBrush="{StaticResource Brush.SurfaceGrey}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False">
                                <Border.CornerRadius>
                                    <Binding Path="ActualHeight"
                                             RelativeSource="{RelativeSource Self}"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="10"/>
                                </Border.CornerRadius>

                                <Grid MinWidth="0"
                                  ClipToBounds="False">

                                <Border x:Name="HoverSurfaceOverlay"
                                        Background="{Binding Path=Theme.HoverBackground}"
                                        BorderThickness="0"
                                        Opacity="0"
                                        IsHitTestVisible="False"
                                        SnapsToDevicePixels="True"
                                        ClipToBounds="False">
                                    <Border.CornerRadius>
                                        <Binding Path="ActualHeight"
                                                 RelativeSource="{RelativeSource Self}"
                                                 Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                 ConverterParameter="10"/>
                                    </Border.CornerRadius>
                                </Border>

                                <Border x:Name="CardContentPaddingHost"
                                        Background="Transparent"
                                        SnapsToDevicePixels="True"
                                        ClipToBounds="False"
                                        Padding="{Binding Source={StaticResource UiScaleState},
                                                         Path=FontScale,
                                                         Converter={StaticResource ThicknessScaleConverter},
                                                         ConverterParameter='16,16,16,16'}">

                                    <Grid x:Name="CardContentHost"
                                          MinWidth="0"
                                          ClipToBounds="False">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="{Binding Source={StaticResource UiScaleState},
                                                                             Path=FontScale,
                                                                             Converter={StaticResource LayoutScaleConverter},
                                                                             ConverterParameter=8}"/>
                                            <ColumnDefinition Width="*" MinWidth="0"/>
                                            <ColumnDefinition Width="{Binding Source={StaticResource UiScaleState},
                                                                             Path=FontScale,
                                                                             Converter={StaticResource LayoutScaleConverter},
                                                                             ConverterParameter=4}"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border x:Name="IconTile"
                                                Grid.Column="0"
                                                SnapsToDevicePixels="True"
                                                Width="{Binding Source={StaticResource UiScaleState},
                                                                 Path=FontScale,
                                                                 Converter={StaticResource LayoutScaleConverter},
                                                                 ConverterParameter=34}"
                                                Height="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=34}"
                                                Background="{Binding Path=Theme.IconBackdrop}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                            <Border.CornerRadius>
                                                <Binding Path="ActualHeight"
                                                         RelativeSource="{RelativeSource Self}"
                                                         Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                         ConverterParameter="8"/>
                                            </Border.CornerRadius>
                                            <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                            <Border.RenderTransform>
                                                <ScaleTransform x:Name="IconTileScaleTransform"
                                                                ScaleX="1"
                                                                ScaleY="1"/>
                                            </Border.RenderTransform>

                                                <Grid SnapsToDevicePixels="True"
      ClipToBounds="False">

                                                    <Border x:Name="IconTileHoverShade"
            Background="{Binding Path=Theme.IconForeground}"
            Opacity="0"
            IsHitTestVisible="False"
            SnapsToDevicePixels="True">
                                                        <Border.CornerRadius>
                                                            <Binding Path="ActualHeight"
                     RelativeSource="{RelativeSource AncestorType=Border}"
                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                     ConverterParameter="8"/>
                                                        </Border.CornerRadius>
                                                    </Border>

                                                    <Viewbox Stretch="Uniform"
             Width="{Binding Source={StaticResource UiScaleState},
                              Path=FontScale,
                              Converter={StaticResource LayoutScaleConverter},
                              ConverterParameter=20}"
             Height="{Binding Source={StaticResource UiScaleState},
                               Path=FontScale,
                               Converter={StaticResource LayoutScaleConverter},
                               ConverterParameter=20}">
                                                        <Path Data="{Binding Path=IconGeometry}"
              Stroke="{Binding Path=Theme.IconForeground}"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              StrokeLineJoin="Round"
              Stretch="Uniform">
                                                            <Path.StrokeThickness>
                                                                <Binding Source="{StaticResource UiScaleState}"
                         Path="FontScale"
                         Converter="{StaticResource LayoutScaleConverter}"
                         ConverterParameter="2"/>
                                                            </Path.StrokeThickness>
                                                        </Path>
                                                    </Viewbox>
                                                </Grid>
                                            
                                            </Border>

                                        <StackPanel Grid.Column="2"
                                                    Orientation="Vertical"
                                                    VerticalAlignment="Center"
                                                    MinWidth="0"
                                                    ClipToBounds="True">
                                            <TextBlock Style="{StaticResource RptDashboardCardTitleStyle}"
                                                       Foreground="{StaticResource MainForeground}"
                                                       FontWeight="SemiBold"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=14}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       MinWidth="0"
                                                       Text="{Binding Path=Report.DisplayName}"/>
                                            <TextBlock Style="{StaticResource RptDashboardCardDetailStyle}"
                                                       Foreground="{StaticResource Brush.TextMuted}"
                                                       FontWeight="Normal"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=14}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       MinWidth="0"
                                                       Text="{Binding Path=LastRunDisplay}"
                                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                                        Path=FontScale,
                                                                        Converter={StaticResource ThicknessScaleConverter},
                                                                        ConverterParameter='0,2,0,0'}"/>
                                        </StackPanel>

                                        <Grid Grid.Column="4"
                                              VerticalAlignment="Center"
                                              Width="{Binding Path=FontScale,
                                                              Source={StaticResource UiScaleState},
                                                              Converter={StaticResource LayoutScaleConverter},
                                                              ConverterParameter=8}"
                                              Height="{Binding Path=FontScale,
                                                               Source={StaticResource UiScaleState},
                                                               Converter={StaticResource LayoutScaleConverter},
                                                               ConverterParameter=18}">
                                            <Path x:Name="ChevronMuted"
                                                  Stretch="Uniform"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Stroke="{StaticResource Brush.BorderGrey}"
                                                  StrokeEndLineCap="Round"
                                                  StrokeStartLineCap="Round"
                                                  Data="{StaticResource Geom.RptDashboardChevronRight}">
                                                <Path.StrokeThickness>
                                                    <Binding Source="{StaticResource UiScaleState}"
                                                             Path="FontScale"
                                                             Converter="{StaticResource LayoutScaleConverter}"
                                                             ConverterParameter="2"/>
                                                </Path.StrokeThickness>
                                            </Path>
                                            <Path x:Name="ChevronHot"
                                                  Stretch="Uniform"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Opacity="0"
                                                  Stroke="{Binding Theme.ChevronHot}"
                                                  StrokeEndLineCap="Round"
                                                  StrokeStartLineCap="Round"
                                                  Data="{StaticResource Geom.RptDashboardChevronRight}">
                                                <Path.StrokeThickness>
                                                    <Binding Source="{StaticResource UiScaleState}"
                                                             Path="FontScale"
                                                             Converter="{StaticResource LayoutScaleConverter}"
                                                             ConverterParameter="2"/>
                                                </Path.StrokeThickness>
                                            </Path>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Hover frame overlay: fades in gradually above the content. -->
                                <Border x:Name="HoverBorderOverlay"
                                        Background="Transparent"
                                        BorderBrush="{Binding Path=Theme.HoverBorder}"
                                        BorderThickness="1"
                                        Opacity="0"
                                        IsHitTestVisible="False"
                                        SnapsToDevicePixels="True"
                                        ClipToBounds="False">
                                    <Border.CornerRadius>
                                        <Binding Path="ActualHeight"
                                                 RelativeSource="{RelativeSource Self}"
                                                 Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                 ConverterParameter="10"/>
                                    </Border.CornerRadius>
                                </Border>
                            </Grid>
                        </Border>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Gradual icon growth. -->
                                            <DoubleAnimation Storyboard.TargetName="IconTileScaleTransform"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.12"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="IconTileScaleTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.12"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="IconTileHoverShade"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.12"
                                                     Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <!-- Gradual card bg and frame fade-in. -->
                                            <DoubleAnimation Storyboard.TargetName="HoverSurfaceOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="HoverBorderOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <!-- Gradual shadow fade-in without affecting text clarity. -->
                                            <DoubleAnimation Storyboard.TargetName="RecentCardShadowHover"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Gradual icon shrink. -->
                                            <DoubleAnimation Storyboard.TargetName="IconTileScaleTransform"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="IconTileScaleTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="IconTileHoverShade"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <!-- Gradual card bg and frame fade-out. -->
                                            <DoubleAnimation Storyboard.TargetName="HoverSurfaceOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="HoverBorderOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <!-- Gradual shadow fade-out without affecting text clarity. -->
                                            <DoubleAnimation Storyboard.TargetName="RecentCardShadowHover"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>

                                <Setter TargetName="ChevronMuted" Property="Opacity" Value="0"/>
                                <Setter TargetName="ChevronHot" Property="Opacity" Value="1"/>

                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AttentionCardButtonStyle" TargetType="Button">
            <Setter Property="Foreground"
                    Value="{StaticResource MainForeground}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <!-- Checks: shadow separated from text; no Grid.Padding; Attention content stays off DropShadowEffect layer. -->
                        <Grid MinWidth="0"
                              ClipToBounds="False"
                              TextOptions.TextFormattingMode="Display"
                              TextOptions.TextRenderingMode="ClearType">

                            <Border x:Name="AttCardShadowNormal"
                                    Background="{StaticResource Brush.White}"
                                    BorderThickness="0"
                                    IsHitTestVisible="False"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False">
                                <Border.CornerRadius>
                                    <Binding Path="ActualHeight"
                                             RelativeSource="{RelativeSource Self}"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="10"/>
                                </Border.CornerRadius>
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0"
                                                      BlurRadius="5"
                                                      Opacity="0.08"
                                                      Color="#FF000000"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="AttCardShadowHover"
                                    Background="{StaticResource Brush.White}"
                                    BorderThickness="0"
                                    Opacity="0"
                                    IsHitTestVisible="False"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False">
                                <Border.CornerRadius>
                                    <Binding Path="ActualHeight"
                                             RelativeSource="{RelativeSource Self}"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="10"/>
                                </Border.CornerRadius>
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0"
                                                      BlurRadius="16"
                                                      Opacity="0.22"
                                                      Color="#FF000000"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="CardRootAtt"
                                    Background="{StaticResource Brush.White}"
                                    BorderBrush="{StaticResource Brush.SurfaceGrey}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False">
                                <Border.CornerRadius>
                                    <Binding Path="ActualHeight"
                                             RelativeSource="{RelativeSource Self}"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="10"/>
                                </Border.CornerRadius>
                                
                                <Grid MinWidth="0"
                                  ClipToBounds="False">

                                <!-- Hover background overlay: fades in gradually. -->
                                <Border x:Name="AttHoverSurfaceOverlay"
                                        Background="{Binding Path=IconTheme.HoverBackground}"
                                        BorderThickness="0"
                                        Opacity="0"
                                        IsHitTestVisible="False"
                                        SnapsToDevicePixels="True"
                                        ClipToBounds="False">
                                    <Border.CornerRadius>
                                        <Binding Path="ActualHeight"
                                                 RelativeSource="{RelativeSource Self}"
                                                 Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                 ConverterParameter="10"/>
                                    </Border.CornerRadius>
                                </Border>

                                <!-- Content padding host: Border supports Padding; Grid does not. -->
                                <Border x:Name="AttCardContentPaddingHost"
                                        Background="Transparent"
                                        SnapsToDevicePixels="True"
                                        ClipToBounds="False"
                                        Padding="{Binding Source={StaticResource UiScaleState},
                                                         Path=FontScale,
                                                         Converter={StaticResource ThicknessScaleConverter},
                                                         ConverterParameter='12,12,12,12'}">

                                    <Grid x:Name="AttCardContentHost"
                                          MinWidth="0"
                                          ClipToBounds="False"
                                          MinHeight="{Binding Path=FontScale,
                                                              Source={StaticResource UiScaleState},
                                                              Converter={StaticResource LayoutScaleConverter},
                                                              ConverterParameter=50}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="{Binding Source={StaticResource UiScaleState},
                                                                             Path=FontScale,
                                                                             Converter={StaticResource LayoutScaleConverter},
                                                                             ConverterParameter=8}"/>
                                            <ColumnDefinition Width="*" MinWidth="0"/>
                                            <ColumnDefinition Width="{Binding Source={StaticResource UiScaleState},
                                                                             Path=FontScale,
                                                                             Converter={StaticResource LayoutScaleConverter},
                                                                             ConverterParameter=4}"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="{Binding Source={StaticResource UiScaleState},
                                                                             Path=FontScale,
                                                                             Converter={StaticResource LayoutScaleConverter},
                                                                             ConverterParameter=6}"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="{Binding Source={StaticResource UiScaleState},
                                                                             Path=FontScale,
                                                                             Converter={StaticResource LayoutScaleConverter},
                                                                             ConverterParameter=6}"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border x:Name="AttIconTile"
                                                Grid.Column="0"
                                                SnapsToDevicePixels="True"
                                                Width="{Binding Source={StaticResource UiScaleState},
                                                                 Path=FontScale,
                                                                 Converter={StaticResource LayoutScaleConverter},
                                                                 ConverterParameter=40}"
                                                Height="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=40}"
                                                Background="{Binding Path=IconTheme.IconBackdrop}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                            <Border.CornerRadius>
                                                <Binding Path="ActualHeight"
                                                         RelativeSource="{RelativeSource Self}"
                                                         Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                         ConverterParameter="8"/>
                                            </Border.CornerRadius>
                                            <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                            <Border.RenderTransform>
                                                <ScaleTransform x:Name="AttIconTileScaleTransform"
                                                                ScaleX="1"
                                                                ScaleY="1"/>
                                            </Border.RenderTransform>

                                                <Grid SnapsToDevicePixels="True"
      ClipToBounds="False">

                                                    <Border x:Name="AttIconTileHoverShade"
            Background="{Binding Path=IconTheme.IconForeground}"
            Opacity="0"
            IsHitTestVisible="False"
            SnapsToDevicePixels="True">
                                                        <Border.CornerRadius>
                                                            <Binding Path="ActualHeight"
                     RelativeSource="{RelativeSource AncestorType=Border}"
                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                     ConverterParameter="8"/>
                                                        </Border.CornerRadius>
                                                    </Border>

                                                    <Viewbox Stretch="Uniform"
             Width="{Binding Source={StaticResource UiScaleState},
                              Path=FontScale,
                              Converter={StaticResource LayoutScaleConverter},
                              ConverterParameter=22}"
             Height="{Binding Source={StaticResource UiScaleState},
                               Path=FontScale,
                               Converter={StaticResource LayoutScaleConverter},
                               ConverterParameter=22}">
                                                        <Path Data="{Binding IconGeometry}"
              Stroke="{Binding IconTheme.IconForeground}"
              StrokeEndLineCap="Round"
              StrokeStartLineCap="Round"
              StrokeLineJoin="Round">
                                                            <Path.StrokeThickness>
                                                                <Binding Source="{StaticResource UiScaleState}"
                         Path="FontScale"
                         Converter="{StaticResource LayoutScaleConverter}"
                         ConverterParameter="2"/>
                                                            </Path.StrokeThickness>
                                                        </Path>
                                                    </Viewbox>
                                                </Grid>
                                            
                                            </Border>

                                        <TextBlock Grid.Column="2"
                                                   Style="{StaticResource RptDashboardCardTitleStyle}"
                                                   Foreground="{StaticResource MainForeground}"
                                                   FontWeight="SemiBold"
                                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                                      Path=FontScale,
                                                                      Converter={StaticResource FontScaleConverter},
                                                                      ConverterParameter=14}"
                                                   HorizontalAlignment="Stretch"
                                                   TextAlignment="Left"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MinWidth="0"
                                                   VerticalAlignment="Center"
                                                   Margin="{Binding Source={StaticResource UiScaleState},
                                                                    Path=FontScale,
                                                                    Converter={StaticResource ThicknessScaleConverter},
                                                                    ConverterParameter='0,0,4,0'}"
                                                   Text="{Binding Report.DisplayName}"/>

                                        <Border Grid.Column="4"
                                                VerticalAlignment="Center"
                                                Background="{Binding BadgeTheme.IconBackdrop}"
                                                Padding="{Binding Source={StaticResource UiScaleState},
                                                                   Path=FontScale,
                                                                   Converter={StaticResource ThicknessScaleConverter},
                                                                   ConverterParameter='8,5,8,5'}"
                                                CornerRadius="{Binding ActualHeight,
                                                                       RelativeSource={RelativeSource Self},
                                                                       Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                       ConverterParameter=6}">
                                            <TextBlock Style="{StaticResource RptDashboardAttentionBadgeCountStyle}"
                                                       Foreground="{Binding BadgeTheme.IconForeground}"
                                                       FontWeight="Bold"
                                                       FontSize="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource FontScaleConverter},
                                                                          ConverterParameter=13}">
                                                <Run Text="{Binding AttentionCount, Mode=OneWay}"/>
                                            </TextBlock>
                                        </Border>

                                        <Viewbox x:Name="EyePeek"
                                                 Grid.Column="6"
                                                 Visibility="Collapsed"
                                                 VerticalAlignment="Center"
                                                 Opacity="0"
                                                 Stretch="Uniform"
                                                 Width="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=16}"
                                                 Height="{Binding Source={StaticResource UiScaleState},
                                                                   Path=FontScale,
                                                                   Converter={StaticResource LayoutScaleConverter},
                                                                   ConverterParameter=16}">
                                            <Canvas Width="24"
                                                    Height="24"
                                                    SnapsToDevicePixels="True">
                                                <Path Stroke="{StaticResource Brush.PasswordRevealEyeStroke}"
                                                      StrokeThickness="2"
                                                      StrokeLineJoin="Round"
                                                      Fill="Transparent"
                                                      Data="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/>
                                                <Path Stroke="{StaticResource Brush.PasswordRevealEyeStroke}"
                                                      StrokeThickness="2"
                                                      Fill="Transparent"
                                                      Data="M12 9a3 3 0 1 1 0 6 3 3 0 0 1 0-6z"/>
                                            </Canvas>
                                        </Viewbox>

                                        <Grid Grid.Column="8"
                                              VerticalAlignment="Center"
                                              Width="{Binding Path=FontScale,
                                                              Source={StaticResource UiScaleState},
                                                              Converter={StaticResource LayoutScaleConverter},
                                                              ConverterParameter=8}"
                                              Height="{Binding Path=FontScale,
                                                               Source={StaticResource UiScaleState},
                                                               Converter={StaticResource LayoutScaleConverter},
                                                               ConverterParameter=18}">
                                            <Path x:Name="AttChevronMuted"
                                                  Stretch="Uniform"
                                                  Stroke="{StaticResource Brush.BorderGrey}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Data="{StaticResource Geom.RptDashboardChevronRight}"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round">
                                                <Path.StrokeThickness>
                                                    <Binding Source="{StaticResource UiScaleState}"
                                                             Path="FontScale"
                                                             Converter="{StaticResource LayoutScaleConverter}"
                                                             ConverterParameter="2"/>
                                                </Path.StrokeThickness>
                                            </Path>
                                            <Path x:Name="AttChevronHot"
                                                  Stretch="Uniform"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Opacity="0"
                                                  Stroke="{Binding IconTheme.ChevronHot}"
                                                  Data="{StaticResource Geom.RptDashboardChevronRight}"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round">
                                                <Path.StrokeThickness>
                                                    <Binding Source="{StaticResource UiScaleState}"
                                                             Path="FontScale"
                                                             Converter="{StaticResource LayoutScaleConverter}"
                                                             ConverterParameter="2"/>
                                                </Path.StrokeThickness>
                                            </Path>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Hover frame overlay: fades in gradually above the content. -->
                                <Border x:Name="AttHoverBorderOverlay"
                                        Background="Transparent"
                                        BorderBrush="{Binding Path=IconTheme.HoverBorder}"
                                        BorderThickness="1"
                                        Opacity="0"
                                        IsHitTestVisible="False"
                                        SnapsToDevicePixels="True"
                                        ClipToBounds="False">
                                    <Border.CornerRadius>
                                        <Binding Path="ActualHeight"
                                                 RelativeSource="{RelativeSource Self}"
                                                 Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                 ConverterParameter="10"/>
                                    </Border.CornerRadius>
                                </Border>
                            </Grid>
                        </Border>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Gradual icon growth. -->
                                            <DoubleAnimation Storyboard.TargetName="AttIconTileScaleTransform"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.12"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="AttIconTileHoverShade"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.12"
                                                     Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            
                                            <DoubleAnimation Storyboard.TargetName="AttIconTileScaleTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.12"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <!-- Gradual card bg and frame fade-in. -->
                                            <DoubleAnimation Storyboard.TargetName="AttHoverSurfaceOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="AttHoverBorderOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <!-- Gradual shadow fade-in without affecting text clarity. -->
                                            <DoubleAnimation Storyboard.TargetName="AttCardShadowHover"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="EyePeek"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.42"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Gradual icon shrink. -->
                                            <DoubleAnimation Storyboard.TargetName="AttIconTileScaleTransform"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="AttIconTileScaleTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="AttIconTileHoverShade"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <!-- Gradual card bg and frame fade-out. -->
                                            <DoubleAnimation Storyboard.TargetName="AttHoverSurfaceOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="AttHoverBorderOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <!-- Gradual shadow fade-out without affecting text clarity. -->
                                            <DoubleAnimation Storyboard.TargetName="AttCardShadowHover"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="EyePeek"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.42"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>

                                <Setter TargetName="AttChevronMuted" Property="Opacity" Value="0"/>
                                <Setter TargetName="AttChevronHot" Property="Opacity" Value="1"/>
                                <Setter TargetName="EyePeek" Property="Visibility" Value="Visible"/>

                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="False">
                                <Setter TargetName="EyePeek" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- View Reports pill: same band height as reporting toolbar (LayoutScaleConverter · 28, OpsTableMgmtDetailPrimaryButtonStyle). -->
        <Style x:Key="RptViewReportsPill" TargetType="Border">
            <Setter Property="Background"
                    Value="{StaticResource Brush.PrimaryBlue}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Padding"
                    Value="{Binding Source={StaticResource UiScaleState},
                                     Path=FontScale,
                                     Converter={StaticResource ThicknessScaleConverter},
                                     ConverterParameter='16,8,16,10'}"/>
            <Setter Property="CornerRadius"
                    Value="{Binding Path=ActualHeight,
                                    RelativeSource={RelativeSource Self},
                                    Converter={StaticResource CornerRadiusFromHeightConverter},
                                    ConverterParameter=8}"/>
        </Style>

        <!-- Browse Reports card -->
        <Style x:Key="GroupBrowseCardButtonStyle" TargetType="Button">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Grid MinWidth="0"
                              ClipToBounds="False"
                              TextOptions.TextFormattingMode="Display"
                              TextOptions.TextRenderingMode="ClearType">

                            <!-- Normal shadow: separate layer so text stays crisp. -->
                            <Border x:Name="BrowseCardShadowNormal"
                                    Background="{StaticResource Brush.White}"
                                    BorderThickness="0"
                                    IsHitTestVisible="False"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False">
                                <Border.CornerRadius>
                                    <Binding Path="ActualHeight"
                                             RelativeSource="{RelativeSource Self}"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="10"/>
                                </Border.CornerRadius>
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0"
                                                      BlurRadius="5"
                                                      Opacity="0.08"
                                                      Color="#FF000000"/>
                                </Border.Effect>
                            </Border>

                            <!-- Hover shadow: fades in without affecting text rendering. -->
                            <Border x:Name="BrowseCardShadowHover"
                                    Background="{StaticResource Brush.White}"
                                    BorderThickness="0"
                                    Opacity="0"
                                    IsHitTestVisible="False"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False">
                                <Border.CornerRadius>
                                    <Binding Path="ActualHeight"
                                             RelativeSource="{RelativeSource Self}"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="10"/>
                                </Border.CornerRadius>
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="0"
                                                      BlurRadius="16"
                                                      Opacity="0.22"
                                                      Color="#FF000000"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="GroupRoot"
                                    Background="{StaticResource Brush.White}"
                                    BorderBrush="{StaticResource Brush.SurfaceGrey}"
                                    BorderThickness="1"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False">
                                <Border.CornerRadius>
                                    <Binding Path="ActualHeight"
                                             RelativeSource="{RelativeSource Self}"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="10"/>
                                </Border.CornerRadius>

                                <Grid MinWidth="0"
                                      ClipToBounds="False">

                                    <!-- Hover background overlay: fades in gradually. -->
                                    <Border x:Name="BrowseHoverSurfaceOverlay"
                                            Background="{Binding Theme.HoverBackground}"
                                            BorderThickness="0"
                                            Opacity="0"
                                            IsHitTestVisible="False"
                                            SnapsToDevicePixels="True"
                                            ClipToBounds="False">
                                        <Border.CornerRadius>
                                            <Binding Path="ActualHeight"
                                                     RelativeSource="{RelativeSource Self}"
                                                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                     ConverterParameter="10"/>
                                        </Border.CornerRadius>
                                    </Border>

                                    <!-- Content padding host: Border supports Padding; Grid does not. -->
                                    <Border x:Name="BrowseContentPaddingHost"
                                            Background="Transparent"
                                            SnapsToDevicePixels="True"
                                            ClipToBounds="False"
                                            Padding="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='18,16,18,18'}">

                                        <DockPanel LastChildFill="True"
                                                   MinWidth="0"
                                                   ClipToBounds="False">

                                            <DockPanel DockPanel.Dock="Bottom"
                                                       LastChildFill="False"
                                                       Margin="{Binding Source={StaticResource UiScaleState},
                                                                        Path=FontScale,
                                                                        Converter={StaticResource ThicknessScaleConverter},
                                                                        ConverterParameter='0,16,0,0'}">

                                                <TextBlock DockPanel.Dock="Left"
                                                           Style="{StaticResource RptDashboardMutedMetaStyle}"
                                                           Foreground="{StaticResource Brush.TextMuted}"
                                                           FontWeight="Normal"
                                                           FontSize="{Binding Source={StaticResource UiScaleState},
                                                                              Path=FontScale,
                                                                              Converter={StaticResource FontScaleConverter},
                                                                              ConverterParameter=14}"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding Path=ReportCount, StringFormat='{}{0} reports'}"/>

                                                <Border DockPanel.Dock="Right"
                                                        Style="{StaticResource RptViewReportsPill}"
                                                        Height="{Binding Path=FontScale,
                                                                        Source={StaticResource UiScaleState},
                                                                        Converter={StaticResource LayoutScaleConverter},
                                                                        ConverterParameter=34}"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Right"
                                                        MouseDown="BrowseViewReports_MouseDown">
                                                    <TextBlock Text="View Reports"
                                                               Foreground="{StaticResource Brush.White}"
                                                               FontWeight="SemiBold"
                                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                                  Path=FontScale,
                                                                                  Converter={StaticResource FontScaleConverter},
                                                                                  ConverterParameter=16}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Style="{StaticResource RptDashboardToolbarActionLabelStyle}"/>
                                                </Border>
                                            </DockPanel>

                                            <DockPanel DockPanel.Dock="Top"
                                                       LastChildFill="True"
                                                       MinWidth="0"
                                                       ClipToBounds="False">

                                                <Border x:Name="GroupIconShell"
                                                        DockPanel.Dock="Left"
                                                        SnapsToDevicePixels="True"
                                                        Width="{Binding Source={StaticResource UiScaleState},
                                                                         Path=FontScale,
                                                                         Converter={StaticResource LayoutScaleConverter},
                                                                         ConverterParameter=52}"
                                                        Height="{Binding Source={StaticResource UiScaleState},
                                                                          Path=FontScale,
                                                                          Converter={StaticResource LayoutScaleConverter},
                                                                          ConverterParameter=52}"
                                                        VerticalAlignment="Top"
                                                        Margin="{Binding Source={StaticResource UiScaleState},
                                                                         Path=FontScale,
                                                                         Converter={StaticResource ThicknessScaleConverter},
                                                                         ConverterParameter='0,0,12,0'}"
                                                        Background="{Binding Theme.IconBackdrop}">
                                                    <Border.CornerRadius>
                                                        <Binding Path="ActualHeight"
                                                                 RelativeSource="{RelativeSource Self}"
                                                                 Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                                 ConverterParameter="8"/>
                                                    </Border.CornerRadius>
                                                    <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>
                                                    <Border.RenderTransform>
                                                        <ScaleTransform x:Name="BrowseIconScaleTransform"
                                                                        ScaleX="0.9"
                                                                        ScaleY="0.9"/>
                                                    </Border.RenderTransform>

                                                    <Grid SnapsToDevicePixels="True"
      ClipToBounds="False">

                                                        <Border x:Name="BrowseIconTileHoverShade"
            Background="{Binding Path=Theme.IconForeground}"
            Opacity="0"
            IsHitTestVisible="False"
            SnapsToDevicePixels="True">
                                                            <Border.CornerRadius>
                                                                <Binding Path="ActualHeight"
                     RelativeSource="{RelativeSource AncestorType=Border}"
                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                     ConverterParameter="8"/>
                                                            </Border.CornerRadius>
                                                        </Border>

                                                        <Viewbox Stretch="Uniform"
             Width="{Binding Source={StaticResource UiScaleState},
                              Path=FontScale,
                              Converter={StaticResource LayoutScaleConverter},
                              ConverterParameter=26}"
             Height="{Binding Source={StaticResource UiScaleState},
                               Path=FontScale,
                               Converter={StaticResource LayoutScaleConverter},
                               ConverterParameter=26}">
                                                            <Path Data="{Binding IconGeometry}"
              Stroke="{Binding Theme.IconForeground}"
              StrokeEndLineCap="Round"
              StrokeStartLineCap="Round"
              StrokeLineJoin="Round">
                                                                <Path.StrokeThickness>
                                                                    <Binding Source="{StaticResource UiScaleState}"
                         Path="FontScale"
                         Converter="{StaticResource LayoutScaleConverter}"
                         ConverterParameter="2"/>
                                                                </Path.StrokeThickness>
                                                            </Path>
                                                        </Viewbox>
                                                    </Grid>
                                                    
                                                </Border>

                                                <StackPanel Orientation="Vertical"
                                                            MinWidth="0"
                                                            ClipToBounds="True">

                                                    <Grid MinWidth="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" MinWidth="0"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   Style="{StaticResource RptDashboardBrowseGroupTitleStyle}"
                                                                   Foreground="{StaticResource MainForeground}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                                                      Path=FontScale,
                                                                                      Converter={StaticResource FontScaleConverter},
                                                                                      ConverterParameter=16}"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MinWidth="0"
                                                                   Text="{Binding Title}"/>

                                                        <TextBlock x:Name="TitleChevron"
                                                                   Grid.Column="1"
                                                                   Margin="{Binding Path=FontScale,
                                                                                    Source={StaticResource UiScaleState},
                                                                                    Converter={StaticResource ThicknessScaleConverter},
                                                                                    ConverterParameter='8,2,0,0'}"
                                                                   Foreground="{Binding Theme.IconForeground}"
                                                                   FontWeight="Bold"
                                                                   FontSize="{Binding Source={StaticResource UiScaleState},
                                                                                      Path=FontScale,
                                                                                      Converter={StaticResource FontScaleConverter},
                                                                                      ConverterParameter=16}"
                                                                   Visibility="Collapsed"
                                                                   VerticalAlignment="Top"
                                                                   Style="{StaticResource RptDashboardBrowseGroupTitleStyle}">
                                                            <Run Text="›"/>
                                                        </TextBlock>
                                                    </Grid>

                                                    <TextBlock Style="{StaticResource RptDashboardBrowseDetailStyle}"
                                                               Foreground="{StaticResource Brush.TextMuted}"
                                                               FontWeight="Normal"
                                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                                  Path=FontScale,
                                                                                  Converter={StaticResource FontScaleConverter},
                                                                                  ConverterParameter=14}"
                                                               Text="{Binding Description}"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxHeight="{Binding Source={StaticResource UiScaleState},
                                                                                   Path=FontScale,
                                                                                   Converter={StaticResource LayoutScaleConverter},
                                                                                   ConverterParameter=46}"
                                                               Margin="{Binding Source={StaticResource UiScaleState},
                                                                                Path=FontScale,
                                                                                Converter={StaticResource ThicknessScaleConverter},
                                                                                ConverterParameter='0,6,0,0'}"/>
                                                </StackPanel>
                                            </DockPanel>
                                        </DockPanel>
                                    </Border>

                                    <!-- Hover frame overlay: fades in gradually above the content. -->
                                    <Border x:Name="BrowseHoverBorderOverlay"
                                            Background="Transparent"
                                            BorderBrush="{Binding Theme.HoverBorder}"
                                            BorderThickness="1"
                                            Opacity="0"
                                            IsHitTestVisible="False"
                                            SnapsToDevicePixels="True"
                                            ClipToBounds="False">
                                        <Border.CornerRadius>
                                            <Binding Path="ActualHeight"
                                                     RelativeSource="{RelativeSource Self}"
                                                     Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                                     ConverterParameter="10"/>
                                        </Border.CornerRadius>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Gradual icon growth. -->
                                            <DoubleAnimation Storyboard.TargetName="BrowseIconScaleTransform"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.12"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="BrowseIconScaleTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.12"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="BrowseIconTileHoverShade"
                 Storyboard.TargetProperty="Opacity"
                 To="0.12"
                 Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <!-- Gradual card bg/frame fade-in. -->
                                            <DoubleAnimation Storyboard.TargetName="BrowseHoverSurfaceOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="BrowseHoverBorderOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <!-- Gradual shadow fade-in without affecting text clarity. -->
                                            <DoubleAnimation Storyboard.TargetName="BrowseCardShadowHover"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>

                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <!-- Gradual icon shrink. -->
                                            <DoubleAnimation Storyboard.TargetName="BrowseIconScaleTransform"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="0.9"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="BrowseIconScaleTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="0.9"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="BrowseIconTileHoverShade"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <!-- Gradual card bg/frame fade-out. -->
                                            <DoubleAnimation Storyboard.TargetName="BrowseHoverSurfaceOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <DoubleAnimation Storyboard.TargetName="BrowseHoverBorderOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>

                                            <!-- Gradual shadow fade-out without affecting text clarity. -->
                                            <DoubleAnimation Storyboard.TargetName="BrowseCardShadowHover"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="0:0:0.42">
                                                <DoubleAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseIn"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>

                                <Setter TargetName="TitleChevron" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RptDashboardFilterComboBoxStyle"
       TargetType="{x:Type ComboBox}">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
            <Setter Property="Background" Value="#FFF3F3F5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ClipToBounds" Value="False"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource IcOpsServicesComboBoxItemStyle}"/>

            <Setter Property="Padding">
                <Setter.Value>
                    <Binding Source="{StaticResource UiScaleState}"
                     Path="FontScale"
                     Converter="{StaticResource ThicknessScaleConverter}"
                     ConverterParameter="10,5,10,5"/>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid SnapsToDevicePixels="True"
                      UseLayoutRounding="True"
                      ClipToBounds="False">

                            <!-- Base visible chrome. -->
                            <Border x:Name="BaseBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                                <Border.CornerRadius>
                                    <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="6"/>
                                </Border.CornerRadius>
                            </Border>

                            <!-- Click/content surface. -->
                            <ToggleButton x:Name="ToggleButton"
                                  Focusable="False"
                                  IsChecked="{Binding IsDropDownOpen,
                                                      Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                  ClickMode="Press"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Stretch">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="Transparent"
                                        SnapsToDevicePixels="True">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>

                                <Grid MinWidth="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="0"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              RecognizesAccessKey="True"/>

                                    <Path Grid.Column="1"
                                  Margin="{Binding Source={StaticResource UiScaleState},
                                                   Path=FontScale,
                                                   Converter={StaticResource ThicknessScaleConverter},
                                                   ConverterParameter='0,0,10,0'}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  Stroke="#9CA3AF"
                                  StrokeThickness="2"
                                  Data="M 0 0 L 5 5 L 10 0"/>
                                </Grid>
                            </ToggleButton>

                            <!-- Focus ring OUTER:
                         No negative margin, so it cannot be clipped by the control slot. -->
                            <Border x:Name="FocusOuter"
                            Visibility="Collapsed"
                            IsHitTestVisible="False"
                            Background="Transparent"
                            BorderBrush="#C1DEFE"
                            SnapsToDevicePixels="True"
                            RenderOptions.EdgeMode="Aliased">
                                <Border.CornerRadius>
                                    <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="7"/>
                                </Border.CornerRadius>
                                <Border.BorderThickness>
                                    <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="3"/>
                                </Border.BorderThickness>
                            </Border>

                            <!-- Focus ring INNER:
                         Slightly inset, also inside the control bounds. -->
                            <Border x:Name="FocusInner"
                            Visibility="Collapsed"
                            IsHitTestVisible="False"
                            Background="Transparent"
                            BorderBrush="#93C5FD"
                            SnapsToDevicePixels="True"
                            Margin="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource ThicknessScaleConverter},
                                             ConverterParameter='2,2,2,2'}"
                            RenderOptions.EdgeMode="Aliased">
                                <Border.CornerRadius>
                                    <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="5"/>
                                </Border.CornerRadius>
                                <Border.BorderThickness>
                                    <Binding Source="{StaticResource UiScaleState}"
                                     Path="FontScale"
                                     Converter="{StaticResource LayoutScaleConverter}"
                                     ConverterParameter="1"/>
                                </Border.BorderThickness>
                            </Border>

                            <!-- Popup dropdown. -->
                            <Popup x:Name="Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Fade">
                                <Grid SnapsToDevicePixels="True"
                              UseLayoutRounding="True"
                              MinWidth="{TemplateBinding ActualWidth}"
                              Margin="{Binding Source={StaticResource UiScaleState},
                                               Path=FontScale,
                                               Converter={StaticResource ThicknessScaleConverter},
                                               ConverterParameter='0,6,0,0'}">
                                    <Border Background="White"
                                    BorderThickness="1"
                                    BorderBrush="#E5E7EB"
                                    SnapsToDevicePixels="True">
                                        <Border.CornerRadius>
                                            <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource LayoutScaleConverter}"
                                             ConverterParameter="9"/>
                                        </Border.CornerRadius>
                                    </Border>

                                    <ScrollViewer Margin="0"
                                          SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="FocusInner" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="FocusInner" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BaseBorder" Property="Background" Value="#FFEFEFF2"/>
                            </Trigger>

                            <Trigger Property="BorderThickness" Value="1">
                                <Setter TargetName="FocusOuter" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="FocusInner" Property="Visibility" Value="Collapsed"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BaseBorder" Property="Background" Value="#FFE5E7EB"/>
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                                <Setter TargetName="FocusOuter" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="FocusInner" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid x:Name="RptDashboardRootGrid">
    <Border Background="Transparent" FocusVisualStyle="{x:Null}">
        <Border BorderBrush="{StaticResource Brush.SurfaceGrey}"
                BorderThickness="1"
                Background="{StaticResource Brush.RptDashboardPageBg}"
                SnapsToDevicePixels="True"
                Margin="{Binding Source={StaticResource UiScaleState},
                                 Path=FontScale,
                                 Converter={StaticResource ThicknessScaleConverter},
                                 ConverterParameter='16,14,16,16'}"
                CornerRadius="{Binding ActualHeight,
                                        RelativeSource={RelativeSource Self},
                                        Converter={StaticResource CornerRadiusFromHeightConverter},
                                        ConverterParameter=12}">

            <ScrollViewer x:Name="PageScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          FocusVisualStyle="{x:Null}"
                          Padding="{Binding Path=FontScale,
                                             Source={StaticResource UiScaleState},
                                             Converter={StaticResource ThicknessScaleConverter},
                                             ConverterParameter='20,14,24,28'}">

                <StackPanel>

                    <!-- Filter row: star-sized combos + search share remaining width; date pill max width from strip (code); no horizontal scroll. -->
                    <Grid x:Name="FilterStripHost"
                          Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"
                          VerticalAlignment="Center"
                          SizeChanged="FilterStripHost_SizeChanged">
                        <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <!-- Date pill -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Combos share one unit each; search column weighted 2× -->
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0"
      VerticalAlignment="Center"
      Margin="{Binding Source={StaticResource UiScaleState},
                       Path=FontScale,
                       Converter={StaticResource ThicknessScaleConverter},
                       ConverterParameter='0,0,10,0'}"
      MaxWidth="{Binding FilterStripDateMaxWidth, ElementName=Root}">

                                <Grid.Resources>

                                    <!-- Date range pill DatePicker:
             The DatePicker is now the visible control.
             The focus ring belongs to the DatePicker chrome, not to an invisible overlay. -->
                                    <Style x:Key="RptDashboardVisibleDateRangePillDatePickerStyle"
               TargetType="{x:Type DatePicker}">

                                        <Setter Property="Background" Value="{StaticResource Brush.White}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderSoft}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Padding"
                    Value="{Binding Source={StaticResource UiScaleState},
                                    Path=FontScale,
                                    Converter={StaticResource ThicknessScaleConverter},
                                    ConverterParameter='9,4,11,4'}" />
                                        <Setter Property="VerticalContentAlignment" Value="Center" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                        <Setter Property="SelectedDateFormat" Value="Short" />
                                        <Setter Property="SnapsToDevicePixels" Value="True" />

                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type DatePicker}">

                                                    <Grid Background="Transparent"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True">

                                                        <Border x:Name="Chrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True">
                                                            <Border.CornerRadius>
                                                                <Binding Path="ActualHeight"
                                             RelativeSource="{RelativeSource Self}"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="5" />
                                                            </Border.CornerRadius>

                                                            <Grid VerticalAlignment="Center"
                                      SnapsToDevicePixels="True"
                                      Margin="{TemplateBinding Padding}">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>

                                                                <Viewbox Grid.Column="0"
                                             Stretch="Uniform"
                                             Width="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource LayoutScaleConverter},
                                                              ConverterParameter=16}"
                                             Height="{Binding Source={StaticResource UiScaleState},
                                                               Path=FontScale,
                                                               Converter={StaticResource LayoutScaleConverter},
                                                               ConverterParameter=16}"
                                             VerticalAlignment="Center"
                                             Margin="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource ThicknessScaleConverter},
                                                              ConverterParameter='0,0,8,0'}">
                                                                    <Canvas Width="24"
                                                Height="24"
                                                SnapsToDevicePixels="True">
                                                                        <Path Stroke="{StaticResource HdrIconStrokeBrush}"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent"
                                                  Data="M8 2v2 M16 2v2 M3 7h18 M5 5h14
                                                        a2 2 0 0 1 2 2v13
                                                        a2 2 0 0 1-2 2H5
                                                        a2 2 0 0 1-2-2V7
                                                        a2 2 0 0 1 2-2z">
                                                                            <Path.StrokeThickness>
                                                                                <Binding Source="{StaticResource UiScaleState}"
                                                             Path="FontScale"
                                                             Converter="{StaticResource LayoutScaleConverter}"
                                                             ConverterParameter="2" />
                                                                            </Path.StrokeThickness>
                                                                        </Path>
                                                                    </Canvas>
                                                                </Viewbox>

                                                                <TextBlock Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource Brush.TextDark}"
                                               FontWeight="Normal"
                                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource FontScaleConverter},
                                                                  ConverterParameter=15}"
                                               TextWrapping="Wrap"
                                               TextTrimming="None"
                                               Style="{StaticResource RptDashboardFilterDateRangeCaptionStyle}"
                                               Text="{Binding RelativeSource={RelativeSource TemplatedParent},
                                                              Path=Tag}" />
                                                            </Grid>
                                                        </Border>

                                                        <!-- Outer focus ring: drawn on top of the visible DatePicker chrome. -->
                                                        <Border x:Name="FocusOuter"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False"
                                    Background="Transparent"
                                    BorderBrush="#C1DEFE"
                                    SnapsToDevicePixels="True"
                                    RenderOptions.EdgeMode="Aliased">
                                                            <Border.CornerRadius>
                                                                <Binding Path="ActualHeight"
                                             RelativeSource="{RelativeSource Self}"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="7" />
                                                            </Border.CornerRadius>
                                                            <Border.Margin>
                                                                <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource ThicknessScaleConverter}"
                                             ConverterParameter="-3,-3,-3,-3" />
                                                            </Border.Margin>
                                                            <Border.BorderThickness>
                                                                <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource LayoutScaleConverter}"
                                             ConverterParameter="3" />
                                                            </Border.BorderThickness>
                                                        </Border>

                                                        <!-- Inner focus ring: drawn on top of the visible DatePicker chrome. -->
                                                        <Border x:Name="FocusInner"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="False"
                                    Background="Transparent"
                                    BorderBrush="#93C5FD"
                                    SnapsToDevicePixels="True"
                                    RenderOptions.EdgeMode="Aliased">
                                                            <Border.CornerRadius>
                                                                <Binding Path="ActualHeight"
                                             RelativeSource="{RelativeSource Self}"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="6" />
                                                            </Border.CornerRadius>
                                                            <Border.Margin>
                                                                <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource ThicknessScaleConverter}"
                                             ConverterParameter="-1,-1,-1,-1" />
                                                            </Border.Margin>
                                                            <Border.BorderThickness>
                                                                <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource LayoutScaleConverter}"
                                             ConverterParameter="1" />
                                                            </Border.BorderThickness>
                                                        </Border>

                                                        <!-- Required template part, hidden because the pill uses custom visible text. -->
                                                        <DatePickerTextBox x:Name="PART_TextBox"
                                               FocusVisualStyle="{x:Null}"
                                               Padding="0"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Visibility="Collapsed"
                                               Width="0"
                                               Height="0"
                                               Opacity="0"
                                               VerticalContentAlignment="Center" />

                                                        <!-- Transparent full-surface click target for opening the calendar. -->
                                                        <ToggleButton x:Name="PART_Button"
                                          FocusVisualStyle="{x:Null}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Margin="0"
                                          Padding="0"
                                          Focusable="False"
                                          IsTabStop="False"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Opacity="0"
                                          IsChecked="{Binding IsDropDownOpen,
                                                              RelativeSource={RelativeSource TemplatedParent},
                                                              Mode=TwoWay}">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                                    <Border Background="Transparent"
                                                SnapsToDevicePixels="True" />
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>

                                                        <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   StaysOpen="False"
                                   HorizontalOffset="0">
                                                            <Popup.VerticalOffset>
                                                                <Binding Source="{StaticResource UiScaleState}"
                                             Path="FontScale"
                                             Converter="{StaticResource LayoutScaleConverter}"
                                             ConverterParameter="6" />
                                                            </Popup.VerticalOffset>

                                                            <Border Background="White"
                                        BorderBrush="#FFE5E7EB"
                                        SnapsToDevicePixels="True"
                                        ClipToBounds="False">
                                                                <Border.Width>
                                                                    <Binding Source="{StaticResource UiScaleState}"
                                                 Path="FontScale"
                                                 Converter="{StaticResource LayoutScaleConverter}"
                                                 ConverterParameter="520" />
                                                                </Border.Width>
                                                                <Border.Height>
                                                                    <Binding Source="{StaticResource UiScaleState}"
                                                 Path="FontScale"
                                                 Converter="{StaticResource LayoutScaleConverter}"
                                                 ConverterParameter="480" />
                                                                </Border.Height>
                                                                <Border.BorderThickness>
                                                                    <Binding Source="{StaticResource UiScaleState}"
                                                 Path="FontScale"
                                                 Converter="{StaticResource LayoutScaleConverter}"
                                                 ConverterParameter="1" />
                                                                </Border.BorderThickness>
                                                                <Border.CornerRadius>
                                                                    <Binding Source="{StaticResource UiScaleState}"
                                                 Path="FontScale"
                                                 Converter="{StaticResource LayoutScaleConverter}"
                                                 ConverterParameter="12" />
                                                                </Border.CornerRadius>

                                                                <Grid RenderTransformOrigin="0,0">
                                                                    <Grid.RenderTransform>
                                                                        <ScaleTransform ScaleX="2"
                                                            ScaleY="2" />
                                                                    </Grid.RenderTransform>

                                                                    <Calendar x:Name="PART_Calendar" />
                                                                </Grid>
                                                            </Border>
                                                        </Popup>
                                                    </Grid>

                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible" />
                                                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible" />
                                                            <Setter TargetName="Chrome" Property="BorderBrush" Value="Transparent" />
                                                        </Trigger>

                                                        <Trigger Property="IsDropDownOpen" Value="True">
                                                            <Setter TargetName="FocusOuter" Property="Visibility" Value="Visible" />
                                                            <Setter TargetName="FocusInner" Property="Visibility" Value="Visible" />
                                                            <Setter TargetName="Chrome" Property="BorderBrush" Value="Transparent" />
                                                        </Trigger>

                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="Chrome" Property="Opacity" Value="0.65" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Grid.Resources>

                                <!-- Hidden captions drive Tag on each DatePicker pill. -->
                                <TextBlock x:Name="TxtReportDateRangeStartPill"
               Visibility="Collapsed"
               IsHitTestVisible="False" />
                                <TextBlock x:Name="TxtReportDateRangeEndPill"
               Visibility="Collapsed"
               IsHitTestVisible="False" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                <DatePicker x:Name="DpReportRangeStart"
                Grid.Column="0"
                VerticalAlignment="Center"
                HorizontalAlignment="Stretch"
                MinHeight="{Binding Path=FontScale,
                                    Source={StaticResource UiScaleState},
                                    Converter={StaticResource LayoutScaleConverter},
                                    ConverterParameter=34}"
                FontWeight="Normal"
                FontSize="{Binding Source={StaticResource UiScaleState},
                                   Path=FontScale,
                                   Converter={StaticResource FontScaleConverter},
                                   ConverterParameter=14}"
                Foreground="{StaticResource MainForeground}"
                Tag="{Binding Text, ElementName=TxtReportDateRangeStartPill}"
                Style="{StaticResource RptDashboardVisibleDateRangePillDatePickerStyle}"
                SelectedDateChanged="ReportRangeDatePicker_SelectedDateChanged" />

                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='6,0,6,0'}"
                                           Foreground="{StaticResource DimmedForeground}"
                                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                           Text="–"/>

                                <DatePicker x:Name="DpReportRangeEnd"
                Grid.Column="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Stretch"
                MinHeight="{Binding Path=FontScale,
                                    Source={StaticResource UiScaleState},
                                    Converter={StaticResource LayoutScaleConverter},
                                    ConverterParameter=34}"
                FontWeight="Normal"
                FontSize="{Binding Source={StaticResource UiScaleState},
                                   Path=FontScale,
                                   Converter={StaticResource FontScaleConverter},
                                   ConverterParameter=14}"
                Foreground="{StaticResource MainForeground}"
                Tag="{Binding Text, ElementName=TxtReportDateRangeEndPill}"
                Style="{StaticResource RptDashboardVisibleDateRangePillDatePickerStyle}"
                SelectedDateChanged="ReportRangeDatePicker_SelectedDateChanged" />
                                </Grid>
                            </Grid>

                            <ComboBox x:Name="BranchFilterCombo"
          Grid.Column="1"                                      
          ClipToBounds="False"
          Style="{StaticResource RptDashboardFilterComboBoxStyle}"
          Foreground="{StaticResource MainForeground}"
          FontWeight="Normal"
          FontSize="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource FontScaleConverter},
                             ConverterParameter=14}"
          HorizontalAlignment="Stretch"
          MinWidth="{Binding Source={StaticResource UiScaleState},
                              Path=FontScale,
                              Converter={StaticResource LayoutScaleConverter},
                              ConverterParameter=72}"
          Height="{Binding Path=FontScale,
                          Source={StaticResource UiScaleState},
                          Converter={StaticResource LayoutScaleConverter},
                          ConverterParameter=34}"
          VerticalAlignment="Center"
          Margin="{Binding Source={StaticResource UiScaleState},
                           Path=FontScale,
                           Converter={StaticResource ThicknessScaleConverter},
                           ConverterParameter='0,0,6,0'}"
          SelectionChanged="FilterCombo_SelectionChanged"/>

                            <ComboBox x:Name="ChannelFilterCombo"
          Grid.Column="2"
          ClipToBounds="False"
          Style="{StaticResource RptDashboardFilterComboBoxStyle}"
          Foreground="{StaticResource MainForeground}"
          FontWeight="Normal"
          FontSize="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource FontScaleConverter},
                             ConverterParameter=14}"
          HorizontalAlignment="Stretch"
          MinWidth="{Binding Source={StaticResource UiScaleState},
                              Path=FontScale,
                              Converter={StaticResource LayoutScaleConverter},
                              ConverterParameter=72}"
          Height="{Binding Path=FontScale,
                          Source={StaticResource UiScaleState},
                          Converter={StaticResource LayoutScaleConverter},
                          ConverterParameter=34}"
          VerticalAlignment="Center"
          Margin="{Binding Source={StaticResource UiScaleState},
                           Path=FontScale,
                           Converter={StaticResource ThicknessScaleConverter},
                           ConverterParameter='0,0,6,0'}"
          SelectionChanged="FilterCombo_SelectionChanged"/>

                            <ComboBox x:Name="RoleFilterCombo"
          Grid.Column="3"
          ClipToBounds="False"
          Style="{StaticResource RptDashboardFilterComboBoxStyle}"
          Foreground="{StaticResource MainForeground}"
          FontWeight="Normal"
          FontSize="{Binding Source={StaticResource UiScaleState},
                             Path=FontScale,
                             Converter={StaticResource FontScaleConverter},
                             ConverterParameter=14}"
          HorizontalAlignment="Stretch"
          MinWidth="{Binding Source={StaticResource UiScaleState},
                              Path=FontScale,
                              Converter={StaticResource LayoutScaleConverter},
                              ConverterParameter=72}"
          Height="{Binding Path=FontScale,
                          Source={StaticResource UiScaleState},
                          Converter={StaticResource LayoutScaleConverter},
                          ConverterParameter=34}"
          VerticalAlignment="Center"
          Margin="{Binding Source={StaticResource UiScaleState},
                           Path=FontScale,
                           Converter={StaticResource ThicknessScaleConverter},
                           ConverterParameter='0,0,10,0'}"
          SelectionChanged="FilterCombo_SelectionChanged"/>
                            
                            <Border x:Name="RptDashboardSearchBorder"
                                    Grid.Column="4"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch"
                                    PreviewMouseLeftButtonDown="RptDashboardSearchBorder_PreviewMouseLeftButtonDown"
                                    Height="{Binding Path=FontScale,
                                                    Source={StaticResource UiScaleState},
                                                    Converter={StaticResource LayoutScaleConverter},
                                                    ConverterParameter=34}"
                                    MinWidth="{Binding Path=FontScale,
                                                       Source={StaticResource UiScaleState},
                                                       Converter={StaticResource LayoutScaleConverter},
                                                       ConverterParameter=120}"
                                    Background="{StaticResource Brush.White}"
                                    BorderBrush="{StaticResource Brush.BorderGrey}"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="False"
                                    Margin="0"
                                    BorderThickness="{Binding Source={StaticResource UiScaleState},
                                                              Path=FontScale,
                                                              Converter={StaticResource LayoutScaleConverter},
                                                              ConverterParameter=1}">
                                <Border.CornerRadius>
                                    <Binding RelativeSource="{RelativeSource Self}"
                                             Path="ActualHeight"
                                             Converter="{StaticResource CornerRadiusFromHeightConverter}"
                                             ConverterParameter="4"/>
                                </Border.CornerRadius>
                                <Grid>
                                    <Border x:Name="RptSearchFocusOuter"
                                            Panel.ZIndex="10"
                                            Visibility="Collapsed"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='-3'}"
                                            CornerRadius="{Binding Path=ActualHeight,
                                                                     ElementName=RptDashboardSearchBorder,
                                                                     Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                     ConverterParameter='9'}"
                                            BorderThickness="3"
                                            BorderBrush="#C1DEFE"
                                            Background="Transparent"
                                            SnapsToDevicePixels="True"
                                            RenderOptions.EdgeMode="Aliased"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin,
                                                                                   ElementName=RptDashboardSearchBox}"
                                                                Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Border x:Name="RptSearchFocusInner"
                                            Panel.ZIndex="11"
                                            Visibility="Collapsed"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='-1'}"
                                            CornerRadius="{Binding Path=ActualHeight,
                                                                     ElementName=RptDashboardSearchBorder,
                                                                     Converter={StaticResource CornerRadiusFromHeightConverter},
                                                                     ConverterParameter='8'}"
                                            BorderThickness="1"
                                            BorderBrush="#93C5FD"
                                            Background="Transparent"
                                            SnapsToDevicePixels="True"
                                            RenderOptions.EdgeMode="Aliased"
                                            IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsKeyboardFocusWithin,
                                                                                   ElementName=RptDashboardSearchBox}"
                                                                Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Viewbox Width="{Binding Source={StaticResource UiScaleState},
                                                                 Path=FontScale,
                                                                 Converter={StaticResource LayoutScaleConverter},
                                                                 ConverterParameter=16}"
                                                 Height="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource LayoutScaleConverter},
                                                                  ConverterParameter=16}"
                                                 Margin="{Binding Source={StaticResource UiScaleState},
                                                                  Path=FontScale,
                                                                  Converter={StaticResource ThicknessScaleConverter},
                                                                  ConverterParameter='10,0,6,0'}"
                                                 VerticalAlignment="Center">
                                            <Canvas Width="16" Height="16" SnapsToDevicePixels="True">
                                                <Ellipse Canvas.Left="2"
                                                         Canvas.Top="2"
                                                         Width="10"
                                                         Height="10"
                                                         Stroke="#9CA3AF"
                                                         StrokeThickness="1.6"
                                                         Fill="Transparent"/>
                                                <Line X1="10.5"
                                                      Y1="10.5"
                                                      X2="15"
                                                      Y2="15"
                                                      Stroke="#9CA3AF"
                                                      StrokeThickness="1.6"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"/>
                                            </Canvas>
                                        </Viewbox>
                                        <TextBox x:Name="RptDashboardSearchBox"
                                                 Grid.Column="1"
                                                 Foreground="{StaticResource MainForeground}"
                                                 FontWeight="Normal"
                                                 FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                                                 VerticalAlignment="Stretch"
                                                 VerticalContentAlignment="Center"
                                                 GotKeyboardFocus="RptDashboardSearchBox_GotKeyboardFocus"
                                                 LostKeyboardFocus="RptDashboardSearchBox_LostKeyboardFocus"
                                                 TextChanged="RptDashboardSearchBox_TextChanged"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                                                 Style="{StaticResource SearchWatermarkTextBox}"
                                                 Tag="Search reports..."/>
                                    </Grid>
                                </Grid>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderGrey}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsKeyboardFocusWithin,
                                                                          ElementName=RptDashboardSearchBox}"
                                                        Value="True">
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                                <Button x:Name="BtnExportDashboard"
                                        Grid.Column="5"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource Brush.White}"
                                        FontWeight="SemiBold"
                                        FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                        Style="{StaticResource VcPrimaryButtonStyle}"
                                        Height="{Binding Path=FontScale,
                                                        Source={StaticResource UiScaleState},
                                                        Converter={StaticResource LayoutScaleConverter},
                                                        ConverterParameter=32}"
                                        Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='8,0,0,0'}"
                                        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,4,10,4'}"
                                        Click="ExportDashboard_Click"
                                        FocusVisualStyle="{x:Null}">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Image Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=18}"
                                               Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=18}"
                                               Source="{StaticResource PeoplePOS.Icon.Download.White}"
                                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='4,0,0,0'}"
                                               SnapsToDevicePixels="True"/>
                                        <TextBlock Text="Export"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='10,0,0,0'}"
                                                   Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,2,2'}"
                                                   Foreground="{Binding Foreground,
                                                                         RelativeSource={RelativeSource AncestorType=Button}}"
                                                   Style="{StaticResource RptDashboardToolbarActionLabelStyle}"/>
                                    </StackPanel>
                                </Button>
                        </Grid>
                    </Grid>

                    <Border Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=1}"
                            Background="{StaticResource Brush.SurfaceGrey}"
                            Margin="{Binding Path=FontScale,
                                               Source={StaticResource UiScaleState},
                                               Converter={StaticResource ThicknessScaleConverter},
                                               ConverterParameter='0,16,0,0'}"/>

                    <TextBlock Style="{StaticResource RptDashboardSectionHeadingStyle}"
                               Foreground="{StaticResource MainForeground}"
                               Margin="{Binding Path=FontScale,
                                   Source={StaticResource UiScaleState},
                                   Converter={StaticResource ThicknessScaleConverter},
                                   ConverterParameter='0,16,0,0'}"
                               FontWeight="Normal"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"
                               Text="Recently Used"/>
                    
                    <Grid x:Name="RecentCardStripHost"
                          HorizontalAlignment="Stretch"
                          FocusVisualStyle="{x:Null}"
                          MinWidth="0"
                          ClipToBounds="False"
                          Margin="{Binding Source={StaticResource UiScaleState},
                                           Path=FontScale,
                                           Converter={StaticResource ThicknessScaleConverter},
                                           ConverterParameter='0,12,-8,14'}"
                          SizeChanged="DashboardCardStripHost_SizeChanged">
                        <ItemsControl ItemsSource="{Binding ElementName=Root, Path=RecentReports}"
                                      HorizontalAlignment="Stretch"
                                      MinWidth="0"
                                      ClipToBounds="False">

                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="{x:Type ContentPresenter}">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Setter Property="ClipToBounds" Value="False"/>
                                    <Setter Property="Panel.ZIndex" Value="0"/>

                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Panel.ZIndex" Value="50"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"
                                                 Columns="{Binding RecentCardUniformColumns, ElementName=Root}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:RptDashboardMain+RecentUsedRow}">
                                    <Button HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Foreground="{StaticResource MainForeground}"
                                            FontWeight="Normal"
                                            FontSize="{Binding Source={StaticResource UiScaleState},
                                                               Path=FontScale,
                                                               Converter={StaticResource FontScaleConverter},
                                                               ConverterParameter=14}"
                                            MinWidth="0"
                                            ClipToBounds="False"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='0,0,14,0'}"
                                            Style="{StaticResource RecentlyUsedCardButtonStyle}"
                                            Click="RecentReport_Click"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <Border Height="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource LayoutScaleConverter},
                                             ConverterParameter=1}"
                            Background="{StaticResource Brush.SurfaceGrey}"
                            Margin="{Binding Path=FontScale,
                                             Source={StaticResource UiScaleState},
                                             Converter={StaticResource ThicknessScaleConverter},
                                             ConverterParameter='0,16,0,14'}"/>

                    <!-- Checks: spacing adjusted only because the Recently Used bottom divider now owns section separation. -->
                    <TextBlock Style="{StaticResource RptDashboardSectionHeadingStyle}"
                               Foreground="{StaticResource MainForeground}"
                               FontWeight="Normal"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=15}"
                               Text="Attention Needed"/>

                    <!-- Checks: Attention Needed stays one row; UniformGrid is allowed to squash cards; no horizontal scroll. -->
                    <Grid x:Name="AttentionCardStripHost"
                          HorizontalAlignment="Stretch"
                          FocusVisualStyle="{x:Null}"
                          MinWidth="0"
                          ClipToBounds="False"
                          Margin="{Binding Source={StaticResource UiScaleState},
                                           Path=FontScale,
                                           Converter={StaticResource ThicknessScaleConverter},
                                           ConverterParameter='0,0,-8,14'}"
                          SizeChanged="DashboardCardStripHost_SizeChanged">
                        <ItemsControl ItemsSource="{Binding ElementName=Root, Path=AttentionItems}"
                                      HorizontalAlignment="Stretch"
                                      MinWidth="0"
                                      ClipToBounds="False">

                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="{x:Type ContentPresenter}">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Setter Property="ClipToBounds" Value="False"/>
                                    <Setter Property="Panel.ZIndex" Value="0"/>

                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Panel.ZIndex" Value="50"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.ItemContainerStyle>

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"
                                                 Columns="{Binding AttentionCardUniformColumns, ElementName=Root}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:RptDashboardMain+AttentionNeededRow}">
                                    <Button HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Foreground="{StaticResource MainForeground}"
                                            FontWeight="Normal"
                                            FontSize="{Binding Source={StaticResource UiScaleState},
                                                               Path=FontScale,
                                                               Converter={StaticResource FontScaleConverter},
                                                               ConverterParameter=14}"
                                            MinWidth="0"
                                            ClipToBounds="False"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='0,0,12,0'}"
                                            Style="{StaticResource AttentionCardButtonStyle}"
                                            Click="AttentionItem_Click"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <Border Height="{Binding Source={StaticResource UiScaleState},
                                             Path=FontScale,
                                             Converter={StaticResource LayoutScaleConverter},
                                             ConverterParameter=1}"
                            Background="{StaticResource Brush.SurfaceGrey}"
                            Margin="{Binding Path=FontScale,
                                             Source={StaticResource UiScaleState},
                                             Converter={StaticResource ThicknessScaleConverter},
                                             ConverterParameter='0,16,0,14'}"/>

                    <TextBlock Style="{StaticResource RptDashboardSectionHeadingStyle}"
                               Foreground="{StaticResource MainForeground}"
                               FontWeight="Normal"
                               FontSize="{Binding Source={StaticResource UiScaleState},
                                                  Path=FontScale,
                                                  Converter={StaticResource FontScaleConverter},
                                                  ConverterParameter=15}"
                               Text="Browse Reports"/>

                    <Grid x:Name="BrowseRow1CardStripHost"
                          HorizontalAlignment="Stretch"
                          FocusVisualStyle="{x:Null}"
                          MinWidth="0"
                          ClipToBounds="False"
                          Margin="{Binding Source={StaticResource UiScaleState},
                                           Path=FontScale,
                                           Converter={StaticResource ThicknessScaleConverter},
                                           ConverterParameter='0,0,-10,0'}"
                          SizeChanged="DashboardCardStripHost_SizeChanged">
                        <ItemsControl ItemsSource="{Binding ElementName=Root, Path=ReportGroupsRow1}"
                                      HorizontalAlignment="Stretch"
                                      MinWidth="0"
                                      ClipToBounds="False">

                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="{x:Type ContentPresenter}">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Setter Property="ClipToBounds" Value="False"/>
                                    <Setter Property="Panel.ZIndex" Value="0"/>

                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Panel.ZIndex" Value="50"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.ItemContainerStyle>

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"
                                                 Columns="{Binding BrowseRow1CardUniformColumns, ElementName=Root}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:RptDashboardMain+BrowseGroupTile}">
                                    <Button HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Foreground="{StaticResource MainForeground}"
                                            FontWeight="Normal"
                                            FontSize="{Binding Source={StaticResource UiScaleState},
                                                               Path=FontScale,
                                                               Converter={StaticResource FontScaleConverter},
                                                               ConverterParameter=14}"
                                            MinWidth="0"
                                            ClipToBounds="False"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='0,0,10,14'}"
                                            Style="{StaticResource GroupBrowseCardButtonStyle}"
                                            Click="ReportGroupChrome_Click"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <Grid x:Name="BrowseRow2CardStripHost"
                          HorizontalAlignment="Stretch"
                          FocusVisualStyle="{x:Null}"
                          MinWidth="0"
                          ClipToBounds="False"
                          Margin="{Binding Source={StaticResource UiScaleState},
                                           Path=FontScale,
                                           Converter={StaticResource ThicknessScaleConverter},
                                           ConverterParameter='0,0,-10,0'}"
                          SizeChanged="DashboardCardStripHost_SizeChanged">
                        <ItemsControl ItemsSource="{Binding ElementName=Root, Path=ReportGroupsRow2}"
                                      HorizontalAlignment="Stretch"
                                      MinWidth="0"
                                      ClipToBounds="False">

                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="{x:Type ContentPresenter}">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Setter Property="ClipToBounds" Value="False"/>
                                    <Setter Property="Panel.ZIndex" Value="0"/>

                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Panel.ZIndex" Value="50"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.ItemContainerStyle>

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"
                                                 Columns="{Binding BrowseRow2CardUniformColumns, ElementName=Root}"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type local:RptDashboardMain+BrowseGroupTile}">
                                    <Button HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Foreground="{StaticResource MainForeground}"
                                            FontWeight="Normal"
                                            FontSize="{Binding Source={StaticResource UiScaleState},
                                                               Path=FontScale,
                                                               Converter={StaticResource FontScaleConverter},
                                                               ConverterParameter=14}"
                                            MinWidth="0"
                                            ClipToBounds="False"
                                            Margin="{Binding Source={StaticResource UiScaleState},
                                                             Path=FontScale,
                                                             Converter={StaticResource ThicknessScaleConverter},
                                                             ConverterParameter='0,0,10,14'}"
                                            Style="{StaticResource GroupBrowseCardButtonStyle}"
                                            Click="ReportGroupChrome_Click"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Border>

        <Grid x:Name="RptOverlayLayer"
              Visibility="Collapsed"
              Panel.ZIndex="200">
            <Border Background="#99000000"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
            <ContentControl x:Name="RptOverlayContentHost"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='24,24,24,24'}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            FocusVisualStyle="{x:Null}"/>
        </Grid>
    </Grid>
</UserControl>
