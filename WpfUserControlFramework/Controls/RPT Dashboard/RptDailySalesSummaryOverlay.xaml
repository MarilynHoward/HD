<UserControl x:Class="RestaurantPosWpf.RptDailySalesSummaryOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True">

    <UserControl.Resources>
        <Style x:Key="RptDailySalesHeaderCellStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Margin" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"/>
        </Style>
        <Style x:Key="RptDailySalesCellStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MainForeground}"/>
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Margin" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"/>
        </Style>
        <!-- Subtitle tier (framework typography ladder). -->
        <Style x:Key="RptDailySalesMetaLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DimmedForeground}"/>
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"/>
            <Setter Property="Margin" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"/>
        </Style>
        <!-- Section-style emphasis between subtitle (15) and page header (18). -->
        <Style x:Key="RptDailySalesMetaValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MainForeground}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource Brush.White}"
            BorderBrush="{StaticResource Brush.BorderGrey}"
            BorderThickness="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter=1}"
            SnapsToDevicePixels="True"
            FocusVisualStyle="{x:Null}"
            CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=12}"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='20,16,20,16'}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header + toolbar (close ✕ matches StaffAccessAuditTrail). -->
            <Grid Grid.Row="0"
                  Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,8'}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{DynamicResource Rpt.Report.DailySales.Title}"
                           FontWeight="Bold"
                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}"
                           Foreground="{StaticResource MainForeground}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}">
                    <Button x:Name="BtnRefresh"
                            Style="{StaticResource VcSecondaryButtonStyle}"
                            Content="{DynamicResource Rpt.Report.Refresh}"
                            FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                            Click="Refresh_Click"/>
                    <Button x:Name="BtnPrint"
                            Style="{StaticResource VcSecondaryButtonStyle}"
                            Content="{DynamicResource Rpt.Report.Print}"
                            FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                            Click="Print_Click"/>
                    <Button x:Name="BtnExport"
                            Style="{StaticResource VcPrimaryButtonStyle}"
                            Content="{DynamicResource Rpt.Report.Export}"
                            FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                            Click="Export_Click"/>
                </StackPanel>
                <!-- Same close chrome as Staff and Access audit trail / Operations popups. -->
                <Button x:Name="BtnClose"
                        Grid.Column="2"
                        Click="Close_Click"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource DimmedForeground}"
                        Content="✕"
                        Padding="0"
                        MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=36}"
                        MinHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=36}"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        FocusVisualStyle="{x:Null}"
                        FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                        ToolTip="{DynamicResource Rpt.Report.Close}"
                        AutomationProperties.Name="Close"/>
            </Grid>

            <Border Grid.Row="1"
                    Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=1}"
                    Background="#E5E7EB"
                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,10'}"/>

            <!-- Read-only filter summary -->
            <Border Grid.Row="2"
                    Background="#F3F4F6"
                    CornerRadius="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}"
                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}"
                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,10'}">
                <TextBlock x:Name="TxtFilterSummary"
                           TextWrapping="Wrap"
                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"
                           Foreground="{StaticResource MainForeground}"/>
            </Border>

            <!-- Metadata -->
            <Grid Grid.Row="3"
                  Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,10'}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource RptDailySalesMetaLabelStyle}" Text="{DynamicResource Rpt.Report.TotalRecords}"/>
                    <TextBlock x:Name="TxtTotalRecords" Style="{StaticResource RptDailySalesMetaValueStyle}" Text="0"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Style="{StaticResource RptDailySalesMetaLabelStyle}" Text="{DynamicResource Rpt.Report.Generated}"/>
                    <TextBlock x:Name="TxtGenerated" Style="{StaticResource RptDailySalesMetaValueStyle}" Text=""/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource RptDailySalesMetaLabelStyle}" Text="{DynamicResource Rpt.Report.Period}"/>
                    <TextBlock x:Name="TxtPeriod" Style="{StaticResource RptDailySalesMetaValueStyle}" Text=""/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="4"
                    Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=1}"
                    Background="#E5E7EB"
                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,8'}"/>

            <!-- Table: header + scroll body (Rule #225 body scroll); totals fixed below -->
            <Border Grid.Row="5"
                    BorderBrush="#E5E7EB"
                    BorderThickness="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter=1}"
                    CornerRadius="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}"
                    ClipToBounds="True"
                    MinHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=120}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=40}"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="{x:Static SystemParameters.VerticalScrollBarWidth}"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Background="#E5E7EB"
                            CornerRadius="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter='8,8,0,0'}">
                        <Grid Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,0,8,4'}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=100}"/>
                                <ColumnDefinition Width="1.2*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=88}"/>
                                <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                                <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                                <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Rpt.Report.Column.Branch}" Style="{StaticResource RptDailySalesHeaderCellStyle}"/>
                            <TextBlock Grid.Column="1" Text="{DynamicResource Rpt.Report.Column.Sales}" Style="{StaticResource RptDailySalesHeaderCellStyle}" HorizontalAlignment="Right" TextAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="{DynamicResource Rpt.Report.Column.Transactions}" Style="{StaticResource RptDailySalesHeaderCellStyle}" HorizontalAlignment="Right" TextAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="{DynamicResource Rpt.Report.Column.AvgTicket}" Style="{StaticResource RptDailySalesHeaderCellStyle}" HorizontalAlignment="Right" TextAlignment="Right"/>
                            <TextBlock Grid.Column="4" Text="{DynamicResource Rpt.Report.Column.Growth}" Style="{StaticResource RptDailySalesHeaderCellStyle}" HorizontalAlignment="Right" TextAlignment="Right"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  Grid.Column="0"
                                  Style="{StaticResource IcPopupShellBodyScrollViewerStyle}"
                                  Padding="0"
                                  Margin="0">
                        <ItemsControl x:Name="RowsItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F3F4F6"
                                            BorderThickness="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,1,0,0'}"
                                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,8,8,8'}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=100}"/>
                                                <ColumnDefinition Width="1.2*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=88}"/>
                                                <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                                                <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                                                <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Branch}" Style="{StaticResource RptDailySalesCellStyle}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Sales}" Style="{StaticResource RptDailySalesCellStyle}" HorizontalAlignment="Right" TextAlignment="Right"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Transactions}" Style="{StaticResource RptDailySalesCellStyle}" HorizontalAlignment="Right" TextAlignment="Right"/>
                                            <TextBlock Grid.Column="3" Text="{Binding AvgTicket}" Style="{StaticResource RptDailySalesCellStyle}" HorizontalAlignment="Right" TextAlignment="Right"/>
                                            <TextBlock Grid.Column="4" Text="{Binding Growth}" Style="{StaticResource RptDailySalesCellStyle}" HorizontalAlignment="Right" TextAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Totals row -->
            <Border Grid.Row="6"
                    Background="#F8FAFC"
                    BorderBrush="#E5E7EB"
                    BorderThickness="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter=1}"
                    CornerRadius="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}"
                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,10,12,10'}"
                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,0'}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=100}"/>
                        <ColumnDefinition Width="1.2*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=88}"/>
                        <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                        <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                        <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{DynamicResource Rpt.Report.TotalRowLabel}"
                               FontWeight="Bold"
                               Foreground="{StaticResource MainForeground}"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalSales" Grid.Column="1" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}" HorizontalAlignment="Right" TextAlignment="Right"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalTransactions" Grid.Column="2" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}" HorizontalAlignment="Right" TextAlignment="Right"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalAvgTicket" Grid.Column="3" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}" HorizontalAlignment="Right" TextAlignment="Right"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalGrowth" Grid.Column="4" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}" HorizontalAlignment="Right" TextAlignment="Right"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
