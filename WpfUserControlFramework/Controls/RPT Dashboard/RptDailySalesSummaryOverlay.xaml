<UserControl x:Class="RestaurantPosWpf.RptDailySalesSummaryOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True">

    <UserControl.Resources>
        <!-- Growth / trend colors: Brush.RptReportPositiveForeground / Brush.RptReportNegativeForeground (PeoplePosTheme.xaml). -->

        <Style x:Key="RptDailySalesHeaderCellStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Margin" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"/>
        </Style>
        <Style x:Key="RptDailySalesCellStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MainForeground}"/>
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Margin" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}"/>
        </Style>
        <!-- Subtitle tier (framework typography ladder). -->
        <Style x:Key="RptDailySalesMetaLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DimmedForeground}"/>
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=12}"/>
            <Setter Property="Margin" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,4'}"/>
        </Style>
        <!-- Section-style emphasis between subtitle (15) and page header (18). -->
        <Style x:Key="RptDailySalesMetaValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MainForeground}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='1,0,0,10'}"/>
            <Setter Property="FontSize" Value="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource Brush.White}"
            BorderBrush="{StaticResource Brush.BorderGrey}"
            BorderThickness="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter=1}"
            SnapsToDevicePixels="True"
            FocusVisualStyle="{x:Null}"
            CornerRadius="{Binding ActualHeight, RelativeSource={RelativeSource Self}, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=12}"
            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,16,0,16'}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header + toolbar (close ✕ matches StaffAccessAuditTrail). -->
            <Grid Grid.Row="0"
                  Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='20,0,20,8'}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Orientation="Vertical"
                            VerticalAlignment="Top">
                    <TextBlock Text="{DynamicResource Rpt.Report.DailySales.Title}"
                               FontWeight="Bold"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=18}"
                               Foreground="{StaticResource MainForeground}"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="Recently Used"
                           Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,2,0,6'}"
                           FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"
                           Foreground="{StaticResource DimmedForeground}"
                           TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,10,0'}">
                    <Button x:Name="BtnRefresh"
                            Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=32}"
                            Style="{StaticResource VcSecondaryButtonStyle}"
                            FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,0,12,0'}"
                            Click="Refresh_Click"
                            AutomationProperties.Name="{DynamicResource Rpt.Report.Refresh}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=18}"
                                   Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=18}"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,6,0'}"
                                   Source="{StaticResource PeoplePOS.Icon.RefreshCw}"/>
                            <TextBlock Text="{DynamicResource Rpt.Report.Refresh}"
                                       VerticalAlignment="Center"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnPrint"
                            Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=32}"
                            Style="{StaticResource VcSecondaryButtonStyle}"
                            FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,0,10,0'}"
                            Click="Print_Click"
                            AutomationProperties.Name="{DynamicResource Rpt.Report.Print}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=18}"
                                   Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=18}"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                                   Source="{StaticResource PeoplePOS.Icon.Printer}"/>
                            <TextBlock Text="{DynamicResource Rpt.Report.Print}"
                                       VerticalAlignment="Center"
                                       Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='2,0,4,2'}"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnExport"
                            Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=32}"
                            Style="{StaticResource VcPrimaryButtonStyle}"
                            FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                            Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                            Click="Export_Click"
                            AutomationProperties.Name="{DynamicResource Rpt.Report.Export}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=18}"
                                   Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=18}"
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='4,0,8,0'}"
                                   Source="{StaticResource PeoplePOS.Icon.Download.White}"/>
                            <TextBlock Text="{DynamicResource Rpt.Report.Export}"
                                   Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='2,0,4,2'}"
                                       VerticalAlignment="Center"
                                       FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <!-- Same close chrome as Staff and Access audit trail / Operations popups. -->
                <Button x:Name="BtnClose"
                        Grid.Column="2"
                        Click="Close_Click"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource DimmedForeground}"
                        Content="✕"
                        Padding="0"
                        MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=36}"
                        MinHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=36}"
                        VerticalAlignment="Top"
                        Cursor="Hand"
                        FocusVisualStyle="{x:Null}"
                        FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=16}"
                        ToolTip="{DynamicResource Rpt.Report.Close}"
                        AutomationProperties.Name="Close"/>
            </Grid>

            <Border Grid.Row="1"
        Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=1}"
        Background="#E5E7EB"
        Margin="0"/>

            <!-- Read-only filter summary -->
            <Border Grid.Row="2"
                    Background="#F3F4F6"
                    BorderBrush="#E5E7EB"
                    BorderThickness="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,1'}"
                    CornerRadius="0"
                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='20,10,20,10'}"
                    Margin="0">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=16}"
                 Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=16}"
                 VerticalAlignment="Center"
                 Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,8,0'}"
                 IsHitTestVisible="False"
                 Focusable="False">
                        <Canvas Width="24" Height="24">
                            <Path Data="{StaticResource Geom.StandardCalendarLucide}"
                      Stroke="{StaticResource DimmedForeground}"
                      StrokeLineJoin="Round"
                      Fill="Transparent">
                                <Path.StrokeThickness>
                                    <Binding Source="{StaticResource UiScaleState}"
                                 Path="FontScale"
                                 Converter="{StaticResource LayoutScaleConverter}"
                                 ConverterParameter="2"/>
                                </Path.StrokeThickness>
                            </Path>
                        </Canvas>
                    </Viewbox>
                    <TextBlock x:Name="TxtFilterSummary"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=15}"
                   Foreground="{StaticResource MainForeground}"/>
                </StackPanel>
            </Border>

            <!-- Metadata -->
            <Border Grid.Row="3"
                    Background="#F3F4F6"
                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='20,16,20,4'}"
                    Margin="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource RptDailySalesMetaLabelStyle}" Text="{DynamicResource Rpt.Report.TotalRecords}"/>
                        <TextBlock x:Name="TxtTotalRecords" Style="{StaticResource RptDailySalesMetaValueStyle}" Text="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource RptDailySalesMetaLabelStyle}" Text="{DynamicResource Rpt.Report.Generated}"/>
                        <TextBlock x:Name="TxtGenerated" Style="{StaticResource RptDailySalesMetaValueStyle}" Text=""/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource RptDailySalesMetaLabelStyle}" Text="{DynamicResource Rpt.Report.Period}"/>
                        <TextBlock x:Name="TxtPeriod" Style="{StaticResource RptDailySalesMetaValueStyle}" Text=""/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=1}"
                Background="#E5E7EB"
                Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,12'}"/>

            <Border Grid.Row="5"
        BorderBrush="Transparent"
        CornerRadius="{Binding RelativeSource={RelativeSource Self},
                                   Path=ActualHeight,
                                   Converter={StaticResource CornerRadiusFromHeightConverter},
                                   ConverterParameter=8}"
        BorderThickness="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter=1}"
        ClipToBounds="True"
        Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='20,0,20,0'}"
        MinHeight="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=120}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=40}"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="{x:Static SystemParameters.VerticalScrollBarWidth}"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource Brush.White}">
                        
                        <Grid Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,0,0'}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=100}"/>
                                <ColumnDefinition Width="1.2*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=88}"/>
                                <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                                <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                                <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Rpt.Report.Column.Branch}" Style="{StaticResource RptDailySalesHeaderCellStyle}"/>
                            <TextBlock Grid.Column="1" Text="{DynamicResource Rpt.Report.Column.Sales}" Style="{StaticResource RptDailySalesHeaderCellStyle}" HorizontalAlignment="Left" TextAlignment="Left"/>
                            <TextBlock Grid.Column="2" Text="{DynamicResource Rpt.Report.Column.Transactions}" Style="{StaticResource RptDailySalesHeaderCellStyle}" HorizontalAlignment="Left" TextAlignment="Left"/>
                            <TextBlock Grid.Column="3" Text="{DynamicResource Rpt.Report.Column.AvgTicket}" Style="{StaticResource RptDailySalesHeaderCellStyle}" HorizontalAlignment="Left" TextAlignment="Left"/>
                            <TextBlock Grid.Column="4" Text="{DynamicResource Rpt.Report.Column.Growth}" Style="{StaticResource RptDailySalesHeaderCellStyle}" HorizontalAlignment="Left" TextAlignment="Left"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Background="{StaticResource Brush.White}"
                        CornerRadius="0,8,0,0"/>
                    
                    <ScrollViewer x:Name="DailySalesListScrollViewer"
                                  Grid.Row="1"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="2"
                                  Style="{StaticResource IcPopupShellBodyScrollViewerStyle}"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="0"
                                  Margin="0">
                        <ItemsControl x:Name="RowsItems">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    
                                    <Setter Property="Margin"
                                            Value="{Binding Source={StaticResource UiScaleState},
                                                            Path=FontScale,
                                                            Converter={StaticResource ThicknessScaleConverter},
                                                            ConverterParameter='0,0,17,0'}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=DailySalesListScrollViewer, Path=ComputedVerticalScrollBarVisibility}"
                                                     Value="Visible">
                                            <Setter Property="Margin" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F3F4F6"
                                            BorderThickness="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,1,0,0'}"
                                            Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,8'}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=100}"/>
                                                <ColumnDefinition Width="1.2*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=88}"/>
                                                <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                                                <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                                                <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Branch}" Style="{StaticResource RptDailySalesCellStyle}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Sales}" Style="{StaticResource RptDailySalesCellStyle}" HorizontalAlignment="Left" TextAlignment="LEft"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Transactions}" Style="{StaticResource RptDailySalesCellStyle}" HorizontalAlignment="Left" TextAlignment="Left"/>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=14}"
                                                         Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=14}"
                                                         VerticalAlignment="Center"
                                                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,2,0'}">
                                                    <Viewbox.Style>
                                                        <Style TargetType="Viewbox">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AvgTicketVariant}" Value="Positive">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Viewbox.Style>
                                                    <Canvas Width="24" Height="24">
                                                        <Polyline Points="22,7 13.5,15.5 8.5,10.5 2,17"
                                                                  Stroke="{StaticResource Brush.RptReportPositiveForeground}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                        <Polyline Points="16,7 22,7 22,13"
                                                                  Stroke="{StaticResource Brush.RptReportPositiveForeground}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    </Canvas>
                                                </Viewbox>
                                                <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=14}"
                                                         Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=14}"
                                                         VerticalAlignment="Center"
                                                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,2,0'}"
                                                         RenderTransformOrigin="0.5,0.5">
                                                    <Viewbox.RenderTransform>
                                                        <RotateTransform Angle="180"/>
                                                    </Viewbox.RenderTransform>
                                                    <Viewbox.Style>
                                                        <Style TargetType="Viewbox">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AvgTicketVariant}" Value="Negative">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Viewbox.Style>
                                                    <Canvas Width="24" Height="24">
                                                        <Polyline Points="22,7 13.5,15.5 8.5,10.5 2,17"
                                                                  Stroke="{StaticResource Brush.RptReportNegativeForeground}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                        <Polyline Points="16,7 22,7 22,13"
                                                                  Stroke="{StaticResource Brush.RptReportNegativeForeground}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Text="{Binding AvgTicket}" HorizontalAlignment="Left" TextAlignment="Left" TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource RptDailySalesCellStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AvgTicketVariant}" Value="Positive">
                                                                    <Setter Property="Foreground" Value="{StaticResource Brush.RptReportPositiveForeground}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding AvgTicketVariant}" Value="Negative">
                                                                    <Setter Property="Foreground" Value="{StaticResource Brush.RptReportNegativeForeground}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=14}"
                                                         Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=14}"
                                                         VerticalAlignment="Center"
                                                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,2,0'}">
                                                    <Viewbox.Style>
                                                        <Style TargetType="Viewbox">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding GrowthVariant}" Value="Positive">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Viewbox.Style>
                                                    <Canvas Width="24" Height="24">
                                                        <Polyline Points="22,7 13.5,15.5 8.5,10.5 2,17"
                                                                  Stroke="{StaticResource Brush.RptReportPositiveForeground}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                        <Polyline Points="16,7 22,7 22,13"
                                                                  Stroke="{StaticResource Brush.RptReportPositiveForeground}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    </Canvas>
                                                </Viewbox>
                                                <Viewbox Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=14}"
                                                         Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=14}"
                                                         VerticalAlignment="Center"
                                                         Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,2,0'}"
                                                         RenderTransformOrigin="0.5,0.5">
                                                    <Viewbox.RenderTransform>
                                                        <RotateTransform Angle="180"/>
                                                    </Viewbox.RenderTransform>
                                                    <Viewbox.Style>
                                                        <Style TargetType="Viewbox">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding GrowthVariant}" Value="Negative">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Viewbox.Style>
                                                    <Canvas Width="24" Height="24">
                                                        <Polyline Points="22,7 13.5,15.5 8.5,10.5 2,17"
                                                                  Stroke="{StaticResource Brush.RptReportNegativeForeground}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                        <Polyline Points="16,7 22,7 22,13"
                                                                  Stroke="{StaticResource Brush.RptReportNegativeForeground}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Text="{Binding Growth}" HorizontalAlignment="Right" TextAlignment="Right" TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource RptDailySalesCellStyle}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding GrowthVariant}" Value="Positive">
                                                                    <Setter Property="Foreground" Value="{StaticResource Brush.RptReportPositiveForeground}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding GrowthVariant}" Value="Negative">
                                                                    <Setter Property="Foreground" Value="{StaticResource Brush.RptReportNegativeForeground}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Totals row -->
            <Border Grid.Row="6"
                    Background="#F8FAFC"
                    BorderBrush="#E5E7EB"
                    BorderThickness="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter=1}"
                    CornerRadius="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource CornerRadiusFromHeightConverter}, ConverterParameter=8}"
                    Padding="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,10,0,10'}"
                    Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,8,0,0'}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="{x:Static SystemParameters.VerticalScrollBarWidth}"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0"
                          Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,0,12,0'}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=100}"/>
                        <ColumnDefinition Width="1.2*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=88}"/>
                        <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                        <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                        <ColumnDefinition Width="*" MinWidth="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=72}"/>
                    </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                               Text="{DynamicResource Rpt.Report.TotalRowLabel}"
                               FontWeight="Bold"
                               Foreground="{StaticResource MainForeground}"
                               Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='12,0,0,0'}"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                               VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtTotalSales" Grid.Column="1" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}" HorizontalAlignment="Left" TextAlignment="Left"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                               VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtTotalTransactions" Grid.Column="2" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}" HorizontalAlignment="Left" TextAlignment="Left"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                               VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtTotalAvgTicket" Grid.Column="3" FontWeight="SemiBold" Foreground="{StaticResource MainForeground}" HorizontalAlignment="Left" TextAlignment="Left"
                               FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"
                               VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Viewbox x:Name="TotalGrowthUpIcon"
                                 Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=14}"
                                 Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=14}"
                                 VerticalAlignment="Center"
                                 Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,2,0'}"
                                 Visibility="Collapsed">
                            <Canvas Width="24" Height="24">
                                <Polyline Points="22,7 13.5,15.5 8.5,10.5 2,17"
                                          Stroke="{StaticResource Brush.RptReportPositiveForeground}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                <Polyline Points="16,7 22,7 22,13"
                                          Stroke="{StaticResource Brush.RptReportPositiveForeground}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                        <Viewbox x:Name="TotalGrowthDownIcon"
                                 Width="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=14}"
                                 Height="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource LayoutScaleConverter}, ConverterParameter=14}"
                                 VerticalAlignment="Center"
                                 Margin="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource ThicknessScaleConverter}, ConverterParameter='0,0,2,0'}"
                                 Visibility="Collapsed"
                                 RenderTransformOrigin="0.5,0.5">
                            <Viewbox.RenderTransform>
                                <RotateTransform Angle="180"/>
                            </Viewbox.RenderTransform>
                            <Canvas Width="24" Height="24">
                                <Polyline Points="22,7 13.5,15.5 8.5,10.5 2,17"
                                          Stroke="{StaticResource Brush.RptReportNegativeForeground}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                                <Polyline Points="16,7 22,7 22,13"
                                          Stroke="{StaticResource Brush.RptReportNegativeForeground}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                            <TextBlock x:Name="TxtTotalGrowth"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MainForeground}"
                                   HorizontalAlignment="Left"
                                   TextAlignment="Left"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   FontSize="{Binding Source={StaticResource UiScaleState}, Path=FontScale, Converter={StaticResource FontScaleConverter}, ConverterParameter=14}"/>
                        </StackPanel>
                    </Grid>
                    <Border Grid.Column="1" Background="Transparent"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
